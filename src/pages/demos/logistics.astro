        </div>
      </div>

      <div class="job-card">
        <div class="job-top">
          <div class="job-id">#JOB-2848</div>
          <div class="job-status pickup">Picking Up</div>
        </div>
        <div class="job-route">
          <div class="job-stop">
            <div class="job-stop-dot" style="background:var(--amber)"></div>
            <div><div class="job-name">Sydney Markets</div><div class="job-addr">Flemington Rd, Homebush</div></div>
          </div>
          <div class="job-line"></div>
          <div class="job-stop">
            <div class="job-stop-dot" style="background:var(--subtle)"></div>
            <div><div class="job-name">Coles DC Smeaton Grange</div><div class="job-addr">Narellan, NSW 2567</div></div>
          </div>
        </div>
        <div class="job-bottom">
          <div class="job-driver">
            <div class="driver-mini-avatar" style="background:rgba(99,102,241,0.2);color:#818cf8">JT</div>
            J. Tran · V-019
          </div>
          <div class="job-eta">ETA 38 min</div>
        </div>
      </div>

      <div class="job-card">
        <div class="job-top">
          <div class="job-id">#JOB-2849</div>
          <div class="job-status en-route">En Route</div>
        </div>
        <div class="job-route">
          <div class="job-stop">
            <div class="job-stop-dot" style="background:var(--green)"></div>
