            <div class="job-stop-dot" style="background:var(--amber)"></div>
            <div><div class="job-name">CommBank Tower</div><div class="job-addr">340 George St, CBD</div></div>
          </div>
        </div>
        <div class="job-progress">
          <div style="display:flex;justify-content:space-between;margin-bottom:3px"><span style="font-size:0.5625rem;color:var(--muted)">Progress</span><span style="font-size:0.5625rem;font-weight:700;color:var(--green)">68%</span></div>
