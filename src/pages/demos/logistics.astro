          <div class="job-stop">
            <div class="job-stop-dot" style="background:var(--subtle)"></div>
            <div><div class="job-name">Minto Industrial Estate</div><div class="job-addr">Minto, NSW 2566</div></div>
          </div>
        </div>
        <div class="job-bottom">
          <div class="job-driver">
            <div class="driver-mini-avatar" style="background:rgba(59,130,246,0.2);color:var(--blue)">AO</div>
            A. Okonkwo · V-031
          </div>
          <div class="job-eta">Dep. 2:30pm</div>
        </div>
      </div>

      <div class="job-card">
        <div class="job-top">
          <div class="job-id">#JOB-2844</div>
          <div class="job-status delivered">Delivered</div>
        </div>
        <div class="job-route">
          <div class="job-stop">
            <div class="job-stop-dot" style="background:var(--subtle)"></div>
            <div><div class="job-name">Amazon Moorebank</div><div class="job-addr">Moorebank Ave, Moorebank</div></div>
          </div>
          <div class="job-line"></div>
          <div class="job-stop">
            <div class="job-stop-dot" style="background:var(--subtle)"></div>
            <div><div class="job-name">Completed ✓</div><div class="job-addr">Signed 1:14pm · M. Wong</div></div>
          </div>
        </div>
        <div class="job-bottom">
          <div class="job-driver">
            <div class="driver-mini-avatar" style="background:rgba(255,255,255,0.06);color:var(--muted)">CL</div>
            C. Lim · V-022
          </div>
          <div class="job-eta" style="color:var(--green)">Delivered ✓</div>
        </div>
      </div>

    </div>

    <!-- Driver grid -->
    <div class="driver-section">
      <div class="driver-section-title">Driver Status</div>
      <div class="driver-grid">
        <div class="driver-card">
          <div class="driver-avatar" style="background:rgba(13,147,115,0.2);color:var(--green)">MK</div>
          <div class="driver-name">M. Kowalski</div>
          <div class="driver-status-badge d-active">Active</div>
        </div>
        <div class="driver-card">
          <div class="driver-avatar" style="background:rgba(99,102,241,0.2);color:#818cf8">JT</div>
          <div class="driver-name">J. Tran</div>
          <div class="driver-status-badge d-active">Active</div>
        </div>
        <div class="driver-card">
          <div class="driver-avatar" style="background:rgba(245,158,11,0.2);color:var(--amber)">RB</div>
          <div class="driver-name">R. Barnes</div>
          <div class="driver-status-badge d-active">Active</div>
        </div>
        <div class="driver-card">
          <div class="driver-avatar" style="background:rgba(59,130,246,0.2);color:var(--blue)">AO</div>
          <div class="driver-name">A. Okonkwo</div>
          <div class="driver-status-badge d-idle">Loading</div>
        </div>
        <div class="driver-card">
          <div class="driver-avatar" style="background:rgba(255,255,255,0.06);color:var(--muted)">CL</div>
          <div class="driver-name">C. Lim</div>
          <div class="driver-status-badge d-break">Break</div>
        </div>
        <div class="driver-card">
          <div class="driver-avatar" style="background:rgba(13,147,115,0.2);color:var(--green)">SW</div>
          <div class="driver-name">S. Walsh</div>
          <div class="driver-status-badge d-active">Active</div>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
  // Animate vehicles moving
  const vehicles = document.querySelectorAll('.vehicle.active');
  vehicles.forEach((v, i) => {
    const el = v as HTMLElement;
    const baseLeft = parseFloat(el.style.left);
    const baseTop = parseFloat(el.style.top);
    setInterval(() => {
      const dx = (Math.random() - 0.5) * 1.5;
      const dy = (Math.random() - 0.5) * 1.2;
      el.style.left = Math.max(5, Math.min(90, baseLeft + dx + (Date.now() / 50000 * i))) + '%';
      el.style.top = Math.max(5, Math.min(85, baseTop + dy)) + '%';
    }, 2000 + i * 300);
  });

  // Live counter update
  let jobCount = 127;
  setInterval(() => {
    const el = document.getElementById('jobs-today');
    if (el && Math.random() > 0.7) {
      jobCount++;
      el.textContent = String(jobCount);
    }
  }, 4000);

  // Panel tabs
  document.querySelectorAll('.panel-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.panel-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
    });
  });

  // Job card selection
  document.querySelectorAll('.job-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.job-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
    });
  });

  // Progress bar animation on selected job
  setInterval(() => {
    const fill = document.querySelector('.job-card.selected .progress-bar-fill') as HTMLElement;
    if (fill) {
      const current = parseFloat(fill.style.width);
      if (current < 98) fill.style.width = (current + 0.3) + '%';
    }
  }, 1000);
</script>
</body>
</html>
