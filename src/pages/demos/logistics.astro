        </div>
        <div class="job-progress">
          <div style="display:flex;justify-content:space-between;margin-bottom:3px"><span style="font-size:0.5625rem;color:var(--muted)">Progress</span><span style="font-size:0.5625rem;font-weight:700;color:var(--green)">45%</span></div>
