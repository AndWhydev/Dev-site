          <div class="job-id">#JOB-2847</div>
          <div class="job-status en-route">En Route</div>
        </div>
        <div class="job-route">
          <div class="job-stop">
            <div class="job-stop-dot" style="background:var(--green)"></div>
            <div><div class="job-name">Toll Distribution</div><div class="job-addr">89 Bourke St, Sydney</div></div>
          </div>
