      </div>
      <div class="map-card">
        <div class="map-legend">
          <div class="legend-item"><div class="legend-dot" style="background:var(--green)"></div>Active</div>
          <div class="legend-item"><div class="legend-dot" style="background:var(--amber)"></div>Idle</div>
          <div class="legend-item"><div class="legend-dot" style="background:var(--red)"></div>Offline</div>
          <div class="legend-item"><div class="legend-dot" style="background:var(--green);opacity:0.4"></div>Route</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Right panel -->
