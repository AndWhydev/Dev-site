<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>AW Labs — Logo Options</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #060b0a;
      color: white;
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      padding: 3rem 2rem;
    }

    h1 {
      font-family: 'Sora', sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #3a5048;
      margin-bottom: 3rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .logo-card {
      background: #0c1411;
      border: 1px solid #1a2620;
      border-radius: 20px;
      overflow: hidden;
    }

    .logo-card-label {
      padding: 0.875rem 1.25rem;
      border-bottom: 1px solid #1a2620;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo-card-label span {
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #3a5048;
    }

    .logo-card-label em {
      font-size: 0.6875rem;
      font-style: normal;
      color: #0d9373;
      background: rgba(13,147,115,0.1);
      border: 1px solid rgba(13,147,115,0.2);
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
    }

    /* Dark preview */
    .preview-dark {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3.5rem 2rem;
      background: #060b0a;
      flex-direction: column;
      gap: 2.5rem;
    }

    /* Light preview */
    .preview-light {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      background: #f8fafc;
      gap: 2.5rem;
    }

    .size-label {
      font-size: 0.5625rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #3a5048;
      margin-top: 0.5rem;
      text-align: center;
    }

    /* ─────────────────────────────────────────
       LOGO OPTION 1: The Arc
    ───────────────────────────────────────── */

    .logo-arc-mark {
      display: inline-flex;
    }

    /* ─────────────────────────────────────────
       LOGO OPTION 2: The Node
    ───────────────────────────────────────── */

    /* ─────────────────────────────────────────
       LOGO OPTION 3: The Slash
    ───────────────────────────────────────── */

    /* ─────────────────────────────────────────
       LOGO OPTION 4: The Monogram
    ───────────────────────────────────────── */

    /* Wordmark styles */
    .wordmark {
      display: flex;
      align-items: center;
      gap: 0.625rem;
    }

    .wordmark-text {
      display: flex;
      flex-direction: column;
      line-height: 1;
    }

    .wm-primary {
      font-family: 'Sora', sans-serif;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: white;
    }

    .wm-sub {
      font-family: 'Sora', sans-serif;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #0d9373;
    }

    .wm-lg .wm-primary { font-size: 1.875rem; }
    .wm-lg .wm-sub { font-size: 0.875rem; margin-top: 2px; }

    .wm-md .wm-primary { font-size: 1.125rem; }
    .wm-md .wm-sub { font-size: 0.5625rem; margin-top: 1px; }

    .wm-sm .wm-primary { font-size: 0.75rem; }
    .wm-sm .wm-sub { font-size: 0.4375rem; }

    /* Light version text */
    .on-light .wm-primary { color: #0a1512; }

    .sizes-row {
      display: flex;
      align-items: flex-end;
      gap: 2.5rem;
    }
  </style>
</head>
<body>

<h1>AW Labs — Logo Concepts · Choose One</h1>

<div class="grid">

  <!-- ══════════════════════════════════════════
       OPTION 1: THE ARC
  ══════════════════════════════════════════ -->
  <div class="logo-card">
    <div class="logo-card-label">
      <span>Option 1 — The Arc</span>
      <em>Premium · Clean</em>
    </div>
    <div class="preview-dark">

      <!-- Full lockup large -->
      <div class="wordmark wm-lg">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Outer arc — 270deg, opens bottom-right -->
          <path d="M26 6 A20 20 0 1 1 46 26" stroke="#0d9373" stroke-width="4.5" stroke-linecap="round" fill="none"/>
          <!-- Inner accent dot -->
          <circle cx="26" cy="26" r="4.5" fill="#0d9373"/>
          <!-- Short arc cap (the gap indicator) -->
          <path d="M40.1 40.1 L44 44" stroke="#0d9373" stroke-width="3" stroke-linecap="round"/>
        </svg>
        <div class="wordmark-text">
          <span class="wm-primary">AW Labs</span>
          <span class="wm-sub">AI · Software · Technology</span>
        </div>
      </div>

      <!-- Sizes -->
      <div class="sizes-row">
        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <div class="wordmark wm-md">
            <svg width="32" height="32" viewBox="0 0 52 52" fill="none">
              <path d="M26 6 A20 20 0 1 1 46 26" stroke="#0d9373" stroke-width="4.5" stroke-linecap="round"/>
              <circle cx="26" cy="26" r="4.5" fill="#0d9373"/>
              <path d="M40.1 40.1 L44 44" stroke="#0d9373" stroke-width="3" stroke-linecap="round"/>
            </svg>
            <div class="wordmark-text">
              <span class="wm-primary">AW Labs</span>
              <span class="wm-sub">AI · Software</span>
            </div>
          </div>
          <span class="size-label">Medium</span>
        </div>

        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <div class="wordmark wm-sm">
            <svg width="20" height="20" viewBox="0 0 52 52" fill="none">
              <path d="M26 6 A20 20 0 1 1 46 26" stroke="#0d9373" stroke-width="5" stroke-linecap="round"/>
              <circle cx="26" cy="26" r="5" fill="#0d9373"/>
            </svg>
            <div class="wordmark-text">
              <span class="wm-primary">AW Labs</span>
              <span class="wm-sub">Technology</span>
            </div>
          </div>
          <span class="size-label">Small</span>
        </div>

        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <!-- Icon only -->
          <svg width="40" height="40" viewBox="0 0 52 52" fill="none">
            <path d="M26 6 A20 20 0 1 1 46 26" stroke="#0d9373" stroke-width="4.5" stroke-linecap="round"/>
            <circle cx="26" cy="26" r="4.5" fill="#0d9373"/>
            <path d="M40.1 40.1 L44 44" stroke="#0d9373" stroke-width="3" stroke-linecap="round"/>
          </svg>
          <span class="size-label">Icon only</span>
        </div>
      </div>
    </div>

    <div class="preview-light">
      <div class="wordmark wm-md on-light">
        <svg width="36" height="36" viewBox="0 0 52 52" fill="none">
          <path d="M26 6 A20 20 0 1 1 46 26" stroke="#0d9373" stroke-width="4.5" stroke-linecap="round"/>
          <circle cx="26" cy="26" r="4.5" fill="#0d9373"/>
          <path d="M40.1 40.1 L44 44" stroke="#0d9373" stroke-width="3" stroke-linecap="round"/>
        </svg>
        <div class="wordmark-text">
          <span class="wm-primary">AW Labs</span>
          <span class="wm-sub">AI · Software</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       OPTION 2: THE CHEVRON STACK
  ══════════════════════════════════════════ -->
  <div class="logo-card">
    <div class="logo-card-label">
      <span>Option 2 — The Chevron</span>
      <em>Bold · Dynamic</em>
    </div>
    <div class="preview-dark">

      <div class="wordmark wm-lg">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Two stacked chevrons — suggests speed, forward motion -->
          <path d="M8 14 L26 28 L44 14" stroke="#0d9373" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <path d="M8 26 L26 40 L44 26" stroke="rgba(13,147,115,0.35)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
        <div class="wordmark-text">
          <span class="wm-primary">AW Labs</span>
          <span class="wm-sub">AI · Software · Technology</span>
        </div>
      </div>

      <div class="sizes-row">
        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <div class="wordmark wm-md">
            <svg width="30" height="30" viewBox="0 0 52 52" fill="none">
              <path d="M8 14 L26 28 L44 14" stroke="#0d9373" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 26 L26 40 L44 26" stroke="rgba(13,147,115,0.35)" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div class="wordmark-text">
              <span class="wm-primary">AW Labs</span>
              <span class="wm-sub">AI · Software</span>
            </div>
          </div>
          <span class="size-label">Medium</span>
        </div>

        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <svg width="40" height="40" viewBox="0 0 52 52" fill="none">
            <path d="M8 14 L26 28 L44 14" stroke="#0d9373" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M8 26 L26 40 L44 26" stroke="rgba(13,147,115,0.35)" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="size-label">Icon only</span>
        </div>
      </div>
    </div>

    <div class="preview-light">
      <div class="wordmark wm-md on-light">
        <svg width="36" height="36" viewBox="0 0 52 52" fill="none">
          <path d="M8 14 L26 28 L44 14" stroke="#0d9373" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M8 26 L26 40 L44 26" stroke="rgba(13,147,115,0.35)" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="wordmark-text">
          <span class="wm-primary">AW Labs</span>
          <span class="wm-sub">AI · Software</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       OPTION 3: THE HEXAGON
  ══════════════════════════════════════════ -->
  <div class="logo-card">
    <div class="logo-card-label">
      <span>Option 3 — The Hexagon</span>
      <em>Scientific · Labs feel</em>
    </div>
    <div class="preview-dark">

      <div class="wordmark wm-lg">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
          <!-- Hexagon outline -->
          <path d="M26 4 L46 15 L46 37 L26 48 L6 37 L6 15 Z" stroke="#0d9373" stroke-width="2.5" fill="rgba(13,147,115,0.05)"/>
          <!-- Inner "AW" text paths — geometric letterforms -->
          <!-- A -->
          <path d="M16 35 L21 17 L26 35" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <path d="M18 28 L24 28" stroke="#0d9373" stroke-width="2" stroke-linecap="round"/>
          <!-- W -->
          <path d="M27 17 L30 30 L33 22 L36 30 L39 17" stroke="rgba(13,147,115,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
        <div class="wordmark-text">
          <span class="wm-primary">AW Labs</span>
          <span class="wm-sub">AI · Software · Technology</span>
        </div>
      </div>

      <div class="sizes-row">
        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <div class="wordmark wm-md">
            <svg width="32" height="32" viewBox="0 0 52 52" fill="none">
              <path d="M26 4 L46 15 L46 37 L26 48 L6 37 L6 15 Z" stroke="#0d9373" stroke-width="2.5" fill="rgba(13,147,115,0.05)"/>
              <path d="M16 35 L21 17 L26 35" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M18 28 L24 28" stroke="#0d9373" stroke-width="2" stroke-linecap="round"/>
              <path d="M27 17 L30 30 L33 22 L36 30 L39 17" stroke="rgba(13,147,115,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div class="wordmark-text">
              <span class="wm-primary">AW Labs</span>
              <span class="wm-sub">AI · Software</span>
            </div>
          </div>
          <span class="size-label">Medium</span>
        </div>

        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <svg width="44" height="44" viewBox="0 0 52 52" fill="none">
            <path d="M26 4 L46 15 L46 37 L26 48 L6 37 L6 15 Z" stroke="#0d9373" stroke-width="2.5" fill="rgba(13,147,115,0.05)"/>
            <path d="M16 35 L21 17 L26 35" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M18 28 L24 28" stroke="#0d9373" stroke-width="2" stroke-linecap="round"/>
            <path d="M27 17 L30 30 L33 22 L36 30 L39 17" stroke="rgba(13,147,115,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="size-label">Icon only</span>
        </div>
      </div>
    </div>

    <div class="preview-light">
      <div class="wordmark wm-md on-light">
        <svg width="36" height="36" viewBox="0 0 52 52" fill="none">
          <path d="M26 4 L46 15 L46 37 L26 48 L6 37 L6 15 Z" stroke="#0d9373" stroke-width="2.5" fill="rgba(13,147,115,0.08)"/>
          <path d="M16 35 L21 17 L26 35" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M18 28 L24 28" stroke="#0d9373" stroke-width="2" stroke-linecap="round"/>
          <path d="M27 17 L30 30 L33 22 L36 30 L39 17" stroke="rgba(13,147,115,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="wordmark-text">
          <span class="wm-primary">AW Labs</span>
          <span class="wm-sub">AI · Software</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       OPTION 4: THE DIAMOND SPLIT
  ══════════════════════════════════════════ -->
  <div class="logo-card">
    <div class="logo-card-label">
      <span>Option 4 — The Diamond</span>
      <em>Premium · Enterprise</em>
    </div>
    <div class="preview-dark">

      <div class="wordmark wm-lg">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
          <!-- Diamond top (solid) -->
          <path d="M26 4 L44 26 L26 26 Z" fill="#0d9373"/>
          <!-- Diamond bottom (outline) -->
          <path d="M26 26 L44 26 L26 48 L8 26 L26 26 Z" fill="none" stroke="#0d9373" stroke-width="2.5"/>
          <!-- Diamond left (dim) -->
          <path d="M26 4 L8 26 L26 26 Z" fill="rgba(13,147,115,0.2)"/>
        </svg>
        <div class="wordmark-text">
          <span class="wm-primary">AW Labs</span>
          <span class="wm-sub">AI · Software · Technology</span>
        </div>
      </div>

      <div class="sizes-row">
        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <div class="wordmark wm-md">
            <svg width="30" height="30" viewBox="0 0 52 52" fill="none">
              <path d="M26 4 L44 26 L26 26 Z" fill="#0d9373"/>
              <path d="M26 26 L44 26 L26 48 L8 26 L26 26 Z" fill="none" stroke="#0d9373" stroke-width="2.5"/>
              <path d="M26 4 L8 26 L26 26 Z" fill="rgba(13,147,115,0.2)"/>
            </svg>
            <div class="wordmark-text">
              <span class="wm-primary">AW Labs</span>
              <span class="wm-sub">AI · Software</span>
            </div>
          </div>
          <span class="size-label">Medium</span>
        </div>

        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <svg width="42" height="42" viewBox="0 0 52 52" fill="none">
            <path d="M26 4 L44 26 L26 26 Z" fill="#0d9373"/>
            <path d="M26 26 L44 26 L26 48 L8 26 L26 26 Z" fill="none" stroke="#0d9373" stroke-width="2.5"/>
            <path d="M26 4 L8 26 L26 26 Z" fill="rgba(13,147,115,0.2)"/>
          </svg>
          <span class="size-label">Icon only</span>
        </div>
      </div>
    </div>

    <div class="preview-light">
      <div class="wordmark wm-md on-light">
        <svg width="34" height="34" viewBox="0 0 52 52" fill="none">
          <path d="M26 4 L44 26 L26 26 Z" fill="#0d9373"/>
          <path d="M26 26 L44 26 L26 48 L8 26 L26 26 Z" fill="none" stroke="#0d9373" stroke-width="2.5"/>
          <path d="M26 4 L8 26 L26 26 Z" fill="rgba(13,147,115,0.25)"/>
        </svg>
        <div class="wordmark-text">
          <span class="wm-primary">AW Labs</span>
          <span class="wm-sub">AI · Software</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       OPTION 5: THE NODE / SIGNAL
  ══════════════════════════════════════════ -->
  <div class="logo-card">
    <div class="logo-card-label">
      <span>Option 5 — The Signal</span>
      <em>Tech · Connected</em>
    </div>
    <div class="preview-dark">

      <div class="wordmark wm-lg">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
          <!-- Central node -->
          <circle cx="26" cy="26" r="5" fill="#0d9373"/>
          <!-- Radiating arcs — signal/connectivity -->
          <path d="M14 14 A17 17 0 0 1 38 14" stroke="#0d9373" stroke-width="3" stroke-linecap="round" fill="none"/>
          <path d="M8 8 A25.5 25.5 0 0 1 44 8" stroke="rgba(13,147,115,0.4)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
          <path d="M14 38 A17 17 0 0 0 38 38" stroke="#0d9373" stroke-width="3" stroke-linecap="round" fill="none" opacity="0.3"/>
        </svg>
        <div class="wordmark-text">
          <span class="wm-primary">AW Labs</span>
          <span class="wm-sub">AI · Software · Technology</span>
        </div>
      </div>

      <div class="sizes-row">
        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <div class="wordmark wm-md">
            <svg width="30" height="30" viewBox="0 0 52 52" fill="none">
              <circle cx="26" cy="26" r="5" fill="#0d9373"/>
              <path d="M14 14 A17 17 0 0 1 38 14" stroke="#0d9373" stroke-width="3.5" stroke-linecap="round"/>
              <path d="M8 8 A25.5 25.5 0 0 1 44 8" stroke="rgba(13,147,115,0.4)" stroke-width="3" stroke-linecap="round"/>
            </svg>
            <div class="wordmark-text">
              <span class="wm-primary">AW Labs</span>
              <span class="wm-sub">AI · Software</span>
            </div>
          </div>
          <span class="size-label">Medium</span>
        </div>

        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <svg width="44" height="44" viewBox="0 0 52 52" fill="none">
            <circle cx="26" cy="26" r="5" fill="#0d9373"/>
            <path d="M14 14 A17 17 0 0 1 38 14" stroke="#0d9373" stroke-width="3.5" stroke-linecap="round"/>
            <path d="M8 8 A25.5 25.5 0 0 1 44 8" stroke="rgba(13,147,115,0.4)" stroke-width="3" stroke-linecap="round"/>
          </svg>
          <span class="size-label">Icon only</span>
        </div>
      </div>
    </div>

    <div class="preview-light">
      <div class="wordmark wm-md on-light">
        <svg width="36" height="36" viewBox="0 0 52 52" fill="none">
          <circle cx="26" cy="26" r="5" fill="#0d9373"/>
          <path d="M14 14 A17 17 0 0 1 38 14" stroke="#0d9373" stroke-width="3.5" stroke-linecap="round"/>
          <path d="M8 8 A25.5 25.5 0 0 1 44 8" stroke="rgba(13,147,115,0.4)" stroke-width="3" stroke-linecap="round"/>
        </svg>
        <div class="wordmark-text">
          <span class="wm-primary">AW Labs</span>
          <span class="wm-sub">AI · Software</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       OPTION 6: THE WORDMARK ONLY
  ══════════════════════════════════════════ -->
  <div class="logo-card">
    <div class="logo-card-label">
      <span>Option 6 — Pure Wordmark</span>
      <em>Minimal · Confident</em>
    </div>
    <div class="preview-dark">

      <!-- Large wordmark, no icon -->
      <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
        <div style="display:flex;align-items:baseline;gap:0.5rem">
          <span style="font-family:'Sora',sans-serif;font-size:3rem;font-weight:800;color:white;letter-spacing:-0.04em;line-height:1">AW</span>
          <span style="font-family:'Sora',sans-serif;font-size:3rem;font-weight:300;color:#0d9373;letter-spacing:-0.02em;line-height:1">Labs</span>
        </div>
        <div style="width:100%;height:2px;background:linear-gradient(90deg,#0d9373,transparent)"></div>
        <span style="font-family:'DM Sans',sans-serif;font-size:0.6875rem;font-weight:500;letter-spacing:0.25em;text-transform:uppercase;color:#3a5048">AI · Software · Technology</span>
      </div>

      <div class="sizes-row">
        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem">
          <div style="display:flex;align-items:baseline;gap:0.3rem">
            <span style="font-family:'Sora',sans-serif;font-size:1.5rem;font-weight:800;color:white;letter-spacing:-0.04em">AW</span>
            <span style="font-family:'Sora',sans-serif;font-size:1.5rem;font-weight:300;color:#0d9373;letter-spacing:-0.02em">Labs</span>
          </div>
