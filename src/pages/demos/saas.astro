---
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>NexusCRM, Enterprise Customer Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #060b0a;
      --surface: #0c1411;
      --surface2: #111a17;
      --border: #1a2620;
      --green: #0d9373;
      --green-dim: rgba(13,147,115,0.1);
      --text: #ffffff;
      --muted: #8aa09a;
      --subtle: #3a5048;
      --purple: #8b5cf6;
      --blue: #3b82f6;
      --amber: #f59e0b;
    }
    body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; height: 100vh; overflow: hidden; display: grid; grid-template-columns: 220px 1fr; }
    ::-webkit-scrollbar { width: 3px; } ::-webkit-scrollbar-thumb { background: var(--border); }

    /* Sidebar */
    .sidebar { background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; }
    .sidebar-top { padding: 1.125rem; border-bottom: 1px solid var(--border); }
    .sidebar-logo { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.875rem; }
    .logo-icon { width: 30px; height: 30px; background: var(--purple); border-radius: 8px; display: flex; align-items: center; justify-content: center; }
    .logo-icon svg { width: 16px; height: 16px; }
    .logo-text { font-family: 'Sora', sans-serif; font-size: 0.9375rem; font-weight: 700; }
    .logo-badge { font-size: 0.5rem; color: var(--subtle); background: var(--surface2); padding: 0.1rem 0.35rem; border-radius: 3px; border: 1px solid var(--border); margin-left: 4px; vertical-align: middle; }
    .search-box { display: flex; align-items: center; gap: 0.375rem; background: var(--surface2); border: 1px solid var(--border); border-radius: 7px; padding: 0.4rem 0.625rem; font-size: 0.6875rem; color: var(--subtle); }
    .search-box svg { width: 12px; height: 12px; flex-shrink: 0; }
    .sidebar-nav { padding: 0.625rem; flex: 1; overflow-y: auto; }
    .nav-section { margin-bottom: 0.875rem; }
    .nav-section-label { font-size: 0.5rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--subtle); padding: 0 0.5rem; margin-bottom: 0.25rem; }
    .nav-item { display: flex; align-items: center; gap: 0.5rem; padding: 0.45rem 0.5rem; border-radius: 6px; font-size: 0.75rem; font-weight: 500; color: var(--muted); cursor: pointer; transition: all 0.15s; }
    .nav-item:hover { background: var(--surface2); color: white; }
    .nav-item.active { background: var(--green-dim); color: var(--green); }
    .nav-item svg { width: 13px; height: 13px; flex-shrink: 0; }
    .nav-badge { margin-left: auto; background: var(--green); color: white; font-size: 0.5rem; font-weight: 700; padding: 0.1rem 0.35rem; border-radius: 50px; }
    .nav-badge.grey { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }
    .sidebar-bottom { padding: 0.75rem; border-top: 1px solid var(--border); }
    .sidebar-user { display: flex; align-items: center; gap: 0.5rem; }
    .s-avatar { width: 28px; height: 28px; border-radius: 50%; background: linear-gradient(135deg, var(--purple), #6d28d9); display: flex; align-items: center; justify-content: center; font-size: 0.5625rem; font-weight: 700; flex-shrink: 0; }
    .s-name { font-size: 0.6875rem; font-weight: 600; color: white; }
    .s-plan { font-size: 0.5625rem; color: var(--subtle); }
    .s-chevron { margin-left: auto; color: var(--subtle); }

    /* Main */
    .main { display: grid; grid-template-rows: 52px 1fr; overflow: hidden; }
    .topbar { background: var(--surface); border-bottom: 1px solid var(--border); display: flex; align-items: center; padding: 0 1.25rem; gap: 1rem; }
    .topbar-breadcrumb { font-family: 'Sora', sans-serif; font-size: 0.8125rem; font-weight: 700; flex: 1; }
    .topbar-breadcrumb span { color: var(--subtle); font-weight: 400; }
    .topbar-actions { display: flex; gap: 0.5rem; align-items: center; }
    .tb-btn { display: flex; align-items: center; gap: 0.375rem; font-size: 0.6875rem; font-weight: 600; padding: 0.375rem 0.75rem; border-radius: 7px; cursor: pointer; transition: background 0.15s; border: none; }
    .tb-btn.outline { background: var(--surface2); border: 1px solid var(--border); color: var(--muted); }
    .tb-btn.outline:hover { color: white; }
    .tb-btn.primary { background: var(--green); color: white; }
    .tb-btn.primary:hover { background: #0a7a5e; }
    .tb-btn svg { width: 12px; height: 12px; }
    .tb-notif { position: relative; }
    .notif-dot { position: absolute; top: 2px; right: 2px; width: 6px; height: 6px; border-radius: 50%; background: var(--green); border: 1px solid var(--surface); }

    /* Content */
    .content { overflow-y: auto; padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }

    /* KPI row */
    .kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.875rem; }
    .kpi-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1rem; }
    .kpi-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 0.75rem; }
    .kpi-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
    .kpi-icon svg { width: 14px; height: 14px; }
    .kpi-trend { font-size: 0.5625rem; font-weight: 700; padding: 0.15rem 0.4rem; border-radius: 4px; }
    .kpi-trend.up { background: rgba(13,147,115,0.12); color: var(--green); }
    .kpi-trend.down { background: rgba(239,68,68,0.1); color: #f87171; }
    .kpi-val { font-family: 'Sora', sans-serif; font-size: 1.5rem; font-weight: 800; color: white; letter-spacing: -0.04em; line-height: 1; margin-bottom: 0.25rem; }
    .kpi-label { font-size: 0.6875rem; color: var(--muted); }
    .kpi-spark { height: 32px; margin-top: 0.625rem; }
    .spark-svg { width: 100%; height: 100%; }

    /* Pipeline + activity row */
    .mid-row { display: grid; grid-template-columns: 1fr 1fr 280px; gap: 0.875rem; }

    .panel { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1rem; }
    .panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.875rem; }
    .panel-title { font-family: 'Sora', sans-serif; font-size: 0.8125rem; font-weight: 700; }
    .panel-action { font-size: 0.6rem; color: var(--green); cursor: pointer; }

    /* Pipeline stages */
    .pipeline { display: flex; flex-direction: column; gap: 0.5rem; }
    .stage { display: flex; align-items: center; gap: 0.625rem; }
    .stage-name { font-size: 0.6875rem; color: var(--muted); width: 80px; flex-shrink: 0; }
    .stage-bar-wrap { flex: 1; background: var(--surface2); height: 8px; border-radius: 4px; overflow: hidden; }
    .stage-bar { height: 100%; border-radius: 4px; }
    .stage-val { font-size: 0.625rem; font-weight: 700; color: white; width: 36px; text-align: right; flex-shrink: 0; }
    .stage-count { font-size: 0.5625rem; color: var(--subtle); width: 24px; text-align: right; flex-shrink: 0; }

    /* Contact list */
    .contact-list { display: flex; flex-direction: column; gap: 0.375rem; }
    .contact-item { display: flex; align-items: center; gap: 0.625rem; padding: 0.5rem; border-radius: 8px; cursor: pointer; transition: background 0.15s; }
    .contact-item:hover { background: var(--surface2); }
    .c-avatar { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.5625rem; font-weight: 700; flex-shrink: 0; }
    .c-name { font-size: 0.6875rem; font-weight: 600; color: white; }
    .c-company { font-size: 0.5625rem; color: var(--subtle); }
    .c-value { font-size: 0.6875rem; font-weight: 700; margin-left: auto; white-space: nowrap; }
    .c-stage { font-size: 0.5rem; padding: 0.1rem 0.35rem; border-radius: 3px; font-weight: 700; }

    /* Activity feed */
    .activity-feed { display: flex; flex-direction: column; gap: 0; overflow: hidden; }
    .activity-item { display: flex; gap: 0.5rem; padding: 0.4rem 0; border-bottom: 1px solid rgba(255,255,255,0.03); align-items: flex-start; }
    .activity-item:last-child { border-bottom: none; }
    .a-icon { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
    .a-icon svg { width: 10px; height: 10px; }
    .a-text { font-size: 0.625rem; color: var(--muted); line-height: 1.5; flex: 1; }
    .a-text strong { color: white; font-weight: 600; }
    .a-time { font-size: 0.5rem; color: var(--subtle); white-space: nowrap; margin-top: 2px; }

    /* Bottom row */
    .bottom-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.875rem; }

    /* Tasks */
    .task-list { display: flex; flex-direction: column; gap: 0.375rem; }
    .task { display: flex; align-items: flex-start; gap: 0.5rem; padding: 0.5rem; border-radius: 8px; transition: background 0.15s; cursor: pointer; }
    .task:hover { background: var(--surface2); }
    .task-check { width: 14px; height: 14px; border-radius: 4px; border: 1.5px solid var(--border); flex-shrink: 0; margin-top: 1px; display: flex; align-items: center; justify-content: center; }
    .task-check.done { background: var(--green); border-color: var(--green); }
    .task-check.done svg { width: 8px; height: 8px; }
    .task-text { font-size: 0.6875rem; color: white; flex: 1; line-height: 1.4; }
    .task-text.done { color: var(--subtle); text-decoration: line-through; }
    .task-due { font-size: 0.5625rem; font-weight: 600; padding: 0.1rem 0.375rem; border-radius: 4px; white-space: nowrap; }
    .task-due.overdue { background: rgba(239,68,68,0.12); color: #f87171; }
    .task-due.today { background: rgba(245,158,11,0.12); color: var(--amber); }
    .task-due.soon { background: var(--green-dim); color: var(--green); }

    /* Donut chart */
    .donut-row { display: flex; align-items: center; gap: 1.25rem; }
    .donut-svg { width: 90px; height: 90px; flex-shrink: 0; }
    .donut-legend { display: flex; flex-direction: column; gap: 0.375rem; flex: 1; }
    .dl-item { display: flex; align-items: center; gap: 0.375rem; font-size: 0.625rem; color: var(--muted); }
    .dl-dot { width: 7px; height: 7px; border-radius: 2px; flex-shrink: 0; }
    .dl-val { font-weight: 700; color: white; margin-left: auto; }
  </style>
</head>
<body>

<div class="sidebar">
  <div class="sidebar-top">
    <div class="sidebar-logo">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
      </div>
      <div class="logo-text">NexusCRM <span class="logo-badge">PRO</span></div>
    </div>
    <div class="search-box">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      Search contacts, deals...
    </div>
  </div>

  <div class="sidebar-nav">
    <div class="nav-section">
      <div class="nav-section-label">Main</div>
      <div class="nav-item active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Dashboard
      </div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        Contacts
        <div class="nav-badge grey">2,847</div>
      </div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        Pipeline
        <div class="nav-badge">14</div>
      </div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        Conversations
        <div class="nav-badge">3</div>
      </div>
    </div>
    <div class="nav-section">
      <div class="nav-section-label">Sales</div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Proposals
      </div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
        Invoices
      </div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        Analytics
      </div>
    </div>
    <div class="nav-section">
      <div class="nav-section-label">Team</div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Calendar
      </div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        Tasks
        <div class="nav-badge">7</div>
      </div>
    </div>
  </div>

  <div class="sidebar-bottom">
    <div class="sidebar-user">
      <div class="s-avatar">JM</div>
      <div>
        <div class="s-name">James Mitchell</div>
        <div class="s-plan">Sales Director</div>
      </div>
      <div class="s-chevron">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    </div>
  </div>
</div>

<div class="main">
  <div class="topbar">
    <div class="topbar-breadcrumb">Dashboard <span>/ Overview</span></div>
    <div class="topbar-actions">
      <button class="tb-btn outline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Export
      </button>
      <button class="tb-btn outline tb-notif">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        <div class="notif-dot"></div>
      </button>
      <button class="tb-btn primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Deal
      </button>
    </div>
  </div>

  <div class="content">

    <!-- KPI row -->
    <div class="kpi-row">
      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon" style="background:rgba(13,147,115,0.12);color:var(--green)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          </div>
          <div class="kpi-trend up">↑ 24.1%</div>
        </div>
        <div class="kpi-val" id="k1">$1,284,000</div>
        <div class="kpi-label">Pipeline Value</div>
        <div class="kpi-spark">
          <svg class="spark-svg" viewBox="0 0 100 32" preserveAspectRatio="none">
            <path d="M0,28 C10,25 20,20 30,18 C40,16 50,12 60,9 C70,6 80,5 90,3 L100,2" fill="none" stroke="rgba(13,147,115,0.5)" stroke-width="1.5"/>
          </svg>
        </div>
      </div>
      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon" style="background:rgba(139,92,246,0.12);color:var(--purple)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <div class="kpi-trend up">↑ 8.3%</div>
        </div>
        <div class="kpi-val">38.4%</div>
        <div class="kpi-label">Win Rate</div>
        <div class="kpi-spark">
          <svg class="spark-svg" viewBox="0 0 100 32" preserveAspectRatio="none">
            <path d="M0,20 C15,22 25,15 35,14 C45,13 55,10 65,11 C75,12 85,8 100,6" fill="none" stroke="rgba(139,92,246,0.5)" stroke-width="1.5"/>
          </svg>
        </div>
      </div>
      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon" style="background:rgba(245,158,11,0.12);color:var(--amber)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="kpi-trend down">↓ 3.2%</div>
        </div>
        <div class="kpi-val">24 days</div>
        <div class="kpi-label">Avg. Close Time</div>
        <div class="kpi-spark">
          <svg class="spark-svg" viewBox="0 0 100 32" preserveAspectRatio="none">
            <path d="M0,8 C15,10 25,14 35,16 C45,18 55,15 65,17 C75,19 85,22 100,20" fill="none" stroke="rgba(245,158,11,0.5)" stroke-width="1.5"/>
          </svg>
        </div>
      </div>
      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon" style="background:rgba(59,130,246,0.12);color:var(--blue)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div class="kpi-trend up">↑ 12.7%</div>
        </div>
        <div class="kpi-val" id="k4">2,847</div>
        <div class="kpi-label">Total Contacts</div>
        <div class="kpi-spark">
          <svg class="spark-svg" viewBox="0 0 100 32" preserveAspectRatio="none">
            <path d="M0,25 C15,22 25,18 35,14 C45,10 55,8 65,6 C75,4 85,3 100,2" fill="none" stroke="rgba(59,130,246,0.5)" stroke-width="1.5"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Mid row -->
    <div class="mid-row">
      <!-- Pipeline -->
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title">Sales Pipeline</div>
          <div class="panel-action">Manage →</div>
        </div>
        <div class="pipeline">
          <div class="stage">
            <div class="stage-name">Prospecting</div>
            <div class="stage-bar-wrap"><div class="stage-bar" style="width:85%;background:var(--blue)"></div></div>
            <div class="stage-val">$340K</div>
            <div class="stage-count">12</div>
          </div>
          <div class="stage">
            <div class="stage-name">Qualified</div>
            <div class="stage-bar-wrap"><div class="stage-bar" style="width:65%;background:var(--purple)"></div></div>
            <div class="stage-val">$228K</div>
            <div class="stage-count">8</div>
          </div>
          <div class="stage">
            <div class="stage-name">Proposal</div>
            <div class="stage-bar-wrap"><div class="stage-bar" style="width:48%;background:var(--amber)"></div></div>
            <div class="stage-val">$184K</div>
            <div class="stage-count">6</div>
          </div>
          <div class="stage">
            <div class="stage-name">Negotiation</div>
            <div class="stage-bar-wrap"><div class="stage-bar" style="width:32%;background:#f97316"></div></div>
            <div class="stage-val">$412K</div>
            <div class="stage-count">4</div>
          </div>
          <div class="stage">
            <div class="stage-name">Closing</div>
            <div class="stage-bar-wrap"><div class="stage-bar" style="width:20%;background:var(--green)"></div></div>
            <div class="stage-val">$120K</div>
            <div class="stage-count">2</div>
          </div>
        </div>
        <div style="margin-top:1rem;padding-top:0.875rem;border-top:1px solid var(--border);display:flex;gap:0.625rem">
          <div style="flex:1;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:0.625rem;text-align:center">
            <div style="font-family:'Sora',sans-serif;font-size:1rem;font-weight:800;color:white">$1.28M</div>
