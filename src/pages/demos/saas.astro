  @keyframes live-pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
</style>

<script>
  // Live counter updates
  setInterval(() => {
    const k1 = document.getElementById('k1');
    if (k1) {
      const base = 1284000;
      const delta = Math.floor((Math.random() - 0.4) * 2000);
      k1.textContent = '$' + (base + delta).toLocaleString();
    }
  }, 3500);

  // Nav clicks
  document.querySelectorAll('.nav-item').forEach(item => {
    item.addEventListener('click', () => {
      document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
      item.classList.add('active');
    });
  });

  // Task checkboxes
  document.querySelectorAll('.task').forEach(task => {
    task.addEventListener('click', () => {
      const check = task.querySelector('.task-check') as HTMLElement;
      const text = task.querySelector('.task-text') as HTMLElement;
      const due = task.querySelector('.task-due') as HTMLElement;
      if (!check.classList.contains('done')) {
        check.classList.add('done');
        check.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';
        text.classList.add('done');
        due.textContent = 'Done';
        due.style.background = 'rgba(255,255,255,0.04)';
        due.style.color = 'var(--subtle)';
      }
    });
  });
</script>
