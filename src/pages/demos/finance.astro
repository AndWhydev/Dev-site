---
// Demo page, for screen recording only, not linked in nav
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FinanceOS, Enterprise Financial Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #060b0a;
      --surface: #0c1411;
      --surface2: #111a17;
      --border: #1a2620;
      --green: #0d9373;
      --green-dim: rgba(13,147,115,0.12);
      --text: #ffffff;
      --muted: #8aa09a;
      --subtle: #3a5048;
    }
    body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; height: 100vh; overflow: hidden; display: grid; grid-template-columns: 220px 1fr; }

    /* Sidebar */
    .sidebar {
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      padding: 1.5rem 0;
    }
    .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0 1.25rem 1.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1.25rem;
    }
    .sidebar-logo-icon {
      width: 32px; height: 32px;
      background: var(--green);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
    }
    .sidebar-logo-icon svg { width: 18px; height: 18px; }
    .sidebar-logo-text { font-family: 'Sora', sans-serif; font-size: 0.875rem; font-weight: 700; color: white; }
    .sidebar-logo-sub { font-size: 0.625rem; color: var(--subtle); }
    .sidebar-nav { display: flex; flex-direction: column; gap: 2px; padding: 0 0.75rem; flex: 1; }
    .nav-item {
      display: flex; align-items: center; gap: 0.625rem;
      padding: 0.6rem 0.75rem;
      border-radius: 8px;
      font-size: 0.8125rem; font-weight: 500; color: var(--muted);
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .nav-item:hover { background: var(--surface2); color: white; }
    .nav-item.active { background: var(--green-dim); color: var(--green); }
    .nav-item svg { width: 15px; height: 15px; flex-shrink: 0; }
    .nav-section-label {
      font-size: 0.5625rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--subtle); padding: 0.875rem 0.75rem 0.375rem;
    }
    .sidebar-user {
      margin: 0 0.75rem;
      padding: 0.875rem 0.75rem;
      border-top: 1px solid var(--border);
      display: flex; align-items: center; gap: 0.625rem;
    }
    .user-avatar {
      width: 30px; height: 30px; border-radius: 50%;
      background: linear-gradient(135deg, var(--green), #0a7a5e);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Sora', sans-serif; font-size: 0.625rem; font-weight: 700;
    }
    .user-name { font-size: 0.75rem; font-weight: 600; color: white; }
    .user-role { font-size: 0.625rem; color: var(--subtle); }

    /* Main */
    .main {
      display: grid;
      grid-template-rows: 56px 1fr;
      overflow: hidden;
    }

    /* Topbar */
    .topbar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center;
      padding: 0 1.5rem;
      gap: 1rem;
    }
    .topbar-title { font-family: 'Sora', sans-serif; font-size: 0.9375rem; font-weight: 700; flex: 1; }
    .topbar-period {
      display: flex; gap: 2px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px; padding: 3px;
    }
    .period-btn {
      padding: 0.25rem 0.625rem;
      border-radius: 6px;
      font-size: 0.6875rem; font-weight: 600;
      color: var(--muted); cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .period-btn.active { background: var(--green); color: white; }
    .live-badge {
      display: flex; align-items: center; gap: 0.35rem;
      font-size: 0.6875rem; font-weight: 600; color: var(--green);
      background: var(--green-dim);
      border: 1px solid rgba(13,147,115,0.25);
      padding: 0.25rem 0.625rem;
      border-radius: 50px;
    }
    .live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: live-pulse 1.5s ease-in-out infinite; }
    @keyframes live-pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }
    .topbar-avatar {
      width: 30px; height: 30px; border-radius: 50%;
      background: linear-gradient(135deg, #6366f1, #4f46e5);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.625rem; font-weight: 700;
    }

    /* Content */
    .content {
      overflow-y: auto;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    /* Stat cards */
    .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.875rem; }
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.125rem;
      position: relative;
      overflow: hidden;
    }
    .stat-card::before {
      content: '';
      position: absolute;
      top: 0; right: 0;
      width: 80px; height: 80px;
      border-radius: 50%;
      background: var(--green-dim);
      transform: translate(30px, -30px);
    }
    .stat-icon {
      width: 32px; height: 32px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 0.625rem;
    }
    .stat-icon.rev { background: rgba(13,147,115,0.12); color: var(--green); }
    .stat-icon.cli { background: rgba(99,102,241,0.12); color: #818cf8; }
    .stat-icon.por { background: rgba(245,158,11,0.12); color: #fbbf24; }
    .stat-icon.pro { background: rgba(236,72,153,0.12); color: #f472b6; }
    .stat-icon svg { width: 15px; height: 15px; }
    .stat-label { font-size: 0.6875rem; color: var(--muted); margin-bottom: 0.25rem; }
    .stat-value { font-family: 'Sora', sans-serif; font-size: 1.375rem; font-weight: 800; color: white; letter-spacing: -0.03em; line-height: 1; margin-bottom: 0.375rem; }
    .stat-change { display: flex; align-items: center; gap: 0.25rem; font-size: 0.6875rem; font-weight: 600; }
    .stat-change.up { color: var(--green); }
    .stat-change.down { color: #f87171; }
    .stat-change-ref { font-size: 0.6rem; color: var(--subtle); font-weight: 400; }

    /* Chart + allocation row */
    .mid-row { display: grid; grid-template-columns: 1fr 280px; gap: 0.875rem; }

    .chart-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.125rem;
    }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
    .card-title { font-family: 'Sora', sans-serif; font-size: 0.8125rem; font-weight: 700; color: white; }
    .card-sub { font-size: 0.625rem; color: var(--muted); margin-top: 1px; }
    .chart-tabs { display: flex; gap: 2px; }
    .chart-tab { font-size: 0.625rem; font-weight: 600; color: var(--subtle); padding: 0.2rem 0.5rem; border-radius: 4px; cursor: pointer; }
    .chart-tab.active { background: var(--green-dim); color: var(--green); }

    .chart-area { position: relative; height: 160px; }
    .chart-svg { width: 100%; height: 100%; }

    /* Y-axis labels */
    .y-label { font-size: 0.5625rem; fill: var(--subtle); font-family: 'DM Sans', sans-serif; }
    .x-label { font-size: 0.5625rem; fill: var(--subtle); font-family: 'DM Sans', sans-serif; }
    .grid-line { stroke: var(--border); stroke-width: 1; }
    .chart-line { stroke: var(--green); stroke-width: 2.5; fill: none; stroke-linecap: round; stroke-linejoin: round; stroke-dasharray: 1000; stroke-dashoffset: 1000; animation: draw-line 2s ease forwards 0.5s; }
    .chart-area-fill { fill: url(#chartGradient); opacity: 0; animation: fade-fill 0.5s ease forwards 2.2s; }
    @keyframes draw-line { to { stroke-dashoffset: 0; } }
    @keyframes fade-fill { to { opacity: 1; } }
    .chart-dot { fill: var(--green); r: 3; }
    .compare-line { stroke: rgba(99,102,241,0.4); stroke-width: 1.5; fill: none; stroke-linecap: round; stroke-dasharray: 4 3; }

    /* Allocation card */
    .alloc-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.125rem;
      display: flex; flex-direction: column; gap: 0.875rem;
    }
    .donut-wrap { display: flex; justify-content: center; position: relative; }
    .donut-svg { width: 120px; height: 120px; }
    .donut-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; }
    .donut-total { font-family: 'Sora', sans-serif; font-size: 1rem; font-weight: 800; color: white; line-height: 1; }
    .donut-label { font-size: 0.5625rem; color: var(--muted); }
    .alloc-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .alloc-item { display: flex; align-items: center; gap: 0.5rem; }
    .alloc-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
    .alloc-name { font-size: 0.6875rem; color: var(--muted); flex: 1; }
    .alloc-pct { font-size: 0.6875rem; font-weight: 700; color: white; }
    .alloc-bar-wrap { width: 50px; background: var(--border); border-radius: 2px; height: 3px; }
    .alloc-bar { height: 3px; border-radius: 2px; }

    /* Bottom row */
    .bottom-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.875rem; }

    /* Table */
    .table-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.125rem;
      overflow: hidden;
    }
    .tx-table { width: 100%; border-collapse: collapse; }
    .tx-table th { font-size: 0.5625rem; font-weight: 700; color: var(--subtle); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.375rem 0.5rem; text-align: left; border-bottom: 1px solid var(--border); }
    .tx-table td { font-size: 0.6875rem; padding: 0.5rem 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.03); color: var(--muted); vertical-align: middle; }
    .tx-table tr:last-child td { border-bottom: none; }
    .tx-name { color: white; font-weight: 500; }
    .tx-badge { display: inline-block; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.5625rem; font-weight: 600; }
    .tx-badge.in { background: rgba(13,147,115,0.12); color: var(--green); }
    .tx-badge.out { background: rgba(248,113,113,0.12); color: #f87171; }
    .tx-badge.pen { background: rgba(251,191,36,0.12); color: #fbbf24; }
    .tx-amount.pos { color: var(--green); font-weight: 600; }
    .tx-amount.neg { color: #f87171; font-weight: 600; }
    .tx-avatar { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.5rem; font-weight: 700; }

    /* Activity feed */
    .feed-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.125rem;
      overflow: hidden;
    }
    .feed-list { display: flex; flex-direction: column; }
    .feed-item { display: flex; gap: 0.625rem; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.03); align-items: flex-start; }
    .feed-item:last-child { border-bottom: none; }
    .feed-dot-wrap { display: flex; flex-direction: column; align-items: center; gap: 0; padding-top: 4px; }
    .feed-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .feed-line { width: 1px; flex: 1; min-height: 20px; background: var(--border); margin-top: 3px; }
    .feed-item:last-child .feed-line { display: none; }
    .feed-title { font-size: 0.6875rem; color: white; font-weight: 500; margin-bottom: 2px; }
    .feed-time { font-size: 0.5625rem; color: var(--subtle); }
    .feed-amount { font-size: 0.6875rem; font-weight: 700; margin-left: auto; white-space: nowrap; }
  </style>
</head>
<body>

<!-- Sidebar -->
<div class="sidebar">
  <div class="sidebar-logo">
    <div class="sidebar-logo-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
    </div>
    <div>
      <div class="sidebar-logo-text">FinanceOS</div>
      <div class="sidebar-logo-sub">Enterprise Platform</div>
    </div>
  </div>

  <div class="sidebar-nav">
    <div class="nav-item active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Dashboard
    </div>
    <div class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      Portfolio
    </div>
    <div class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
      Markets
    </div>
    <div class="nav-section-label">Management</div>
    <div class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      Reports
    </div>
    <div class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      Clients
    </div>
    <div class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
      Payments
    </div>
    <div class="nav-section-label">Settings</div>
    <div class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      Settings
    </div>
  </div>

  <div class="sidebar-user">
    <div class="user-avatar">SA</div>
    <div>
      <div class="user-name">Sarah Anderson</div>
      <div class="user-role">CFO · All Webbed Corp</div>
    </div>
  </div>
</div>

<!-- Main -->
<div class="main">
  <div class="topbar">
    <div class="topbar-title">Financial Dashboard</div>
    <div class="topbar-period">
      <div class="period-btn">1W</div>
      <div class="period-btn">1M</div>
      <div class="period-btn active">3M</div>
      <div class="period-btn">1Y</div>
    </div>
    <div class="live-badge">
      <div class="live-dot"></div>
      Live Data
    </div>
    <div class="topbar-avatar">SA</div>
  </div>

  <div class="content">

    <!-- Stat cards -->
    <div class="stat-row">
      <div class="stat-card">
        <div class="stat-icon rev">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        </div>
        <div class="stat-label">Total Revenue</div>
        <div class="stat-value" id="s1">$2,847,392</div>
        <div class="stat-change up">↑ 18.3% <span class="stat-change-ref">vs last quarter</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon cli">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        </div>
        <div class="stat-label">Active Clients</div>
        <div class="stat-value" id="s2">1,247</div>
        <div class="stat-change up">↑ 4.2% <span class="stat-change-ref">new onboards</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon por">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div class="stat-label">Portfolio Value</div>
        <div class="stat-value">$48.2M</div>
        <div class="stat-change up">↑ 12.1% <span class="stat-change-ref">AUM growth</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon pro">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <div class="stat-label">Net Profit</div>
        <div class="stat-value" id="s4">$284,739</div>
        <div class="stat-change up">↑ 22.7% <span class="stat-change-ref">margin improved</span></div>
      </div>
    </div>

    <!-- Chart + allocation -->
    <div class="mid-row">
      <div class="chart-card">
        <div class="card-header">
          <div>
            <div class="card-title">Revenue Performance</div>
            <div class="card-sub">Comparing Q3 2026 vs Q3 2025</div>
          </div>
          <div class="chart-tabs">
            <div class="chart-tab active">Revenue</div>
            <div class="chart-tab">Expenses</div>
            <div class="chart-tab">Profit</div>
          </div>
        </div>
        <div class="chart-area">
          <svg class="chart-svg" viewBox="0 0 600 160" preserveAspectRatio="none">
            <defs>
              <linearGradient id="chartGradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#0d9373" stop-opacity="0.25"/>
                <stop offset="100%" stop-color="#0d9373" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <!-- Grid lines -->
            <line x1="60" y1="10" x2="590" y2="10" class="grid-line"/>
            <line x1="60" y1="45" x2="590" y2="45" class="grid-line"/>
            <line x1="60" y1="80" x2="590" y2="80" class="grid-line"/>
            <line x1="60" y1="115" x2="590" y2="115" class="grid-line"/>
            <!-- Y labels -->
            <text x="50" y="13" class="y-label" text-anchor="end">$3.5M</text>
            <text x="50" y="48" class="y-label" text-anchor="end">$2.5M</text>
            <text x="50" y="83" class="y-label" text-anchor="end">$1.5M</text>
            <text x="50" y="118" class="y-label" text-anchor="end">$0.5M</text>
            <!-- X labels -->
            <text x="100" y="148" class="x-label" text-anchor="middle">Jan</text>
            <text x="170" y="148" class="x-label" text-anchor="middle">Feb</text>
            <text x="240" y="148" class="x-label" text-anchor="middle">Mar</text>
            <text x="310" y="148" class="x-label" text-anchor="middle">Apr</text>
            <text x="380" y="148" class="x-label" text-anchor="middle">May</text>
            <text x="450" y="148" class="x-label" text-anchor="middle">Jun</text>
            <text x="520" y="148" class="x-label" text-anchor="middle">Jul</text>
            <text x="590" y="148" class="x-label" text-anchor="middle">Aug</text>
            <!-- Previous year line -->
            <path d="M60,100 C100,95 130,90 170,88 C210,86 240,80 280,78 C320,76 350,72 390,70 C430,68 460,65 500,62 C530,60 560,58 600,55" class="compare-line"/>
            <!-- Current year line -->
            <path d="M60,95 C100,85 130,75 170,68 C210,60 240,55 280,48 C320,40 350,38 390,30 C430,22 460,18 500,15 C530,12 560,11 600,10" class="chart-line"/>
