    {
      term: 'Blue-green deployment',
      definition: 'Running two identical production environments and switching all traffic from the old (blue) to the new (green) at once, allowing instant rollback if the new version misbehaves.',
    },
    {
      term: 'Canary deployment',
      definition: 'Releasing a new version to a small fraction of traffic first and widening the rollout only if error rates and latency stay healthy, limiting the blast radius of a bad release.',
