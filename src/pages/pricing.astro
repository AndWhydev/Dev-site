---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';

const engagementModels = [
  {
    id: 'fixed-price',
    name: 'Fixed Price Project',
    bestFor: 'Well-defined projects with clear requirements',
    description: 'A fully scoped engagement with a fixed cost and timeline. Ideal when you know exactly what you need and want full budget certainty before work begins.',
    timeline: '8–20 weeks',
    budget: '$50K – $500K+',
    highlight: false,
    included: [
      'Detailed discovery and scoping workshop',
      'Full product specification and architecture document',
      'Dedicated project manager and tech lead',
      'Weekly progress reports and demos',
      'Comprehensive test coverage and QA sign-off',
      'Deployment and go-live support',
      'Post-launch warranty period (30 days)',
      'Knowledge transfer and documentation handover',
    ],
  },
  {
    id: 'time-materials',
    name: 'Time & Materials',
    bestFor: 'Projects with evolving or exploratory requirements',
    description: 'Pay for actual time spent. Perfect for projects where the scope will naturally evolve, or when you need the flexibility to pivot as you learn more.',
    timeline: 'Ongoing / project-based',
    budget: 'Hourly / daily rate',
    highlight: false,
    included: [
      'Senior engineer allocation (minimum 20 hrs/week)',
      'Weekly timesheets with task-level detail',
      'Slack / Teams channel with your team',
      'Daily standups (async or live)',
      'Continuous delivery to staging environment',
      'No lock-in — pause or stop at any sprint boundary',
      'Full IP ownership transferred on payment',
      'Monthly retrospective and planning session',
    ],
  },
  {
    id: 'dedicated-team',
    name: 'Dedicated Development Team',
    bestFor: 'Ongoing product development at scale',
    description: 'A fully dedicated team of engineers, designers and QA specialists embedded in your product cycle. They become an extension of your internal team.',
    timeline: 'Monthly (3-month minimum)',
    budget: 'Custom — from $40K/month',
    highlight: true,
    included: [
      '2–6 senior engineers fully allocated to your product',
      'Dedicated UX/UI designer (optional)',
      'QA engineer and DevOps specialist',
      'Delivery manager handling all coordination',
      'Full access to team via your preferred tools',
      'Two-week sprint cycles with demos',
      'Quarterly strategy and roadmap planning',
      'Seamless team scaling up or down with 2-week notice',
    ],
  },
  {
    id: 'retainer',
    name: 'Monthly Retainer',
    bestFor: 'Ongoing support, iteration and feature work',
    description: 'A fixed monthly block of hours for ongoing development, maintenance, security updates and incremental feature work. Predictable costs, continuous momentum.',
    timeline: 'Monthly rolling',
    budget: 'From $10K/month',
    highlight: false,
    included: [
      'Agreed monthly hours (40–160 hrs/month)',
      'Priority response SLA (4-hour critical, 1 business day standard)',
      'Bug fixes and security patches included',
      'Monthly feature development sprint',
      'Proactive performance monitoring and reporting',
      'Quarterly technology health review',
      'Dedicated account manager',
      'Unused hours roll over up to 20%',
    ],
  },
  {
    id: 'mvp',
    name: 'Startup MVP Package',
    bestFor: 'Founders going from idea to first users',
    description: 'Purpose-built for founders and early-stage startups. We deliver a validated, deployable MVP within a fixed timeline and budget, ready to show investors and users.',
    timeline: '8–12 weeks',
    budget: '$40K – $80K',
    highlight: false,
    included: [
      'Product strategy and feature prioritisation workshop',
      'UX/UI design (up to 15 screens)',
      'Full-stack web or mobile app development',
      'User authentication, payments and core integrations',
      'Cloud infrastructure setup (AWS or GCP)',
      'App Store / Play Store submission support',
      'Analytics and error tracking configured',
      '4-week post-launch support included',
    ],
  },
  {
    id: 'enterprise',
    name: 'Enterprise Agreement',
    bestFor: 'Large organisations with multi-project or multi-year needs',
    description: 'A strategic partnership arrangement for enterprises requiring priority access, multiple concurrent projects, volume pricing and executive-level account management.',
    timeline: '12+ months',
    budget: 'Custom pricing',
    highlight: false,
    included: [
      'Dedicated executive account manager',
      'Priority resource allocation across all projects',
      'Volume discounts across all engagement types',
      'On-site workshops and quarterly business reviews',
      'Access to full Labs team including specialised roles',
      'Security review and penetration testing included',
      'Custom SLAs and compliance documentation',
      'White-label and NDA options available',
    ],
  },
];

const comparisonRows = [
  { feature: 'IP Ownership', values: ['Full', 'Full', 'Full', 'Full', 'Full', 'Full'] },
  { feature: 'Dedicated Team', values: ['Partial', 'Partial', 'Yes', 'Partial', 'Partial', 'Yes'] },
  { feature: 'Fixed Price', values: ['Yes', 'No', 'No', 'Yes', 'Yes', 'Negotiable'] },
  { feature: 'Flexible Scope', values: ['No', 'Yes', 'Yes', 'Limited', 'Limited', 'Yes'] },
  { feature: 'Support Included', values: ['30-day', 'No', 'Yes', 'Yes', '4-week', 'Custom SLA'] },
  { feature: 'Min. Commitment', values: ['Project', 'Sprint', '3 months', '1 month', 'Project', '12 months'] },
];

const costFactors = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'Project Complexity',
    desc: 'The number of distinct features, integrations, and technical decisions drives most of the cost. A simple CRUD app differs vastly from a multi-tenant SaaS with real-time data pipelines.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Timeline & Urgency',
    desc: 'Compressed timelines require larger teams working in parallel. A 12-week project timeline delivered in 6 weeks typically requires 40–60% more budget due to concurrent resource allocation.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: 'Platform Scope',
    desc: 'Building for web only, or web plus iOS plus Android plus admin dashboard? Each additional platform adds engineering effort, though cross-platform frameworks like Flutter reduce this significantly.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Security & Compliance',
    desc: 'Projects requiring SOC 2, ISO 27001, HIPAA, PCI DSS or government security frameworks need additional architecture work, documentation and testing to meet compliance requirements.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/></svg>`,
    title: 'Third-Party Integrations',
    desc: 'ERP systems, payment gateways, government APIs, legacy databases — each integration adds scope. Well-documented modern APIs take hours; undocumented legacy systems can take weeks.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`,
    title: 'Design Requirements',
    desc: 'Using an existing design system vs. creating a custom brand experience from scratch is a significant variable. Custom animations, 3D elements and complex data visualisation all add design time.',
  },
];

const faqs = [
  {
    q: 'How does the quoting process work?',
    a: 'We start with a free 30-minute discovery call to understand your requirements. If there\'s a fit, we conduct a paid scoping workshop (credited against the project if you proceed) to define the full scope, architecture and timeline. You receive a detailed proposal with fixed pricing or a rate card within 5 business days.',
  },
  {
    q: 'What are your payment terms?',
    a: 'For fixed-price projects, we typically structure payments as: 30% upfront, 40% at mid-project milestone and 30% on delivery. For T&M engagements, we invoice fortnightly in arrears. Retainers and dedicated team arrangements are invoiced monthly in advance. All major payment methods accepted.',
  },
  {
    q: 'What happens if the scope changes mid-project?',
    a: 'Scope changes are a normal part of software development. For fixed-price projects, we use a formal change request process — any material additions are quoted and approved before work begins. For T&M and dedicated team arrangements, scope changes are handled naturally within the hourly/monthly model.',
  },
  {
    q: 'Do you work with offshore development?',
    a: 'No. All Webbed Labs is a 100% Australian-based team. We do not offshore or outsource any development work. When you engage us, you\'re working with the same senior engineers who are on your calls. This is a conscious decision — we believe quality enterprise software requires deep communication, cultural alignment and accountability.',
  },
  {
    q: 'Who owns the intellectual property?',
    a: 'You do. Full stop. Once you\'ve paid for the work, all intellectual property — including code, designs, documentation and data models — belongs entirely to you. Our contracts are clear on this with no ambiguity. We retain no licensing rights or code ownership after delivery.',
  },
  {
    q: 'Do you offer any guarantees?',
    a: 'Yes. For fixed-price projects, we offer a 30-day post-launch warranty covering any defects that exist in the delivered scope. For ongoing engagements, issues are addressed within agreed SLA timeframes. We also offer a satisfaction guarantee on discovery workshops — if you\'re not satisfied with the output, we\'ll refund it.',
  },
  {
    q: 'Can I start small and scale up the engagement?',
    a: 'Absolutely — this is actually our most common path. Many clients start with a 4-week discovery and prototype, then move to a fixed-price MVP, then transition to a monthly retainer or dedicated team for ongoing product work. We\'re designed to scale with you as your needs evolve.',
  },
  {
    q: 'How long does it take to get started?',
    a: 'For smaller retainer and T&M engagements, we can typically onboard within 1–2 weeks. Dedicated team arrangements take 2–3 weeks to staff correctly. For large fixed-price projects, the scoping phase runs 2–4 weeks before development begins. We maintain a roster of available senior engineers to minimise ramp-up time.',
  },
];
---

<Layout
  title="Pricing & Engagement Models — All Webbed Labs"
  description="Transparent pricing and flexible engagement models for enterprise software development. Fixed price, T&M, dedicated teams, retainers and more."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="pricing-hero">
      <div class="pricing-hero-bg" aria-hidden="true">
        <div class="hero-glow"></div>
        <div class="hero-grid"></div>
      </div>
      <div class="pricing-hero-inner">
        <div class="reveal">
          <span class="section-label">Pricing & Engagement</span>
          <h1 class="pricing-title">
            Transparent Pricing.<br />
            <span class="gradient-text">Flexible Engagement.</span>
          </h1>
          <p class="pricing-sub">
            No hidden fees, no bait-and-switch, no offshore surprises. Choose the engagement model that fits
            your project, your team and your budget — then get a detailed proposal before committing to a cent.
          </p>
          <div class="hero-trust">
            <div class="trust-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>100% Australian team</span>
            </div>
            <div class="trust-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>No lock-in contracts</span>
            </div>
            <div class="trust-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Full IP ownership from day one</span>
            </div>
            <div class="trust-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Free discovery call</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Engagement Models -->
    <section class="models-section">
      <div class="models-inner">
        <div class="models-header reveal">
          <span class="section-label">Engagement Models</span>
          <h2 class="section-heading">Six Ways to Work With Us</h2>
          <p class="section-subheading">
            Every project is different. We offer six engagement models so you can choose the arrangement that matches your requirements, risk tolerance and budget.
          </p>
        </div>

        <div class="models-grid">
          {engagementModels.map((model, i) => (
            <div class={`model-card reveal stagger-${(i % 3) + 1} ${model.highlight ? 'model-card--featured' : ''}`}>
              {model.highlight && <div class="model-featured-badge">Most Popular</div>}
              <div class="model-header">
                <h3 class="model-name">{model.name}</h3>
                <div class="model-best-for">Best for: {model.bestFor}</div>
              </div>
              <p class="model-desc">{model.description}</p>
              <div class="model-meta">
                <div class="model-meta-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <span>{model.timeline}</span>
                </div>
                <div class="model-meta-item model-meta-budget">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                  <span>{model.budget}</span>
                </div>
              </div>
              <div class="model-divider"></div>
              <div class="model-includes-label">What's included</div>
              <ul class="model-includes">
                {model.included.map((item) => (
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
              <a href="/contact" class={model.highlight ? 'btn-primary model-cta' : 'btn-outline model-cta'}>
                Get a Quote
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="comparison-section">
      <div class="comparison-inner">
        <div class="comparison-header reveal">
          <span class="section-label">Side-by-Side Comparison</span>
          <h2 class="section-heading">Find the Right Fit</h2>
          <p class="section-subheading">
            A quick-reference guide to the key differences between each engagement model.
          </p>
        </div>
        <div class="table-wrap reveal">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>Feature</th>
                {engagementModels.map((m) => <th>{m.name}</th>)}
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row) => (
                <tr>
                  <td class="feature-col">{row.feature}</td>
                  {row.values.map((val) => (
                    <td>
                      {val === 'Yes' || val === 'Full'
                        ? <span class="val-yes">{val}</span>
                        : val === 'No'
                          ? <span class="val-no">{val}</span>
                          : <span class="val-partial">{val}</span>
                      }
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Cost Factors -->
    <section class="factors-section">
      <div class="factors-inner">
        <div class="factors-header reveal">
          <span class="section-label">What Affects Cost</span>
          <h2 class="section-heading">Six Factors That Drive Project Budget</h2>
          <p class="section-subheading">
            Understanding these factors helps you scope projects accurately and make smart trade-off decisions before a quote is issued.
          </p>
        </div>
        <div class="factors-grid">
          {costFactors.map((factor, i) => (
            <div class={`factor-card reveal stagger-${(i % 3) + 1}`}>
              <div class="factor-icon" set:html={factor.icon}></div>
              <h3 class="factor-title">{factor.title}</h3>
              <p class="factor-desc">{factor.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="faq-inner">
        <div class="faq-header reveal">
          <span class="section-label">Frequently Asked Questions</span>
          <h2 class="section-heading">Pricing Questions, Answered</h2>
          <p class="section-subheading">
            Everything you need to know before reaching out. If your question isn't here, just ask.
          </p>
        </div>
        <div class="faq-list">
          {faqs.map((faq, i) => (
            <div class={`faq-item reveal stagger-${(i % 4) + 1}`}>
              <button class="faq-q" aria-expanded="false">
                <span>{faq.q}</span>
                <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-a" hidden>
                <p>{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Guarantee -->
    <section class="guarantee-section">
      <div class="guarantee-inner reveal">
        <div class="guarantee-icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        </div>
        <div class="guarantee-content">
          <h2 class="guarantee-title">Our Satisfaction Guarantee</h2>
          <p class="guarantee-text">
            We stand behind our work. Every fixed-price project includes a 30-day post-launch warranty — if a defect exists within the agreed scope, we fix it at no charge. Our paid scoping workshops include a full refund if you're not satisfied with the output. And for ongoing engagements, we work to SLAs with financial accountability built in.
          </p>
          <p class="guarantee-text">
            We've built long-term relationships with clients because we do what we say we'll do. If we make a mistake, we own it, fix it and learn from it. That's the All Webbed Labs standard.
          </p>
          <div class="guarantee-badges">
            <div class="g-badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              30-day post-launch warranty
            </div>
            <div class="g-badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Scoping workshop money-back guarantee
            </div>
            <div class="g-badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              SLA-backed ongoing engagements
            </div>
          </div>
        </div>
      </div>
    </section>

    <CTABanner />
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .pricing-hero {
    padding: 10rem 0 6rem;
    background: #0a0f0e;
    position: relative;
    overflow: hidden;
  }
  .pricing-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(13,147,115,0.1) 0%, transparent 65%);
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(13,147,115,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(13,147,115,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .pricing-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }
  .pricing-title {
    font-family: 'Sora', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    color: white;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    max-width: 800px;
  }
  .pricing-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    color: #8aa09a;
    max-width: 640px;
    line-height: 1.7;
    margin: 0 0 2rem;
  }
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #4a6359;
  }
  .trust-item svg { color: #0d9373; flex-shrink: 0; }

  /* Models */
  .models-section {
    padding: 7rem 0;
    background: #0f1614;
  }
  .models-inner {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .models-header {
    max-width: 640px;
    margin-bottom: 4rem;
  }
  .models-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .model-card {
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 20px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .model-card:hover {
    border-color: rgba(13,147,115,0.25);
    transform: translateY(-4px);
  }
  .model-card--featured {
    border-color: rgba(13,147,115,0.4);
    background: linear-gradient(135deg, #0a1510 0%, #0a0f0e 100%);
    box-shadow: 0 0 0 1px rgba(13,147,115,0.2), 0 20px 60px rgba(0,0,0,0.3);
  }
  .model-card--featured:hover {
    border-color: rgba(13,147,115,0.6);
  }
  .model-featured-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #0d9373;
    color: white;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 1rem;
    border-radius: 50px;
    white-space: nowrap;
  }
  .model-header {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .model-name {
    font-family: 'Sora', sans-serif;
    font-size: 1.1875rem;
