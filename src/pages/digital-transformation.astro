</style>

<script>
  // ─── FAQ accordion ─────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      const idx = btn.dataset.faq;
      const panel = document.getElementById(`faq-${idx}`);
      btn.setAttribute('aria-expanded', String(!isOpen));
      if (panel) panel.hidden = isOpen;
    });
  });

  // ─── Maturity Assessment Quiz ──────────────────
  const scores: number[] = [];
  let currentQ = 0;
  const totalQ = 5;

  const questions = document.querySelectorAll<HTMLElement>('.quiz-question');
  const progressFill = document.getElementById('quiz-progress-fill') as HTMLElement;
  const progressLabel = document.getElementById('quiz-progress-label') as HTMLElement;
  const quizResult = document.getElementById('quiz-result') as HTMLElement;
  const resultBadge = document.getElementById('result-badge') as HTMLElement;
  const resultScore = document.getElementById('result-score') as HTMLElement;
  const resultContent = document.getElementById('result-content') as HTMLElement;
  const restartBtn = document.getElementById('quiz-restart') as HTMLButtonElement;
  const questionsContainer = document.getElementById('quiz-questions') as HTMLElement;

  const results = {
    beginner: {
      label: 'Beginner',
      title: 'Early-Stage: Significant Transformation Opportunity',
      desc: 'Your organisation is in the early stages of digital maturity. The gap between your current systems and what is possible is large — which means the ROI from a structured transformation programme is also large. The risk: doing too much at once and creating disruption without momentum.',
      steps: [
        'Conduct an IT portfolio audit to understand what you own and what it costs',
        'Identify one or two high-pain, high-volume manual processes for quick-win automation',
        'Begin cloud readiness assessment for non-critical workloads',
        'Establish a data governance baseline covering naming, ownership and quality',
        'Book a discovery engagement to build a prioritised 12-month roadmap',
      ],
    },
    developing: {
      label: 'Developing',
      title: 'Developing: Mid-Transformation Inflection Point',
      desc: 'You have made meaningful progress — some cloud adoption, some automation, improving tooling. But the organisation is likely operating in hybrid mode: modern tools in some areas, legacy drag in others. This creates complexity and prevents full productivity gains from becoming visible.',
      steps: [
        'Map remaining legacy dependencies and build a decommissioning sequencing plan',
        'Standardise your data stack — data warehouse, BI tooling, data catalogue',
        'Move CI/CD from some teams to standard practice across engineering',
        'Expand process automation to end-to-end workflows rather than individual tasks',
        'Build or engage an internal platform team — developer experience now compounds',
      ],
    },
    advanced: {
      label: 'Advanced',
      title: 'Advanced: Optimise and Differentiate',
      desc: 'Your digital foundations are solid. Cloud-native, automated, data-driven and deploying continuously — you are in the top quartile of Australian enterprise digital maturity. The focus now shifts from foundational transformation to competitive differentiation through AI, personalisation and next-generation customer experience.',
      steps: [
        'Invest in AI/ML capabilities layered onto your clean data foundation',
        'Platform engineering: build the internal developer platform that compounds productivity',
        'Explore real-time data architecture for customer-facing personalisation',
        'Extend automation into supplier and customer-facing workflows',
        'Conduct a security posture review — maturity in other dimensions often reveals security gaps',
      ],
    },
  } as const;

  type ResultKey = keyof typeof results;

  function updateProgress(): void {
    const pct = (currentQ / totalQ) * 100;
    progressFill.style.width = `${pct}%`;
    progressLabel.textContent = currentQ < totalQ
      ? `Question ${currentQ + 1} of ${totalQ}`
      : 'Complete';
  }

  function showQuestion(idx: number): void {
    questions.forEach((q) => q.classList.remove('active'));
    if (questions[idx]) questions[idx].classList.add('active');
    updateProgress();
  }

  function showResult(): void {
    const total = scores.reduce((a, b) => a + b, 0);
    let key: ResultKey;
    if (total <= 8) key = 'beginner';
    else if (total <= 12) key = 'developing';
    else key = 'advanced';

    const r = results[key];
    resultBadge.textContent = r.label;
    resultScore.textContent = `${total}/15`;
    resultContent.innerHTML = `
      <h3>${r.title}</h3>
      <p>${r.desc}</p>
      <p><strong style="color:#8aa09a;font-family:'Sora',sans-serif;font-size:0.875rem;">Recommended next steps:</strong></p>
      <ul>${r.steps.map((s) => `<li>${s}</li>`).join('')}</ul>
      <a href="/contact" class="btn-primary" style="display:inline-flex;margin-top:1.5rem;">
        Book a Transformation Consultation
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    `;
    questionsContainer.hidden = true;
    progressFill.style.width = '100%';
    progressLabel.textContent = 'Complete';
    quizResult.hidden = false;
  }

  document.querySelectorAll<HTMLButtonElement>('.quiz-option').forEach((btn) => {
    btn.addEventListener('click', () => {
      const qEl = btn.closest<HTMLElement>('.quiz-question');
      const val = parseInt(btn.dataset.value ?? '1', 10);
      qEl?.querySelectorAll('.quiz-option').forEach((b) => b.classList.remove('selected'));
      btn.classList.add('selected');
      setTimeout(() => {
        scores[currentQ] = val;
        currentQ++;
        if (currentQ < totalQ) {
          showQuestion(currentQ);
        } else {
          showResult();
        }
      }, 280);
    });
  });

  restartBtn.addEventListener('click', () => {
    scores.length = 0;
    currentQ = 0;
    questionsContainer.hidden = false;
    quizResult.hidden = true;
    document.querySelectorAll('.quiz-option').forEach((b) => b.classList.remove('selected'));
    showQuestion(0);
  });

  showQuestion(0);
</script>
