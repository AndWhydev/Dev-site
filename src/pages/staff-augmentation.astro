---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';

// PAGE: Staff Augmentation
// TODO: Replace placeholder case studies with real client data when available
---

<Layout
  title="Staff Augmentation — All Webbed Labs | Extend Your Tech Team"
  description="Extend your development team with senior Australian engineers. Flutter, React, Node.js, AI/ML, DevOps and more. Flexible engagement, no lock-in."
>
  <Header />
  <main>

    <!-- ═══════════════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════════════ -->
    <section class="sa-hero">
      <div class="sa-hero-bg" aria-hidden="true">
        <div class="sa-glow-1"></div>
        <div class="sa-glow-2"></div>
        <div class="sa-grid"></div>
      </div>
      <div class="sa-hero-inner">
        <div class="sa-hero-content reveal">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a><span>/</span><span>Staff Augmentation</span>
          </nav>
          <span class="section-label">Staff Augmentation</span>
          <h1 class="sa-hero-title">
            Extend Your Team With<br />
            <span class="gradient-text">World-Class Developers</span>
          </h1>
          <p class="sa-hero-sub">
            Senior engineers embedded into your team, working in your timezone, using your tools, aligned to your
            engineering culture. No agency overhead. No offshore communication delays. No juniors billing at senior rates.
            Engineers who show up on day one and deliver.
          </p>
          <div class="sa-hero-ctas">
            <a href="/contact" class="btn-primary">
              Brief Us on Your Needs
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#roles" class="btn-outline">View Available Roles</a>
          </div>
          <div class="hero-trust-row">
            <div class="trust-item"><span class="trust-num">48hr</span><span class="trust-label">Match-to-Interview Time</span></div>
            <div class="trust-divider"></div>
            <div class="trust-item"><span class="trust-num">Senior</span><span class="trust-label">Engineers Only</span></div>
            <div class="trust-divider"></div>
            <div class="trust-item"><span class="trust-num">AEST</span><span class="trust-label">Timezone Aligned</span></div>
          </div>
        </div>
        <div class="sa-hero-visual reveal-right stagger-2" aria-hidden="true">
          <div class="team-card">
            <div class="team-member-row">
              {['Frontend', 'Backend', 'Flutter', 'AI/ML', 'DevOps'].map((role) => (
                <div class="team-pill">{role}</div>
              ))}
            </div>
            <div class="team-plus">+Your Team</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         HOW IT WORKS
    ═══════════════════════════════════════════════════ -->
    <section class="sa-section bg-surface">
      <div class="sa-inner">
        <div class="section-header reveal">
          <span class="section-label">How It Works</span>
          <h2 class="section-heading">Three Steps to Your Extended Team</h2>
          <p class="section-subheading">
            We've streamlined the process so you have a matched, vetted engineer ready to start within days — not weeks.
          </p>
        </div>
        <div class="how-grid">
          <div class="how-step reveal stagger-1">
            <div class="how-num">01</div>
            <div class="how-content">
              <h3>Brief Us</h3>
              <p>
                Tell us what you need: the role, the tech stack, the team context, the engagement length and when you
                want to start. We do not need a formal job description — a 30-minute call is enough.
                We ask the questions other agencies don't: what does your team culture look like? What's the biggest
                delivery challenge? What does failure look like in this role?
              </p>
            </div>
          </div>
          <div class="how-connector reveal stagger-2" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1e2d28" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
          <div class="how-step reveal stagger-2">
            <div class="how-num">02</div>
            <div class="how-content">
              <h3>Match Engineers</h3>
              <p>
                Within 48 hours, we present two to three pre-screened candidates from our pool — not CVs from a database,
                but engineers we know personally, whose code we have reviewed and whose working style we can vouch for.
                You interview them. If none are right, we keep looking. No fee until you say yes.
              </p>
            </div>
          </div>
          <div class="how-connector reveal stagger-3" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1e2d28" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
          <div class="how-step reveal stagger-3">
            <div class="how-num">03</div>
            <div class="how-content">
              <h3>Embed and Deliver</h3>
              <p>
                Your new engineer joins your Slack, your GitHub, your sprint ceremonies and your team calls. They
                operate as a member of your team — not a contractor who disappears after a ticket is closed. We stay
                in the background: monthly check-ins, performance oversight and rapid replacement if something is not working.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         ROLES AVAILABLE
    ═══════════════════════════════════════════════════ -->
    <section class="sa-section bg-dark" id="roles">
      <div class="sa-inner">
        <div class="section-header reveal">
          <span class="section-label">Roles Available</span>
          <h2 class="section-heading">Every Engineering Role You Need</h2>
          <p class="section-subheading">
            Senior practitioners across the full software development lifecycle. All with minimum five years commercial experience.
          </p>
        </div>
        <div class="roles-grid">
          {[
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>`,
              role: 'Frontend Engineer',
              skills: 'React, Next.js, Vue, TypeScript, Tailwind, performance, accessibility'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
              role: 'Backend Engineer',
              skills: 'Node.js, Python, Go, Java, PostgreSQL, Redis, API design, microservices'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
              role: 'Mobile Engineer',
              skills: 'React Native, Swift, Kotlin, iOS/Android, App Store deployment, offline-first'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
              role: 'Flutter Developer',
              skills: 'Flutter, Dart, BLoC, Riverpod, Firebase, platform channels, CI/CD for mobile'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M20 12c0-4.4-3.6-8-8-8s-8 3.6-8 8 3.6 8 8 8 8-3.6 8-8z"/></svg>`,
              role: 'AI / ML Engineer',
              skills: 'Python, PyTorch, LLM fine-tuning, RAG, LangChain, MLOps, data pipelines'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
              role: 'DevOps / Platform Engineer',
              skills: 'AWS, GCP, Terraform, Kubernetes, GitHub Actions, observability, security'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
              role: 'UI / UX Designer',
              skills: 'Figma, design systems, user research, prototyping, accessibility, brand'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
              role: 'QA / Test Engineer',
              skills: 'Cypress, Playwright, Jest, API testing, load testing, test strategy, automation'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
              role: 'Solutions Architect',
              skills: 'System design, cloud architecture, ADRs, technical due diligence, vendor evaluation'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
              role: 'Engineering Manager',
              skills: 'Team leadership, delivery planning, 1:1s, hiring, technical roadmaps, stakeholder comms'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
              role: 'Technical Lead',
              skills: 'Code review, architecture decisions, mentoring, sprint ownership, cross-functional delivery'
            },
          ].map((r, i) => (
            <div class={`role-card card-hover reveal stagger-${Math.min((i % 6) + 1, 6)}`}>
              <div class="role-icon" set:html={r.icon} />
              <div class="role-details">
                <div class="role-title">{r.role}</div>
                <div class="role-skills">{r.skills}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         AUGMENT VS HIRE
    ═══════════════════════════════════════════════════ -->
    <section class="sa-section bg-surface">
      <div class="sa-inner">
        <div class="section-header reveal">
          <span class="section-label">The Comparison</span>
          <h2 class="section-heading">Staff Augmentation vs Direct Hire</h2>
          <p class="section-subheading">
            Neither is always right. Here is an honest comparison to help you decide what fits your situation.
          </p>
        </div>
        <div class="comparison-table reveal stagger-1">
          <div class="comp-header">
            <div class="comp-dim">Dimension</div>
            <div class="comp-aug">Staff Augmentation</div>
            <div class="comp-hire">Direct Hire</div>
          </div>
          {[
            { dim: 'Time to start', aug: '1–2 weeks', hire: '3–6 months (hiring cycle)' },
            { dim: 'Upfront cost', aug: 'No recruiter fee, no equity dilution', hire: 'Recruiter fee or equity' },
            { dim: 'Flexibility', aug: 'Scale up, down or out with notice', hire: 'Fixed headcount, complex to unwind' },
            { dim: 'Payroll overhead', aug: 'None — we handle employment, super, leave', hire: 'Employer of record obligations' },
            { dim: 'Commitment risk', aug: 'Low — typically 3-month minimum', hire: 'High — cultural misfit is expensive' },
            { dim: 'Deep team integration', aug: 'Good — works within your team fully', hire: 'Strongest — permanent member' },
            { dim: 'Long-term cost', aug: 'Higher hourly rate than salary equivalent', hire: 'Lower total cost over 2+ years' },
            { dim: 'Best suited for', aug: 'Surge capacity, skill gap, time-sensitive projects', hire: 'Core long-term roles, culture carriers' },
          ].map((row, i) => (
            <div class={`comp-row ${i % 2 === 0 ? 'comp-row-alt' : ''}`}>
              <div class="comp-dim">{row.dim}</div>
              <div class="comp-aug">{row.aug}</div>
              <div class="comp-hire">{row.hire}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         VETTING PROCESS
    ═══════════════════════════════════════════════════ -->
    <section class="sa-section bg-dark">
      <div class="sa-inner">
        <div class="section-header reveal">
          <span class="section-label">Quality Assurance</span>
          <h2 class="section-heading">Our 5-Step Engineer Vetting Process</h2>
          <p class="section-subheading">
            Every engineer in our pool has passed this process. We decline 85% of applicants.
            You should never receive a candidate who is not genuinely senior.
          </p>
        </div>
        <div class="vetting-steps">
          {[
            {
              step: '01',
              title: 'Application Screening',
              desc: 'CV and portfolio review against senior engineer benchmarks. We filter on genuine commercial experience — not credentials. FAANG or startup, what matters is shipped production code in demanding environments.'
            },
            {
              step: '02',
              title: 'Technical Assessment',
              desc: 'A take-home assessment calibrated to the role — not a whiteboard algorithm test. Frontend engineers build a real component. Backend engineers design a system. We assess code quality, decisions made and what was asked about edge cases.'
            },
            {
              step: '03',
              title: 'Live Code Review',
              desc: 'A 60-minute live session: reviewing real production code they have written, discussing the decisions made and what they would change. This reveals far more about engineering judgment than any prepared exercise.'
            },
            {
              step: '04',
              title: 'Cultural Fit Interview',
              desc: 'A structured conversation about how they work in teams: how they give feedback, handle technical disagreements, communicate blockers and approach ambiguous requirements. Senior engineers must communicate, not just code.'
            },
            {
              step: '05',
              title: 'Trial Project',
              desc: 'For placement, a short paid trial project with our team before client placement. This validates performance under real conditions — not interview conditions — and ensures the engineer is ready to contribute from day one of your engagement.'
            },
          ].map((v, i) => (
            <div class={`vetting-item reveal stagger-${Math.min(i + 1, 5)}`}>
              <div class="vetting-step">{v.step}</div>
              <div class="vetting-content">
                <h3>{v.title}</h3>
                <p>{v.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         ENGAGEMENT MODELS
    ═══════════════════════════════════════════════════ -->
    <section class="sa-section bg-surface">
      <div class="sa-inner">
        <div class="section-header reveal">
          <span class="section-label">Engagement Models</span>
          <h2 class="section-heading">Flexible Engagements Built Around Your Needs</h2>
          <p class="section-subheading">
            Three engagement models to fit different team structures and project types.
          </p>
        </div>
        <div class="models-grid">
          <div class="model-card reveal stagger-1">
            <div class="model-header">
              <div class="model-name">Part-Time</div>
              <div class="model-hours">Minimum 20 hrs/week</div>
            </div>
            <p class="model-desc">
              Ideal for augmenting your team with specialised expertise you need consistently but not full-time.
              Common for: DevOps support, QA oversight, UI/UX design or AI/ML capability that doesn't warrant a full-time placement.
            </p>
            <ul class="model-features">
              <li>Minimum 20 hours per week</li>
              <li>Consistent weekly availability — not ad hoc</li>
              <li>Participates in stand-ups and sprint ceremonies</li>
              <li>3-month minimum engagement</li>
            </ul>
            <div class="model-price">Rate on application</div>
            <a href="/contact?model=part-time" class="btn-outline model-cta">Enquire</a>
          </div>

          <div class="model-card model-featured reveal stagger-2">
            <div class="model-featured-badge">Most Requested</div>
            <div class="model-header">
              <div class="model-name">Full-Time</div>
              <div class="model-hours">40 hrs/week</div>
            </div>
            <p class="model-desc">
              A dedicated engineer embedded fully into your team. Attends all team ceremonies, integrates with your
              culture and operates as an equivalent member to your permanent staff. The most productive model
              for sustained delivery velocity.
            </p>
            <ul class="model-features">
              <li>Full 40-hour week, your core hours</li>
              <li>AEST timezone, same-day response</li>
              <li>Full sprint participation + ownership</li>
              <li>Dedicated to one client only</li>
              <li>3-month minimum, extend as needed</li>
            </ul>
            <div class="model-price">Rate on application</div>
            <a href="/contact?model=full-time" class="btn-primary model-cta">
              Enquire
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <div class="model-card reveal stagger-3">
            <div class="model-header">
              <div class="model-name">Project-Based</div>
              <div class="model-hours">Fixed scope</div>
            </div>
            <p class="model-desc">
              When you have a well-defined deliverable with a clear scope and timeline. We assemble a small, focused
              team — typically two to four engineers — and deliver to the agreed spec. Best for migrations,
              specific feature builds or legacy system replacements.
            </p>
            <ul class="model-features">
              <li>Defined scope, timeline and acceptance criteria</li>
              <li>Fixed or capped price available</li>
              <li>Dedicated team for duration</li>
              <li>Full handover and documentation</li>
            </ul>
            <div class="model-price">Quote-based</div>
            <a href="/contact?model=project" class="btn-outline model-cta">Get a Quote</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         TIMEZONE & COMMUNICATION
    ═══════════════════════════════════════════════════ -->
    <section class="sa-section bg-dark">
      <div class="sa-inner">
        <div class="tz-grid">
          <div class="reveal-left">
            <span class="section-label">Timezone and Communication</span>
            <h2 class="section-heading">Australian-Based, Globally Connected</h2>
            <p class="tz-para">
              All Webbed Labs engineers operate on AEST (UTC+10) or AEDT (UTC+11). This places us in complete overlap
              with Australian teams and provides workable overlap for UK and US-based clients.
            </p>
            <p class="tz-para">
              UK teams (GMT) have 9–11 hours overlap during summer and roughly 8 hours during Australian standard time.
              US West Coast teams (PST) can align start-of-day calls with Australian end-of-day for synchronous check-ins,
              with async handoffs covering the gap.
            </p>
            <p class="tz-para">
              We work in the tools your team already uses. If you use Jira, we use Jira. If you prefer Linear, we use Linear.
              Communication happens in your Slack or Teams workspace — not ours.
            </p>
          </div>
          <div class="tz-right reveal-right stagger-2">
            <div class="tz-card">
              <div class="tz-heading">Timezone Overlap</div>
              {[
                { region: 'Australia (AEST)', hours: 'Full overlap — same timezone', bar: 100 },
                { region: 'Singapore / SEA', hours: '3 hrs difference — good overlap', bar: 88 },
                { region: 'United Kingdom (GMT)', hours: '9–11 hrs ahead', bar: 55 },
                { region: 'US East (EST)', hours: '14–15 hrs difference — async-first', bar: 28 },
                { region: 'US West (PST)', hours: '17–18 hrs — daily sync possible', bar: 20 },
              ].map((tz) => (
                <div class="tz-row">
                  <div class="tz-region">{tz.region}</div>
                  <div class="tz-bar-wrap">
                    <div class="tz-bar" style={`width: ${tz.bar}%`}></div>
                  </div>
                  <div class="tz-hours">{tz.hours}</div>
                </div>
              ))}
            </div>
            <div class="tools-card">
              <div class="tools-heading">Tools We Work In</div>
              <div class="tools-list">
                {['Slack', 'Microsoft Teams', 'Jira', 'Linear', 'GitHub', 'GitLab', 'Notion', 'Confluence', 'Figma', 'Loom'].map((t) => (
                  <span class="tool-badge">{t}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         CASE STUDIES PLACEHOLDER
    ═══════════════════════════════════════════════════ -->
    {/* Case studies section removed — previous content was fabricated. Will return with real, signed-off client work. */}

    <!-- ═══════════════════════════════════════════════════
         FAQ
    ═══════════════════════════════════════════════════ -->
    <section class="sa-section bg-dark">
      <div class="sa-inner">
        <div class="section-header reveal">
          <span class="section-label">Common Questions</span>
          <h2 class="section-heading">Staff Augmentation — Frequently Asked Questions</h2>
        </div>
        <div class="faq-list">
          {[
            {
              q: 'What are your day rates for augmented engineers?',
              a: 'Rates vary by role seniority, technology specialisation and engagement length, and longer-term commitments attract discounted rates. Rather than publish a static rate card that will not match your specific mix of roles, we issue a fixed rate card at the start of every engagement once we understand the shape of what you need — no hidden charges, no markup surprises, super and insurance included in the stated rate.'
            },
            {
              q: 'Are your engineers genuinely senior — not just billed at senior rates?',
              a: 'This is the most important question to ask any augmentation provider and most cannot answer it honestly. Our benchmark is clear: five or more years of commercial experience shipping production software, at least two years in a role with genuine technical ownership (not junior tasks), able to independently design and implement features end-to-end, and capable of reviewing code and mentoring others. We decline 85% of applicants. If we recommend an engineer, it is because we would put them on our own internal projects.'
            },
            {
              q: 'What is the minimum engagement length?',
              a: 'Three months for part-time and full-time placements. This minimum exists because the ramp-up time — learning your codebase, team conventions, domain context — means the first four to six weeks of any placement are below peak contribution. A three-month minimum protects both sides: it gives the engineer time to add genuine value and gives you enough of a run to assess fit and performance fairly.'
            },
            {
              q: 'What happens if the engineer is not a good fit?',
              a: 'We have a 30-day performance review built into every new placement. If, after a reasonable period, the engineer is not working out, we will replace them at no additional placement cost. We ask for honest, documented feedback so we can brief the replacement correctly. In practice, this is rare — our vetting process and the matching conversation before placement significantly reduces mismatches.'
            },
            {
              q: 'How quickly can you place someone?',
              a: 'For common roles (frontend, backend, React, Flutter) we can typically present matched candidates within 48 hours and have an engineer starting within two weeks. For specialist roles (AI/ML engineering, solutions architects, highly specific tech stacks) it may take one to two weeks to identify the right match. We will tell you honestly when we cannot move fast enough for your timeline rather than rushing a poor placement.'
            },
            {
              q: 'Do your engineers work exclusively for us during the engagement?',
              a: 'Yes. Full-time placements are dedicated to a single client. Part-time placements may have one other client engagement, but their committed hours are yours and we ensure there is no capacity conflict. We do not run engineers across multiple concurrent clients — it degrades performance and focus, and we would rather have fewer, more effective placements.'
            },
            {
              q: 'What is your IP and confidentiality position?',
              a: 'All work product created by our engineers during an engagement belongs to you. Engineers sign IP assignment agreements before starting. We also provide mutual NDAs for all engagements as standard — there is no additional negotiation required. Confidentiality extends to any proprietary code, business logic, data or product information the engineer encounters.'
            },
            {
              q: 'Can you provide a team rather than individual engineers?',
              a: 'Yes. Project-based engagements typically involve teams of two to six engineers, a tech lead and optionally a QA engineer, working together on a defined deliverable. We have also provided embedded squads to enterprises during large-scale programmes where multiple stream leads, engineers and architects were needed simultaneously. Brief us on the team shape you need and we will scope accordingly.'
            },
          ].map((faq, i) => (
            <div class={`faq-item reveal stagger-${Math.min(i + 1, 6)}`}>
              <button class="faq-q" data-faq={`sa-${i}`} aria-expanded="false">
                <span>{faq.q}</span>
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-a" id={`faq-sa-${i}`} hidden>
                <p>{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>

