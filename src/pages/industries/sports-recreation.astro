  ],

  solutions: [
    'Member registration and management platforms',
    'Performance analytics and athlete tracking apps',
    'Facility and court booking systems',
    'Fan engagement and club apps',
    'Online coaching and training plan platforms',
    'Live scoring and results publication',
    'Merchandise and event ticketing integrations',
    'Coaching and squad management apps',
  ],

  useCases: [
