      title: 'Multi-Sport Facility Booking and Member Portal',
      description: "A real-time booking system for a multi-sport complex managing courts, lanes, pitches and group class schedules. Members book and pay via the app, receive automated reminders and can manage their own bookings. Administrators see live facility utilisation, manage peak-period pricing and push communications to all members or specific cohorts. Integrates with turnstile access control systems to automate entry on confirmed bookings.",
      techStack: 'React Native · Node.js · Stripe · WebSockets · Access control API',
      videoNote: 'facility booking app showing court selection, real-time availability and access control integration',
    },
  ],

  relevantServices: [
    { title: 'Custom Web Application Development', href: '/services/react-nextjs' },
    { title: 'Mobile App Development', href: '/services/flutter-development' },
    { title: 'API Development & Integrations', href: '/services/api-development' },
    { title: 'Data & Analytics Platforms', href: '/services/data-analytics' },
    { title: 'SaaS Product Development', href: '/services/saas-development' },
    { title: 'UI/UX Design', href: '/services/ui-ux-design' },
