---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';

// PAGE: AI Consulting
// TODO: Replace placeholder stats with real client data when available
---

<Layout
  title="AI Consulting — All Webbed Labs | Custom AI Development Australia"
  description="Custom AI tools, LLM integration and intelligent automation for Australian enterprises. OpenAI, Claude, Llama — we build AI that works in production."
>
  <Header />
  <main>

    <!-- ═══════════════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════════════ -->
    <section class="ai-hero">
      <div class="ai-hero-bg" aria-hidden="true">
        <div class="hero-glow-1"></div>
        <div class="hero-glow-2"></div>
        <div class="hero-grid"></div>
      </div>
      <div class="ai-hero-inner">
        <div class="ai-hero-content reveal">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a><span>/</span><span>AI Consulting</span>
          </nav>
          <span class="section-label">AI Consulting &amp; Development</span>
          <h1 class="ai-hero-title">
            Transform Your Business<br />
            With <span class="gradient-text">Artificial Intelligence</span>
          </h1>
          <p class="ai-hero-sub">
            We build production-ready AI systems that solve real operational problems. Not demos. Not prototypes that never ship.
            Custom LLMs, intelligent document processing, predictive analytics and conversational AI — integrated into your
            existing systems and running at enterprise scale.
          </p>
          <div class="ai-hero-ctas">
            <a href="/contact" class="btn-primary">
              Book an AI Strategy Session
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#what-we-do" class="btn-outline">See What We Build</a>
          </div>
          <div class="hero-trust-row">
            <div class="trust-item">
              <span class="trust-num">150+</span>
              <span class="trust-label">AI Projects Delivered</span>
            </div>
            <div class="trust-divider"></div>
            <div class="trust-item">
              <span class="trust-num">6</span>
              <span class="trust-label">LLM Platforms Certified</span>
            </div>
            <div class="trust-divider"></div>
            <div class="trust-item">
              <span class="trust-num">100%</span>
              <span class="trust-label">Australian Data Sovereignty</span>
            </div>
          </div>
        </div>
        <div class="ai-hero-visual reveal-right stagger-2" aria-hidden="true">
          <div class="ai-orb">
            <svg width="120" height="120" viewBox="0 0 120 120" fill="none">
              <circle cx="60" cy="60" r="58" stroke="rgba(13,147,115,0.2)" stroke-width="1"/>
              <circle cx="60" cy="60" r="42" stroke="rgba(13,147,115,0.15)" stroke-width="1"/>
              <circle cx="60" cy="60" r="26" fill="rgba(13,147,115,0.08)" stroke="rgba(13,147,115,0.3)" stroke-width="1.5"/>
              <path d="M45 60L57 72L78 48" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="ai-node ai-node-1">GPT-4o</div>
          <div class="ai-node ai-node-2">Claude 3.5</div>
          <div class="ai-node ai-node-3">Gemini</div>
          <div class="ai-node ai-node-4">Llama 3</div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         WHAT WE DO
    ═══════════════════════════════════════════════════ -->
    <section class="ai-section bg-surface" id="what-we-do">
      <div class="ai-inner">
        <div class="section-header reveal">
          <span class="section-label">What We Build</span>
          <h2 class="section-heading">End-to-End AI Development Services</h2>
          <p class="section-subheading">
            From initial strategy through to production deployment and ongoing monitoring — we handle every layer of the AI stack.
          </p>
        </div>
        <div class="services-grid">
          {[
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
              title: 'AI Strategy & Roadmap',
              desc: 'We assess your operations, data assets and competitive landscape to produce a prioritised AI roadmap with clear ROI targets, risk registers and build-vs-buy recommendations.'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
              title: 'Custom LLM Development',
              desc: 'We build, fine-tune and deploy large language models tailored to your domain — whether that\'s legal, medical, financial or industrial. Proprietary knowledge stays proprietary.'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
              title: 'Document Processing & OCR',
              desc: 'Automate the extraction, classification and validation of information from invoices, contracts, forms and unstructured documents at scale — with accuracy rates above 95%.'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
              title: 'AI Chatbots & Virtual Agents',
              desc: 'Conversational AI that goes beyond scripted flows. Context-aware agents that integrate with your CRM, knowledge base and internal systems to handle complex, multi-turn interactions.'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
              title: 'Predictive Analytics & ML Pipelines',
              desc: 'Machine learning models for forecasting demand, predicting churn, scoring leads and identifying anomalies. Built on your data, deployed in your infrastructure.'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
              title: 'AI System Integration',
              desc: 'Connect AI capabilities directly into your existing ERP, CRM, HRIS, and data warehouse via secure APIs. No workflow disruption — AI augments what you already have.'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
              title: 'Prompt Engineering & RAG',
              desc: 'Retrieval-Augmented Generation architectures that ground LLM responses in your verified knowledge base — eliminating hallucinations and keeping outputs current and accurate.'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
              title: 'AI Governance & Compliance',
              desc: 'Responsible AI frameworks covering model explainability, bias auditing, data lineage, consent management and compliance with the Australian AI Ethics Framework.'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>`,
              title: 'Model Fine-Tuning',
              desc: 'Domain-specific fine-tuning of foundation models on your proprietary datasets. Better performance, lower token costs, and responses calibrated to your brand voice and terminology.'
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
              title: 'Computer Vision',
              desc: 'Image and video analysis pipelines for quality control, security monitoring, medical imaging, retail analytics and any task that requires machines to reliably interpret visual data.'
            },
          ].map((svc, i) => (
            <div class={`svc-card card-hover reveal stagger-${Math.min((i % 6) + 1, 6)}`}>
              <div class="svc-card-icon" set:html={svc.icon} />
              <h3>{svc.title}</h3>
              <p>{svc.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         AI PARTNERS
    ═══════════════════════════════════════════════════ -->
    <section class="ai-section bg-dark">
      <div class="ai-inner">
        <div class="section-header reveal">
          <span class="section-label">AI Platforms</span>
          <h2 class="section-heading">We Work Across Every Major AI Platform</h2>
          <p class="section-subheading">
            Model-agnostic by design. We select the right foundation model for your use case — not the one that's fashionable.
          </p>
        </div>
        <div class="partners-grid">
          {[
            { name: 'OpenAI', models: 'GPT-4o, o1, Embeddings', colour: '#10a37f' },
            { name: 'Anthropic', models: 'Claude 3.5 Sonnet, Haiku, Opus', colour: '#d4a27f' },
            { name: 'Google Gemini', models: 'Gemini 1.5 Pro, Flash, Nano', colour: '#4285f4' },
            { name: 'Meta Llama', models: 'Llama 3.1, 3.2, Code Llama', colour: '#1877f2' },
            { name: 'Hugging Face', models: 'Transformers, PEFT, Diffusers', colour: '#ff9d00' },
            { name: 'Mistral AI', models: 'Mistral Large, Mixtral 8x7B', colour: '#ff7000' },
          ].map((p, i) => (
            <div class={`partner-card card-hover reveal stagger-${Math.min(i + 1, 6)}`}>
              <div class="partner-dot" style={`background:${p.colour}`}></div>
              <div class="partner-name">{p.name}</div>
              <div class="partner-models">{p.models}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         REAL-WORLD USE CASES
    ═══════════════════════════════════════════════════ -->
    <section class="ai-section bg-surface">
      <div class="ai-inner">
        <div class="section-header reveal">
          <span class="section-label">Use Cases</span>
          <h2 class="section-heading">AI That Solves Real Business Problems</h2>
          <p class="section-subheading">
            These aren't theoretical applications. They're production systems running in Australian enterprises today.
          </p>
        </div>
        <div class="usecases-grid">
          {[
            {
              industry: 'Customer Experience',
              title: 'Customer Service Automation',
              desc: 'Tier-1 support agents that resolve 70% of inbound queries without human escalation. Integrated with Zendesk, Salesforce and custom ticketing systems. Learns from every resolved ticket.'
            },
            {
              industry: 'Operations',
              title: 'Intelligent Document Processing',
              desc: 'Automated extraction and validation of invoice line items, contract clauses and compliance certificates. Reduces manual processing time by 85% and virtually eliminates keying errors.'
            },
            {
              industry: 'Revenue',
              title: 'Sales & Revenue Forecasting',
              desc: 'ML models trained on historical pipeline data, seasonal signals and market indicators to produce weekly revenue forecasts with 90%+ accuracy — enabling confident resource planning.'
            },
            {
              industry: 'Risk & Compliance',
              title: 'Fraud Detection',
              desc: 'Real-time transaction scoring using anomaly detection and behavioural models. Flags suspicious activity within milliseconds, with explainable outputs that satisfy AML regulatory requirements.'
            },
            {
              industry: 'Marketing',
              title: 'Content Generation at Scale',
              desc: 'Brand-voice-calibrated content pipelines for product descriptions, email campaigns and social copy. Runs on fine-tuned models — not generic prompts — producing content that actually converts.'
            },
            {
              industry: 'Engineering',
              title: 'AI-Assisted Code Generation',
              desc: 'Internal developer tools powered by code-focused LLMs trained on your codebase conventions, security policies and architecture patterns. Reduces boilerplate and accelerates PR review.'
            },
            {
              industry: 'Manufacturing & Logistics',
              title: 'Visual Quality Inspection',
              desc: 'Computer vision pipelines that inspect products at line speed, detecting defects, foreign objects and dimensional variances — replacing manual visual checks with consistent, objective scoring.'
            },
          ].map((uc, i) => (
            <div class={`usecase-item reveal stagger-${Math.min((i % 4) + 1, 4)}`}>
              <div class="uc-industry">{uc.industry}</div>
              <h3>{uc.title}</h3>
              <p>{uc.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         ROI STATS
    ═══════════════════════════════════════════════════ -->
    <section class="ai-section bg-dark">
      <div class="ai-inner">
        <div class="section-header reveal">
          <span class="section-label">The Business Case</span>
          <h2 class="section-heading">What AI Implementation Typically Returns</h2>
          <p class="section-subheading">
            Based on McKinsey Global Institute research and our own client outcomes across 150+ AI projects.
          </p>
        </div>
        <div class="roi-grid">
          <div class="roi-card reveal stagger-1">
            <div class="roi-num gradient-text-green">3.5×</div>
            <div class="roi-title">Average ROI Within 18 Months</div>
            <div class="roi-desc">
              Enterprises that deploy AI across at least three business functions see an average return of 3.5x their total
              implementation investment within 18 months, driven primarily by labour automation and error reduction.
            </div>
          </div>
          <div class="roi-card reveal stagger-2">
            <div class="roi-num gradient-text-green">68%</div>
            <div class="roi-title">Reduction in Manual Processing Costs</div>
            <div class="roi-desc">
              Document-intensive processes — accounts payable, claims handling, compliance reporting — see an average
              68% reduction in per-unit processing cost when AI is applied to extraction, validation and routing tasks.
            </div>
          </div>
          <div class="roi-card reveal stagger-3">
            <div class="roi-num gradient-text-green">4.2hrs</div>
            <div class="roi-title">Saved Per Knowledge Worker Per Day</div>
            <div class="roi-desc">
              Knowledge workers using AI copilots and automation recover an average of 4.2 hours per day previously
              spent on search, synthesis and routine correspondence — redirecting that time to high-value work.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         OUR PROCESS
    ═══════════════════════════════════════════════════ -->
    <section class="ai-section bg-surface">
      <div class="ai-inner">
        <div class="section-header reveal">
          <span class="section-label">How We Work</span>
          <h2 class="section-heading">Our 8-Step AI Delivery Process</h2>
          <p class="section-subheading">
            A rigorous methodology that eliminates the most common failure modes in enterprise AI projects.
          </p>
        </div>
        <div class="process-timeline">
          {[
            {
              num: '01',
              title: 'Discovery & Problem Definition',
              duration: 'Week 1–2',
              desc: 'We run structured discovery workshops to map your operations, identify the highest-value AI opportunities and define success metrics before a single line of code is written.'
            },
            {
              num: '02',
              title: 'Data Audit & Quality Assessment',
              duration: 'Week 2–3',
              desc: 'AI performance is determined by data quality. We assess your existing data assets for volume, completeness, bias and governance compliance — and define a data preparation strategy.'
            },
            {
              num: '03',
              title: 'Model Selection & Architecture',
              duration: 'Week 3–4',
              desc: 'We evaluate foundation models, open-source alternatives and custom training options against your cost, latency, accuracy and sovereignty requirements to recommend the optimal architecture.'
            },
            {
              num: '04',
              title: 'Fine-Tuning & Training',
              duration: 'Week 4–8',
              desc: 'Where standard models fall short, we fine-tune on your domain-specific datasets using PEFT, LoRA or full fine-tuning depending on resource constraints and accuracy targets.'
            },
            {
              num: '05',
              title: 'Integration Engineering',
              duration: 'Week 6–10',
              desc: 'We build the API layer, authentication, rate limiting and monitoring infrastructure needed to connect AI capabilities safely into your existing systems and workflows.'
            },
            {
              num: '06',
              title: 'Evaluation & Red-Teaming',
              duration: 'Week 9–11',
              desc: 'Systematic evaluation against accuracy benchmarks, edge cases and adversarial inputs. We don\'t ship AI that we haven\'t stress-tested against realistic failure scenarios.'
            },
            {
              num: '07',
              title: 'Production Deployment',
              duration: 'Week 11–12',
              desc: 'Blue-green deployment to production with rollback capability, autoscaling, cost guardrails and full observability. Staged rollout to minimise operational risk.'
            },
            {
              num: '08',
              title: 'Monitoring & Continuous Improvement',
              duration: 'Ongoing',
              desc: 'Model drift detection, performance dashboards, feedback loops and quarterly retraining cycles. AI systems degrade without maintenance — we build the systems to prevent that.'
            },
          ].map((step, i) => (
            <div class={`process-item reveal stagger-${Math.min((i % 4) + 1, 4)}`}>
              <div class="process-num">{step.num}</div>
              <div class="process-content">
                <div class="process-duration">{step.duration}</div>
                <h3>{step.title}</h3>
                <p>{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         CASE STUDY PLACEHOLDER
    ═══════════════════════════════════════════════════ -->
    <section class="ai-section bg-dark">
      <div class="ai-inner">
        <div class="casestudy-block reveal">
          <!-- CASE_STUDY_PLACEHOLDER — Replace with real client case study when signed off -->
          <div class="cs-badge">Case Study</div>
          <h3>Enterprise Document Intelligence: 85% Faster Processing</h3>
          <p>
            We're preparing a detailed case study documenting how we deployed an intelligent document processing
            pipeline for a major Australian financial services group — reducing invoice processing time from
            4 days to under 6 hours while eliminating keying errors across 12,000+ monthly documents.
            <br /><br />
            <em style="color: #2a3d35; font-size: 0.85rem;"><!-- PLACEHOLDER: Add real metrics, client name and approval before publishing --></em>
          </p>
          <div class="cs-stats">
            <div class="cs-stat">
              <span class="cs-num">TODO</span>
              <span class="cs-label">Documents/month processed</span>
            </div>
            <div class="cs-stat">
              <span class="cs-num">TODO</span>
              <span class="cs-label">Processing time reduction</span>
            </div>
            <div class="cs-stat">
              <span class="cs-num">TODO</span>
              <span class="cs-label">Annual cost saving</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         FAQ
    ═══════════════════════════════════════════════════ -->
    <section class="ai-section bg-surface">
      <div class="ai-inner">
        <div class="section-header reveal">
          <span class="section-label">Common Questions</span>
          <h2 class="section-heading">AI Consulting — Frequently Asked Questions</h2>
        </div>
        <div class="faq-list">
          {[
            {
              q: 'What does an AI consulting engagement typically cost?',
              a: 'Engagements range from $25,000 for a focused AI strategy and roadmap through to $500,000+ for a full enterprise AI platform. A typical production AI feature — a document processing pipeline, a custom chatbot or a forecasting model — runs $60,000–$150,000 including discovery, development, integration, testing and a 90-day hypercare period. We provide fixed-price proposals after the discovery workshop so there are no surprises.'
            },
            {
              q: 'How long does it take to build and deploy an AI system?',
              a: 'A focused AI feature deployed into an existing system typically takes 10–14 weeks from kick-off to production. Projects involving custom model training, significant data preparation or complex system integration can run 16–24 weeks. Our 8-step delivery process is designed to surface risk early and maintain momentum throughout.'
            },
            {
              q: 'Where is our data processed? Can we ensure Australian data sovereignty?',
              a: 'Yes. We can architect AI solutions that process all data within AWS Sydney (ap-southeast-2) or Azure Australia East regions, ensuring your data never leaves Australian borders. For organisations with sensitive data classifications, we also offer on-premise and private cloud deployment options that eliminate third-party API calls entirely.'
            },
            {
              q: 'How accurate are AI models in production — and what happens when they\'re wrong?',
              a: 'Accuracy varies significantly by task. Document extraction typically achieves 94–98% field-level accuracy after fine-tuning. Classification tasks can reach 97%+. Generative tasks require human-in-the-loop review for high-stakes outputs. We always build human escalation pathways, confidence score thresholds and audit trails into production systems so errors are caught, logged and used to improve the model.'
            },
            {
              q: 'Do we need a large dataset to get started with AI?',
              a: 'Not necessarily. Modern foundation models require surprisingly little domain-specific data for effective fine-tuning — in some cases as few as 500–1,000 examples. For retrieval-augmented generation (RAG) systems, your existing documents and knowledge base are the data. Where data is genuinely sparse, we can advise on synthetic data generation, data labelling workflows or transfer learning approaches.'
            },
            {
              q: 'Who owns the AI model and the intellectual property after the project?',
              a: 'You do. All custom models, training data, fine-tuning weights and associated code are transferred to your organisation on project completion. We operate as a work-for-hire partner — no usage royalties, no lock-in, no ongoing licensing fees for the models themselves.'
            },
            {
              q: 'How do you handle ongoing model maintenance and drift?',
              a: 'AI models degrade over time as real-world data distributions shift away from training data — this is called model drift. Our standard post-deployment package includes monthly performance reporting, quarterly retraining reviews, automated drift detection alerts, and a model update SLA. This is not optional — we won\'t deploy AI without a maintenance plan in place.'
            },
            {
              q: 'What industries are you most experienced in for AI projects?',
              a: 'We have the deepest experience in financial services (fraud detection, document processing, compliance automation), healthcare (clinical note processing, patient triage chatbots), logistics (demand forecasting, route optimisation), and enterprise SaaS (product recommendation, customer success prediction). That said, our architecture and delivery methodology adapts to any domain where the underlying data problems are well-defined.'
            },
          ].map((faq, i) => (
            <div class={`faq-item reveal stagger-${Math.min(i + 1, 6)}`}>
              <button class="faq-q" data-faq={`ai-${i}`} aria-expanded="false">
                <span>{faq.q}</span>
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-a" id={`faq-ai-${i}`} hidden>
                <p>{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <CTABanner />

  </main>
  <Footer />
</Layout>

<style>
  /* ── Layout ── */
  .ai-hero {
    padding: 9rem 0 6rem;
    background: #0a0f0e;
    position: relative;
    overflow: hidden;
  }

  .ai-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-glow-1 {
    position: absolute;
    top: -10%;
    right: 10%;
    width: 700px;
    height: 700px;
    background: radial-gradient(ellipse, rgba(13,147,115,0.12) 0%, transparent 65%);
  }

  .hero-glow-2 {
    position: absolute;
    bottom: 0;
    left: 5%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(13,147,115,0.05) 0%, transparent 70%);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(13,147,115,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(13,147,115,0.03) 1px, transparent 1px);
    background-size: 80px 80px;
  }

  .ai-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 4rem;
