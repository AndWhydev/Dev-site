---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found — All Webbed Labs"
  description="The page you're looking for doesn't exist. Navigate back to All Webbed Labs."
  noindex={true}
>
  <Header />
  <main>
    <section class="notfound-section">
      <div class="notfound-bg" aria-hidden="true"></div>
      <div class="notfound-inner">
        <div class="notfound-code" aria-hidden="true">404</div>
        <h1 class="notfound-title">This page doesn't exist.</h1>
        <p class="notfound-sub">
          The URL may have changed, been removed, or you may have followed a broken link.
          Let's get you back on track.
        </p>

        <div class="notfound-links">
          <a href="/" class="btn-primary">
            Back to Home
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/services" class="btn-outline">Our Services</a>
          <a href="/contact" class="btn-outline">Contact Us</a>
        </div>

        <div class="notfound-nav">
          <p class="notfound-nav-label">Popular pages</p>
          <div class="notfound-nav-grid">
            {[
              { label: 'AI Consulting', href: '/ai-consulting' },
              { label: 'Flutter Development', href: '/services/flutter-development' },
              { label: 'Digital Transformation', href: '/digital-transformation' },
              { label: 'Startup MVP', href: '/startup-mvp' },
              { label: 'Pricing', href: '/pricing' },
              { label: 'About Us', href: '/about' },
            ].map((link) => (
              <a href={link.href} class="notfound-nav-link">
                {link.label}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .notfound-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0a0f0e;
    position: relative;
    overflow: hidden;
    padding: 8rem 2rem;
  }

  .notfound-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(13,147,115,0.07) 0%, transparent 65%);
    pointer-events: none;
  }

  .notfound-inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .notfound-code {
    font-family: 'Sora', sans-serif;
    font-size: clamp(6rem, 20vw, 12rem);
    font-weight: 800;
    color: rgba(13,147,115,0.12);
    letter-spacing: -0.06em;
    line-height: 1;
    user-select: none;
    margin-bottom: -1rem;
  }

  .notfound-title {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: white;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
  }

  .notfound-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: #8aa09a;
    line-height: 1.65;
    margin: 0;
    max-width: 480px;
  }

  .notfound-links {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .notfound-nav {
    width: 100%;
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 16px;
    padding: 1.75rem;
    margin-top: 1rem;
  }

  .notfound-nav-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #4a6359;
    margin: 0 0 1.25rem;
  }

  .notfound-nav-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.625rem;
  }

  .notfound-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: #8aa09a;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .notfound-nav-link:hover {
    border-color: rgba(13,147,115,0.35);
    color: white;
  }

  .notfound-nav-link svg {
    flex-shrink: 0;
    color: #4a6359;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .notfound-nav-link:hover svg {
    color: #0d9373;
    transform: translateX(2px);
  }

  @media (max-width: 600px) {
    .notfound-links {
      flex-direction: column;
      align-items: center;
    }
    .notfound-nav-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 400px) {
    .notfound-nav-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
