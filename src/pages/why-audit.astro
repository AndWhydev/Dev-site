---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const riskCategories = [
  {
    order: '01',
    name: 'Payments and Money Movement',
    visible: ['Merchant of Record', 'AFSL Licensing'],
    items: [
      { title: 'Merchant of Record', body: 'If money flows through your platform between buyers and sellers, you may be legally classified as the merchant. You are responsible for every chargeback, fraud claim and refund. Stripe and PayPal freeze accounts of platforms that haven’t structured this correctly. We have seen founders lose access to their revenue overnight.' },
      { title: 'PCI DSS Compliance', body: 'If your app touches card data in any way, non compliance fines start at $5,000 per month. Your payment processor can terminate your account without notice.' },
      { title: 'AFSL Licensing', body: 'Any app touching financial advice, lending, insurance, investment or superannuation may require an Australian Financial Services Licence. Building without one isn’t a grey area. It carries criminal penalties.' },
      { title: 'Buy Now Pay Later', body: 'Integrating BNPL or deferred payment features may trigger credit licensing requirements under the National Consumer Credit Protection Act. You cannot build first and apply later.' },
      { title: 'Foreign Transaction Obligations', body: 'Overseas users may trigger tax and regulatory obligations in their jurisdictions including EU VAT and US sales tax by state.' },
    ],
  },
  {
    order: '02',
    name: 'Data and Privacy',
    visible: ['Australian Privacy Act', 'GDPR'],
    items: [
      { title: 'Australian Privacy Act', body: 'Fines for serious breaches now reach $50 million, or three times the benefit obtained, or 30% of adjusted turnover, whichever is greater. If you are collecting any user data without proper architecture and a compliant privacy policy, this is your exposure.' },
      { title: 'Health Data', body: 'Apps collecting health information are subject to the Health Records Act and potentially HIPAA for US users. Breaches carry mandatory notification obligations and significantly higher penalties.' },
      { title: 'GDPR', body: 'If any EU resident can access your app, even if you are based in Australia and not targeting Europe, you may be subject to GDPR. Fines reach €20 million or 4% of global annual turnover.' },
      { title: 'Children’s Data', body: 'COPPA and equivalent Australian obligations apply to any platform accessible by users under 13. Non compliance is grounds for immediate app store removal.' },
      { title: 'Tracking and Cookie Consent', body: 'Your analytics, ad pixels and retargeting tools may be collecting and transmitting user data without legally required consent flows. This is increasingly enforced.' },
    ],
  },
  {
    order: '03',
    name: 'Cybersecurity',
    visible: ['Cloud Misconfiguration', 'API Security'],
    items: [
      { title: 'OWASP Top 10 Vulnerabilities', body: 'The ten most critical web application security risks are present in the majority of freelancer built apps. Most MVPs fail at least three of these out of the box without the developer or the founder knowing.' },
      { title: 'API Security', body: 'Exposed or unauthenticated API endpoints are the number one attack vector in modern applications. Most early stage products have zero API security strategy. Your data, your users’ data and your business logic are all accessible to anyone who knows where to look.' },
      { title: 'Cloud Misconfiguration', body: 'Publicly exposed S3 buckets, unsecured Firebase databases, unprotected environment variables and missing access controls are how most startups get breached. It looks fine from your dashboard. It is wide open from the outside.' },
      { title: 'Dependency Vulnerabilities', body: 'Every open source library in your tech stack is a potential attack vector. If those libraries haven’t been audited, you’ve inherited someone else’s security problem.' },
      { title: 'No Penetration Testing', body: 'Launching without a penetration test is the equivalent of opening a business without ever checking whether the locks work. You are inviting the first person who tries.' },
    ],
  },
  {
    order: '04',
    name: 'Intellectual Property',
    visible: ['IP Ownership of the Codebase', 'Open Source Licence Compliance'],
    items: [
      { title: 'IP Ownership of the Codebase', body: 'In Australia, copyright defaults to the creator, not the person who paid, unless there is a written IP assignment agreement. If a freelancer or contractor built any part of your product without one in place, you may not legally own your own app.' },
      { title: 'Open Source Licence Compliance', body: 'Using GPL licensed code in a commercial product can legally require you to open source your entire codebase. Most developers drop in open source libraries without checking the licence terms. This can destroy your IP position overnight.' },
      { title: 'Third Party API Terms of Service', body: 'Building a business on top of another platform without understanding their commercial use terms is a significant risk. Platforms change terms, restrict commercial use or shut down APIs with limited notice. Your business model may not survive it.' },
      { title: 'Trademark Clearance', body: 'Launching under a name without checking whether it is already registered is one of the most common and most expensive mistakes founders make. A cease and desist six months after launch with a brand and marketing spend behind you is a serious problem.' },
    ],
  },
  {
    order: '05',
    name: 'Legal Structure and Liability',
    visible: ['Limitation of Liability', 'App Store Compliance'],
    items: [
      { title: 'Terms of Service and Acceptable Use Policy', body: 'Without these, your users have no obligations and you have no protection. You cannot enforce restrictions on how your platform is used or terminate abusive users with legal standing.' },
      { title: 'Limitation of Liability', body: 'If your app fails or results in a user experiencing financial loss, what is your legal exposure without a properly drafted limitation of liability clause? In many cases: unlimited.' },
      { title: 'Australian Consumer Law', body: 'Statutory guarantees, refund rights and misleading conduct provisions apply to digital products. They cannot be contracted out of. If your product doesn’t work as described, you have legal obligations regardless of what your terms say.' },
      { title: 'App Store Compliance', body: 'Apple and Google have their own rules on subscriptions, in app purchases, data collection disclosures and content. They will remove your app without warning. We have seen products with tens of thousands of users pulled overnight.' },
      { title: 'Dispute Resolution', body: 'Without a governing law clause and a clear dispute resolution mechanism, any user anywhere in the world can potentially bring a claim in their local jurisdiction.' },
    ],
  },
  {
    order: '06',
    name: 'Tax and Financial',
    visible: ['R&D Tax Incentive', 'GST on Digital Services'],
    items: [
      { title: 'R&D Tax Incentive', body: 'Most founders building software don’t know they may be eligible for up to 43.5 cents back on every dollar of eligible development expenditure. This must be structured correctly from day one. Retroactive registration rarely captures the full benefit. AWLabs helps every client access this.' },
      { title: 'GST on Digital Services', body: 'If you have overseas customers, you may have tax obligations in their jurisdictions including EU VAT registration and US sales tax obligations that vary by state.' },
    ],
  },
  {
    order: '07',
    name: 'Employment and Contractor Risk',
    visible: ['Sham Contracting', 'IP Assignment Gaps'],
    items: [
      { title: 'Sham Contracting', body: 'If you are engaging contractors who work exclusively for you or under your direct control, the ATO may reclassify them as employees, triggering superannuation obligations, leave entitlements and payroll tax liabilities, potentially backdated.' },
      { title: 'Equity and Co Founder Agreements', body: 'Without properly documented vesting schedules, cliff periods and exit provisions, a co founder or early team member who leaves can walk away with equity they did nothing to earn, or hold the company hostage.' },
      { title: 'IP Assignment Gaps', body: 'Every developer, contractor and consultant who contributes to your codebase needs a signed IP assignment agreement. One gap in that chain can cloud your IP ownership permanently.' },
    ],
  },
  {
    order: '08',
    name: 'Regulated Industry Triggers',
    visible: ['Health and Medical Apps', 'Legal Tech'],
    items: [
      { title: 'Health and Medical Apps', body: 'Any app that makes therapeutic claims, processes clinical data or could be used in a clinical setting may need TGA registration. This is a lengthy and expensive process. You cannot launch first and register later.' },
      { title: 'Legal Tech', body: 'The line between providing legal information and legal advice is narrow and actively enforced. Crossing it, even through an AI feature, exposes you to professional liability claims.' },
      { title: 'Education and Child Safety', body: 'Platforms with minors as users carry Working With Children Check obligations, child safety policy requirements and mandatory reporting obligations that vary by state.' },
      { title: 'Property and Real Estate Features', body: 'Certain property related features may require real estate agent licensing. Penalties for unlicensed conduct are significant.' },
    ],
  },
  {
    order: '09',
    name: 'Accessibility',
    visible: ['WCAG 2.2 Compliance'],
    items: [
      { title: 'WCAG 2.2 Compliance', body: 'Under the Disability Discrimination Act 1992, digital products must be accessible to users with disabilities. Government contracts will not proceed without WCAG compliance. Enforcement is increasing. Retrofitting accessibility into an existing product is significantly more expensive than building it in from the start.' },
    ],
  },
  {
    order: '10',
    name: 'Architecture and Scalability',
    visible: ['Wrong Tech Stack', 'No Disaster Recovery Strategy'],
    items: [
      { title: 'Wrong Tech Stack', body: 'A freelancer builds in what they know, not what is right for your scale, your use case or your long term roadmap. Rebuilding from scratch because the original architecture cannot handle growth is one of the most common and most expensive problems we see.' },
      { title: 'No Disaster Recovery Strategy', body: 'If your database goes down, what happens? Most early stage products have no backup strategy and no defined recovery time. One infrastructure event can mean permanent data loss.' },
      { title: 'Vendor Lock In', body: 'Building entirely on one cloud provider or proprietary platform with no exit strategy means that provider controls your costs, your uptime and ultimately your business continuity.' },
    ],
  },
  {
    order: '11',
    name: 'Insurance',
    visible: ['Cyber Liability Insurance', 'Professional Indemnity'],
    items: [
      { title: 'Cyber Liability Insurance', body: 'The average cost of a data breach in Australia is now over $4 million. Most early stage founders have no cyber liability coverage. One breach can exceed the cost of the entire build.' },
      { title: 'Professional Indemnity', body: 'If your software causes a client financial loss, professional indemnity insurance is your protection. Without it you are personally exposed.' },
    ],
  },
];

const standards = [
  { code: 'ISO 27001', name: 'Information Security Management', when: 'Every project. Gold standard for data security.' },
  { code: 'ISO 27701', name: 'Privacy Information Management', when: 'Any project collecting personal data.' },
  { code: 'ISO 27017', name: 'Cloud Security', when: 'All cloud hosted projects.' },
  { code: 'ISO 27018', name: 'Personal Data in the Cloud', when: 'Any project storing user data in the cloud.' },
  { code: 'ISO 25010', name: 'Software Product Quality', when: 'Every project.' },
  { code: 'ISO 12207', name: 'Software Lifecycle Processes', when: 'Every project. Internationally auditable build process.' },
  { code: 'ISO 29119', name: 'Software Testing', when: 'Every project requiring pre launch verification.' },
  { code: 'ISO 31000', name: 'Risk Management', when: 'Every project. The framework underpinning the DA itself.' },
  { code: 'PCI DSS', name: 'Payment Card Industry Standard', when: 'Any app touching card data.' },
  { code: 'SOC 2 Type II', name: 'Service Organisation Control', when: 'B2B SaaS targeting enterprise or US clients.' },
  { code: 'ISO 13485', name: 'Medical Devices Quality Management', when: 'Health and medical apps.' },
  { code: 'ISO 14971', name: 'Risk Management for Medical Devices', when: 'Software as a medical device.' },
  { code: 'HL7 FHIR', name: 'Health Data Interoperability', when: 'Health apps integrating with clinical systems.' },
  { code: 'ISO 42001', name: 'AI Management System', when: 'Any project with AI or machine learning features.' },
  { code: 'EU AI Act', name: 'AI Regulatory Compliance', when: 'Any AI feature accessible to EU users.' },
  { code: 'WCAG 2.2', name: 'Web Content Accessibility Guidelines', when: 'Every project.' },
  { code: 'ISO 9001', name: 'Quality Management Systems', when: 'Every project.' },
];

const consequences = [
  { title: 'Merchant of record misclassification', body: 'We had a client whose marketplace hit $2M in GMV before Stripe froze their account due to undisclosed platform transactions. They couldn’t pay their vendors for six weeks. The business nearly collapsed.' },
  { title: 'IP ownership gap', body: 'A founder paid $60,000 to a development agency under a poorly drafted contract. When the relationship broke down, the agency retained ownership of the codebase. The founder had to rebuild from scratch.' },
  { title: 'Privacy Act breach', body: 'A Sydney based startup suffered a data breach affecting 4,000 users. Without a mandatory breach response plan, they notified the OAIC 47 days late. The investigation cost more than the original build.' },
  { title: 'Cloud misconfiguration', body: 'A Firebase misconfiguration exposed the personal data of 100,000 users of an Australian fintech app. The database had been publicly readable for eight months before anyone discovered it.' },
  { title: 'App store removal', body: 'A consumer app with 30,000 active users was removed from the App Store for undisclosed data collection. It took four months and a full rebuild to get it reinstated. Four months of zero new users.' },
  { title: 'Open source licence violation', body: 'A SaaS founder built their core product on a GPL licensed library. When they went to raise their Series A, legal due diligence flagged the violation. They had to open source their product or rebuild the affected components before the round could close.' },
];

const deliverables = [
  { order: '01', title: 'Full Scope and Risk Audit', body: 'We go deep on your idea or existing product. Every feature mapped. Every risk area across security, cyber exposure, legal liability, compliance and architecture identified and addressed.' },
  { order: '02', title: 'Investor Ready Roadmap Document', body: 'A formal strategic document you can take to a VC, investor, bank, accelerator or board. Not a quote. A proper document showing what is being built, how it is being built, what the risks are and how they are mitigated, and what the path to market looks like. This document alone can open doors.' },
  { order: '03', title: 'Pitch Deck and Strategy Session', body: 'We prepare a full pitch deck and present it to you in a dedicated strategy session. You are not getting an email with a number. You are getting a proper presentation of how we see your project playing out, including timeline and full investment required.' },
];

const pillars = [
  { title: 'Development', body: 'Custom software, app builds, AI integration.' },
  { title: 'Marketing', body: 'User acquisition through our in house team at All Webbed Up.' },
  { title: 'Capital', body: 'R&D subsidies, government grants, financial structuring.' },
  { title: 'Legal', body: 'Compliance, privacy policy, IP protection built in from day one.' },
];
---

<Layout
  title="Discovery Audit. Before We Build Anything | All Webbed Labs"
  description="The Discovery Audit covers every legal, compliance, security and IP risk before a dollar goes into development. Credited to your build if you proceed."
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="audit-hero">
      <div class="audit-hero-inner">
        <div class="reveal">
          <span class="section-label">The Discovery Audit</span>
          <h1 class="audit-title">
            Most founders don&rsquo;t find out<br />
            <span class="gradient-text">until it&rsquo;s too late.</span>
          </h1>
          <p class="audit-lead">
            You just got off a call with Andy. What he told you about the Discovery Audit is real. This is the full picture of what it covers, and what happens to founders who skip it.
          </p>
          <p class="audit-sub">
            Most agencies take your brief, build what you ask for and send an invoice. Nobody checks whether you legally own the code. Nobody checks whether your payment setup will get your account frozen. Nobody checks whether you are sitting on a six figure compliance exposure. That is what the Discovery Audit is for.
          </p>
        </div>
      </div>
    </section>

    <!-- Problem lede -->
    <section class="lede-section">
      <div class="lede-inner">
        <div class="reveal">
          <p class="lede-quote">
            You could spend $50,000 building something that looks fine, works fine, and is a liability underneath. You would not know. Until something goes wrong.
          </p>
        </div>
      </div>
    </section>

    <!-- Risks -->
    <section class="risks-section">
      <div class="risks-inner">
        <div class="reveal">
          <span class="section-label">Risk Breakdown</span>
          <h2 class="section-heading">Every risk area the Discovery Audit covers.</h2>
          <div class="exposure-callout">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <p>
              Across the categories below, the combined regulatory and legal exposure for an unaudited app build can run into the millions. Privacy Act fines alone reach $50 million. A single data breach averages over $4 million in Australia. PCI non compliance runs $5,000 per month. IP ownership disputes have cost founders their entire codebase. Most of it is invisible until something triggers it. That is the point.
            </p>
          </div>
          <p class="risks-sub">
            These are real, legally enforceable obligations. Most founders don&rsquo;t know they exist until they are facing the consequences.
          </p>
        </div>

        <div class="risks-list">
          {riskCategories.map((cat, i) => {
            const visibleItems = cat.items.filter((it) => cat.visible.includes(it.title));
            const hiddenItems = cat.items.filter((it) => !cat.visible.includes(it.title));
            const moreLabel = hiddenItems.length === 1
              ? 'Show 1 more risk in this category'
              : `Show ${hiddenItems.length} more risks in this category`;
            const staggerClass = `stagger-${Math.min((i % 5) + 1, 5)}`;
            return (
              <article class={`risk-card reveal ${staggerClass}`}>
                <div class="risk-order">{cat.order}</div>
                <div class="risk-body">
                  <div class="risk-meta">
                    <span class="risk-tag">Category</span>
                    <span class="risk-divider">·</span>
                    <span class="risk-count">{cat.items.length} {cat.items.length === 1 ? 'risk' : 'risks'}</span>
                  </div>
                  <h3 class="risk-title">{cat.name}</h3>
                  <div class="risk-items">
                    {visibleItems.map((item) => (
                      <div class="risk-item">
                        <h4 class="risk-item-title">{item.title}</h4>
                        <p class="risk-item-body">{item.body}</p>
                      </div>
                    ))}
                  </div>
                  {hiddenItems.length > 0 && (
                    <details class="risk-more">
                      <summary class="risk-more-toggle">
                        <span class="show-more">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                          {moreLabel}
                        </span>
                        <span class="show-less">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
                          Show less
                        </span>
                      </summary>
                      <div class="risk-items risk-items-more">
                        {hiddenItems.map((item) => (
                          <div class="risk-item">
                            <h4 class="risk-item-title">{item.title}</h4>
                            <p class="risk-item-body">{item.body}</p>
                          </div>
                        ))}
                      </div>
                    </details>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Standards -->
    <section class="standards-section">
      <div class="standards-inner">
        <div class="reveal">
          <span class="section-label">Compliance Standards</span>
          <h2 class="section-heading">The standards we audit against.</h2>
          <p class="section-sub">
            These are the internationally recognised frameworks AWLabs applies to every project. This is what enterprise clients, investors and acquirers will ask for. Most founders have never heard of them.
          </p>
        </div>

        <div class="standards-grid">
          {standards.map((s, i) => (
            <div class={`standard-card reveal stagger-${(i % 6) + 1}`}>
              <div class="std-code">{s.code}</div>
              <div class="std-name">{s.name}</div>
              <div class="std-when">{s.when}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Consequences -->
    <section class="consequences-section">
      <div class="consequences-inner">
        <div class="reveal">
          <span class="section-label">Real World Consequences</span>
          <h2 class="section-heading">What happens when founders skip it.</h2>
          <p class="section-sub">First person because we have seen them.</p>
        </div>

        <div class="consequences-grid">
          {consequences.map((c, i) => (
            <article class={`consequence-card reveal stagger-${(i % 3) + 1}`}>
              <h3 class="consequence-title">{c.title}</h3>
              <p class="consequence-body">{c.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Deliverables -->
    <section class="deliverables-section">
      <div class="deliverables-inner">
        <div class="reveal">
          <span class="section-label">Deliverables</span>
          <h2 class="section-heading">What the Discovery Audit delivers.</h2>
        </div>

        <div class="deliverables-grid">
          {deliverables.map((d, i) => (
            <article class={`deliverable-card reveal stagger-${i + 1}`}>
              <div class="del-order">{d.order}</div>
              <h3 class="del-title">{d.title}</h3>
              <p class="del-body">{d.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Pillars -->
    <section class="pillars-section">
      <div class="pillars-inner">
        <div class="pillars-grid">
          <div class="reveal-left">
            <span class="section-label">Not Just A Dev Shop</span>
            <h2 class="section-heading">Code, capital and compliance. One team, one roof.</h2>
            <p>AWLabs is a full end to end solution. Development, marketing, capital and legal, all under the same roof, all working from the same brief. You are not stitching four vendors together. You are talking to one team.</p>
            <p>The Discovery Audit is the point where that comes together. Every risk we surface is something one of these four pillars addresses. Nothing is thrown over a fence.</p>
          </div>
          <div class="pillars-list reveal-right stagger-2">
            {pillars.map((p, i) => (
              <div class="pillar">
                <div class="pillar-num">{String(i + 1).padStart(2, '0')}</div>
                <div class="pillar-body">
                  <strong>{p.title}</strong>
                  <span>{p.body}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Close -->
    <section class="close-section">
      <div class="close-inner">
        <div class="reveal">
          <span class="section-label">The Decision</span>
          <h2 class="section-heading">Not everyone gets to this point.</h2>
          <p class="close-urgency">
            Every week you build without this audit is another week of compounding exposure.
          </p>
          <div class="close-body">
            <p>Andy is personally across every Discovery Audit we take on. We work with a limited number of clients at a time and we are selective about who we take on, because the DA only works when we can go deep.</p>
            <p>If you are reading this, it means Andy thinks there is something real here.</p>
            <p>The Discovery Audit is a fixed fee. If we proceed to build, that fee is credited in full to your build — so it is not an extra cost. It is money toward your project.</p>
            <p>For what it protects you from, what it sets you up with and the doors it can open, whether you proceed with us or not, it is one of the most important line items you will approve on this project.</p>
          </div>

          <div class="close-social" aria-label="Client credentials">
            <span class="close-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <p>AWLabs and All Webbed Up have served over 150 Australian clients. Rated 5.0 on Google across 118 reviews.</p>
          </div>

          <div class="close-actions">
            <a href="mailto:andy@awlabs.com.au" class="btn-primary">
              Book Your Discovery Audit
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
            </a>
            <a href="/how-we-work" class="btn-outline">View Case Studies and NDA</a>
          </div>
          <p class="close-note">Or call 1800 714 148</p>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ------------------------------------------------------------------
     Hero
     ------------------------------------------------------------------ */
  .audit-hero {
    padding: 10rem 0 6rem;
    background: #0a0f0e;
    position: relative;
    overflow: hidden;
  }
  .audit-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 60% 30%, rgba(13, 147, 115, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .audit-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }
  .audit-title {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.875rem, 6.5vw, 4.5rem);
    font-weight: 800;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
    max-width: 820px;
    overflow-wrap: break-word;
  }
  .audit-lead {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    font-weight: 500;
    color: #cde0da;
    max-width: 720px;
    line-height: 1.55;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
    padding: 1rem 1.25rem;
    border-left: 2px solid #0d9373;
    background: rgba(13, 147, 115, 0.05);
    border-radius: 0 10px 10px 0;
    overflow-wrap: break-word;
  }
  .audit-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.9375rem, 2vw, 1.125rem);
    color: #8aa09a;
    max-width: 720px;
    line-height: 1.7;
    margin: 0;
    overflow-wrap: break-word;
  }

  /* ------------------------------------------------------------------
     Lede
     ------------------------------------------------------------------ */
  .lede-section {
    padding: 5rem 0;
    background: #0f1614;
    border-top: 1px solid #1e2d28;
    border-bottom: 1px solid #1e2d28;
  }
  .lede-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 2rem;
    text-align: center;
  }
  .lede-quote {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.375rem, 3.6vw, 2.375rem);
    font-weight: 700;
