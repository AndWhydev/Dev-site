---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';

// CASE_STUDY_PLACEHOLDER — replace with real client details when approved
const data = {
  metaTitle: "AI Sales Forecasting & Demand Planning Tool | All Webbed Labs",
  metaDescription: "How we built an ML-powered demand forecasting system for a Sydney national FMCG distributor — reducing overstock write-downs by 23%, stockouts by 31% and improving forecast accuracy from 31% to 14% MAPE across 2,800 SKUs.",

  industry: "AI & Automation",
  tags: ["Machine Learning", "Demand Forecasting", "Python", "scikit-learn", "FMCG"],

  title: "Sales Forecasting & Demand Planning Tool",
  summary: "A national FMCG distributor in Sydney was writing down $1.2M per year in overstock while simultaneously losing an estimated $800K in sales to stockouts — both caused by demand planning based on gut feel and basic Excel trend lines across 2,800 SKUs. We built a gradient boosting demand forecasting model with seasonal decomposition, promotional calendar integration and a planning dashboard that cut write-downs by 23% and stockouts by 31% within the first year.",

  heroImageDescription: "Demand planning dashboard showing SKU-level weekly forecast vs actual charts, overstock risk heatmap across product categories, stockout risk alerts with lead time countdown and planner workflow queue showing items needing review",

  clientOverview: "Placeholder Distribution Co is a national FMCG distributor headquartered in Sydney, supplying 340 independent retailers across NSW, Victoria and Queensland with a portfolio of 2,800 SKUs across grocery, personal care and household categories. The company operates on consignment and firm purchase models with different inventory risk profiles, and manages a network of three warehouses across the eastern seaboard. They are a mid-tier player in a market where margins are tight and where overstock and stockouts have direct bottom-line consequences.",
  clientSize: "National operations, 2,800 SKUs, 340 independent retailers",
  clientLocation: "Sydney, NSW (national operations)",

  pullQuote: "We were spending money we didn't have to and losing money we should have had. The problem wasn't that our demand planners were bad at their jobs — they were experienced people working with tools that weren't good enough for the complexity of what we were asking them to do. Two experienced people cannot manually track seasonality, promotions and retailer-specific trends across 2,800 SKUs.",
  pullQuoteAuthor: "Phil N.",
  pullQuoteRole: "Head of Supply Chain, Placeholder Distribution Co",

  challenge: [
    "Demand planning for 2,800 SKUs across three warehouses and 340 geographically dispersed retailers is fundamentally a data problem that exceeds human cognitive capacity. Even experienced demand planners working full-time can meaningfully track perhaps 100–150 SKUs with genuine analytical depth. The remaining 2,650 SKUs were effectively managed on auto-pilot — reorder at the same level as last month, adjusted for any obvious seasonal effect the planner happened to remember. This worked well for stable, predictable SKUs and failed systematically for anything with meaningful seasonality, promotional sensitivity or retailer-specific demand patterns.",
    "Overstock was costing $1.2M per year in write-downs. The write-down categories broke down as follows: seasonal products ordered at peak-season volumes that didn't sell through before the season ended, promotional stock ordered in excess of actual promotional uplift, and slow-moving SKUs that had been ordered at historical rates but whose underlying demand had declined. All three root causes had one thing in common: the forecast had not incorporated available information that should have predicted the outcome.",
    "Stockouts were estimated to be costing $800K per year in lost sales. These estimates were conservative — based on known out-of-stock events where alternative product was available in the same category, but not accounting for customers who simply bought from a competitor when their preferred SKU was unavailable. The stockout-prone SKUs were primarily fast-moving items in categories where lead times were long (imported product with 8–12 week ocean freight lead times), meaning a single missed forecast could create a 6–8 week stockout window.",
    "The promotional calendar was not integrated into the planning process in any systematic way. Promotional uplifts for supported retailers are known in advance — promotional agreements are signed weeks or months before execution — but this information existed in a separate system (a combination of spreadsheets and a trade promotions management tool) with no connection to the demand planning process. A planned 30% promotional uplift for a product at three major retailers would generate extra orders from those retailers that the planning system would interpret as unexpected demand, then over-order to meet in subsequent periods.",
    "The two demand planners were spending approximately 35 hours per week on spreadsheet analysis — building rolling averages, applying ad-hoc seasonal adjustments, manually formatting historical sales data from the ERP extract into usable form. This left them approximately 5 hours per week for the actual planning decisions, conversations with sales representatives about upcoming promotional activity, and working through exceptions and anomalies. The tool was consuming the time of the people who were most qualified to make the judgement calls.",
  ],

  whyUs: [
    "The Head of Supply Chain had previously worked at a company where an ML forecasting project had been oversold and underdelivered. His specific concern when he engaged us was not 'can you build a better forecast' — he assumed we could — but 'how will you avoid the failure modes I've seen before'. The failure modes he described were: a black-box model that the team couldn't interrogate when it gave a suspicious result, a model that performed well in testing but degraded in production as conditions changed, and a model that was too complex for the planning team to adopt without months of additional training.",
    "Our response to these concerns shaped the project scope. We proposed gradient boosting (specifically LightGBM) over more complex deep learning approaches because it is interpretable — the feature importance output can explain which factors are driving a specific SKU's forecast — and it degrades gracefully with less data, which was important for newer SKUs with short sales histories. We proposed a planning dashboard designed around the planners' existing workflow, not a replacement workflow. And we proposed an explicit model monitoring and retraining schedule as part of the deliverable, not as a future phase.",
    "We were also transparent that a MAPE of 14% — our approximate target for this problem, based on published benchmarks for FMCG demand forecasting — does not mean 86% of forecasts are exactly right. It means the average percentage error is 14%. Some SKUs would forecast at 5% MAPE, some at 30%. The client's planning team needed to understand this distribution, and the dashboard needed to show forecast confidence intervals, not just point estimates, so planners could prioritise their attention on high-uncertainty, high-stakes items.",
  ],

  approach: [
    "The data preparation and exploration phase ran for three weeks and was the most consequential part of the project. Five years of sales history from the ERP was extracted and cleaned: we identified and resolved data quality issues including duplicate transactions from a billing system migration, missing weeks from a warehouse management system outage, and a period of inconsistent SKU coding during a product catalogue consolidation exercise. Cleaning this data accounted for approximately 30% of the data preparation work.",
    "Feature engineering was the most impactful single contribution to forecast accuracy, more so than model selection. The feature set included: week-of-year seasonality (cyclic encoding via sine/cosine transforms to handle the year-boundary correctly), rolling mean sales at 4, 8 and 13-week windows, lag features at 1, 2, 4 and 8 weeks, promotional calendar indicators (binary flags for whether a retailer had an active promotion in the forecast week, and the agreed promotional uplift percentage), product category encoding, warehouse location encoding, retailer segment encoding, and price elasticity indicators based on historical promotional response.",
    "Promotional calendar integration required building a lightweight integration between the trade promotions management tool and the forecasting pipeline. Planned promotions for the next 16 weeks were pulled weekly via API and joined to the forecast feature set. This single feature accounted for approximately 8 percentage points of the improvement in MAPE on promotional SKUs specifically — the promotional flag and uplift percentage gave the model the information it needed to correctly anticipate demand spikes that had previously been invisible to it.",
    "We trained separate models for three product lifecycle stages: established SKUs with 2+ years of history (the majority, using the full feature set), newer SKUs with 6–24 months of history (using a reduced feature set with more regularisation), and new SKUs under 6 months old (using a category-level average plus promotional indicators, with a manual planner override mechanism). This segmented approach outperformed a single model applied across all SKUs.",
  ],

  solution: [
    "The forecasting model is a LightGBM gradient boosting model trained on the full five-year historical dataset with 47 features. LightGBM was chosen over XGBoost for its memory efficiency with the full 2,800-SKU feature matrix and its categorical feature handling, which simplified the retailer and product category encoding. The model produces weekly point forecasts and 80% prediction intervals for each SKU-retailer-warehouse combination in the planning horizon (1–16 weeks ahead).",
    "Seasonal decomposition was applied as a preprocessing step to separate trend, seasonality and residual components before training. This improved model stability for SKUs with strong seasonal patterns (summer/winter product categories in particular) by allowing the model to learn from deseasonalised residuals rather than having to discover seasonal patterns from raw data. The seasonal components are recomposed into the final forecast output.",
    "The planning dashboard is a React application built over a FastAPI backend, providing planners with a prioritised work queue based on forecast uncertainty and business impact. The queue ranking algorithm combines forecast prediction interval width (uncertainty), SKU revenue contribution (business impact), days of stock remaining based on current inventory and forecast demand (urgency), and upcoming promotional activity (which amplifies both uncertainty and impact). This means planners see the 20 items that most need their attention at the top of their queue every morning, rather than reviewing all 2,800 SKUs in alphabetical order.",
    "Feature importance output from the LightGBM model is surfaced in the dashboard for each SKU. When a planner clicks into a specific SKU's forecast, they can see which features the model weighted most heavily in that forecast. A forecast with a high promotional uplift feature importance is interpretable: the model expects elevated demand because a promotion is planned. This explainability was explicitly designed to build planner trust and reduce the black-box rejection pattern the client had experienced with a previous vendor.",
    "Model retraining runs weekly via an Airflow-scheduled job, incorporating the most recent week's actual sales data and the updated promotional calendar. A performance monitoring dashboard tracks rolling MAPE by SKU category and alerts when any category's MAPE degrades more than 3 percentage points from the trailing 8-week average. This provides an early warning for distributional shift — when real-world demand patterns are diverging from what the model was trained on.",
  ],

  implementation: [
    "The project ran over 14 weeks from discovery to production deployment. Data preparation and feature engineering occupied weeks one through five. Model training, validation and hyperparameter tuning ran through weeks six and seven. Dashboard development ran in parallel with model development from weeks four through eleven. A three-week validation period followed in which model forecasts were compared to actuals on held-out recent data before production deployment.",
    "Cross-validation was structured as a rolling-window time-series split — not standard k-fold — because demand forecasting has temporal dependencies that standard cross-validation violates. We used five rolling windows of increasing training period and held out the most recent 8 weeks in each window as validation data. This gave us a reliable estimate of out-of-sample forecast accuracy before deployment.",
    "The held-out validation MAPE of 14.2% compared to the baseline MAPE of 31% (measured using the planners' own Excel forecasts over the same validation period) confirmed the model's value before production deployment. Breaking down the MAPE improvement by category: established SKUs improved from 28% to 12%, promotional SKUs improved from 41% to 18% (driven primarily by the promotional calendar integration), and seasonal SKUs improved from 38% to 16%.",
    "Planner onboarding took two weeks and involved three half-day workshops. The first workshop covered the model's inputs and outputs — what it knows, what it doesn't know, when to trust it and when to override it. The second covered the dashboard workflow — the priority queue, forecast detail view, feature importance interpretation and override mechanism. The third was a live session working through the current week's actual planning queue with the model running. Post-training surveys rated planner confidence with the new system at 4.1/5.",
    "Data integration with the ERP (weekly extract via automated SQL job to AWS S3) and the trade promotions management tool (weekly API pull) was the most technically fragile component during the first month of production. Two data quality incidents in the first four weeks — a failed ERP extract and a promotional calendar API schema change — required rapid response. Both were resolved within hours, and we added data quality validation checks to the Airflow pipeline that now catch these issues automatically before they affect forecast quality.",
  ],

  lessonsLearned: [
    "Data cleaning is not preparatory work — it is where accuracy is made or lost. The three data quality issues we found and fixed during the preparation phase (duplicate transactions, missing weeks, inconsistent SKU coding) would each have degraded model accuracy in specific, hard-to-diagnose ways if left unaddressed. We now require a data quality report as a formal deliverable before model training begins, with sign-off from the client on data issues that require source system corrections.",
    "Feature engineering for FMCG demand forecasting is more domain-specific than most ML projects. The promotional calendar integration, the lag and rolling window structures, and the seasonal decomposition preprocessing are not generic ML techniques — they reflect specific properties of FMCG demand dynamics. Working with demand planners rather than just data to design the feature set was essential. The two planners contributed directly to the feature engineering decisions, and several of their suggestions improved model accuracy measurably.",
    "Model explainability directly affected adoption. Both demand planners reported that being able to see why the model was forecasting a spike or a trough — which features were driving the prediction — made them more willing to trust the model and less likely to override it without reason. This is consistent with adoption research in ML-augmented decision systems. Future projects of this type should treat explainability as a first-class requirement, not an optional feature.",
    "Prediction intervals matter as much as point forecasts for operational planning. Planning purely to the point forecast means treating all forecasts as equally certain, which leads to either systematic over-ordering (to hedge against uncertainty) or systematic stockouts (when uncertainty is higher than assumed). Showing planners the 80% prediction interval alongside the point forecast gave them meaningful information about which forecasts to trust and which to dig into further.",
  ],

  whatCameNext: [
    "Following a successful first year in production, the client commissioned a second phase to extend the forecasting system to supplier order optimisation — using the demand forecasts and inventory position data to generate automated purchase order recommendations with lead time awareness and minimum order quantity constraints. This reduced the planner's remaining manual workload on standard reorder decisions by approximately 60%.",
    "The promotional calendar integration was deepened to include post-promotional demand correction — a feature that accounts for the demand pull-forward effect where a promotion cannibalises future sales. This further improved MAPE on promotional SKUs in the weeks following a promotion end.",
    "The client's CFO, having seen the write-down reduction in the first year's results, approved a budget expansion for a third phase integrating the forecasting outputs with the warehouse management system to automate put-away location assignment based on forecast velocity. This project is currently in scoping.",
  ],

  resultsNarrative: "In year one of production operation, overstock write-downs reduced by 23% — a saving of $276,000 against the $1.2M baseline. Stockout frequency reduced by 31%, recovering an estimated portion of the previously lost $800K in sales. Forecast accuracy (MAPE) improved from a 31% baseline (using the planners' prior Excel models) to 14% — a 55% improvement in accuracy. The two demand planners' time on spreadsheet analysis dropped from 35 hours per week to 8 hours, freeing approximately 54 person-hours per week for the judgement-intensive work that actually requires their expertise. The project cost was recovered in under 7 months from write-down savings alone.",

  metrics: [
    { value: "23%", label: "Overstock write-down reduction", context: "$276K saved in year 1 against a $1.2M baseline" },
    { value: "31%", label: "Stockout frequency reduction", context: "Recovering a portion of estimated $800K in annual lost sales" },
    { value: "14%", label: "Forecast MAPE (accuracy)", context: "Down from 31% baseline — a 55% improvement across 2,800 SKUs" },
    { value: "8hrs/wk", label: "Planner time on spreadsheet analysis", context: "Down from 35hrs/week — freeing 54 hours for higher-value decisions" },
    { value: "2,800", label: "SKUs with weekly automated forecasts", context: "Previously limited to ~150 SKUs receiving meaningful analytical attention" },
    { value: "7 months", label: "ROI payback period", context: "From write-down savings alone, before stockout recovery is counted" },
  ],

  techStack: [
    { name: "Python (scikit-learn / LightGBM)", reason: "Gradient boosting model; LightGBM chosen for memory efficiency with 2,800-SKU feature matrices and built-in categorical feature handling" },
    { name: "Apache Airflow", reason: "Weekly model retraining pipeline, ERP data extract, promotional calendar refresh, and performance monitoring jobs" },
    { name: "FastAPI", reason: "Backend API serving forecast data, planner queue prioritisation, override recording and model performance analytics" },
    { name: "React (planning dashboard)", reason: "Priority queue interface, SKU forecast detail views, feature importance visualisation, prediction interval charts and override workflow" },
    { name: "PostgreSQL", reason: "Historical sales data, forecast outputs, prediction intervals, planner overrides and model performance tracking" },
    { name: "AWS (ap-southeast-2)", reason: "Model training infrastructure, Airflow managed on MWAA, API hosting and data storage within Australian data sovereignty constraints" },
  ],

  relatedCaseStudies: [
    {
      title: "Customer Service AI Chatbot",
      href: "/case-studies/customer-service-ai-chatbot",
      industry: "AI & Automation",
      summary: "GPT-4 powered chatbot for a Queensland regional telco resolving 71% of enquiries without human escalation, cutting average wait times from 18 minutes to under 2 minutes.",
    },
    {
      title: "Document Processing & Data Extraction",
      href: "/case-studies/document-processing-data-extraction",
      industry: "AI & Automation",
      summary: "AI-powered invoice processing pipeline for a national logistics company, reducing manual data entry by 89% and tripling processing capacity.",
    },
    {
      title: "AI-Powered Content Generation Platform",
      href: "/case-studies/ai-content-generation-platform",
      industry: "AI & Automation",
      summary: "Brand-voice-consistent content generation for a Melbourne marketing agency, cutting first draft time from 4 hours to 35 minutes and increasing agency capacity 40%.",
    },
  ],

  relatedServices: [
    { title: "Machine Learning & Predictive Analytics", href: "/services/machine-learning-predictive-analytics" },
    { title: "AI Integration & Automation", href: "/services/ai-integration-automation" },
    { title: "Data Pipeline Development", href: "/services/data-pipeline-development" },
    { title: "Business Intelligence & Dashboards", href: "/services/business-intelligence-dashboards" },
  ],
};
---
<CaseStudyLayout {...data} />
