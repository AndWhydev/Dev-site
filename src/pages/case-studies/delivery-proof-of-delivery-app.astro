    { name: "Google Maps (Directions API)", reason: "In-app navigation and ETA calculation for accurate customer notification timing" },
    { name: "Digital Signature Capture", reason: "In-app finger signature on tablet screen, stored as SVG alongside delivery record" },
    { name: "Twilio SMS", reason: "Evening pre-delivery window notification and day-of ETA update to customers" },
    { name: "PDF Proof of Delivery", reason: "Auto-generated delivery certificate with timestamp, GPS, signature, and photos for client portal" },
    { name: "AWS (ECS, RDS)", reason: "Containerised backend deployment and managed PostgreSQL database" },
    { name: "Android MDM", reason: "Device management for 18 company tablets — app locking, WiFi config, and remote wipe" }
  ],

