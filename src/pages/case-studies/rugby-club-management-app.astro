      industry: "Hospitality",
      summary: "A 12-location café franchise launched a branded loyalty app that drove a 27% increase in repeat visits within the first six months."
    }
  ],

  relatedServices: [
    { title: "Mobile App Development", href: "/services/mobile-app-development" },
    { title: "Custom Software Development", href: "/services/custom-software-development" },
    { title: "Payment Integration", href: "/services/payment-integration" },
    { title: "Database Design", href: "/services/database-design" }
  ]
