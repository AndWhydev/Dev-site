<script>
  const searchInput = document.getElementById('cs-search') as HTMLInputElement;
  const industryFilter = document.getElementById('cs-industry-filter') as HTMLSelectElement;
  const serviceFilter = document.getElementById('cs-service-filter') as HTMLSelectElement;
  const techFilter = document.getElementById('cs-tech-filter') as HTMLSelectElement;
  const cards = document.querySelectorAll<HTMLElement>('.cs-card');
  const countEl = document.getElementById('cs-count')!;
  const noResults = document.getElementById('cs-no-results')!;

  function filterCards() {
    const q = searchInput.value.toLowerCase();
    const ind = industryFilter.value;
    const svc = serviceFilter.value;
    const tech = techFilter.value;
    let visible = 0;

    cards.forEach((card) => {
      const matchQ = !q || card.dataset.title?.includes(q) || card.dataset.industry?.toLowerCase().includes(q);
      const matchInd = !ind || card.dataset.industry === ind;
      const matchSvc = !svc || card.dataset.services?.includes(svc);
      const matchTech = !tech || card.dataset.techs?.includes(tech);

      if (matchQ && matchInd && matchSvc && matchTech) {
        card.hidden = false;
        visible++;
      } else {
        card.hidden = true;
      }
    });

    countEl.textContent = String(visible);
    noResults.hidden = visible > 0;
  }

  function clearFilters() {
    searchInput.value = '';
    industryFilter.value = '';
    serviceFilter.value = '';
    techFilter.value = '';
    filterCards();
  }

  searchInput.addEventListener('input', filterCards);
  industryFilter.addEventListener('change', filterCards);
  serviceFilter.addEventListener('change', filterCards);
  techFilter.addEventListener('change', filterCards);
  document.getElementById('cs-clear')?.addEventListener('click', clearFilters);
  document.getElementById('cs-clear-2')?.addEventListener('click', clearFilters);
</script>
