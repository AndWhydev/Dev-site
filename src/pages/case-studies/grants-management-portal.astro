      href: '/case-studies/loan-application-assessment-platform',
      industry: 'Financial Services',
      summary: 'A government-backed lending programme replaced a paper application process with a structured digital portal, reducing assessment time per application by 40% and eliminating manual data re-entry.',
    },
  ],

  relatedServices: [
