    {
      title: 'SaaS Development',
      href: '/services/saas-development',
      industry: 'Service',
      summary: 'We build multi-tenant SaaS products and two-sided marketplace platforms from concept to launch, with a focus on the payment architecture, onboarding flows and growth infrastructure that early-stage products need.',
    },
  ],

  relatedServices: [
