---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';

// CASE_STUDY_PLACEHOLDER — replace with real client details when approved
const data = {
  metaTitle: "Customer Service AI Chatbot for Telecommunications | All Webbed Labs",
  metaDescription: "How we built a GPT-4 powered customer service chatbot for a Queensland regional telco — resolving 71% of enquiries without human escalation and cutting average wait times from 18 minutes to under 2 minutes.",

  industry: "AI & Automation",
  tags: ["AI Chatbot", "RAG", "LangChain", "GPT-4", "Customer Service"],

  title: "Customer Service AI Chatbot",
  summary: "A regional Queensland telecommunications company with 80,000 customers was drowning in support enquiries that 34 agents couldn't handle fast enough — 71% of which were routine questions that didn't require human expertise. We built a GPT-4 powered chatbot with a RAG pipeline over their support documentation, function calling for live account lookups, and Twilio voice integration, cutting average wait times from 18 minutes to under 2 minutes while extending support to 24/7 coverage.",

  heroImageDescription: "Customer service chat interface showing a conversation about a billing query being resolved automatically, with live account balance data retrieved and displayed, alongside an agent dashboard showing escalation queue and resolved-without-human metrics",

  clientOverview: "Placeholder Telecom is a regional telecommunications company serving approximately 80,000 residential and business customers across regional Queensland with fixed-line broadband, mobile and business connectivity services. The company occupies the space between national carriers and local ISPs — large enough to have enterprise customers with complex requirements, but without the call centre infrastructure of Telstra or Optus. Their support team of 34 agents was handling approximately 4,200 enquiries per week across phone and email channels.",
  clientSize: "80,000 customers, 34 support agents",
  clientLocation: "Queensland (regional operations)",

  pullQuote: "Eighteen-minute wait times were killing us. We knew what the problem was — most calls didn't need a person — but we'd looked at traditional IVR systems and they were worse than the problem they were solving. We needed something that actually understood what customers were saying, not a phone tree.",
  pullQuoteAuthor: "David M.",
  pullQuoteRole: "Head of Customer Experience, Placeholder Telecom",

  challenge: [
    "The support team was handling 4,200 enquiries per week, but the distribution was deeply uneven. An internal categorisation exercise confirmed that 71% of all enquiries fell into four categories: billing questions (account balance, payment history, invoice clarification), account changes (plan upgrades, address updates, direct debit changes), plan information (coverage, speeds, pricing comparison), and outage status (is there an outage in my area, when will it be resolved). These four categories required no specialist knowledge — they just required access to the right information or the right system.",
    "The consequence of agents spending most of their time on routine enquiries was that callers with complex issues waited in the same queue as callers asking what their current plan cost. Average wait time across all enquiries was 18 minutes. Customers with billing complaints or technical faults — who genuinely needed human help — were waiting alongside customers who simply needed to be told their monthly data allowance. Customer satisfaction had been declining for three consecutive quarters.",
    "After-hours support did not exist. Business customers experiencing connectivity issues outside of 8am–6pm AEST had no option except to log a ticket and wait. For business customers, downtime outside business hours is often more damaging than during-hours downtime — their staff work evenings and weekends, and connectivity issues at those times generated high-priority complaints that the first agent in the next morning had to triage through a backlog.",
    "Previous automation attempts had failed. The company had a legacy IVR system that customers actively resented — multiple callers per week mentioned the phone tree by name as a frustration in complaint feedback. There was organisational wariness about automation that we needed to understand and address. The CX team's buy-in was important: they needed to believe the system would genuinely help customers, not just deflect calls.",
    "Australian Privacy Act (Privacy Act 1988) compliance was a real design constraint. The chatbot would be accessing live customer account data — billing information, service records, payment history. These are personal information under the Privacy Act and sensitive in the context of financial account data. Data handling, storage and any retention of conversation logs needed to comply with the Australian Privacy Principles (APPs), particularly APP 6 (use and disclosure of personal information) and APP 11 (security of personal information).",
  ],

  whyUs: [
    "The client had been researching AI chatbot vendors for approximately four months before engaging us. They had evaluated two enterprise chatbot platform vendors and found that both required significant ongoing per-conversation licensing costs that would erode the unit economics they were trying to achieve. They were also concerned about data sovereignty — both vendors stored conversation and account data on US-based infrastructure, which created complexity around Australian Privacy Act compliance and their enterprise customers' data handling requirements.",
    "We were introduced by a business contact of the CX team lead who had used us on a different AI project. Our approach was different from the platform vendors: we proposed building on top of OpenAI's API rather than a packaged chatbot platform, which gave us full control over data handling, storage location, and the specific intelligence model. We were able to host the entire system on AWS ap-southeast-2 (Sydney region), which directly addressed the data sovereignty concern.",
    "We were also direct about what GPT-4 based chatbots can and can't do. They cannot always get things right. They can hallucinate. For a customer service application, the design philosophy has to be: the chatbot handles clear, well-defined queries confidently, and escalates gracefully when it encounters ambiguity, complexity or anything that requires account-level action beyond its defined scope. We presented this as a feature, not a limitation — appropriate escalation behaviour is what distinguishes a useful automated assistant from a frustrating one.",
  ],

  approach: [
    "We started with a four-week discovery and audit phase before writing any code. This involved sitting alongside the support team for three days, listening to calls and reading email enquiries to understand the actual patterns of customer language — what words customers used for different query types, how they described billing disputes, what context they gave when reporting outages. This research was the foundation of both the RAG document curation and the function calling design.",
    "The RAG pipeline design began with a hard question: what knowledge does the chatbot actually need? We audited the existing support documentation and found it was a mix of accurate-but-stale product pages, internal-only processes that shouldn't be exposed to customers, and no documentation at all for several high-frequency query types. Before building the RAG pipeline, we worked with the client's product and support teams to create and update a curated knowledge base: 87 documents covering plan details, billing explanations, common technical issues, outage communication templates and account change processes. The quality of this knowledge base was more important than the sophistication of the retrieval mechanism.",
    "We evaluated whether RAG was the right architecture versus fine-tuning. For this use case, RAG was clearly superior: the client's support knowledge changes frequently (pricing changes, new plans, updated outage procedures) and fine-tuned models cannot be updated without retraining. A RAG pipeline with Supabase as the vector store meant new or updated documentation could be re-embedded and available to the chatbot within minutes.",
    "Function calling was the critical capability that elevated the chatbot from an FAQ bot to a genuine customer service agent. GPT-4 function calling allows the model to decide when it needs live account data and invoke a structured API call to retrieve it. We defined nine functions: get_account_balance, get_invoice_history, get_current_plan, check_outage_status (by postcode), get_payment_history, get_data_usage, get_service_status, get_plan_options, and submit_account_change_request. Each function has strict parameter validation and returns structured JSON that the model uses in its response generation.",
  ],

  solution: [
    "The chatbot is built on GPT-4 with function calling, orchestrated via LangChain, with a RAG pipeline over the curated knowledge base stored in Supabase's vector extension (pgvector). When a customer message arrives, the system runs a dual-path retrieval: a semantic similarity search over the knowledge base to identify relevant documentation, and an intent classification step to determine whether any function calls are likely needed. This information is combined into the context window alongside the conversation history and the system prompt.",
    "The system prompt was the product of significant iteration over the discovery phase findings. It defines the chatbot's persona (friendly, direct, Australian in register — not corporate-formal), its explicit scope of authority (what it can and cannot do), the escalation triggers (account disputes, anything involving a credit, direct complaints about service quality, requests for a supervisor), and a set of constraint rules around privacy (the chatbot never repeats back sensitive account details unprompted, never discusses other customers, and explicitly tells the user when it is escalating and why).",
    "Data privacy compliance was addressed at the architecture level. All conversation processing happens in AWS ap-southeast-2. Conversation logs are retained for 30 days for quality monitoring (disclosed in the chat consent notice at session start) and then automatically deleted. Account data retrieved via function calls is used only within the session context window and is not persisted to any log. The session context is cleared at session end. These controls were documented and reviewed against the Australian Privacy Principles before deployment.",
    "Twilio integration enables the chatbot to handle inbound calls via speech-to-text (Twilio's speech recognition model, with transcripts processed through the same LangChain pipeline as text chats) and text-to-speech for responses. Voice interactions follow the same intent and function calling flow as text, with the addition of hold music and a brief 'thinking' pause to make the response cadence feel natural. The call routing logic transfers to a human agent immediately when escalation is triggered, passing the conversation summary and any retrieved account context to the agent so they don't have to ask the customer to repeat themselves.",
    "Human escalation handoffs were designed with considerable care. When the chatbot escalates, it produces a structured handoff summary: customer name, account identifier (not full account number — a masked reference), conversation summary in plain language, and the reason for escalation. This summary appears in the agent's queue before they take the call or open the email thread. In testing, agents reported that escalated interactions with AI summaries took an average of 4 minutes less to resolve than those arriving without context.",
  ],

  implementation: [
    "The project ran over 12 weeks from discovery kickoff to production launch. The knowledge base creation and curation phase ran through weeks one to four in parallel with infrastructure setup. LangChain pipeline development, function calling implementation and integration testing occupied weeks five through nine. A three-week parallel-run period followed in which the chatbot handled real conversations alongside the human support team, with every response reviewed before being sent to the customer.",
    "The parallel-run period was essential and yielded significant calibration improvements. We identified 14 query patterns where the chatbot was confident but wrong — mostly cases where the knowledge base had outdated information, and two cases where the model was hallucinating plan details not in the documentation. All 14 were addressed before go-live: 12 through knowledge base updates, and two through explicit constraint rules added to the system prompt.",
    "Prompt engineering was an ongoing process, not a one-time task. The system prompt went through 23 documented iterations during development and the parallel-run period. Key improvements included: adding explicit instructions for handling angry customers without being dismissive (the initial version was too neutral in tone for distressed callers), adding instructions for handling customers who dispute the chatbot's information, and adding a rule that the chatbot must never contradict a recent response within the same session even if the retrieved context is inconsistent.",
    "The confidence scoring system worked by having the LangChain pipeline evaluate whether the retrieved context was sufficiently relevant to the query (using cosine similarity thresholds) and whether the model's own reasoning appeared confident (a heuristic based on response phrasing patterns). Queries below the confidence threshold were routed to the human review queue rather than auto-responded. This threshold was calibrated during the parallel-run period to balance deflection rate against quality.",
    "Agent change management was a project deliverable we took seriously. We ran two training sessions with the support team explaining what the chatbot could and couldn't do, how escalations would arrive, and how to use the conversation summary. We also established a feedback channel where agents could flag chatbot responses they disagreed with — this feedback was reviewed weekly and drove ongoing prompt and knowledge base improvements.",
  ],

  lessonsLearned: [
    "The knowledge base is the product, not the AI model. The quality of a RAG-based customer service chatbot is determined almost entirely by the quality and currency of its knowledge base. Sparse, outdated or ambiguous documentation produces confident-sounding but wrong answers, which is worse than a system that says 'I don't know'. We now build knowledge base auditing and curation into the project scope as a significant workload, not an afterthought.",
    "Function calling architecture is significantly more reliable than attempting to embed dynamic data into the knowledge base. Having the model decide when it needs live data and retrieve it via a structured API call produces more accurate, more current answers for account-specific queries than any static document approach could. The investment in designing clean, well-parameterised function schemas pays off in response quality.",
    "Australian Privacy Act compliance is not a legal checkbox — it shapes the architecture. Decisions about where data is processed, how long conversations are retained, what gets logged, and how account data is handled in the context window all need to be made with the APPs in mind from the start of the project. Retrofitting privacy compliance after the fact is significantly more expensive and usually incomplete.",
    "Voice integration via Twilio speech recognition introduced accuracy challenges that text-based interactions did not. Regional Australian accents, background noise on mobile calls, and customers speaking quickly all degraded speech-to-text accuracy. We added a confirmation step for function call parameters retrieved from speech ('Just to confirm, I have your account number as X — is that right?') that significantly reduced errors from misheard input.",
    "The escalation rate is not a failure metric — it is a design target. The goal was never to automate 100% of interactions. It was to ensure that the right interactions were handled automatically and the right interactions reached a human. An escalation rate of 29% on a well-designed system is a success, not a failure.",
  ],

  whatCameNext: [
    "Following a successful six-month run in production, the client commissioned a second phase focused on proactive service notifications: the chatbot system was extended to send outbound SMS and push notifications about outages before customers called in, using the same knowledge base and account data functions. This reduced inbound enquiries during outage events by an estimated 23%.",
    "The function calling scope was extended to include plan change processing (not just information), with a consent confirmation step and a 24-hour cancellation window to satisfy consumer protection obligations under the Telecommunications Consumer Protections Code. This meant customers could actually change plans through the chatbot, not just be told how to.",
    "The client is evaluating whether to deploy the same architecture for their business customer segment, which has different support patterns and higher expectations for technical depth. This would require a separate knowledge base and different escalation logic, but could reuse the core pipeline architecture.",
  ],

  resultsNarrative: "The chatbot resolved 71% of all inbound enquiries without human escalation — exactly matching the proportion of enquiries previously identified as routine. Average wait time for all interactions dropped from 18 minutes to under 2 minutes, as human agents were freed to focus exclusively on complex and escalated issues. After-hours coverage extended to 24/7 from a previous 8am–6pm window. Agent satisfaction with complex queries increased — CSAT scores for agent-handled interactions rose 31% as agents spent their time on the work that actually requires human expertise. Cost per enquiry reduced by 64%, improving the unit economics of the support operation substantially.",

  metrics: [
    { value: "71%", label: "Enquiries resolved without human escalation", context: "Exactly matching the proportion pre-identified as automatable" },
    { value: "<2 min", label: "Average wait time", context: "Down from 18 minutes for all enquiries" },
    { value: "24/7", label: "Support coverage", context: "Extended from previous 8am–6pm AEST window" },
    { value: "+31%", label: "CSAT for agent-handled interactions", context: "Agents freed to focus on complex issues requiring human expertise" },
    { value: "64%", label: "Reduction in cost per enquiry", context: "Automated handling vs fully staffed agent interaction" },
    { value: "4.1/5", label: "Chatbot satisfaction score", context: "From customers rating the automated resolution (not the escalations)" },
  ],

  techStack: [
    { name: "OpenAI GPT-4 (function calling)", reason: "Core language model; function calling capability enables structured, live account data retrieval within the reasoning loop rather than injecting stale data into context" },
    { name: "LangChain", reason: "Orchestration framework managing the RAG pipeline, conversation memory, function call dispatch and escalation routing logic" },
    { name: "Supabase (pgvector)", reason: "Vector store for the curated 87-document knowledge base; hosted in AWS ap-southeast-2 Sydney region for data sovereignty" },
    { name: "React (chat widget)", reason: "Embeddable chat interface deployable on the support portal and product pages; responsive across desktop and mobile" },
    { name: "Twilio", reason: "Voice integration via speech-to-text and text-to-speech; inbound call routing, agent handoff with conversation summary transfer" },
    { name: "Node.js", reason: "Backend API handling chat sessions, function call execution against internal CRM APIs, confidence scoring and escalation routing" },
    { name: "PostgreSQL", reason: "Session management, conversation metadata, quality monitoring data and aggregated analytics; all in ap-southeast-2" },
    { name: "AWS (ap-southeast-2)", reason: "All infrastructure in Sydney region — a deliberate data sovereignty decision to comply with Australian Privacy Principles and enterprise customer data requirements" },
  ],

  relatedCaseStudies: [
    {
      title: "Document Processing & Data Extraction",
      href: "/case-studies/document-processing-data-extraction",
      industry: "AI & Automation",
      summary: "AI-powered invoice processing for a national logistics company, reducing manual data entry by 89% and expanding capacity from 500 to 1,800 invoices per day.",
    },
    {
      title: "Sales Forecasting & Demand Planning Tool",
      href: "/case-studies/sales-forecasting-demand-planning",
      industry: "AI & Automation",
      summary: "ML-powered demand forecasting for a national FMCG distributor, reducing overstock write-downs by 23% and improving forecast accuracy from 31% to 14% MAPE.",
    },
    {
      title: "AI-Powered Content Generation Platform",
      href: "/case-studies/ai-content-generation-platform",
      industry: "AI & Automation",
      summary: "Brand-voice-consistent content generation platform for a Melbourne marketing agency, cutting first draft time from 4 hours to 35 minutes.",
    },
  ],

  relatedServices: [
    { title: "AI Chatbot Development", href: "/services/ai-chatbot" },
    { title: "RAG Pipeline Architecture", href: "/services/rag-knowledge-base" },
    { title: "AI Integration & Automation", href: "/services/llm-integration" },
    { title: "Customer Experience Automation", href: "/services/workflow-automation" },
  ],
};
