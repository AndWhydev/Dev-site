---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';

/* Posts array emptied — three previous posts each contained
   FABRICATED case studies presented as factual (e.g. 'a major
   Australian insurer reduced manual review time by 68%', 'Queensland
   government department reduced call handle time by 22%', 'Responsible
   Wood reduced audit costs by 40%' — all unverifiable). Posts will
   return once written from real, defensible client work. */
const posts: any[] = [];

const categories = [
  { name: 'All Posts', count: 0, href: '/blog' },
];

const categoryColors: Record<string, string> = {
  'AI & Automation': 'cat-ai',
  'Mobile Development': 'cat-mobile',
  'Web3 & Blockchain': 'cat-web3',
};
---

<Layout
  title="Blog — All Webbed Labs | Enterprise Technology Insights"
  description="Insights, deep dives and practical guides from the All Webbed Labs engineering team. AI, mobile, Web3, enterprise architecture and more."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="blog-hero">
      <div class="blog-hero-bg" aria-hidden="true">
        <div class="blog-hero-glow"></div>
      </div>
      <div class="blog-hero-inner">
        <div class="reveal">
          <span class="section-label">The Labs Blog</span>
          <h1 class="blog-hero-title">
            Engineering Insights<br />
            <span class="gradient-text">From the Field</span>
          </h1>
          <p class="blog-hero-sub">
            Practical articles from the engineers building enterprise software every day. No fluff, no sponsored content — just real insights on AI, mobile, Web3 and software architecture.
          </p>
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="blog-content-section">
      <div class="blog-content-inner">
        <div class="blog-layout">
          <!-- Posts -->
          <div class="blog-posts">
            <h2 class="posts-heading reveal">Latest Articles</h2>
            <div class="posts-list">
              {posts.map((post, i) => (
                <article class={`post-card reveal stagger-${i + 1}`}>
                  <div class="post-card-inner">
                    <div class="post-meta-top">
                      <span class={`post-category ${categoryColors[post.category] ?? ''}`}>{post.category}</span>
                      <span class="post-read-time">{post.readTime}</span>
                    </div>
                    <h3 class="post-title">
                      <a href={`/blog/${post.slug}`}>{post.title}</a>
                    </h3>
                    <p class="post-excerpt">{post.excerpt}</p>
                    <div class="post-footer">
                      <div class="post-author-info">
                        <div class="post-author-avatar" aria-hidden="true">AWL</div>
                        <div>
                          <div class="post-author-name">{post.author}</div>
                          <div class="post-date">{post.dateFormatted}</div>
                        </div>
                      </div>
                      <a href={`/blog/${post.slug}`} class="post-read-link">
                        Read article
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                      </a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>

          <!-- Sidebar -->
          <aside class="blog-sidebar">
            <!-- Categories -->
            <div class="sidebar-widget reveal">
              <h3 class="sidebar-widget-title">Categories</h3>
              <ul class="sidebar-categories">
                {categories.map((cat) => (
                  <li>
                    <a href={cat.href} class="sidebar-cat-link">
                      <span>{cat.name}</span>
                      <span class="sidebar-cat-count">{cat.count}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Newsletter -->
            <div class="sidebar-widget sidebar-newsletter reveal">
              <div class="newsletter-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <h3 class="sidebar-widget-title">Stay in the Loop</h3>
              <p class="newsletter-desc">Get our latest articles on enterprise AI, mobile and software architecture — delivered fortnightly.</p>
              <form class="newsletter-form" onsubmit="return false;">
                <input
                  type="email"
                  placeholder="your@email.com"
                  class="newsletter-input"
                  aria-label="Email address"
                  required
                />
                <button type="submit" class="newsletter-btn">
                  Subscribe
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
              <p class="newsletter-fine">No spam. Unsubscribe any time.</p>
            </div>

            <!-- Featured post -->
            <div class="sidebar-widget reveal">
              <h3 class="sidebar-widget-title">Most Read</h3>
              <div class="sidebar-featured-posts">
                {posts.map((post) => (
                  <a href={`/blog/${post.slug}`} class="sidebar-post-link">
                    <span class={`sidebar-post-cat ${categoryColors[post.category] ?? ''}`}>{post.category}</span>
                    <span class="sidebar-post-title">{post.title}</span>
                    <span class="sidebar-post-date">{post.dateFormatted}</span>
                  </a>
                ))}
              </div>
            </div>

            <!-- CTA widget -->
            <div class="sidebar-widget sidebar-cta-widget reveal">
              <h3 class="sidebar-cta-title">Ready to build?</h3>
              <p class="sidebar-cta-desc">Talk to our engineering team about your next project.</p>
              <a href="/contact" class="btn-primary sidebar-cta-btn">
                Book a free call
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <CTABanner />
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .blog-hero {
    padding: 10rem 0 6rem;
    background: #0a0f0e;
    position: relative;
    overflow: hidden;
  }
  .blog-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .blog-hero-glow {
    position: absolute;
    top: -10%;
    left: 40%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(13,147,115,0.08) 0%, transparent 65%);
  }
  .blog-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }
  .blog-hero-title {
    font-family: 'Sora', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    color: white;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    max-width: 700px;
  }
  .blog-hero-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    color: #8aa09a;
    max-width: 580px;
    line-height: 1.7;
    margin: 0;
  }

  /* Content layout */
  .blog-content-section {
    padding: 6rem 0;
    background: #0f1614;
  }
  .blog-content-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .blog-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 4rem;
    align-items: start;
  }

  /* Posts list */
  .posts-heading {
    font-family: 'Sora', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
    margin: 0 0 2rem;
  }
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .post-card {
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 20px;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .post-card:hover {
    border-color: rgba(13,147,115,0.3);
    transform: translateY(-3px);
  }
  .post-card-inner {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .post-meta-top {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }
  .post-category {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
  }
  .cat-ai { color: #0d9373; background: rgba(13,147,115,0.1); }
  .cat-mobile { color: #3b82f6; background: rgba(59,130,246,0.1); }
  .cat-web3 { color: #a855f7; background: rgba(168,85,247,0.1); }
  .post-read-time {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #4a6359;
  }
  .post-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.3125rem;
    font-weight: 700;
    color: white;
    line-height: 1.3;
    margin: 0;
  }
  .post-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .post-title a:hover { color: #0d9373; }
  .post-excerpt {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #4a6359;
    line-height: 1.7;
    margin: 0;
  }
  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid #1e2d28;
  }
  .post-author-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .post-author-avatar {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: linear-gradient(135deg, #0d9373, #0a7a5e);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Sora', sans-serif;
    font-size: 0.5625rem;
    font-weight: 700;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .post-author-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #8aa09a;
  }
  .post-date {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #4a6359;
  }
  .post-read-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: #0d9373;
    text-decoration: none;
    transition: gap 0.2s ease;
  }
  .post-read-link:hover { gap: 0.625rem; }

  /* Sidebar */
  .blog-sidebar {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .sidebar-widget {
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 16px;
    padding: 1.5rem;
  }
  .sidebar-widget-title {
    font-family: 'Sora', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: white;
    margin: 0 0 1.125rem;
  }

  /* Categories */
  .sidebar-categories {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .sidebar-cat-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #8aa09a;
    text-decoration: none;
    border-bottom: 1px solid #1e2d28;
    transition: color 0.2s ease;
  }
  .sidebar-categories li:last-child .sidebar-cat-link { border-bottom: none; }
  .sidebar-cat-link:hover { color: #0d9373; }
  .sidebar-cat-count {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: #0d9373;
    background: rgba(13,147,115,0.1);
    padding: 0.15rem 0.5rem;
    border-radius: 50px;
  }

  /* Newsletter */
  .sidebar-newsletter {
    background: linear-gradient(135deg, #0a1510 0%, #0a0f0e 100%);
    border-color: rgba(13,147,115,0.2);
  }
  .newsletter-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(13,147,115,0.1);
    border: 1px solid rgba(13,147,115,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0d9373;
    margin-bottom: 1rem;
  }
  .newsletter-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
    line-height: 1.6;
    margin: 0 0 1rem;
  }
  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .newsletter-input {
    background: rgba(255,255,255,0.04);
    border: 1px solid #1e2d28;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: white;
    outline: none;
    transition: border-color 0.2s ease;
    width: 100%;
  }
  .newsletter-input::placeholder { color: #4a6359; }
  .newsletter-input:focus { border-color: rgba(13,147,115,0.4); }
  .newsletter-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    background: #0d9373;
    color: white;
    padding: 0.75rem 1.25rem;
    border-radius: 10px;
    border: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease;
    width: 100%;
  }
  .newsletter-btn:hover { background: #10b88a; }
  .newsletter-fine {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    color: #2a3d35;
    margin: 0.25rem 0 0;
    text-align: center;
  }

  /* Sidebar featured posts */
  .sidebar-featured-posts {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .sidebar-post-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid #1e2d28;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .sidebar-featured-posts a:last-child { border-bottom: none; }
  .sidebar-post-link:hover { opacity: 0.8; }
  .sidebar-post-cat {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    align-self: flex-start;
  }
  .sidebar-post-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #8aa09a;
    line-height: 1.45;
  }
  .sidebar-post-date {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    color: #4a6359;
  }

  /* Sidebar CTA widget */
  .sidebar-cta-widget {
    background: linear-gradient(135deg, #0a1510 0%, #0a0f0e 100%);
    border-color: rgba(13,147,115,0.2);
    text-align: center;
  }
  .sidebar-cta-title {
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: white;
    margin: 0 0 0.5rem;
  }
  .sidebar-cta-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }
  .sidebar-cta-btn {
    width: 100%;
    justify-content: center;
    font-size: 0.875rem;
    padding: 0.75rem 1.25rem;
  }

  @media (max-width: 1100px) {
    .blog-layout { grid-template-columns: 1fr; }
    .blog-sidebar { position: static; }
  }
</style>
