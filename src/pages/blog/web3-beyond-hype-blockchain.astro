  author: 'All Webbed Labs Team',
  date: '2026-03-20',
  dateFormatted: 'Mar 20, 2026',
  category: 'Web3 & Blockchain',
  readTime: '7 min read',
  slug: 'web3-beyond-hype-blockchain',
};

const relatedPosts = [
  {
    slug: 'future-of-ai-australian-enterprise',
    title: 'The Future of AI in Australian Enterprise: What Leaders Need to Know in 2026',
    category: 'AI & Automation',
    date: 'May 1, 2026',
  },
  {
    slug: 'flutter-smart-choice-mobile-2026',
    title: 'Why Flutter is the Smart Choice for Enterprise Mobile App Development in 2026',
    category: 'Mobile Development',
    date: 'Apr 15, 2026',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  author: {
    '@type': 'Organization',
    name: post.author,
    url: 'https://awlabs.com.au',
  },
  publisher: {
    '@type': 'Organization',
    name: 'All Webbed Labs',
    url: 'https://awlabs.com.au',
    logo: {
      '@type': 'ImageObject',
      url: 'https://awlabs.com.au/logo.svg',
    },
  },
  datePublished: post.date,
  dateModified: post.date,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://awlabs.com.au/blog/${post.slug}`,
  },
