          <p class="article-cta-desc">
            All Webbed Labs has delivered production smart contract systems, tokenised asset platforms and enterprise blockchain integrations. We'll help you identify the right approach — or tell you honestly when blockchain isn't the answer.
          </p>
          <div class="article-cta-actions">
            <a href="/contact" class="btn-primary">
              Start the conversation
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/web3-crypto" class="btn-outline">
              Our Web3 services
            </a>
          </div>
        </div>
      </div>
    </section>

    <CTABanner />
  </main>

  <Footer />
</Layout>

