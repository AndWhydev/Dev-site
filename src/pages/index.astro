---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroWebGL from '../components/HeroWebGL.astro';
import OurStory from '../components/OurStory.astro';
import TrustedBy from '../components/TrustedBy.astro';
import LiveAppDemo from '../components/LiveAppDemo.astro';
import RealAppEmbed from '../components/RealAppEmbed.astro';
import ProductShowcase from '../components/ProductShowcase.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import TechStack from '../components/TechStack.astro';
import WhyLabs from '../components/WhyLabs.astro';
import Process from '../components/Process.astro';
import IndustryShowcase from '../components/IndustryShowcase.astro';
import AISpotlight from '../components/AISpotlight.astro';
import Web3Spotlight from '../components/Web3Spotlight.astro';
import ROICalculator from '../components/ROICalculator.astro';
import CTABanner from '../components/CTABanner.astro';
/* BlogPreview removed — its 3 hardcoded links target blog posts
   that were deleted (each contained fabricated case studies). Will
   return once new posts written from real client work. */
/* Removed for credibility — these components contain fabricated client
   names, fabricated stats, or fabricated case-study outcomes. Add back
   only when replaced with real, defensible content:
   - StatsBar           (150+ Projects / 98% Retention / 4.49 Rating — unverifiable)
   - Testimonials       (Sarah Mitchell / James Okafor / Marcus Chen — fictional)
   - FeaturedCaseStudies (Qld telco / Melbourne lender / Sydney courier — fictional) */
---

<Layout
  title="All Webbed Labs — Enterprise Software Development Australia"
  description="Australian software development partner. Custom apps, AI tools, Web3, cloud infrastructure and digital transformation. The tech arm of All Webbed Up."
>
  <Header />
  <main>
    <HeroWebGL />

    <!-- Premium marquee strip -->
    <div class="marquee-strip">
      <div class="marquee-inner">
        {['Enterprise Software', 'AI & Automation', 'Flutter Development', 'Cloud Infrastructure', 'Web3 & Blockchain', 'Digital Transformation', 'Custom SaaS', 'API Development', 'Cybersecurity', 'Data Analytics', 'Legacy Modernisation', 'Staff Augmentation', 'Enterprise Software', 'AI & Automation', 'Flutter Development', 'Cloud Infrastructure', 'Web3 & Blockchain', 'Digital Transformation', 'Custom SaaS', 'API Development', 'Cybersecurity', 'Data Analytics', 'Legacy Modernisation', 'Staff Augmentation'].map(item => (
          <span class="marquee-item">{item}</span>
        ))}
      </div>
    </div>

    <!-- Entity definition band (GEO entity locking) -->
    <section class="home-entity" aria-label="About All Webbed Labs">
      <div class="home-entity-inner reveal">
        <p>
          <strong>All Webbed Labs</strong> is the enterprise AI and software development arm of
          <a href="https://allwebbedup.com.au" target="_blank" rel="noopener noreferrer">All Webbed Up</a>,
          a Sydney based agency building autonomous systems for Australian businesses.
        </p>
      </div>
    </section>

    <OurStory />
    <TrustedBy />
    <LiveAppDemo />
    <RealAppEmbed />
    <ProductShowcase />
    <ServicesGrid />
    <IndustryShowcase />
    <TechStack />
    <WhyLabs />
    <Process />
    <AISpotlight />
    <Web3Spotlight />
    <ROICalculator />
    <CTABanner />
  </main>
  <Footer />
</Layout>

<style>
  .home-entity {
    background: #0a0f0e;
    padding: 3.5rem 2rem;
    border-bottom: 1px solid #1e2d28;
  }
  .home-entity-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .home-entity-inner p {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 500;
    color: #cde0da;
    line-height: 1.5;
    letter-spacing: -0.01em;
    margin: 0;
    text-align: center;
  }
  .home-entity-inner strong { color: white; font-weight: 700; }
  .home-entity-inner a {
    color: #0d9373;
    text-decoration: none;
    border-bottom: 1px solid rgba(13,147,115,0.4);
    transition: border-color 0.2s ease;
  }
  .home-entity-inner a:hover { border-color: #0d9373; }
</style>
