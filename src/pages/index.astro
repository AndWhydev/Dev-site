---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroWebGL from '../components/HeroWebGL.astro';
import TrustBar from '../components/TrustBar.astro';
import DemosShowcase from '../components/DemosShowcase.astro';
import LiveAppDemo from '../components/LiveAppDemo.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import Process from '../components/Process.astro';
import TeamSection from '../components/TeamSection.astro';
import CTABanner from '../components/CTABanner.astro';
import AutonomousAISection from '../components/sections/AutonomousAISection.astro';
/* Home page trimmed to the credibility spine: hero → trust → autonomy
   pitch → live craft (demos) → real shipped app → services → process → CTA.
   OurStory, IndustryShowcase, TechStack, WhyLabs, AISpotlight,
   Web3Spotlight, ProductShowcase and ROICalculator all live on their own
   pages and are reachable via the header nav, duplicating them on home
   diluted every other proof signal. */
---

<Layout
  title="All Webbed Labs, Enterprise Software Development Australia"
  description="Australian software development partner. Custom apps, AI tools, Web3, cloud infrastructure and digital transformation. Sister company to All Webbed Up."
>
  <Header />
  <main>
    <HeroWebGL />

    <TrustBar />

    <TeamSection />

    <AutonomousAISection />

    {/* Capability marquee, client-facing language only. Avoid internal tool
        names that read as boasting; favour the outcomes a buyer cares about.
        Doubled via spread so translateX(-50%) infinite-scroll seams cleanly. */}
    <div class="marquee-strip">
      <div class="marquee-inner">
        {(() => {
          const phrases = [
            'Australian-owned',
            'Full IP transferred to you',
            'Fixed-price or time-and-materials',
            'AEST delivery, no offshore handoffs',
            'Source code, not a black box',
            'NDA-first engagements',
            'R&D tax incentive eligible',
            'Production-grade from day one',
            'Quality gates before deploy',
            'Human review on every release',
          ];
          return [...phrases, ...phrases].map(item => (
            <span class="marquee-item">{item}</span>
          ));
        })()}
      </div>
    </div>

    <!-- Entity definition band (GEO entity locking) -->
    <section class="home-entity" aria-label="About All Webbed Labs">
      <div class="home-entity-inner reveal">
        <p>
          <strong>All Webbed Labs</strong> is a Sydney based enterprise AI and software development company.
          Sister company to <a href="https://allwebbedup.com.au" target="_blank" rel="noopener noreferrer">All Webbed Up</a>,
          the branding and marketing agency we deliver client work alongside.
        </p>
      </div>
    </section>

    <DemosShowcase />
    <LiveAppDemo />
    <ServicesGrid />
    <Process />
    <CTABanner />
  </main>
  <Footer />
</Layout>

<style>
  .home-entity {
    background: #0a0f0e;
    padding: 3.5rem 2rem;
    border-bottom: 1px solid #1e2d28;
  }
  .home-entity-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .home-entity-inner p {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 500;
    color: #cde0da;
    line-height: 1.5;
    letter-spacing: -0.01em;
    margin: 0;
    text-align: center;
  }
  .home-entity-inner strong { color: white; font-weight: 700; }
  .home-entity-inner a {
    color: #0d9373;
    text-decoration: none;
    border-bottom: 1px solid rgba(13,147,115,0.4);
    transition: border-color 0.2s ease;
  }
  .home-entity-inner a:hover { border-color: #0d9373; }
</style>
