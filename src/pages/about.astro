---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';
import TechStack from '../components/TechStack.astro';
import TeamSection from '../components/TeamSection.astro';

const values = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>`,
    title: 'Outcomes Over Outputs',
    description: 'We measure success by business outcomes — not lines of code, features shipped or hours logged. Every decision is filtered through a single question: does this deliver real value for the client?',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`,
    title: 'Partners, Not Vendors',
    description: 'We invest in understanding your business as deeply as your own team. Long-term relationships built on radical transparency, honest advice and genuine care for your success — even when that means telling you what you don\'t want to hear.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Engineering Excellence',
    description: 'We hold ourselves to the highest engineering standards. Clean, well-tested, documented code that your team can own, maintain and evolve long after the engagement ends. No cowboy code, no shortcuts.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: 'Continuous Learning',
    description: 'Technology moves fast. Our team dedicates structured time each week to R&D so we\'re always ahead of the curve. When something transformative like LLMs arrives, we\'re deploying it for clients in months, not years.',
  },
];

---

<Layout
  title="About All Webbed Labs — Our Story & Values | Australian AI Software Agency"
  description="All Webbed Labs is a Sydney based enterprise AI and software development company. Sister to All Webbed Up, the branding and marketing agency we work alongside. Read our story, team and values."
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="about-hero">
      <div class="about-hero-inner">
        <div class="reveal">
          <span class="section-label">About All Webbed Labs</span>
          <h1 class="about-title">
            We Are<br />
            <span class="gradient-text">All Webbed Labs.</span>
          </h1>
          <p class="about-lead">
            All Webbed Labs is a Sydney based enterprise AI and software development company. Sister to All Webbed Up, the branding and marketing agency we deliver client work alongside.
          </p>
          <p class="about-sub">
            Software engineers, AI specialists and technology strategists — built around a single belief:
            that Australian businesses deserve technology partners who understand enterprise as deeply as they understand code.
          </p>
        </div>
      </div>
    </section>

    <!-- Team + partner network — lifted to the top because /about is the
         destination of the header "Team" link. The narrative sections (Story,
         Values, Culture, Philosophy, Location, Tech Stack) continue below. -->
    <TeamSection />

    <!-- Story -->
    <section class="story-section">
      <div class="story-inner">
        <div class="story-narrative reveal-left">
          <span class="section-label">Our Story</span>
          <h2 class="section-heading">Why We Built All Webbed Labs</h2>
          <p>All Webbed Labs is the AI and enterprise software arm of <a href="https://allwebbedup.com.au" target="_blank" rel="noopener noreferrer">All Webbed Up</a> — a Sydney based agency. Labs was created to focus on a single question: what happens when an agency runs itself on autonomous AI workers instead of selling them by the hour.</p>
          <p>AW Labs Pty Ltd was incorporated in June 2026, but the team behind it isn't new to this work. Our founder and senior engineers have years of hands-on experience building enterprise software and AI systems for real clients — projects delivered long before we formalised under this entity. The company is recent; the practice isn't.</p>
          <p>The product you see across this site — Overseer, the multi-agent build pipeline, and the internal apps that triage briefs, plan projects and ship code — is the same software we use every day to deliver client work. For specifics on past engagements, get in touch and we'll walk you through them directly.</p>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="values-section">
      <div class="values-inner">
        <div class="reveal">
          <span class="section-label">Our Values</span>
          <h2 class="section-heading">What Drives Everything We Do</h2>
          <p class="section-subheading">Not wall decorations — these are the criteria by which we hire, the standards by which we deliver and the promises we keep to every client.</p>
        </div>
        <div class="values-grid">
          {values.map((v, i) => (
            <div class={`value-card reveal stagger-${i + 1}`}>
              <div class="value-icon" set:html={v.icon} />
              <h3>{v.title}</h3>
              <p>{v.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Culture section -->
    <section class="culture-section">
      <div class="culture-inner">
        <div class="culture-grid">
          <div class="reveal-left">
            <span class="section-label">Our Culture</span>
            <h2 class="section-heading">How We Work</h2>
            <p>All Webbed Labs operates as a flat, senior-heavy team. We don't have account managers who sit between you and the engineers. You talk directly to the people building your product — because we believe that directness produces better outcomes.</p>
            <p>Every engagement has a dedicated lead engineer and a delivery manager. Weekly status calls. Transparent project portals. Honest status reports. If something's off-track, we tell you before you need to ask.</p>
            <p>We work remotely but communicate like we're in the same room. Async by default, synchronous when it matters. We respect your timezone and expect the same in return.</p>
          </div>
          <div class="culture-cards reveal-right stagger-2">
            <div class="culture-card">
              <div class="cc-icon">🧑‍💻</div>
              <div class="cc-label">Senior-only team</div>
              <div class="cc-desc">Minimum 5 years professional experience. No juniors on client projects.</div>
            </div>
            <div class="culture-card">
              <div class="cc-icon">🔍</div>
              <div class="cc-label">Transparent delivery</div>
              <div class="cc-desc">Live project dashboards, weekly updates, no hidden scope.</div>
            </div>
            <div class="culture-card">
              <div class="cc-icon">🇦🇺</div>
              <div class="cc-label">Australian entity</div>
              <div class="cc-desc">Sydney-registered Pty Ltd, AEST hours, local compliance knowledge.</div>
            </div>
            <div class="culture-card">
              <div class="cc-icon">📖</div>
              <div class="cc-label">Continuous learning</div>
              <div class="cc-desc">Structured R&D time every week — when something transformative arrives, we're already using it.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Technology Philosophy -->
    <section class="philosophy-section">
      <div class="philosophy-inner">
        <div class="phil-grid">
          <div class="reveal-left">
            <span class="section-label">Technology Philosophy</span>
            <h2 class="section-heading">We Choose Tools, Not Trends</h2>
            <p>Enterprise software outlives the frameworks it's built with. We choose technology based on stability, community longevity, performance at scale and the ease with which your internal team can take ownership after we deliver.</p>
            <p>We're pragmatic engineers. A proven, slightly boring technology stack beats a flashy new framework for anything business-critical. That said, we stay at the cutting edge — when something genuinely transformative arrives, we deploy it for clients quickly, with the rigour enterprise demands.</p>
            <div class="phil-principles">
              <div class="phil-p"><span>01</span> Boring technology for critical infrastructure</div>
              <div class="phil-p"><span>02</span> Modern tooling where it accelerates delivery</div>
              <div class="phil-p"><span>03</span> AI augmentation for everything repetitive</div>
              <div class="phil-p"><span>04</span> Open source first, where enterprise-grade options exist</div>
            </div>
          </div>
          <div class="phil-layers reveal-right stagger-2">
            <div class="phil-layer">
              <div class="phil-lbl">Presentation</div>
              <div class="phil-techs"><span>React</span><span>Next.js</span><span>Flutter</span><span>Swift</span></div>
            </div>
            <div class="phil-layer">
              <div class="phil-lbl">API & Logic</div>
              <div class="phil-techs"><span>Node.js</span><span>Python</span><span>FastAPI</span><span>GraphQL</span></div>
            </div>
            <div class="phil-layer">
              <div class="phil-lbl">Data</div>
              <div class="phil-techs"><span>PostgreSQL</span><span>MongoDB</span><span>Redis</span><span>Supabase</span></div>
            </div>
            <div class="phil-layer">
              <div class="phil-lbl">Infrastructure</div>
              <div class="phil-techs"><span>AWS / GCP</span><span>Docker</span><span>Kubernetes</span><span>Terraform</span></div>
            </div>
            <div class="phil-layer phil-ai">
              <div class="phil-lbl">AI Layer</div>
              <div class="phil-techs"><span>OpenAI</span><span>Claude</span><span>LangChain</span><span>Custom ML</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Office / Location -->
    <section class="location-section">
      <div class="location-inner">
        <div class="location-grid">
          <div class="reveal-left">
            <span class="section-label">Where We Are</span>
            <h2 class="section-heading">Five Dock, New South Wales</h2>
            <p>Our team is based in Sydney, NSW — operating across Australia and internationally, with delivery capabilities in every timezone.</p>
            <div class="location-details">
              <div class="loc-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>1 Ramsay Rd, Five Dock NSW 2046</span>
              </div>
              <div class="loc-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.15a16 16 0 006.29 6.29l1.42-1.42a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 15.16v.76z"/></svg>
                <span>1800 714 148</span>
              </div>
              <div class="loc-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Mon–Fri, 9am–6pm AEST</span>
              </div>
              <div class="loc-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <span>labs@allwebbedup.com.au</span>
              </div>
            </div>
            <a href="/contact" class="btn-primary" style="margin-top: 1.5rem; display: inline-flex; align-items: center; gap: 0.5rem;">
              Get In Touch
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="location-mark reveal-right stagger-2" aria-hidden="true">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div class="location-mark-text">
              <strong>Sydney · New South Wales</strong>
              <span>Working with Australian clients in every time zone.</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <TechStack />

    <!-- CTA -->
    <section class="about-cta">
      <div class="about-cta-inner">
        <div class="reveal" style="text-align: center; max-width: 760px; margin: 0 auto;">
          <span class="section-label">Work With Us</span>
          <h2 class="section-heading">Two Ways to Engage</h2>
          <div class="engage-grid">
            <div class="engage-card">
              <div class="engage-icon">🤝</div>
              <h3>Work With Us On a Project</h3>
              <p>Bring us a brief — defined or exploratory — and let's build something exceptional together.</p>
              <a href="/contact" class="btn-primary">Book a Call</a>
            </div>
            <div class="engage-card">
              <div class="engage-icon">💼</div>
              <h3>Join Our Team</h3>
              <p>We're always looking for senior engineers who care deeply about quality and client outcomes.</p>
              <a href="/careers" class="btn-outline">See Open Roles</a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .about-hero {
    padding: 10rem 0 6rem;
    background: #0a0f0e;
    position: relative;
    overflow: hidden;
  }
  .about-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 60% 30%, rgba(13,147,115,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .about-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }
  .about-title {
    font-family: 'Sora', sans-serif;
    /* Min lowered so "All Webbed Labs." fits a 360px phone without clipping. */
    font-size: clamp(1.875rem, 6.5vw, 4.5rem);
    font-weight: 800;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    max-width: 700px;
    overflow-wrap: break-word;
  }
  .about-lead {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    font-weight: 500;
    color: #cde0da;
    max-width: 720px;
    line-height: 1.55;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
    padding: 1rem 1.25rem;
    border-left: 2px solid #0d9373;
    background: rgba(13,147,115,0.05);
    border-radius: 0 10px 10px 0;
    overflow-wrap: break-word;
  }
  .about-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.9375rem, 2vw, 1.125rem);
    color: #8aa09a;
    max-width: 640px;
    line-height: 1.7;
    margin-bottom: 0;
    overflow-wrap: break-word;
  }

  /* Story */
  .story-section { padding: 7rem 0; background: #0f1614; }
  .story-inner { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
  .story-narrative { max-width: 780px; }
  .story-section p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: #8aa09a;
    line-height: 1.75;
    margin: 0 0 1.25rem;
  }
  .story-section p a { color: #0d9373; text-decoration: none; }

  /* Values */
  .values-section { padding: 7rem 0; background: #0a0f0e; }
  .values-inner { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
  .values-inner .section-subheading { margin-bottom: 3rem; }
  .values-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .value-card {
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 20px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.3s ease;
  }
  .value-card:hover { border-color: rgba(13,147,115,0.3); }
  .value-icon { width: 52px; height: 52px; border-radius: 14px; background: rgba(13,147,115,0.08); border: 1px solid rgba(13,147,115,0.15); display: flex; align-items: center; justify-content: center; color: #0d9373; }
  .value-card h3 { font-family: 'Sora', sans-serif; font-size: 1.25rem; font-weight: 700; color: white; margin: 0; }
  .value-card p { font-family: 'DM Sans', sans-serif; font-size: 0.9375rem; color: #4a6359; line-height: 1.7; margin: 0; }

  /* Culture */
  .culture-section { padding: 7rem 0; background: #0f1614; }
  .culture-inner { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
  .culture-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
  .culture-section p { font-family: 'DM Sans', sans-serif; font-size: 1rem; color: #4a6359; line-height: 1.75; margin: 0 0 1.25rem; }
  .culture-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 4.5rem; }
  .culture-card { background: #0a0f0e; border: 1px solid #1e2d28; border-radius: 14px; padding: 1.5rem; }
  .cc-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
  .cc-label { font-family: 'Sora', sans-serif; font-size: 0.9375rem; font-weight: 600; color: white; margin-bottom: 0.375rem; }
  .cc-desc { font-family: 'DM Sans', sans-serif; font-size: 0.8125rem; color: #4a6359; line-height: 1.5; }

  /* Philosophy */
  .philosophy-section { padding: 7rem 0; background: #0a0f0e; }
  .philosophy-inner { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
  .phil-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
  .philosophy-section p { font-family: 'DM Sans', sans-serif; font-size: 1rem; color: #4a6359; line-height: 1.75; margin: 0 0 1.25rem; }
  .phil-principles { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 0.5rem; }
  .phil-p { display: flex; align-items: center; gap: 0.875rem; font-family: 'DM Sans', sans-serif; font-size: 0.9375rem; color: #8aa09a; }
  .phil-p span { font-family: 'Sora', sans-serif; font-size: 0.6875rem; font-weight: 700; color: #0d9373; background: rgba(13,147,115,0.1); padding: 0.2rem 0.5rem; border-radius: 4px; }
  .phil-layers { background: #0f1614; border: 1px solid #1e2d28; border-radius: 20px; overflow: hidden; margin-top: 4.5rem; }
  .phil-layer { padding: 1.125rem 1.5rem; border-bottom: 1px solid #1e2d28; }
  .phil-layer:last-child { border-bottom: none; }
  .phil-ai { background: rgba(13,147,115,0.04); }
  .phil-lbl { font-family: 'DM Sans', sans-serif; font-size: 0.625rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #4a6359; margin-bottom: 0.5rem; }
  .phil-techs { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  .phil-techs span { font-family: 'DM Sans', sans-serif; font-size: 0.75rem; font-weight: 500; color: #8aa09a; background: rgba(255,255,255,0.04); border: 1px solid #1e2d28; padding: 0.2rem 0.5rem; border-radius: 5px; }
  .phil-ai .phil-techs span { color: #0d9373; background: rgba(13,147,115,0.08); border-color: rgba(13,147,115,0.2); }

  /* Team */
  .team-section { padding: 7rem 0; background: #0f1614; }
  .team-inner { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
  .team-header { max-width: 640px; margin: 0 auto 2rem; text-align: center; }
  .team-header .section-subheading { margin-bottom: 0; }
  .team-join { background: rgba(255,255,255,0.02); border: 1px dashed #1e2d28; border-radius: 12px; padding: 1.5rem; text-align: center; max-width: 640px; margin: 0 auto; }
  .team-join p { font-family: 'DM Sans', sans-serif; font-size: 0.9375rem; color: #4a6359; margin: 0; }
  .team-join p a { color: #0d9373; text-decoration: none; }

  /* Location */
  .location-section { padding: 7rem 0; background: #0f1614; }
  .location-inner { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
  .location-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .location-section p { font-family: 'DM Sans', sans-serif; font-size: 1rem; color: #4a6359; line-height: 1.75; margin: 0 0 1.5rem; }
  .location-details { display: flex; flex-direction: column; gap: 0.875rem; }
  .loc-item { display: flex; align-items: flex-start; gap: 0.625rem; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; color: #8aa09a; line-height: 1.5; }
  .loc-item svg { flex-shrink: 0; margin-top: 2px; }
  .location-mark { background: #0a0f0e; border: 1px solid #1e2d28; border-radius: 20px; padding: 3rem 2.5rem; display: flex; flex-direction: column; align-items: flex-start; gap: 1.25rem; }
  .location-mark-text { display: flex; flex-direction: column; gap: 0.375rem; }
  .location-mark-text strong { font-family: 'Sora', sans-serif; font-size: 1.125rem; font-weight: 700; color: white; }
  .location-mark-text span { font-family: 'DM Sans', sans-serif; font-size: 0.9375rem; color: #8aa09a; line-height: 1.55; }

  /* About CTA */
  .about-cta { padding: 7rem 0; background: #0a0f0e; }
  .about-cta-inner { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
  .engage-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 3rem; }
  .engage-card { background: #0f1614; border: 1px solid #1e2d28; border-radius: 20px; padding: 2.5rem; display: flex; flex-direction: column; align-items: flex-start; gap: 1rem; text-align: left; }
  .engage-icon { font-size: 2rem; }
  .engage-card h3 { font-family: 'Sora', sans-serif; font-size: 1.25rem; font-weight: 700; color: white; margin: 0; }
  .engage-card p { font-family: 'DM Sans', sans-serif; font-size: 0.9375rem; color: #4a6359; line-height: 1.6; margin: 0; }

  @media (max-width: 1024px) {
    .culture-grid, .phil-grid, .location-grid { grid-template-columns: 1fr; }
    .culture-cards { margin-top: 0; }
    .phil-layers { margin-top: 0; }
    .values-grid { grid-template-columns: 1fr; }
    .engage-grid { grid-template-columns: 1fr; }
  }
</style>
