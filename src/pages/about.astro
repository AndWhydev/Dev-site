---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';
import TechStack from '../components/TechStack.astro';

// TODO: Replace ALL placeholder team members with real bios, photos and LinkedIn URLs
// Photos: 400x400px, square crop, professional. Place in public/team/[slug].jpg
const team = [
  {
    name: 'Team Member Name',  // TEAM_PLACEHOLDER — add real name
    role: 'Founder & CEO',
    bio: 'TEAM_PLACEHOLDER — add real bio. Focus on enterprise experience, technical background and what drives them to build world-class software. 2-3 sentences.',
    linkedin: '#',  // TEAM_PLACEHOLDER — add real LinkedIn URL
    initials: 'FC',
    specialties: ['Strategy', 'Enterprise', 'Architecture'],
    photo: null,  // TEAM_PLACEHOLDER — add: '/team/founder-name.jpg'
  },
  {
    name: 'Team Member Name',
    role: 'Chief Technology Officer',
    bio: 'TEAM_PLACEHOLDER — add real bio. Focus on technical leadership, architecture decisions and what makes their approach to engineering unique.',
    linkedin: '#',
    initials: 'CT',
    specialties: ['Full-Stack', 'Cloud', 'AI/ML'],
    photo: null,
  },
  {
    name: 'Team Member Name',
    role: 'Head of Delivery',
    bio: 'TEAM_PLACEHOLDER — add real bio. Focus on delivery methodology, number of projects managed and how they keep enterprise projects on track.',
    linkedin: '#',
    initials: 'HD',
    specialties: ['Agile', 'Delivery', 'Client Success'],
    photo: null,
  },
  {
    name: 'Team Member Name',
    role: 'Lead Mobile Engineer',
    bio: 'TEAM_PLACEHOLDER — add real bio. Flutter specialist. Include apps shipped, industries worked in and technical depth.',
    linkedin: '#',
    initials: 'LM',
    specialties: ['Flutter', 'iOS', 'Android'],
    photo: null,
  },
  {
    name: 'Team Member Name',
    role: 'AI & ML Engineer',
    bio: 'TEAM_PLACEHOLDER — add real bio. Focus on AI/ML specialisation, models worked with and production AI systems delivered.',
    linkedin: '#',
    initials: 'AI',
    specialties: ['LLMs', 'Python', 'ML Ops'],
    photo: null,
  },
  {
    name: 'Team Member Name',
    role: 'Senior DevOps Engineer',
    bio: 'TEAM_PLACEHOLDER — add real bio. Cloud infrastructure expertise, certifications and the scale of systems managed.',
    linkedin: '#',
    initials: 'DO',
    specialties: ['AWS', 'Kubernetes', 'Terraform'],
    photo: null,
  },
];

const values = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>`,
    title: 'Outcomes Over Outputs',
    description: 'We measure success by business outcomes — not lines of code, features shipped or hours logged. Every decision is filtered through a single question: does this deliver real value for the client?',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`,
    title: 'Partners, Not Vendors',
    description: 'We invest in understanding your business as deeply as your own team. Long-term relationships built on radical transparency, honest advice and genuine care for your success — even when that means telling you what you don\'t want to hear.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Engineering Excellence',
    description: 'We hold ourselves to the highest engineering standards. Clean, well-tested, documented code that your team can own, maintain and evolve long after the engagement ends. No cowboy code, no shortcuts.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: 'Continuous Learning',
    description: 'Technology moves fast. Our team dedicates structured time each week to R&D so we\'re always ahead of the curve. When something transformative like LLMs arrives, we\'re deploying it for clients in months, not years.',
  },
];

const awards = [
  // LOGO_PLACEHOLDER — add real awards and recognition here
  { name: 'Google Partner', placeholder: true },
  { name: 'AWS Partner', placeholder: true },
  { name: 'Microsoft Partner', placeholder: true },
  { name: 'Flutter Certified', placeholder: true },
];
---

<Layout
  title="About All Webbed Labs — Our Team, Story & Values | Enterprise Software Australia"
  description="All Webbed Labs is Australia's premier enterprise software partner. Learn about our team, values, technology philosophy and why leading corporations trust us with their most critical software projects."
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="about-hero">
      <div class="about-hero-inner">
        <div class="reveal">
          <span class="section-label">About All Webbed Labs</span>
          <h1 class="about-title">
            We Are<br />
            <span class="gradient-text">All Webbed Labs.</span>
          </h1>
          <p class="about-lead">
            All Webbed Labs is the enterprise AI and software development arm of All Webbed Up, a Sydney based agency building autonomous systems for Australian businesses.
          </p>
          <p class="about-sub">
            Enterprise software engineers, AI specialists and technology strategists — built around a single belief:
            that Australian businesses deserve world-class technology partners who understand enterprise as deeply as they understand code.
          </p>
        </div>
        <div class="hero-stats-row reveal stagger-2">
          <div class="hs">
            <span class="hs-num">150+</span>
            <span class="hs-lbl">Projects Delivered</span>
          </div>
          <div class="hs">
            <span class="hs-num">8+</span>
            <span class="hs-lbl">Years Experience</span>
          </div>
          <div class="hs">
            <span class="hs-num">100%</span>
            <span class="hs-lbl">Australian Team</span>
          </div>
          <div class="hs">
            <span class="hs-num">98%</span>
            <span class="hs-lbl">Client Retention</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Story -->
    <section class="story-section">
      <div class="story-inner">
        <div class="story-grid">
          <div class="reveal-left">
            <span class="section-label">Our Story</span>
            <h2 class="section-heading">Why We Built All Webbed Labs</h2>
            <p>All Webbed Labs is the enterprise software division of <a href="https://allwebbedup.com.au" target="_blank" rel="noopener noreferrer">All Webbed Up</a> — an Australian digital agency with a decade of experience delivering technology for clients across every industry.</p>
            <p>We created Labs to focus specifically on what large organisations need: enterprise security standards, deep integration expertise, complex architecture decisions and engineering teams who've seen what production systems at scale actually require.</p>
            <p>Today we work with some of Australia's most demanding organisations — delivering software that processes millions of transactions, serves tens of thousands of users and runs business-critical operations around the clock. Our clients trust us because we operate like a senior part of their team, not an external vendor.</p>
            <!-- TODO: Add the real founding story, key milestones, client wins and growth narrative -->
          </div>
          <div class="story-right reveal-right stagger-2">
            <div class="story-card">
              <div class="story-year">Founded</div>
              <div class="story-val">2016</div><!-- TODO: Update with real founding year -->
            </div>
            <div class="story-card">
              <div class="story-year">Projects</div>
              <div class="story-val">150+</div>
            </div>
            <div class="story-card">
              <div class="story-year">Engineers</div>
              <div class="story-val">20+</div><!-- TODO: Update headcount -->
            </div>
            <div class="story-card">
              <div class="story-year">Industries</div>
              <div class="story-val">12+</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="values-section">
      <div class="values-inner">
        <div class="reveal">
          <span class="section-label">Our Values</span>
          <h2 class="section-heading">What Drives Everything We Do</h2>
          <p class="section-subheading">Not wall decorations — these are the criteria by which we hire, the standards by which we deliver and the promises we keep to every client.</p>
        </div>
        <div class="values-grid">
          {values.map((v, i) => (
            <div class={`value-card reveal stagger-${i + 1}`}>
              <div class="value-icon" set:html={v.icon} />
              <h3>{v.title}</h3>
              <p>{v.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Culture section -->
    <section class="culture-section">
      <div class="culture-inner">
        <div class="culture-grid">
          <div class="reveal-left">
            <span class="section-label">Our Culture</span>
            <h2 class="section-heading">How We Work</h2>
            <p>All Webbed Labs operates as a flat, senior-heavy team. We don't have account managers who sit between you and the engineers. You talk directly to the people building your product — because we believe that directness produces better outcomes.</p>
            <p>Every engagement has a dedicated lead engineer and a delivery manager. Weekly status calls. Transparent project portals. Honest status reports. If something's off-track, we tell you before you need to ask.</p>
            <p>We work remotely but communicate like we're in the same room. Async by default, synchronous when it matters. We respect your timezone and expect the same in return.</p>
          </div>
          <div class="culture-cards reveal-right stagger-2">
            <div class="culture-card">
              <div class="cc-icon">🧑‍💻</div>
              <div class="cc-label">Senior-only team</div>
              <div class="cc-desc">Minimum 5 years professional experience. No juniors on client projects.</div>
            </div>
            <div class="culture-card">
              <div class="cc-icon">🔍</div>
              <div class="cc-label">Transparent delivery</div>
              <div class="cc-desc">Live project dashboards, weekly updates, no hidden scope.</div>
            </div>
            <div class="culture-card">
              <div class="cc-icon">🇦🇺</div>
              <div class="cc-label">100% Australian</div>
              <div class="cc-desc">AEST timezone, local compliance knowledge, real accountability.</div>
            </div>
            <div class="culture-card">
              <div class="cc-icon">📖</div>
              <div class="cc-label">Continuous learning</div>
              <div class="cc-desc">10% of working hours dedicated to R&D and skill development.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Technology Philosophy -->
    <section class="philosophy-section">
      <div class="philosophy-inner">
        <div class="phil-grid">
          <div class="reveal-left">
            <span class="section-label">Technology Philosophy</span>
            <h2 class="section-heading">We Choose Tools, Not Trends</h2>
            <p>Enterprise software outlives the frameworks it's built with. We choose technology based on stability, community longevity, performance at scale and the ease with which your internal team can take ownership after we deliver.</p>
            <p>We're pragmatic engineers. A proven, slightly boring technology stack beats a flashy new framework for anything business-critical. That said, we stay at the cutting edge — when something genuinely transformative arrives, we deploy it for clients quickly, with the rigour enterprise demands.</p>
            <div class="phil-principles">
              <div class="phil-p"><span>01</span> Boring technology for critical infrastructure</div>
              <div class="phil-p"><span>02</span> Modern tooling where it accelerates delivery</div>
              <div class="phil-p"><span>03</span> AI augmentation for everything repetitive</div>
              <div class="phil-p"><span>04</span> Open source first, where enterprise-grade options exist</div>
            </div>
          </div>
          <div class="phil-layers reveal-right stagger-2">
            <div class="phil-layer">
              <div class="phil-lbl">Presentation</div>
              <div class="phil-techs"><span>React</span><span>Next.js</span><span>Flutter</span><span>Swift</span></div>
            </div>
            <div class="phil-layer">
              <div class="phil-lbl">API & Logic</div>
              <div class="phil-techs"><span>Node.js</span><span>Python</span><span>FastAPI</span><span>GraphQL</span></div>
            </div>
            <div class="phil-layer">
              <div class="phil-lbl">Data</div>
              <div class="phil-techs"><span>PostgreSQL</span><span>MongoDB</span><span>Redis</span><span>Supabase</span></div>
            </div>
            <div class="phil-layer">
              <div class="phil-lbl">Infrastructure</div>
              <div class="phil-techs"><span>AWS / GCP</span><span>Docker</span><span>Kubernetes</span><span>Terraform</span></div>
            </div>
            <div class="phil-layer phil-ai">
              <div class="phil-lbl">AI Layer</div>
              <div class="phil-techs"><span>OpenAI</span><span>Claude</span><span>LangChain</span><span>Custom ML</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="team-section">
      <div class="team-inner">
        <div class="team-header reveal">
          <span class="section-label">The Team</span>
          <h2 class="section-heading">The People Behind Your Project</h2>
          <p class="section-subheading">Senior engineers, delivery specialists and AI experts. Every person on your project is experienced, accountable and committed to your success.</p>
        </div>
        <div class="team-grid">
          {team.map((member, i) => (
            <div class={`team-card reveal stagger-${Math.min(i + 1, 6)}`}>
              <div class="team-photo">
                {member.photo
                  ? <img src={member.photo} alt={member.name} loading="lazy" width="400" height="400" />
                  : <div class="team-initials">{member.initials}</div>
                }
              </div>
              <div class="team-body">
                <h3 class="team-name">{member.name}</h3>
                <div class="team-role">{member.role}</div>
                <p class="team-bio">{member.bio}</p>
                <div class="team-tags">
                  {member.specialties.map((s) => <span class="team-tag">{s}</span>)}
                </div>
                <a href={member.linkedin} class="team-li" target="_blank" rel="noopener noreferrer">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  LinkedIn
                </a>
              </div>
            </div>
          ))}
        </div>
        <div class="team-join reveal">
          <p>Our team is growing. We hire senior engineers passionate about enterprise software and honest client relationships. <a href="/careers">See open roles →</a></p>
        </div>
      </div>
    </section>

    <!-- Awards & Partners -->
    <section class="awards-section">
      <div class="awards-inner">
        <div class="awards-header reveal">
          <span class="section-label">Recognition & Partnerships</span>
          <h2 class="section-heading">Awards & Technology Partners</h2>
        </div>
        <div class="awards-grid reveal stagger-1">
          {awards.map((award) => (
            <div class="award-card">
              <!-- LOGO_PLACEHOLDER — replace with real partner/award badge image -->
              <div class="award-placeholder">
                <span>{award.name}</span>
                <div class="award-placeholder-note">LOGO_PLACEHOLDER</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Office / Location -->
    <section class="location-section">
      <div class="location-inner">
        <div class="location-grid">
          <div class="reveal-left">
            <span class="section-label">Where We Are</span>
            <h2 class="section-heading">Georges Hall, New South Wales</h2>
            <p>Our team is based in Sydney, NSW — operating across Australia and internationally, with delivery capabilities in every timezone.</p>
            <div class="location-details">
              <div class="loc-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>204 Birdwood Rd, Georges Hall NSW 2198</span>
              </div>
              <div class="loc-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.15a16 16 0 006.29 6.29l1.42-1.42a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 15.16v.76z"/></svg>
                <span>1800 714 148</span>
              </div>
              <div class="loc-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Mon–Fri, 9am–6pm AEST</span>
              </div>
              <div class="loc-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <span>labs@allwebbedup.com.au</span>
              </div>
            </div>
            <a href="/contact" class="btn-primary" style="margin-top: 1.5rem; display: inline-flex; align-items: center; gap: 0.5rem;">
              Get In Touch
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <!-- MAP_PLACEHOLDER — add Google Maps embed here -->
          <div class="map-placeholder reveal-right stagger-2">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4a6359" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <p>MAP_PLACEHOLDER</p>
            <span>Add Google Maps embed here</span>
          </div>
        </div>
      </div>
    </section>

    <TechStack />

    <!-- CTA -->
    <section class="about-cta">
      <div class="about-cta-inner">
        <div class="reveal" style="text-align: center; max-width: 760px; margin: 0 auto;">
          <span class="section-label">Work With Us</span>
          <h2 class="section-heading">Two Ways to Engage</h2>
          <div class="engage-grid">
            <div class="engage-card">
              <div class="engage-icon">🤝</div>
              <h3>Work With Us On a Project</h3>
              <p>Bring us a brief — defined or exploratory — and let's build something exceptional together.</p>
              <a href="/contact" class="btn-primary">Book a Call</a>
            </div>
            <div class="engage-card">
              <div class="engage-icon">💼</div>
              <h3>Join Our Team</h3>
              <p>We're always looking for senior engineers who care deeply about quality and client outcomes.</p>
              <a href="/careers" class="btn-outline">See Open Roles</a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .about-hero {
    padding: 10rem 0 6rem;
    background: #0a0f0e;
    position: relative;
    overflow: hidden;
  }
  .about-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 60% 30%, rgba(13,147,115,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .about-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }
  .about-title {
    font-family: 'Sora', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    color: white;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    max-width: 700px;
  }
  .about-lead {
    font-family: 'Sora', sans-serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: #cde0da;
    max-width: 720px;
    line-height: 1.55;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
    padding: 1rem 1.25rem;
    border-left: 2px solid #0d9373;
    background: rgba(13,147,115,0.05);
    border-radius: 0 10px 10px 0;
  }
  .about-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    color: #8aa09a;
    max-width: 640px;
    line-height: 1.7;
    margin-bottom: 3rem;
  }
  .hero-stats-row {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .hs {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .hs-num {
    font-family: 'Sora', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: #0d9373;
    letter-spacing: -0.04em;
  }
  .hs-lbl {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
  }

  /* Story */
  .story-section { padding: 7rem 0; background: #0f1614; }
  .story-inner { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
  .story-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
  .story-section p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: #4a6359;
    line-height: 1.75;
    margin: 0 0 1.25rem;
  }
  .story-section p a { color: #0d9373; text-decoration: none; }
  .story-right { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 4.5rem; }
  .story-card {
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
  }
  .story-year { font-family: 'DM Sans', sans-serif; font-size: 0.75rem; font-weight: 600; color: #4a6359; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.5rem; }
  .story-val { font-family: 'Sora', sans-serif; font-size: 2rem; font-weight: 800; color: #0d9373; letter-spacing: -0.04em; }

  /* Values */
  .values-section { padding: 7rem 0; background: #0a0f0e; }
  .values-inner { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
  .values-inner .section-subheading { margin-bottom: 3rem; }
  .values-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .value-card {
