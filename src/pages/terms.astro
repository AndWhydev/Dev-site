---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Terms of Service, All Webbed Labs"
  description="All Webbed Labs terms of service and conditions of use."
  noindex={true}
>
  <Header />
  <main>
    <section class="policy-section">
      <div class="policy-inner">
        <div class="policy-header reveal">
          <span class="section-label">Legal</span>
          <h1>Terms of Service</h1>
          <p class="policy-meta">Last updated: January 2026, TODO: Replace with legally reviewed terms</p>
        </div>
        <div class="policy-content reveal stagger-1">
          <div class="policy-notice">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            <p><strong>PLACEHOLDER CONTENT:</strong> These terms must be replaced with a legally reviewed document before the site goes live. Engage an Australian commercial lawyer to draft compliant terms of service.</p>
          </div>
          <h2>1. Acceptance of Terms</h2>
          <p>By accessing the All Webbed Labs website, you agree to be bound by these Terms of Service and all applicable laws and regulations.</p>
          <h2>2. Use of Services</h2>
          <p>Our services are provided for legitimate business purposes only. You agree not to use our services for any unlawful purpose.</p>
          <h2>3. Intellectual Property</h2>
          <p>All content on this website is the property of AW Labs Pty Ltd (trading as All Webbed Labs) unless otherwise stated. Upon project completion, full IP ownership is transferred to the client as agreed in our engagement contracts.</p>
          <h2>4. Limitation of Liability</h2>
          <p>To the extent permitted by Australian law, AW Labs Pty Ltd shall not be liable for any indirect, incidental or consequential damages.</p>
          <h2>5. Governing Law</h2>
          <p>These terms are governed by the laws of Queensland, Australia.</p>
          <h2>6. Contact</h2>
          <p>Legal enquiries: <a href="mailto:legal@allwebbedup.com.au">legal@allwebbedup.com.au</a></p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .policy-section { padding: 9rem 0 6rem; background: #0a0f0e; min-height: 80vh; }
  .policy-inner { max-width: 800px; margin: 0 auto; padding: 0 2rem; }
  .policy-header { margin-bottom: 3rem; }
  .policy-header h1 { font-family: 'Sora', sans-serif; font-size: 2.5rem; font-weight: 800; color: white; margin: 0.75rem 0 0.5rem; }
  .policy-meta { font-family: 'DM Sans', sans-serif; font-size: 0.875rem; color: #4a6359; margin: 0; }
  .policy-content h2 { font-family: 'Sora', sans-serif; font-size: 1.25rem; font-weight: 700; color: white; margin: 2rem 0 0.75rem; }
  .policy-content p { font-family: 'DM Sans', sans-serif; font-size: 0.9375rem; color: #4a6359; line-height: 1.75; margin: 0 0 1rem; }
  .policy-content a { color: #0d9373; text-decoration: none; }
  .policy-notice {
    display: flex;
    gap: 0.875rem;
    background: rgba(239,68,68,0.06);
    border: 1px solid rgba(239,68,68,0.2);
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 2.5rem;
    align-items: flex-start;
  }
  .policy-notice svg { flex-shrink: 0; color: #f87171; margin-top: 2px; }
  .policy-notice p { color: #f87171; margin: 0; font-size: 0.875rem; line-height: 1.5; }
</style>
