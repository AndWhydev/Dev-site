---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';

/**
 * R&D Tax Incentive page — structural differentiator vs offshore agencies.
 * The page is careful: every figure cited is a published AusIndustry / ATO
 * rate (not an AWL claim), and the bottom of the page tells the reader to
 * consult a registered R&D tax agent. We are software people, not tax
 * agents. What we *can* truthfully claim is how we structure project
 * documentation so the eventual claim is defensible.
 */

const docs = [
  {
    title: 'Technical uncertainty register',
    body: 'For each work package, we document the technical question we were trying to answer, why the answer was not obvious from existing knowledge or commercial off-the-shelf solutions, and the experimental path we took.',
  },
  {
    title: 'Experiment logs',
    body: 'Branch-level evidence of the hypothesis-test-result loop: what we tried, what happened, what we learnt. Git history is the spine; ADRs (architecture decision records) are the flesh.',
  },
  {
    title: 'Time and effort allocation',
    body: 'Engineer time tracked per work package so the eligible vs ineligible split is computable, not estimated.',
  },
  {
    title: 'Resource and expenditure summary',
    body: 'Cleanly separated invoices that map onto the eligible activity categories — so your tax agent does not spend $5k reconstructing it from emails.',
  },
];

const ineligibles = [
  'Pure UI restyles with no underlying technical uncertainty',
  'Integration of well-documented third-party APIs where the path is obvious',
  'Bug fixes, maintenance and routine deployment work',
  'Market research, sales, marketing and routine business analysis',
  'Work conducted outside Australia (overseas activity needs a separate application)',
];

const eligibles = [
  'Building a novel system architecture where the existing literature does not give a known-good answer',
  'Algorithm or model development where the result cannot be predicted in advance',
  'Performance, scale or reliability work where the outcome requires experimentation to confirm',
  'Integration patterns where the technical path involves genuine trial-and-error',
  'AI/ML work where the model behaviour is itself the experiment',
];
---

<Layout
  title="R&D Tax Incentive for Software Builds — All Webbed Labs"
  description="The Australian R&D Tax Incentive can return a substantial portion of eligible software development spend. How it works, what qualifies, and how we structure projects so your claim is defensible."
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="rnd-hero">
      <div class="rnd-hero-inner">
        <div class="reveal">
          <span class="section-label">R&amp;D Tax Incentive</span>
          <h1 class="rnd-title">
            A structural reason to build in Australia.
          </h1>
          <p class="rnd-lead">
            The Australian R&amp;D Tax Incentive (RDTI) — administered jointly by AusIndustry and the ATO — can return a meaningful portion of eligible software development expenditure to your business. This is a benefit you do not have when you commission a build offshore.
          </p>
          <p class="rnd-sub">
            We are software engineers, not tax agents. What follows is a plain-English orientation; the rates and rules below are published by the Australian Government and your eventual claim should be lodged by a registered R&amp;D tax agent.
          </p>
        </div>
      </div>
    </section>

    <!-- The rates -->
    <section class="rnd-rates">
      <div class="rnd-rates-inner">
        <div class="reveal" style="max-width: 760px;">
          <span class="section-label">The rates, as published</span>
          <h2 class="section-heading">What the program currently returns.</h2>
          <p class="section-subheading">
            Source: <a href="https://business.gov.au/grants-and-programs/research-and-development-tax-incentive" target="_blank" rel="noopener noreferrer">business.gov.au</a> and the ATO. We cite these — we do not set them.
          </p>
        </div>

        <div class="rates-grid">
          <div class="rate-card reveal">
            <div class="rate-card-tag">Aggregated turnover &lt; $20M</div>
            <div class="rate-card-val">43.5%</div>
            <div class="rate-card-desc">
              <strong>Refundable</strong> tax offset on eligible R&amp;D expenditure. Refundable means it can be paid as cash where the offset exceeds the company's tax liability — particularly relevant for pre-revenue startups.
            </div>
          </div>
          <div class="rate-card reveal">
            <div class="rate-card-tag">Aggregated turnover ≥ $20M</div>
            <div class="rate-card-val">38.5% +</div>
            <div class="rate-card-desc">
              <strong>Non-refundable</strong> base rate, with a premium tier for higher R&amp;D intensity. The effective benefit depends on the company's tax rate and the intensity of R&amp;D spend relative to total expenditure.
            </div>
          </div>
        </div>

        <p class="rates-note">
          Rates current as published by AusIndustry / ATO. Eligibility, registration and claim mechanics change from year to year — always verify with a registered R&amp;D tax agent before relying on a number.
        </p>
      </div>
    </section>

    <!-- Eligible vs ineligible -->
    <section class="rnd-eligibility">
      <div class="rnd-eligibility-inner">
        <div class="reveal" style="max-width: 760px;">
          <span class="section-label">What typically qualifies</span>
          <h2 class="section-heading">Eligibility, in software terms.</h2>
          <p class="section-subheading">
            The RDTI tests for "core" and "supporting" R&amp;D activities. The legal definitions are precise — what follows is the engineering shape of what tends to qualify and what tends not to.
          </p>
        </div>

        <div class="elig-grid">
          <div class="elig-col reveal-left">
            <div class="elig-col-head elig-col-head--yes">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Tends to qualify</span>
            </div>
            <ul>
              {eligibles.map((e) => <li>{e}</li>)}
            </ul>
          </div>
          <div class="elig-col reveal-right">
            <div class="elig-col-head elig-col-head--no">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              <span>Tends not to qualify</span>
            </div>
            <ul>
              {ineligibles.map((i) => <li>{i}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- How we structure documentation -->
    <section class="rnd-docs">
      <div class="rnd-docs-inner">
        <div class="reveal" style="max-width: 760px;">
          <span class="section-label">How we help — the truthful version</span>
          <h2 class="section-heading">Project artefacts your tax agent can actually use.</h2>
          <p class="section-subheading">
            We will not file a claim for you — that is your tax agent's job. What we can do is structure the project documentation so the claim is defensible, the contemporaneous evidence is there, and the eligible vs ineligible split is computable rather than estimated.
          </p>
        </div>

        <div class="docs-list">
          {docs.map((d) => (
            <article class="doc-card reveal">
              <h3>{d.title}</h3>
              <p>{d.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- The offshore comparison -->
    <section class="rnd-compare">
      <div class="rnd-compare-inner">
        <div class="reveal" style="max-width: 760px;">
          <span class="section-label">Why this matters</span>
          <h2 class="section-heading">The structural argument for building in Australia.</h2>
        </div>

        <div class="compare-grid">
          <div class="compare-card compare-card--au reveal-left">
            <div class="compare-card-flag">🇦🇺</div>
            <div class="compare-card-title">AU-conducted build</div>
            <ul>
              <li>R&amp;D Tax Incentive eligibility for the Australian-conducted portion</li>
              <li>Australian Privacy Principles compliance designed in, not bolted on</li>
              <li>Data sovereignty by default — Australian hosting region</li>
              <li>AEST working hours, no overnight queue</li>
              <li>Australian legal recourse if something goes wrong</li>
            </ul>
          </div>
          <div class="compare-card compare-card--off reveal-right">
            <div class="compare-card-flag">🌐</div>
            <div class="compare-card-title">Pure offshore build</div>
            <ul>
              <li>No access to the AU R&amp;D Tax Incentive on overseas-conducted work</li>
              <li>Privacy / sovereignty obligations harder to evidence and defend</li>
              <li>Cross-border data flow disclosures and contracts required</li>
              <li>Timezone lag — multiple business days per round-trip on tricky questions</li>
              <li>Limited legal recourse if delivery or quality falls over</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Disclaimer -->
    <section class="rnd-disclaimer">
      <div class="rnd-disclaimer-inner">
        <div class="reveal">
          <p>
            <strong>Important.</strong> This page is general information about a public Australian Government program. It is not tax advice. It is not financial advice. Eligibility for the R&amp;D Tax Incentive depends on the specific facts of your business, the activities you conduct and how those activities are documented. Before relying on anything here, speak to a registered R&amp;D tax agent. We can refer you to firms we have worked with — that is the limit of what we, as software engineers, are equipped to do on this topic.
          </p>
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>

<style>
  /* Hero */
  .rnd-hero {
    padding: 10rem 0 5rem;
    background: #0a0f0e;
    position: relative;
    overflow: hidden;
  }
  .rnd-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 60% 30%, rgba(13,147,115,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .rnd-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }
  .rnd-title {
    font-family: 'Sora', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    color: white;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
    max-width: 760px;
  }
  .rnd-lead {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    color: #cde0da;
    line-height: 1.7;
    max-width: 760px;
    margin: 0 0 1.25rem;
  }
  .rnd-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #8aa09a;
    line-height: 1.65;
    max-width: 760px;
    margin: 0;
    font-style: italic;
  }

  /* Sections */
  .rnd-rates, .rnd-eligibility, .rnd-docs, .rnd-compare, .rnd-disclaimer {
    padding: 6.5rem 0;
  }
  .rnd-rates { background: #0f1614; }
  .rnd-eligibility { background: #0a0f0e; }
  .rnd-docs { background: #0f1614; }
  .rnd-compare { background: #0a0f0e; }
  .rnd-disclaimer { background: #0f1614; padding: 4.5rem 0; }

  .rnd-rates-inner, .rnd-eligibility-inner, .rnd-docs-inner, .rnd-compare-inner, .rnd-disclaimer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Rates */
  .rates-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .rate-card {
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 18px;
    padding: 2.25rem 2.25rem;
    transition: border-color 0.3s ease;
  }
  .rate-card:hover { border-color: rgba(13,147,115,0.3); }
  .rate-card-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0d9373;
    margin-bottom: 1rem;
  }
  .rate-card-val {
    font-family: 'Sora', sans-serif;
    font-size: clamp(3rem, 5vw, 4.25rem);
    font-weight: 800;
    color: white;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 1.25rem;
  }
  .rate-card-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #8aa09a;
    line-height: 1.65;
    margin: 0;
  }
  .rate-card-desc strong { color: #cde0da; font-weight: 700; }

  .rates-note {
    margin: 2rem 0 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
    font-style: italic;
    line-height: 1.6;
  }

  .rnd-rates a {
    color: #0d9373;
    text-decoration: none;
    border-bottom: 1px solid rgba(13,147,115,0.4);
  }
  .rnd-rates a:hover { border-color: #0d9373; }

  /* Eligibility */
  .elig-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .elig-col {
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 14px;
    padding: 1.75rem 2rem;
  }
  .elig-col-head {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    padding-bottom: 0.875rem;
    border-bottom: 1px solid #1e2d28;
  }
  .elig-col-head--yes { color: #0d9373; }
  .elig-col-head--no { color: #c8704a; }
  .elig-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .elig-col li {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #8aa09a;
    line-height: 1.6;
    padding-left: 1.125rem;
    position: relative;
  }
  .elig-col--yes li::before, .elig-col li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    background: #4a6359;
    border-radius: 50%;
  }

  /* Docs */
  .docs-list {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .doc-card {
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 14px;
    padding: 1.75rem 2rem;
    transition: border-color 0.3s ease;
  }
  .doc-card:hover { border-color: rgba(13,147,115,0.3); }
  .doc-card h3 {
    font-family: 'Sora', sans-serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: white;
    margin: 0 0 0.75rem;
  }
  .doc-card p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #8aa09a;
    line-height: 1.65;
    margin: 0;
  }

  /* Compare */
  .compare-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .compare-card {
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 18px;
    padding: 2rem 2.25rem;
  }
  .compare-card--au { border-color: rgba(13,147,115,0.3); background: linear-gradient(180deg, rgba(13,147,115,0.04), #0f1614 60%); }
  .compare-card-flag {
    font-size: 2rem;
    margin-bottom: 0.875rem;
  }
  .compare-card-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1.25rem;
    padding-bottom: 0.875rem;
    border-bottom: 1px solid #1e2d28;
  }
  .compare-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .compare-card li {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #8aa09a;
    line-height: 1.6;
    padding-left: 1.125rem;
    position: relative;
  }
  .compare-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }
  .compare-card--au li::before { background: #0d9373; }
  .compare-card--off li::before { background: #4a6359; }

  /* Disclaimer */
  .rnd-disclaimer p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #8aa09a;
    line-height: 1.75;
    margin: 0;
    max-width: 880px;
    background: rgba(13,147,115,0.04);
    border: 1px solid rgba(13,147,115,0.15);
    border-left: 3px solid #0d9373;
    padding: 1.5rem 1.75rem;
    border-radius: 0 12px 12px 0;
  }
  .rnd-disclaimer p strong { color: white; font-weight: 700; }

  /* Responsive */
  @media (max-width: 1024px) {
    .rates-grid, .elig-grid, .docs-list, .compare-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .rnd-hero { padding: 8rem 0 4rem; }
    .rnd-rates, .rnd-eligibility, .rnd-docs, .rnd-compare { padding: 4rem 0; }
    .rnd-disclaimer { padding: 3rem 0; }
    .rnd-rates-inner, .rnd-eligibility-inner, .rnd-docs-inner, .rnd-compare-inner, .rnd-disclaimer-inner { padding: 0 1.25rem; }
    .rate-card, .elig-col, .doc-card, .compare-card { padding: 1.5rem 1.5rem; }
  }
</style>
