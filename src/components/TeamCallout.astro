---
/**
 * Compact "meet the team" teaser for the home page. Stacked avatars + one-line
 * positioning + CTA into /about#team where the full team grid lives.
 *
 * Photos here are the same files served from /public/team/. Jack uses the
 * stylised silhouette (no real face — same treatment as the about-page card).
 */

type Avatar = {
  name: string;
  role: string;
  photo?: string;
  silhouette?: boolean;
  initials: string;
  accent: 'green' | 'violet' | 'amber';
};

const avatars: Avatar[] = [
  { name: 'Andy Taleb', role: 'Founder & Developer', photo: '/team/andy-taleb.webp', initials: 'AT', accent: 'green' },
  { name: 'Jack Stacey', role: 'Senior Developer', silhouette: true, initials: 'JS', accent: 'violet' },
  { name: 'Hyacinth Soriano', role: 'Brand & Design', photo: '/team/hyacinth-soriano.png', initials: 'HS', accent: 'amber' },
  { name: 'Jared Bachman', role: 'Servers & IT', photo: '/team/jared-bachman.png', initials: 'JB', accent: 'green' },
  { name: 'Troy Schoenfisch', role: 'R&D Tax', photo: '/team/troy-schoenfisch.png', initials: 'TS', accent: 'violet' },
  { name: 'Elena Nelyubina', role: 'Commercial & IT Law', photo: '/team/elena-nelyubina.png', initials: 'EN', accent: 'amber' },
];
---

<section class="team-callout" aria-label="Meet the All Webbed Labs team">
  <div class="tc-inner">
    <div class="tc-stack reveal" aria-hidden="true">
      {avatars.map((a, i) => (
        <div class={`tc-avatar accent-${a.accent}`} style={`--i: ${i}`}>
          {a.photo ? (
            <img src={a.photo} alt="" loading="lazy" />
          ) : a.silhouette ? (
            <svg viewBox="0 0 64 64" width="100%" height="100%" aria-hidden="true">
              <defs>
                <linearGradient id={`tc-sil-${a.initials}`} x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#b9a4ff"/>
                  <stop offset="100%" stop-color="#5b3fbf"/>
                </linearGradient>
              </defs>
              <g fill={`url(#tc-sil-${a.initials})`}>
                <circle cx="32" cy="24" r="10"/>
                <path d="M10,64 C10,48 19,40 32,40 C45,40 54,48 54,64 Z"/>
              </g>
            </svg>
          ) : (
            <span class="tc-initials">{a.initials}</span>
          )}
        </div>
      ))}
    </div>

    <div class="tc-text reveal">
      <span class="section-label">The team</span>
      <h2 class="tc-heading">Real people. Named partners. No stock photos.</h2>
      <p class="tc-sub">
        A founder, a senior engineer and a brand lead — backed by named specialists for tax, IP and on-site infrastructure. Every face is a person you can verify, and the one face we don't show is a real engineer who keeps a low profile by choice.
      </p>
      <a href="/about#team" class="tc-cta">
        Meet the team
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .team-callout {
    background: #0a0f0e;
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
    border-top: 1px solid #1e2d28;
    border-bottom: 1px solid #1e2d28;
  }
  .team-callout::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(13,147,115,0.08) 0%, transparent 65%);
    pointer-events: none;
  }

  .tc-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    align-items: center;
  }

  /* ── Avatar stack ─────────────────────────── */
  .tc-stack {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    /* Negative margin per item creates the overlap */
  }
  .tc-avatar {
    width: 78px;
    height: 78px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: linear-gradient(155deg, #1a2620 0%, #0a0f0e 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid #0a0f0e;
    box-shadow: 0 8px 24px rgba(0,0,0,0.45);
    transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
  }
  .tc-avatar + .tc-avatar { margin-left: -22px; }
  .tc-avatar:hover { transform: translateY(-4px) scale(1.06); z-index: 5; }

  .tc-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .tc-avatar svg { display: block; }
  .tc-initials {
    font-family: 'Sora', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: rgba(255,255,255,0.85);
  }

  .tc-avatar.accent-green   { box-shadow: 0 0 0 2px rgba(13,147,115,0.5), 0 8px 24px rgba(0,0,0,0.45); }
  .tc-avatar.accent-violet  { box-shadow: 0 0 0 2px rgba(139,92,246,0.5), 0 8px 24px rgba(0,0,0,0.45); }
  .tc-avatar.accent-amber   { box-shadow: 0 0 0 2px rgba(245,158,11,0.5), 0 8px 24px rgba(0,0,0,0.45); }

  /* ── Text panel ──────────────────────────── */
  .tc-text {
    min-width: 0;
  }
  .tc-heading {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.625rem, 3.2vw, 2.25rem);
    font-weight: 700;
    color: white;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0.625rem 0 0.875rem;
    max-width: 24ch;
  }
  .tc-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    color: #8aa09a;
    margin: 0 0 1.5rem;
    max-width: 56ch;
  }
  .tc-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Sora', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, #0d9373 0%, #0a7559 100%);
    border-radius: 999px;
    padding: 0.85rem 1.4rem;
    text-decoration: none;
    min-height: 44px;
    box-shadow: 0 10px 28px rgba(13,147,115,0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease, gap 0.2s ease;
  }
  .tc-cta:hover {
    transform: translateY(-1px);
    gap: 0.75rem;
    box-shadow: 0 14px 34px rgba(13,147,115,0.42);
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 900px) {
    .tc-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }
    .tc-stack { justify-self: center; }
    .tc-heading { margin-left: auto; margin-right: auto; }
    .tc-sub { margin-left: auto; margin-right: auto; }
  }
  @media (max-width: 560px) {
    .team-callout { padding: 4.5rem 0; }
    .tc-inner { padding: 0 1.25rem; }
    .tc-avatar { width: 60px; height: 60px; border-width: 2.5px; }
    .tc-avatar + .tc-avatar { margin-left: -16px; }
    .tc-initials { font-size: 0.9375rem; }
  }
</style>
