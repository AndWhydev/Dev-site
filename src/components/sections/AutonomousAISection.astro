---
/**
 * Sovereign AI style full-bleed section — positioned after the hero on the
 * homepage. Dark circuit-board aesthetic with a slowly rotating decorative
 * rings element in the top-right and a bottom-aligned content block.
 *
 * Pure CSS background (gradient base + animated grid overlay + radial accent).
 * No external image required.
 *
 * Entrance animations are driven by an IntersectionObserver inline script and
 * respect prefers-reduced-motion.
 */
---

<section
  class="autonomous-ai"
  id="autonomous-ai"
  aria-labelledby="autonomous-ai-heading"
>
  <div class="autonomous-ai__grid" aria-hidden="true"></div>
  <div class="autonomous-ai__accent" aria-hidden="true"></div>

  <div class="autonomous-ai__rings" aria-hidden="true">
    <span class="autonomous-ai__ring autonomous-ai__ring--outer"></span>
    <span class="autonomous-ai__ring autonomous-ai__ring--inner"></span>
  </div>

  <div class="autonomous-ai__inner">
    <div class="autonomous-ai__content">
      <div class="autonomous-ai__left" data-anim="left">
        <p class="autonomous-ai__eyebrow">Inside our delivery pipeline</p>
        <h2 id="autonomous-ai-heading" class="autonomous-ai__heading">
          Multi-agent build pipeline. Senior engineers in review.
        </h2>
      </div>

      <div class="autonomous-ai__right" data-anim="right">
        <p class="autonomous-ai__copy">
          Overseer is our internal orchestration layer — it dispatches parallel
          Claude workers to deliver vertical slices, runs every change through
          our quality gate matrix (Hallmark design, Playwright visual,
          type-check, security scan), and holds at the deploy gate until a
          senior engineer signs off. It compresses delivery time without
          compressing standards.
        </p>
        <a class="autonomous-ai__cta" href="/methodology">See the methodology</a>
      </div>
    </div>

    <ul class="autonomous-ai__pills" data-anim="pills">
      <li>Multi-agent dispatch</li>
      <li>Quality gates per commit</li>
      <li>Human review gate</li>
      <li>Audit-logged pipeline</li>
      <li>Source in your repository</li>
      <li>Australian-owned IP</li>
    </ul>
  </div>
</section>

<style>
  .autonomous-ai {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: linear-gradient(135deg, #0a0a0c 0%, #051a14 50%, #0a0a0c 100%);
    isolation: isolate;
    color: #ffffff;
  }

  /* Animated circuit-board grid overlay — 1px lines on a 60px cell, drifting
     diagonally for a subtle living circuitry feel. */
  .autonomous-ai__grid {
    position: absolute;
    inset: -60px;
    z-index: 1;
    pointer-events: none;
    background-image:
      linear-gradient(to right, rgba(13, 147, 115, 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(13, 147, 115, 0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: autonomous-ai-grid-drift 24s linear infinite;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, #000 40%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, #000 40%, transparent 100%);
  }
  @keyframes autonomous-ai-grid-drift {
    0%   { background-position: 0 0, 0 0; }
    100% { background-position: 60px 60px, 60px 60px; }
  }

  /* Centred accent light — soft electric green halo */
  .autonomous-ai__accent {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: radial-gradient(
      ellipse 60% 55% at 50% 50%,
      rgba(13, 147, 115, 0.15) 0%,
      transparent 70%
    );
  }

  /* Top-right decorative concentric rings (slowly rotating) */
  .autonomous-ai__rings {
    position: absolute;
    top: -120px;
    right: -120px;
    width: 400px;
    height: 400px;
    z-index: 3;
    pointer-events: none;
  }
  .autonomous-ai__ring {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }
  .autonomous-ai__ring--outer {
    width: 400px;
    height: 400px;
    border: 1px solid rgba(13, 147, 115, 0.10);
    animation: autonomous-ai-spin 30s linear infinite;
  }
  .autonomous-ai__ring--inner {
    width: 240px;
    height: 240px;
    border: 1px solid rgba(13, 147, 115, 0.10);
    animation: autonomous-ai-spin 30s linear infinite reverse;
  }
  .autonomous-ai__ring--outer::before,
  .autonomous-ai__ring--inner::before {
    content: '';
    position: absolute;
    top: -3px;
    left: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(13, 147, 115, 0.55);
    transform: translateX(-50%);
    box-shadow: 0 0 12px rgba(13, 147, 115, 0.55);
  }
  @keyframes autonomous-ai-spin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }

  .autonomous-ai__inner {
    position: relative;
    z-index: 10;
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 2rem 5rem;
    display: flex;
    flex-direction: column;
  }

  .autonomous-ai__content {
    display: grid;
    grid-template-columns: minmax(0, 40fr) minmax(0, 35fr);
    gap: 6vw;
    align-items: end;
    margin-bottom: 3.5rem;
  }

  /* Animatable wrappers — start hidden, IntersectionObserver flips
     .is-visible to play. */
  .autonomous-ai [data-anim] {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .autonomous-ai.is-visible [data-anim="left"] {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0ms;
  }
  .autonomous-ai.is-visible [data-anim="right"] {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 150ms;
  }
  .autonomous-ai.is-visible [data-anim="pills"] {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 300ms;
  }

  .autonomous-ai__eyebrow {
    margin: 0 0 18px;
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #0d9373;
  }

  .autonomous-ai__heading {
    margin: 0;
    font-family: 'Sora', sans-serif;
    font-size: 56px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
    color: #ffffff;
    max-width: 14ch;
  }

  .autonomous-ai__copy {
    margin: 0 0 28px;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.75);
  }

  .autonomous-ai__cta {
    display: inline-block;
    padding: 14px 28px;
    border-radius: 100px;
    background: #ffffff;
    color: #0a0a0c;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  }
  .autonomous-ai__cta:hover {
    transform: translateY(-2px);
    background: #f4fffb;
    box-shadow: 0 14px 30px -10px rgba(13, 147, 115, 0.45);
  }
  .autonomous-ai__cta:focus-visible {
    outline: 2px solid #0d9373;
    outline-offset: 3px;
  }

  .autonomous-ai__pills {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 12px;
  }
  .autonomous-ai__pills li {
    border: 0.8px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    padding: 7px 14px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.6);
    background: transparent;
    white-space: nowrap;
  }

  @media (max-width: 960px) {
    .autonomous-ai__content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      margin-bottom: 2.5rem;
    }
    .autonomous-ai__heading { font-size: 42px; max-width: none; }
    .autonomous-ai__rings { width: 280px; height: 280px; top: -80px; right: -80px; }
    .autonomous-ai__ring--outer { width: 280px; height: 280px; }
    .autonomous-ai__ring--inner { width: 170px; height: 170px; }
  }

  @media (max-width: 640px) {
    .autonomous-ai__inner {
      padding: 48px 24px;
    }
    .autonomous-ai__heading { font-size: 36px; }
    .autonomous-ai__copy { font-size: 15px; }
    .autonomous-ai__rings { opacity: 0.55; }
  }

  @media (prefers-reduced-motion: reduce) {
    .autonomous-ai__grid,
    .autonomous-ai__ring--outer,
    .autonomous-ai__ring--inner { animation: none; }
    .autonomous-ai [data-anim] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  /* Entrance — IntersectionObserver flips the section into .is-visible the
     first time it scrolls into view, which triggers the staggered transitions
     on the [data-anim] children. Re-bound after each Astro view transition. */
  function bindAutonomousAI() {
    const section = document.getElementById('autonomous-ai');
    if (!section) return;
    if (section.dataset.bound === '1') return;
    section.dataset.bound = '1';

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      section.classList.add('is-visible');
      return;
    }

    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          section.classList.add('is-visible');
          io.disconnect();
        }
      });
    }, { threshold: 0.2 });
    io.observe(section);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindAutonomousAI);
  } else {
    bindAutonomousAI();
  }
  document.addEventListener('astro:after-swap', () => {
    const section = document.getElementById('autonomous-ai');
    if (section) section.dataset.bound = '';
    bindAutonomousAI();
  });
</script>
