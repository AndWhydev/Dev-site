---
/**
 * Credibility strip — concrete provable facts, not client logos.
 * Lives directly under the hero. Every item here is verifiable from public
 * record (ASIC, ABR) or from the engagement contract itself. Nothing here
 * makes a claim about *who* we work with — only about *how* we work.
 */
/**
 * Verifiable items get a `href` — the value becomes a real link that opens
 * the independent source of truth (ABR, Google Maps, internal NDA PDF).
 * Items without `href` render as plain text. Anything we make clickable
 * must be checkable in one click; we will not link to our own marketing.
 */
const items = [
  {
    label: 'ABN',
    value: '32 698 684 105',
    detail: 'AW Labs Pty Ltd · trading as All Webbed Labs',
    href: 'https://abr.business.gov.au/ABN/View?id=32698684105',
    hrefLabel: 'Verify on the Australian Business Register',
  },
  {
    label: 'Registered',
    value: 'Sydney, NSW',
    detail: '1 Ramsay Rd, Five Dock 2046',
    href: 'https://www.google.com/maps/search/?api=1&query=1+Ramsay+Rd+Five+Dock+NSW+2046',
    hrefLabel: 'Open the registered office on Google Maps',
  },
  {
    label: 'Delivery',
    value: 'AEST hours',
    detail: 'No offshore handoffs, no timezone lag',
  },
  {
    label: 'IP transfer',
    value: 'Full, on completion',
    detail: 'Source code, schemas, designs — yours',
  },
  {
    label: 'Engagement',
    value: 'NDA-first',
    detail: 'Mutual NDA template available before scoping',
    href: '/docs/mutual-nda.pdf',
    hrefLabel: 'Download the mutual NDA template',
  },
  {
    label: 'Tax position',
    value: 'R&D eligible',
    detail: 'Australian-conducted build qualifies for the AU R&D Tax Incentive',
  },
];
---

<section class="trust-bar" aria-label="About this company">
  <div class="trust-bar-inner">
    <div class="trust-bar-grid">
      {items.map((item) => (
        <div class="trust-item">
          <div class="trust-item-label">{item.label}</div>
          <div class="trust-item-value">
            {item.href ? (
              <a
                href={item.href}
                class="trust-item-link"
                target={item.href.startsWith('http') ? '_blank' : undefined}
                rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                aria-label={item.hrefLabel}
              >
                {item.value}
                <svg class="trust-item-arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17l10-10M9 7h8v8"/></svg>
              </a>
            ) : (
              <>{item.value}</>
            )}
          </div>
          <div class="trust-item-detail">{item.detail}</div>
        </div>
      ))}
    </div>
    <div class="trust-bar-footer">
      <a href="/trust">See full compliance, IP and security detail
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    background: #060c0b;
    padding: 2.75rem 2rem 2.25rem;
    border-bottom: 1px solid #1e2d28;
    position: relative;
  }
  .trust-bar::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(13,147,115,0.45), transparent);
  }

  .trust-bar-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .trust-bar-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.5rem;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.25rem 0;
    border-left: 1px solid #1e2d28;
    padding-left: 1.125rem;
  }
  .trust-item:first-child {
    border-left: none;
    padding-left: 0;
  }

  .trust-item-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #4a6359;
  }

  .trust-item-value {
    font-family: 'Sora', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.005em;
    line-height: 1.25;
  }
  .trust-item-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #ffffff;
    text-decoration: none;
    border-bottom: 1px solid rgba(13,147,115,0.45);
    padding-bottom: 1px;
    transition: color 0.2s ease, border-color 0.2s ease, gap 0.2s ease;
  }
  .trust-item-link:hover {
    color: #10b88a;
    border-color: #10b88a;
    gap: 0.45rem;
  }
  .trust-item-arrow {
    color: #0d9373;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .trust-item-link:hover .trust-item-arrow { transform: translate(2px, -2px); }

  .trust-item-detail {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #4a6359;
    line-height: 1.45;
  }

  .trust-bar-footer {
    margin-top: 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid #1e2d28;
    display: flex;
    justify-content: center;
  }

  .trust-bar-footer a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #0d9373;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: gap 0.2s ease, color 0.2s ease;
  }
  .trust-bar-footer a:hover {
    gap: 0.75rem;
    color: #10b88a;
  }

  @media (max-width: 1100px) {
    .trust-bar-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem 2rem;
    }
    .trust-item {
      border-left: none;
      padding-left: 0;
    }
  }

  @media (max-width: 640px) {
    .trust-bar { padding: 2rem 1.25rem 1.75rem; }
    .trust-bar-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem 1.5rem;
    }
    .trust-item-value { font-size: 0.875rem; }
    .trust-item-detail { font-size: 0.6875rem; }
  }
</style>
