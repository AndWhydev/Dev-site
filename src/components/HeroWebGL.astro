---
/**
 * AWL — WebGL particle-network hero (Lusion-inspired).
 * Three.js point cloud + connected node graph that responds to cursor.
 * Graceful fallback to a CSS gradient mesh when WebGL is unavailable.
 * Reduced motion: single static frame (no animation loop).
 */
---

<section class="awl-hero" id="awl-hero" aria-label="All Webbed Labs hero">
  <!-- CSS gradient mesh shown until WebGL takes over (and used as fallback if WebGL fails). -->
  <div class="awl-hero__mesh" aria-hidden="true"></div>
  <canvas id="awl-hero-canvas" aria-hidden="true"></canvas>
  <!-- FIX 12 — soft accent-coloured radial glow that follows the cursor.
       Position is updated via CSS variables in the mousemove handler; pure CSS,
       no per-frame layout. Sits above the WebGL canvas with mix-blend-mode:screen
       so it brightens rather than tints. -->
  <div class="awl-hero__cursor-glow" id="awl-cursor-glow" aria-hidden="true"></div>
  <div class="awl-hero__scrim" aria-hidden="true"></div>

  <div class="awl-hero__inner">
    <div class="awl-hero__copy">
      <p class="awl-hero__eyebrow">AI-POWERED DEVELOPMENT AGENCY</p>
      <h1 id="awl-hero-heading" class="hero-heading">We don't just build software.</h1>
      <p class="awl-hero__sub">Autonomous AI systems for Australian businesses. From websites to enterprise software — built faster, operated smarter.</p>
      <div class="awl-hero__ctas">
        <a href="/methodology" class="btn-fill btn-magnetic" data-hover>How we work</a>
        <a href="/contact" class="awl-hero__link" data-hover>Book a call <span class="arrow">&rarr;</span></a>
      </div>
    </div>

    {/* Overseer pipeline mock — illustrative log of how an AWL build run
        actually executes. Deliberately generic (no client/project names) and
        labeled "example run" so a sharp reader doesn't read it as proof of a
        specific client. Decorative only. */}
    <aside class="awl-hero__terminal" aria-hidden="true">
      <div class="awl-term__head">
        <span class="awl-term__pulse"></span>
        <span class="awl-term__title">Overseer · example run</span>
        <span class="awl-term__path">awl-pipeline</span>
      </div>
      <div class="awl-term__rule"></div>
      <div class="awl-term__log">
        <div class="awl-term__line"><span class="ts">[09:14]</span> Brief received <span class="awl-term__tag">demo</span></div>
        <div class="awl-term__line"><span class="ts">[09:14]</span> Scope locked · surfaces &amp; integrations mapped</div>
        <div class="awl-term__line"><span class="ts">[09:15]</span> Workers dispatched <span class="awl-term__ok">parallel</span></div>
        <div class="awl-term__line"><span class="ts">[09:18]</span> Schema · APIs · payments wired</div>
        <div class="awl-term__line"><span class="ts">[09:22]</span> Asset pipeline · generation pass</div>
        <div class="awl-term__line"><span class="ts">[09:31]</span> Hallmark quality gate <span class="awl-term__ok">✓</span></div>
        <div class="awl-term__line"><span class="ts">[09:34]</span> Playwright visual tests <span class="awl-term__ok">green</span></div>
        <div class="awl-term__line"><span class="ts">[09:35]</span> Preview deployed · awaiting human review</div>
      </div>
      <div class="awl-term__rule"></div>
      <div class="awl-term__foot">
        <span>Pipeline: <strong>Overseer</strong></span>
        <span>Gate: <strong>Hallmark</strong></span>
        <span>Review: <strong>human</strong></span>
      </div>
    </aside>
  </div>

  <div class="awl-hero__hint" aria-hidden="true">
    <span>Scroll</span>
    <span class="down"></span>
  </div>
</section>

<style is:global>
  /* New homepage tokens (scoped to pages that include this component via :root cascade). */
  :root {
    --color-bg: #0a0a0a;
    --color-bg-raised: #111111;
    --color-surface: #1a1a1a;
    --color-border: rgba(255,255,255,0.06);
    --color-border-strong: rgba(255,255,255,0.12);
    --color-text: #ededed;
    --color-muted: #888888;
    --color-accent: #0d9373;
    --color-accent-hover: #0fb888;
    --color-accent-muted: rgba(13,147,115,0.15);
    --accent-rgb: 13,147,115;
  }
</style>

<style>
  .awl-hero {
    position: relative;
    min-height: 100svh;
    width: 100%;
    overflow: hidden;
    /* Solid fallback colour painted by the browser before any JS/WebGL runs —
       guarantees no flash of unstyled blackness even if Three.js fails to load. */
    background: #0a0f0e;
    display: flex;
    align-items: center;
    isolation: isolate;
  }

  /* CSS gradient mesh — fallback + initial paint before WebGL boots. */
  .awl-hero__mesh {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse 70% 60% at 15% 50%, rgba(13,147,115,0.22) 0%, transparent 65%),
      radial-gradient(ellipse 55% 45% at 85% 35%, rgba(13,147,115,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 80% 70% at 50% 100%, rgba(13,147,115,0.06) 0%, transparent 70%),
      #0a0a0a;
    animation: awl-mesh-drift 32s ease-in-out infinite alternate;
  }
  @keyframes awl-mesh-drift {
    0%   { background-position: 0% 50%, 100% 35%, 50% 100%; }
    100% { background-position: 8% 55%, 92% 30%, 55% 105%; }
  }

  #awl-hero-canvas {
    /* No initial opacity:0 — the canvas is transparent until WebGL paints into it,
       so the mesh underneath stays visible during init. Removing the fade avoids
       the "black screen until I move the mouse" perception. */
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    opacity: 1;
    display: block;
  }

  /* FIX 12 — cursor-following radial glow. CSS-only, driven by --x/--y variables
     set in JS. mix-blend-mode: screen so it brightens whatever is underneath. */
  .awl-hero__cursor-glow {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
    background: radial-gradient(
      circle 340px at var(--x, 50%) var(--y, 50%),
      rgba(13, 147, 115, 0.20) 0%,
      rgba(13, 147, 115, 0.10) 30%,
      transparent 70%
    );
    mix-blend-mode: screen;
  }
  .awl-hero__cursor-glow.is-live { opacity: 1; }

  /* Subtle scrim under the text so the heading stays legible over busy particle areas. */
  .awl-hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    background: linear-gradient(135deg, rgba(10,10,10,0.55) 0%, rgba(10,10,10,0.15) 45%, rgba(10,10,10,0.40) 100%);
  }

  .awl-hero__inner {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 8rem 6vw 7rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.85fr);
    align-items: center;
    gap: 5vw;
  }
  .awl-hero__copy { min-width: 0; }

  /* FIX 6 — terminal mock card. Subtle green border, faint accent glow,
     slight rotation, monospace log. Hidden under 1024px (mobile falls back
     to a single-column hero where the copy gets the full width). */
  .awl-hero__terminal {
    position: relative;
    border: 1px solid rgba(13, 147, 115, 0.35);
    background: linear-gradient(180deg, rgba(8, 14, 12, 0.92) 0%, rgba(6, 11, 10, 0.92) 100%);
    backdrop-filter: blur(14px) saturate(115%);
    -webkit-backdrop-filter: blur(14px) saturate(115%);
    border-radius: 12px;
    padding: 1.1rem 1.35rem 1.25rem;
    color: rgba(205, 224, 218, 0.92);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12.5px;
    line-height: 1.55;
    transform: rotate(-2deg);
    box-shadow:
      0 28px 70px -22px rgba(0, 0, 0, 0.85),
      0 0 60px -20px rgba(13, 147, 115, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    opacity: 0;
    transform-origin: center;
    animation: awl-term-in 1.0s 0.9s cubic-bezier(.19,1,.22,1) forwards;
    will-change: transform, opacity;
  }
  @keyframes awl-term-in {
    to { opacity: 1; transform: rotate(-2deg) translateY(0); }
  }
  .awl-hero__terminal::before {
    /* Outer glow halo */
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 13px;
    background: radial-gradient(ellipse 70% 50% at 50% 50%, rgba(13, 147, 115, 0.25), transparent 70%);
    z-index: -1;
    filter: blur(20px);
    opacity: 0.55;
  }
  .awl-term__head {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #0d9373;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .awl-term__pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #0d9373;
    box-shadow: 0 0 0 0 rgba(13, 147, 115, 0.7);
    animation: awl-term-pulse 1.6s ease-out infinite;
  }
  @keyframes awl-term-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(13, 147, 115, 0.65); }
    70%  { box-shadow: 0 0 0 10px rgba(13, 147, 115, 0); }
    100% { box-shadow: 0 0 0 0 rgba(13, 147, 115, 0); }
  }
  .awl-term__title { color: #0d9373; }
  .awl-term__path {
    margin-left: auto;
    color: rgba(205, 224, 218, 0.4);
    font-size: 11px;
  }
  .awl-term__rule {
    height: 1px;
    background: rgba(13, 147, 115, 0.18);
    margin: 0.75rem 0;
  }
  .awl-term__log {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: rgba(176, 207, 197, 0.95);
  }
  .awl-term__line {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .awl-term__line .ts {
    color: rgba(205, 224, 218, 0.45);
    margin-right: 8px;
  }
  .awl-term__ok {
    color: #20d3a3;
    font-weight: 700;
  }
  .awl-term__tag {
    display: inline-block;
    margin-left: 4px;
    padding: 1px 6px;
    border-radius: 4px;
    background: rgba(13,147,115,0.18);
    border: 1px solid rgba(13,147,115,0.35);
    color: #20d3a3;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .awl-term__foot {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    color: rgba(205, 224, 218, 0.6);
    font-size: 11.5px;
  }
  .awl-term__foot strong { color: #ffffff; font-weight: 600; }

  .awl-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 32px;
    font-family: 'Sora', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--color-accent);
    text-transform: uppercase;
  }
  .awl-hero__eyebrow::before {
    content: '';
    width: 36px;
    height: 1px;
    background: var(--color-accent);
    display: inline-block;
  }

  .hero-heading {
    font-family: 'Sora', sans-serif;
    font-size: clamp(52px, 7vw, 110px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 28px;
    max-width: 14ch;
    overflow: hidden;
  }
  .hero-heading .w {
    display: inline-block;
    overflow: hidden;
    vertical-align: top;
  }
  .hero-heading .w > span {
    display: inline-block;
    transform: translateY(110%) rotate(3deg);
    opacity: 0;
    will-change: transform, opacity;
  }
  .hero-heading.is-in .w > span {
    animation: awl-word-up 0.95s cubic-bezier(.19,1,.22,1) forwards;
  }
  @keyframes awl-word-up {
    to { transform: translateY(0) rotate(0); opacity: 1; }
  }

  .awl-hero__sub {
    /* FIX 8 — bumped from clamp(16,1.3vw,19) → clamp(20,1.6vw,22) and capped at 600px. */
    margin: 0 0 44px;
    font-family: 'Inter', 'DM Sans', system-ui, sans-serif;
    font-size: clamp(20px, 1.6vw, 22px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
    max-width: 600px;
    opacity: 0;
    transform: translateY(20px);
    animation: awl-rise 0.9s 0.55s cubic-bezier(.19,1,.22,1) forwards;
  }
  @keyframes awl-rise {
    to { opacity: 1; transform: translateY(0); }
  }

  .awl-hero__ctas {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(20px);
    animation: awl-rise 0.9s 0.75s cubic-bezier(.19,1,.22,1) forwards;
  }

  /* Primary CTA — solid filled at rest, darker fill slides in left→right on hover.
     btn-fill from ANIMATIONS.md, switched from ghost to solid as the hero's
     dominant action surface. */
  .btn-fill {
    position: relative;
    overflow: hidden;
    z-index: 0;
    display: inline-block;
    padding: 16px 40px;
    border: none;
    background: var(--color-accent);
    color: #ffffff;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 4px;
    text-decoration: none;
    cursor: pointer;
    box-shadow: 0 8px 24px -8px rgba(13, 147, 115, 0.55);
    transition: box-shadow 0.35s ease, transform 0.35s ease;
  }
  .btn-fill::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.28);
    transform: translateX(-101%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: -1;
  }
  .btn-fill:hover { box-shadow: 0 14px 32px -8px rgba(13, 147, 115, 0.75); }
  .btn-fill:hover::before { transform: translateX(0); }
  .btn-fill:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 3px;
  }

  .awl-hero__link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #ededed;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    transition: gap 0.3s ease, color 0.3s ease;
  }
  .awl-hero__link:hover { gap: 16px; color: var(--color-accent); }
  .awl-hero__link .arrow { transition: transform 0.3s ease; }
  .awl-hero__link:hover .arrow { transform: translateX(3px); }

  .awl-hero__hint {
    position: absolute;
    left: 50%;
    bottom: 34px;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: rgba(255,255,255,0.55);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .awl-hero__hint .down {
    width: 14px;
    height: 14px;
    border-right: 1.5px solid rgba(255,255,255,0.55);
    border-bottom: 1.5px solid rgba(255,255,255,0.55);
    transform: rotate(45deg);
    animation: awl-bounce 1.8s cubic-bezier(.22,.61,.36,1) infinite;
  }
  @keyframes awl-bounce {
    0%,100% { transform: rotate(45deg) translate(0,0); opacity: 0.4; }
    50%     { transform: rotate(45deg) translate(4px,4px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .awl-hero__mesh { animation: none; }
    .hero-heading.is-in .w > span,
    .awl-hero__sub,
    .awl-hero__ctas { animation-duration: 0.001s; }
    .awl-hero__hint .down { animation: none; opacity: 0.55; }
  }

  @media (max-width: 1024px) {
    /* Hide the terminal on tablet + mobile — copy collapses to a single column
       with breathing room. The hero is busy enough without it on small screens. */
    .awl-hero__inner {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .awl-hero__terminal { display: none; }
  }

  @media (max-width: 720px) {
    .awl-hero__inner { padding: 7rem 24px 6rem; }
    .awl-hero__ctas { gap: 20px; }
    /* Bring the headline down so 'software that runs itself.' wraps nicely
       on a phone instead of one giant word per line at 52px. */
    .hero-heading { font-size: clamp(44px, 11vw, 64px); max-width: 12ch; }
    .awl-hero__sub { font-size: clamp(17px, 4.4vw, 19px); max-width: 100%; }
  }

  @media (max-width: 480px) {
    /* Phone-specific tuning. Less padding, even more compact type, and
       stack the CTAs vertically so 'See our work' + 'Book a call →' each
       sit full-width — easier 44px touch targets, no accidental wraps. */
    .awl-hero { min-height: 100svh; }
    .awl-hero__inner { padding: 6rem 20px 4.5rem; }
    .awl-hero__eyebrow { font-size: 11px; letter-spacing: 0.18em; margin-bottom: 22px; }
    .awl-hero__eyebrow::before { width: 24px; }
    .hero-heading {
      font-size: clamp(38px, 12vw, 52px);
      line-height: 1.02;
      max-width: 100%;
      margin-bottom: 20px;
    }
    .awl-hero__sub {
      font-size: 16px;
      line-height: 1.55;
      max-width: 100%;
      margin-bottom: 32px;
    }
    .awl-hero__ctas {
      flex-direction: column;
      align-items: stretch;
      gap: 14px;
    }
    .btn-fill {
      display: block;
      width: 100%;
      text-align: center;
      padding: 16px 24px;
    }
    .awl-hero__link {
      justify-content: center;
      padding: 14px 0;
    }
    /* Scroll hint takes valuable bottom real estate on a phone — hide it. */
    .awl-hero__hint { display: none; }
  }
</style>

<script is:inline>
  /* Hero boot — split the heading, play intro, lazy-load + init Three.js.
     Re-runs on Astro view transitions. is:inline so Astro doesn't bundle this
     as a module — we need direct access to the global THREE.

     Three.js (~118KB) is NOT preloaded — it is injected on idle after the page
     has reached `load`, which keeps it off the critical path. The CSS gradient
     mesh underneath the canvas is the static fallback that paints first and is
     also the final state on reduced-motion, save-data, and WebGL-failure paths. */
  function awlSplitHeading() {
    const h = document.getElementById('awl-hero-heading');
    if (!h || h.dataset.split === '1') return;
    const text = h.textContent ? h.textContent.trim() : '';
    const words = text.split(/\s+/);
    h.innerHTML = words.map(w => `<span class="w"><span>${w}</span></span>`).join(' ');
    h.dataset.split = '1';
  }

  function awlPlayIntro() {
    const h = document.getElementById('awl-hero-heading');
    if (h) requestAnimationFrame(() => h.classList.add('is-in'));
    // Magnetic button(s) inside the hero.
    document.querySelectorAll('#awl-hero .btn-magnetic').forEach(btn => {
      if (btn.dataset.mag === '1') return;
      btn.dataset.mag = '1';
      btn.addEventListener('mousemove', (e) => {
        const r = btn.getBoundingClientRect();
        const dx = (e.clientX - r.left - r.width / 2) * 0.28;
        const dy = (e.clientY - r.top - r.height / 2) * 0.28;
        btn.style.transform = `translate(${dx}px, ${dy}px)`;
      });
      btn.addEventListener('mouseleave', () => { btn.style.transform = ''; });
    });
  }

  /* Lazy-load three.min.js exactly once. Resolves immediately if already loaded. */
  let awlThreePromise = null;
  function awlLoadThree() {
    if (typeof THREE !== 'undefined') return Promise.resolve();
    if (awlThreePromise) return awlThreePromise;
    awlThreePromise = new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
      s.async = true;
      s.onload = () => resolve();
      s.onerror = () => reject(new Error('three.js failed to load'));
      document.head.appendChild(s);
    });
    return awlThreePromise;
  }

  function awlInitWebGL() {
    const canvas = document.getElementById('awl-hero-canvas');
    const section = document.getElementById('awl-hero');
    if (!canvas || !section) return;
    if (typeof THREE === 'undefined') {
      // Three.js hasn't arrived yet — try again shortly.
      return setTimeout(awlInitWebGL, 200);
    }
    if (canvas.dataset.booted === '1') return;
    canvas.dataset.booted = '1';

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let renderer;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true, powerPreference: 'high-performance' });
    } catch (e) {
      console.warn('[AWL hero] WebGL unavailable — using CSS mesh fallback.', e);
      return;
    }
    if (!renderer.getContext()) { console.warn('[AWL hero] no WebGL context — fallback.'); return; }

    /* Mobile performance budget. Phones / small tablets get a third of the
       particles + a lower pixel ratio so the hero stays at 60fps on mid-tier
       Android. Desktop keeps the full density. Re-evaluated only at boot —
       window resize after that doesn't change the budget (rebooting the
       scene mid-session would be more disruptive than a slightly suboptimal
       resize). */
    const isMobile = window.innerWidth < 768;
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, section.clientWidth / section.clientHeight, 1, 2000);
    camera.position.set(0, 0, 420);

    /* ---------- soft circular sprite (additive blending = bloom-like glow without postprocessing) ---------- */
    function makeDotTexture() {
      const c = document.createElement('canvas');
      c.width = c.height = 64;
      const g = c.getContext('2d');
      const grad = g.createRadialGradient(32, 32, 0, 32, 32, 32);
      grad.addColorStop(0.0, 'rgba(255,255,255,1)');
      grad.addColorStop(0.35, 'rgba(255,255,255,0.65)');
      grad.addColorStop(1.0, 'rgba(255,255,255,0)');
      g.fillStyle = grad;
      g.fillRect(0, 0, 64, 64);
      const tex = new THREE.CanvasTexture(c);
      tex.minFilter = THREE.LinearFilter;
      return tex;
    }
    const dotTex = makeDotTexture();

    /* ---------- ambient cloud (6000 points desktop, 2000 mobile) ---------- */
    const AMB_COUNT = isMobile ? 2000 : 6000;
    const ambPositions = new Float32Array(AMB_COUNT * 3);
    const ambVel = new Float32Array(AMB_COUNT * 3);
    for (let i = 0; i < AMB_COUNT; i++) {
      ambPositions[i * 3 + 0] = (Math.random() - 0.5) * 1300;
      ambPositions[i * 3 + 1] = (Math.random() - 0.5) * 800;
      ambPositions[i * 3 + 2] = (Math.random() - 0.5) * 700;
      ambVel[i * 3 + 0] = (Math.random() - 0.5) * 0.04;
      ambVel[i * 3 + 1] = (Math.random() - 0.5) * 0.04;
      ambVel[i * 3 + 2] = (Math.random() - 0.5) * 0.04;
    }
    const ambGeom = new THREE.BufferGeometry();
    ambGeom.setAttribute('position', new THREE.BufferAttribute(ambPositions, 3));
    const ambMat = new THREE.PointsMaterial({
      size: 2.3,
      map: dotTex,
      color: 0x0d9373,
      transparent: true,
      opacity: 0.70,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      sizeAttenuation: true,
    });
    const ambPoints = new THREE.Points(ambGeom, ambMat);
    scene.add(ambPoints);

    /* ---------- node graph (260 desktop, 140 mobile — O(n²) connection
         pass on this cohort, so cutting count gives quadratic perf win) ---------- */
    const NODE_COUNT = isMobile ? 140 : 260;
    const CONNECT_THRESH = 95;
    const nodePositions = new Float32Array(NODE_COUNT * 3);
    const nodeVel = new Float32Array(NODE_COUNT * 3);
    for (let i = 0; i < NODE_COUNT; i++) {
      nodePositions[i * 3 + 0] = (Math.random() - 0.5) * 700;
      nodePositions[i * 3 + 1] = (Math.random() - 0.5) * 460;
      nodePositions[i * 3 + 2] = (Math.random() - 0.5) * 380;
      nodeVel[i * 3 + 0] = (Math.random() - 0.5) * 0.08;
      nodeVel[i * 3 + 1] = (Math.random() - 0.5) * 0.08;
      nodeVel[i * 3 + 2] = (Math.random() - 0.5) * 0.06;
    }
    const nodeGeom = new THREE.BufferGeometry();
    nodeGeom.setAttribute('position', new THREE.BufferAttribute(nodePositions, 3));
    const nodeMat = new THREE.PointsMaterial({
      size: 5.2,
      map: dotTex,
      color: 0xffffff,
      transparent: true,
      opacity: 0.95,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      sizeAttenuation: true,
    });
    const nodePoints = new THREE.Points(nodeGeom, nodeMat);
    scene.add(nodePoints);

    /* ---------- FIX 12 — 10 BIG hero nodes that pulse slowly. A separate Points
       cloud with a custom per-vertex size attribute driven by a sin wave. Brighter
       (white core) and bigger (4–6px nominal, scaled by sizeAttenuation). ---------- */
    const BIG_NODE_COUNT = isMobile ? 6 : 10;
    const bigPos = new Float32Array(BIG_NODE_COUNT * 3);
    const bigVel = new Float32Array(BIG_NODE_COUNT * 3);
    const bigPhase = new Float32Array(BIG_NODE_COUNT);
    const bigSize = new Float32Array(BIG_NODE_COUNT);
    for (let i = 0; i < BIG_NODE_COUNT; i++) {
      bigPos[i * 3 + 0] = (Math.random() - 0.5) * 720;
      bigPos[i * 3 + 1] = (Math.random() - 0.5) * 440;
      bigPos[i * 3 + 2] = (Math.random() - 0.5) * 280;
      bigVel[i * 3 + 0] = (Math.random() - 0.5) * 0.05;
      bigVel[i * 3 + 1] = (Math.random() - 0.5) * 0.05;
      bigVel[i * 3 + 2] = (Math.random() - 0.5) * 0.04;
      bigPhase[i] = Math.random() * Math.PI * 2;
      bigSize[i] = 14; // base value — overwritten every frame by the pulse
    }
    const bigGeom = new THREE.BufferGeometry();
    bigGeom.setAttribute('position', new THREE.BufferAttribute(bigPos, 3));
    bigGeom.setAttribute('size', new THREE.BufferAttribute(bigSize, 1));
    // Custom shader to read per-vertex size — PointsMaterial only supports a single uniform size.
    const bigMat = new THREE.ShaderMaterial({
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      uniforms: { uTex: { value: dotTex } },
      vertexShader: `
        attribute float size;
        varying float vSize;
        void main() {
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = size * (300.0 / -mv.z);
          gl_Position = projectionMatrix * mv;
          vSize = size;
        }
      `,
      fragmentShader: `
        uniform sampler2D uTex;
        void main() {
          vec4 t = texture2D(uTex, gl_PointCoord);
          gl_FragColor = vec4(1.0, 1.0, 0.95, t.a * 0.95);
        }
      `,
    });
    const bigPoints = new THREE.Points(bigGeom, bigMat);
    scene.add(bigPoints);

    /* lines connecting nearby nodes (rebuilt each frame from a flat segment buffer) */
    const MAX_SEGMENTS = NODE_COUNT * 10; // generous cap; truncated as needed
    const segPositions = new Float32Array(MAX_SEGMENTS * 6);
    const segColors = new Float32Array(MAX_SEGMENTS * 6);
    const segGeom = new THREE.BufferGeometry();
    segGeom.setAttribute('position', new THREE.BufferAttribute(segPositions, 3).setUsage(THREE.DynamicDrawUsage));
    segGeom.setAttribute('color', new THREE.BufferAttribute(segColors, 3).setUsage(THREE.DynamicDrawUsage));
    const segMat = new THREE.LineBasicMaterial({
      vertexColors: true,
      transparent: true,
      opacity: 0.55,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    const segments = new THREE.LineSegments(segGeom, segMat);
    scene.add(segments);

    /* ---------- pointer projected onto z=0 plane for repulsion ---------- */
    const pointer = new THREE.Vector2(-2, -2); // off-screen until first move
    const repulse = new THREE.Vector3();
    const ndc = new THREE.Vector2();
    const raycaster = new THREE.Raycaster();
    const repelPlane = new THREE.Plane(new THREE.Vector3(0, 0, 1), 0);
    const repelTarget = new THREE.Vector3();
    function updateRepulse() {
      ndc.set(pointer.x, pointer.y);
      raycaster.setFromCamera(ndc, camera);
      raycaster.ray.intersectPlane(repelPlane, repelTarget);
      repulse.copy(repelTarget);
    }
    /* FIX 12 — combined handler: feed Three.js raycaster AND drive the
       CSS cursor-glow div via CSS variables. One mousemove listener for both. */
    const cursorGlow = document.getElementById('awl-cursor-glow');
    let glowLive = false;
    window.addEventListener('mousemove', (e) => {
      const r = section.getBoundingClientRect();
      pointer.x = ((e.clientX - r.left) / r.width) * 2 - 1;
      pointer.y = -(((e.clientY - r.top) / r.height) * 2 - 1);
      if (cursorGlow) {
        const x = e.clientX - r.left;
        const y = e.clientY - r.top;
        cursorGlow.style.setProperty('--x', x + 'px');
        cursorGlow.style.setProperty('--y', y + 'px');
        if (!glowLive) { cursorGlow.classList.add('is-live'); glowLive = true; }
      }
    });
    section.addEventListener('mouseleave', () => {
      if (cursorGlow) { cursorGlow.classList.remove('is-live'); glowLive = false; }
    });

    /* ---------- resize ---------- */
    function resize() {
      const w = section.clientWidth, h = section.clientHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    window.addEventListener('resize', resize);
    resize();

    /* ---------- frame ---------- */
    const BOUND_X = 600, BOUND_Y = 380, BOUND_Z = 320;
    const ambPos = ambGeom.attributes.position.array;
    const nodePos = nodeGeom.attributes.position.array;

    // FIX 12 — repulsion tuning. Much stronger forces + larger reach so the
    // whole field visibly reacts to cursor motion (was 0.6/22000 + 1.8/34000).
    const AMB_REPEL_R2 = 55000;
    const AMB_REPEL_F  = 3.4;
    const NODE_REPEL_R2 = 75000;
    const NODE_REPEL_F  = 7.5;

    const bigSizeAttr = bigGeom.attributes.size.array;

    function step() {
      // ambient drift + strong mouse push
      updateRepulse();
      const rx = repulse.x, ry = repulse.y;
      for (let i = 0; i < AMB_COUNT; i++) {
        const ix = i * 3;
        ambPos[ix]     += ambVel[ix];
        ambPos[ix + 1] += ambVel[ix + 1];
        ambPos[ix + 2] += ambVel[ix + 2];
        // gentle bounds
        if (ambPos[ix]     >  BOUND_X || ambPos[ix]     < -BOUND_X) ambVel[ix]     *= -1;
        if (ambPos[ix + 1] >  BOUND_Y || ambPos[ix + 1] < -BOUND_Y) ambVel[ix + 1] *= -1;
        if (ambPos[ix + 2] >  BOUND_Z || ambPos[ix + 2] < -BOUND_Z) ambVel[ix + 2] *= -1;
        // mouse repulsion — strong + wide so the field visibly scatters
        const dx = ambPos[ix] - rx, dy = ambPos[ix + 1] - ry;
        const d2 = dx * dx + dy * dy;
        if (d2 < AMB_REPEL_R2) {
          const f = (1 - d2 / AMB_REPEL_R2) * AMB_REPEL_F;
          const inv = 1 / Math.max(Math.sqrt(d2), 0.001);
          ambPos[ix]     += dx * inv * f;
          ambPos[ix + 1] += dy * inv * f;
        }
      }
      ambGeom.attributes.position.needsUpdate = true;

      // nodes — much stronger repulsion + wider reach for a fluid scatter feel
      for (let i = 0; i < NODE_COUNT; i++) {
        const ix = i * 3;
        nodePos[ix]     += nodeVel[ix];
        nodePos[ix + 1] += nodeVel[ix + 1];
        nodePos[ix + 2] += nodeVel[ix + 2];
        if (nodePos[ix]     >  BOUND_X * 0.85 || nodePos[ix]     < -BOUND_X * 0.85) nodeVel[ix]     *= -1;
        if (nodePos[ix + 1] >  BOUND_Y * 0.85 || nodePos[ix + 1] < -BOUND_Y * 0.85) nodeVel[ix + 1] *= -1;
        if (nodePos[ix + 2] >  BOUND_Z * 0.85 || nodePos[ix + 2] < -BOUND_Z * 0.85) nodeVel[ix + 2] *= -1;
        const dx = nodePos[ix] - rx, dy = nodePos[ix + 1] - ry;
        const d2 = dx * dx + dy * dy;
        if (d2 < NODE_REPEL_R2) {
          const f = (1 - d2 / NODE_REPEL_R2) * NODE_REPEL_F;
          const inv = 1 / Math.max(Math.sqrt(d2), 0.001);
          nodePos[ix]     += dx * inv * f;
          nodePos[ix + 1] += dy * inv * f;
        }
      }
      nodeGeom.attributes.position.needsUpdate = true;

      // FIX 12 — big nodes: gentle drift + slow individual pulse (size oscillates
      // 12 → 22 over ~3s per node, each with its own phase offset for life).
      const tNow = performance.now() * 0.001;
      for (let i = 0; i < BIG_NODE_COUNT; i++) {
        const ix = i * 3;
        bigPos[ix]     += bigVel[ix];
        bigPos[ix + 1] += bigVel[ix + 1];
        bigPos[ix + 2] += bigVel[ix + 2];
        if (bigPos[ix]     >  BOUND_X * 0.75 || bigPos[ix]     < -BOUND_X * 0.75) bigVel[ix]     *= -1;
        if (bigPos[ix + 1] >  BOUND_Y * 0.75 || bigPos[ix + 1] < -BOUND_Y * 0.75) bigVel[ix + 1] *= -1;
        if (bigPos[ix + 2] >  BOUND_Z * 0.75 || bigPos[ix + 2] < -BOUND_Z * 0.75) bigVel[ix + 2] *= -1;
        // Big nodes feel the cursor too, just lazily
        const dx = bigPos[ix] - rx, dy = bigPos[ix + 1] - ry;
        const d2 = dx * dx + dy * dy;
        if (d2 < NODE_REPEL_R2 * 1.2) {
          const f = (1 - d2 / (NODE_REPEL_R2 * 1.2)) * 4.0;
          const inv = 1 / Math.max(Math.sqrt(d2), 0.001);
          bigPos[ix]     += dx * inv * f;
          bigPos[ix + 1] += dy * inv * f;
        }
        // Per-vertex size pulse — sin wave around 17, ±5
        bigSizeAttr[i] = 17 + Math.sin(tNow * 2.0 + bigPhase[i]) * 5;
      }
      bigGeom.attributes.position.needsUpdate = true;
      bigGeom.attributes.size.needsUpdate = true;

      // connections (O(n²) on the 260 nodes — fine). FIX 12: stronger near-far
      // brightness ramp so the web visibly throbs as nodes scatter & re-collapse.
      let segIdx = 0;
      const t2 = CONNECT_THRESH * CONNECT_THRESH;
      for (let i = 0; i < NODE_COUNT && segIdx < MAX_SEGMENTS; i++) {
        const ix = i * 3;
        const ax = nodePos[ix], ay = nodePos[ix + 1], az = nodePos[ix + 2];
        for (let j = i + 1; j < NODE_COUNT && segIdx < MAX_SEGMENTS; j++) {
          const jx = j * 3;
          const bx = nodePos[jx], by = nodePos[jx + 1], bz = nodePos[jx + 2];
          const dx = ax - bx, dy = ay - by, dz = az - bz;
          const d2 = dx * dx + dy * dy + dz * dz;
          if (d2 < t2) {
            // Quadratic falloff = more contrast between near + far connections.
            const lin = 1 - Math.sqrt(d2) / CONNECT_THRESH; // 0..1
            const a = lin * lin; // closer pairs glow much brighter
            const s6 = segIdx * 6;
            segPositions[s6 + 0] = ax; segPositions[s6 + 1] = ay; segPositions[s6 + 2] = az;
            segPositions[s6 + 3] = bx; segPositions[s6 + 4] = by; segPositions[s6 + 5] = bz;
            // colour: AWL green, drives from dim → bright cyan-green as a → 1
            const g = 0.85 * a + 0.05;
            const b = 0.65 * a + 0.05;
            segColors[s6 + 0] = 0.05; segColors[s6 + 1] = g; segColors[s6 + 2] = b;
            segColors[s6 + 3] = 0.05; segColors[s6 + 4] = g; segColors[s6 + 5] = b;
            segIdx++;
          }
        }
      }
      segGeom.setDrawRange(0, segIdx * 2);
      segGeom.attributes.position.needsUpdate = true;
      segGeom.attributes.color.needsUpdate = true;

      // slow camera sway
      const t = performance.now() * 0.0001;
      camera.position.x = Math.sin(t) * 28;
      camera.position.y = Math.cos(t * 0.8) * 14;
      camera.lookAt(0, 0, 0);

      renderer.render(scene, camera);
      if (!reduced) requestAnimationFrame(step);
    }

    // initial paint, then either loop (normal) or stop (reduced motion → single static frame).
    step();
  }

  /* Defer Three.js to idle so the CDN fetch + parse never blocks first paint
     or LCP. The CSS gradient mesh is the static fallback shown until WebGL
     boots — and the only state shown to reduced-motion / save-data users. */
  function awlScheduleWebGL() {
    if (typeof window === 'undefined') return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const conn = navigator.connection;
    const saveData = conn && (conn.saveData || /^(slow-2g|2g)$/.test(conn.effectiveType || ''));
    if (reduced || saveData) return; // keep the static CSS mesh — no JS load
    const start = () => {
      awlLoadThree().then(awlInitWebGL).catch((e) => {
        console.warn('[AWL hero] three.js load failed — using CSS mesh fallback.', e);
      });
    };
    const kick = () => {
      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(start, { timeout: 2500 });
      } else {
        setTimeout(start, 600);
      }
    };
    if (document.readyState === 'complete') kick();
    else window.addEventListener('load', kick, { once: true });
  }

  function awlBoot() {
    awlSplitHeading();
    awlPlayIntro();
    awlScheduleWebGL();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', awlBoot);
  } else {
    awlBoot();
  }
  // Astro view transitions: re-run when the homepage swaps in.
  document.addEventListener('astro:after-swap', awlBoot);
</script>
