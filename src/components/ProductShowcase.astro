  /* ============================================================
     2. Analytics dashboard
     ============================================================ */
  .ps-ana {
    display: grid;
    grid-template-columns: 44px 1fr;
    height: 100%;
    background: #0a0f0e;
  }
  .ps-ana-side {
    background: #080d0c;
    border-right: 1px solid #1e2d28;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.625rem 0;
    gap: 6px;
  }
  .ps-ana-logo { padding: 0.25rem; margin-bottom: 0.25rem; }
  .ps-ana-nav {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4a6359;
  }
  .ps-ana-nav.is-active { background: rgba(13,147,115,0.15); color: #0d9373; }

  .ps-ana-main {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 12px 14px 12px;
    gap: 12px;
  }
  .ps-ana-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .ps-ana-title {
    font-family: 'Sora', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: white;
  }
  .ps-ana-sub {
    font-size: 10px;
    color: #6b8079;
    margin-top: 2px;
  }
  .ps-ana-actions { display: flex; gap: 6px; align-items: center; }
  .ps-ana-chip {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    color: #8aa09a;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 6px;
    padding: 4px 9px;
  }
  .ps-ana-chip.is-primary {
    background: rgba(13,147,115,0.2);
    color: #0d9373;
    border-color: rgba(13,147,115,0.3);
    font-weight: 600;
  }

  .ps-ana-kpis {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  .ps-ana-kpi {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 10px;
    padding: 9px 11px;
  }
  .ps-ana-kpi-label {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #6b8079;
    font-weight: 600;
  }
  .ps-ana-kpi-val {
    font-family: 'Sora', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: white;
    line-height: 1.2;
    margin-top: 4px;
    letter-spacing: -0.02em;
  }
  .ps-ana-kpi-delta {
    font-size: 10px;
    font-weight: 600;
    margin-top: 3px;
  }
  .ps-ana-kpi-delta.up { color: #0d9373; }
  .ps-ana-kpi-delta.down { color: #f87171; }

  .ps-ana-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 8px;
    flex: 1;
    min-height: 0;
  }
  .ps-ana-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 10px;
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .ps-ana-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .ps-ana-card-title {
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: white;
  }
  .ps-ana-card-meta {
    font-size: 9px;
    color: #6b8079;
  }
  .ps-ana-bars {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
    align-items: end;
    height: 100px;
    flex: 1;
  }
  .ps-ana-bar {
    background: linear-gradient(180deg, #0d9373 0%, rgba(13,147,115,0.4) 100%);
    border-radius: 4px 4px 2px 2px;
    /* Rest at full target height — animate the visual with transform: scaleY
       (GPU-compositable) rather than `height` (re-layouts the grid every frame). */
    height: var(--h);
    transform: scaleY(0);
    transform-origin: bottom;
  }
  .ps-item.in-view .ps-ana-bar {
    animation: psBarGrow 5.6s ease-in-out infinite;
    animation-delay: var(--d, 0s);
    will-change: transform;
  }
  .ps-ana-bar:nth-child(1) { --d: 0s; }
  .ps-ana-bar:nth-child(2) { --d: 0.08s; }
  .ps-ana-bar:nth-child(3) { --d: 0.16s; }
  .ps-ana-bar:nth-child(4) { --d: 0.24s; }
  .ps-ana-bar:nth-child(5) { --d: 0.32s; }
  .ps-ana-bar:nth-child(6) { --d: 0.4s; }
  .ps-ana-bar:nth-child(7) { --d: 0.48s; }
  @keyframes psBarGrow {
    0% { transform: scaleY(0); }
    20% { transform: scaleY(1); }
    80% { transform: scaleY(1); }
    100% { transform: scaleY(0); }
  }
  .ps-ana-bars-axis {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
    margin-top: 4px;
    font-size: 9px;
    color: #6b8079;
    text-align: center;
  }
  .ps-ana-table { display: flex; flex-direction: column; gap: 6px; flex: 1; }
  .ps-ana-trow {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 8px;
    align-items: center;
    padding: 5px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 10px;
    color: #cde0da;
  }
  .ps-ana-trow:last-child { border-bottom: none; }
  .ps-ana-tv { color: white; font-weight: 600; }
  .ps-ana-td { font-weight: 600; font-size: 9px; }
  .ps-ana-td.up { color: #0d9373; }
  .ps-ana-td.down { color: #f87171; }

  /* ============================================================
     3. Booking calendar
     ============================================================ */
  .ps-bk {
    background: #0a0f0e;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 12px 14px 14px;
    color: white;
    position: relative;
  }
  .ps-bk-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .ps-bk-title {
    font-family: 'Sora', sans-serif;
    font-size: 14px;
    font-weight: 600;
  }
  .ps-bk-sub {
    font-size: 10px;
    color: #6b8079;
    margin-top: 2px;
  }
  .ps-bk-head-right {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ps-bk-chev {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #8aa09a;
  }
  .ps-bk-this {
    font-size: 10px;
    color: #cde0da;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 6px;
    padding: 4px 9px;
  }
  .ps-bk-new {
    font-size: 10px;
    color: white;
    background: linear-gradient(135deg, #0d9373, #0a6e57);
    border-radius: 6px;
    padding: 4px 10px;
    font-weight: 600;
  }
  .ps-bk-grid {
    display: grid;
    grid-template-columns: 22px repeat(5, 1fr);
    gap: 6px;
    flex: 1;
    min-height: 0;
  }
  .ps-bk-times {
    display: grid;
    grid-template-rows: repeat(6, 1fr);
    padding-top: 22px;
    font-size: 9px;
    color: #6b8079;
    text-align: right;
    padding-right: 4px;
  }
  .ps-bk-col {
    display: flex;
    flex-direction: column;
    background: rgba(255,255,255,0.015);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 8px;
    overflow: hidden;
  }
  .ps-bk-col-h {
    font-family: 'Sora', sans-serif;
    font-size: 10px;
    font-weight: 600;
    color: #cde0da;
    text-align: center;
    padding: 4px 0;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .ps-bk-slots {
    display: grid;
    grid-template-rows: repeat(6, 1fr);
    flex: 1;
    padding: 3px;
    gap: 2px;
    position: relative;
  }
  .ps-bk-appt {
    grid-row: var(--row) / span var(--span);
    border-radius: 5px;
    padding: 4px 6px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }
  .ps-bk-appt .t {
    font-size: 8px;
    font-weight: 600;
    opacity: 0.7;
  }
  .ps-bk-appt .n {
    font-size: 9px;
    font-weight: 600;
    color: white;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ps-bk-appt.c-green { background: rgba(13,147,115,0.2); border-left: 2px solid #0d9373; color: #6ee7b7; }
  .ps-bk-appt.c-blue { background: rgba(99,102,241,0.18); border-left: 2px solid #818cf8; color: #c7d2fe; }
  .ps-bk-appt.c-amber { background: rgba(251,191,36,0.16); border-left: 2px solid #fbbf24; color: #fcd34d; }

  /* Animated "new" appointment appears */
  .ps-bk-new-appt {
    opacity: 0;
    transform: scale(0.6);
    transform-origin: top center;
  }
  .ps-item.in-view .ps-bk-new-appt {
    animation: psApptIn 6.2s ease-in-out infinite;
  }
  @keyframes psApptIn {
    0%, 25% { opacity: 0; transform: scale(0.6); }
    35%, 85% { opacity: 1; transform: scale(1); }
    95%, 100% { opacity: 0; transform: scale(0.6); }
  }

  .ps-bk-toast {
    position: absolute;
    left: 50%;
    bottom: 14px;
    transform: translateX(-50%) translateY(14px);
    background: #0a0f0e;
    border: 1px solid rgba(13,147,115,0.4);
    border-radius: 12px;
    padding: 8px 14px 8px 10px;
    display: flex;
    align-items: center;
    gap: 9px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.7), 0 0 22px rgba(13,147,115,0.25);
    opacity: 0;
    pointer-events: none;
  }
  .ps-bk-toast-check {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: linear-gradient(135deg, #0d9373, #0a6e57);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ps-bk-toast-text { display: flex; flex-direction: column; gap: 1px; line-height: 1.2; }
  .ps-bk-toast-text strong {
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: white;
  }
  .ps-bk-toast-text span {
    font-size: 9px;
    color: #6b8079;
  }
  .ps-item.in-view .ps-bk-toast {
    animation: psToast 6.2s ease-in-out infinite;
  }
  @keyframes psToast {
    0%, 35% { opacity: 0; transform: translateX(-50%) translateY(14px); }
    45%, 80% { opacity: 1; transform: translateX(-50%) translateY(0); }
    90%, 100% { opacity: 0; transform: translateX(-50%) translateY(14px); }
  }

  /* ============================================================
     4. Fleet tracking (tablet)
     ============================================================ */
  .ps-fl {
    display: grid;
    grid-template-columns: 160px 1fr;
    height: 100%;
    background: #0a0f0e;
    color: white;
    font-family: 'DM Sans', sans-serif;
  }
  .ps-fl-side {
    background: #080d0c;
    border-right: 1px solid #1e2d28;
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow: hidden;
  }
  .ps-fl-side-h {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: white;
    padding: 0 2px 4px;
  }
  .ps-fl-side-count {
    font-size: 9px;
    color: #6b8079;
    background: rgba(255,255,255,0.04);
    padding: 2px 7px;
    border-radius: 50px;
  }
  .ps-fl-veh {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 8px;
    padding: 7px 9px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .ps-fl-veh.is-active {
    background: rgba(13,147,115,0.1);
    border-color: rgba(13,147,115,0.3);
  }
  .ps-fl-veh-row { display: flex; justify-content: space-between; align-items: center; }
  .ps-fl-veh-id {
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: white;
  }
  .ps-fl-veh-status {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 50px;
  }
  .ps-fl-veh-status.en-route { background: rgba(13,147,115,0.18); color: #0d9373; }
  .ps-fl-veh-status.arrived { background: rgba(99,102,241,0.18); color: #a5b4fc; }
  .ps-fl-veh-status.idle { background: rgba(255,255,255,0.06); color: #8aa09a; }
  .ps-fl-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
  }
  .ps-fl-veh.is-active .ps-fl-dot {
    animation: psPulse 1.8s ease-in-out infinite;
  }
  @keyframes psPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.4); opacity: 0.55; }
  }
  .ps-fl-veh-meta {
    display: flex;
    justify-content: space-between;
    font-size: 9px;
    color: #6b8079;
  }

  .ps-fl-map {
    position: relative;
    background: #060a09;
    overflow: hidden;
  }
  .ps-fl-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .ps-fl-stop-pulse {
    transform-origin: 340px 90px;
    animation: psStopPulse 2.4s ease-out infinite;
  }
  @keyframes psStopPulse {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(2.6); opacity: 0; }
  }
  .ps-fl-vehicle {
    position: absolute;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: linear-gradient(135deg, #0d9373, #0a6e57);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 3px rgba(13,147,115,0.25), 0 6px 14px rgba(0,0,0,0.5);
    top: 0;
    left: 0;
    offset-path: path('M 30 230 C 80 220 130 180 190 160 C 240 144 280 120 340 90');
    offset-distance: 0%;
    offset-rotate: 0deg;
  }
  .ps-item.in-view .ps-fl-vehicle {
    animation: psVehicle 8s ease-in-out infinite;
  }
  @keyframes psVehicle {
    0% { offset-distance: 0%; }
    100% { offset-distance: 100%; }
  }
  .ps-fl-eta-card {
    position: absolute;
    right: 12px;
    bottom: 12px;
    background: rgba(10,15,14,0.92);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(13,147,115,0.3);
    border-radius: 12px;
    padding: 9px 12px;
    min-width: 130px;
    box-shadow: 0 12px 28px rgba(0,0,0,0.6);
  }
  .ps-fl-eta-label {
    font-size: 9px;
    color: #8aa09a;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }
  .ps-fl-eta-val {
    font-family: 'Sora', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: white;
    line-height: 1.1;
    margin-top: 3px;
    letter-spacing: -0.02em;
  }
  .ps-fl-eta-meta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 9px;
    color: #0d9373;
    font-weight: 600;
    margin-top: 3px;
  }
  .ps-fl-eta-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #0d9373;
    box-shadow: 0 0 6px #0d9373;
  }

