  @keyframes psSendPulse {
    0%, 100% { transform: scale(1); box-shadow: 0 8px 24px rgba(13,147,115,0.35); }
    50% { transform: scale(1.025); box-shadow: 0 10px 30px rgba(13,147,115,0.55); }
