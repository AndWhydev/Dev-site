  .ps-crm-card.is-won .ps-crm-card-co { color: #6ee7b7; }
  /* Deal-advances animation: three identical ghost cards in Proposal → Negotiation → Closed won, fading in turn */
  .ps-crm-stage {
    background: rgba(13,147,115,0.15);
    border: 1px solid rgba(13,147,115,0.35);
    box-shadow: 0 8px 18px rgba(0,0,0,0.35), 0 0 14px rgba(13,147,115,0.18);
    opacity: 0;
    transform: scale(0.85);
    transform-origin: center;
  }
  .ps-crm-stage .ps-crm-card-co { color: white; }
  .ps-crm-stage .ps-crm-card-val { color: #6ee7b7; font-weight: 600; }
  .ps-item.in-view .ps-crm-stage[data-stage="0"] {
    animation: psCrmStage0 6.4s ease-in-out infinite;
  }
  .ps-item.in-view .ps-crm-stage[data-stage="1"] {
    animation: psCrmStage1 6.4s ease-in-out infinite;
  }
  .ps-item.in-view .ps-crm-stage[data-stage="2"] {
    animation: psCrmStage2 6.4s ease-in-out infinite;
  }
  @keyframes psCrmStage0 {
    0% { opacity: 0; transform: scale(0.85); }
    5%, 30% { opacity: 1; transform: scale(1); }
    36%, 100% { opacity: 0; transform: scale(0.85); }
  }
  @keyframes psCrmStage1 {
    0%, 32% { opacity: 0; transform: scale(0.85); }
    38%, 60% { opacity: 1; transform: scale(1); }
    66%, 100% { opacity: 0; transform: scale(0.85); }
  }
  @keyframes psCrmStage2 {
    0%, 62% { opacity: 0; transform: scale(0.85); }
    68%, 92% { opacity: 1; transform: scale(1); box-shadow: 0 8px 22px rgba(0,0,0,0.4), 0 0 22px rgba(13,147,115,0.4); }
    100% { opacity: 0; transform: scale(0.85); }
  }

  /* ============================================================
     Prefers-reduced-motion
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .ps-item.in-view .ps-pay-send,
    .ps-item.in-view .ps-ana-bar,
    .ps-item.in-view .ps-bk-new-appt,
    .ps-item.in-view .ps-bk-toast,
    .ps-item.in-view .ps-fl-vehicle,
    .ps-fl-stop-pulse,
    .ps-fl-veh.is-active .ps-fl-dot,
    .ps-item.in-view .ps-crm-stage {
      animation: none !important;
    }
    .ps-ana-bar { height: var(--h); transform: none; }
    .ps-bk-new-appt { opacity: 1; transform: scale(1); }
    .ps-bk-toast { opacity: 1; transform: translateX(-50%) translateY(0); }
    .ps-fl-vehicle { offset-distance: 100%; }
    .ps-crm-stage[data-stage="2"] { opacity: 1; transform: scale(1); }
    .ps-crm-stage[data-stage="0"],
    .ps-crm-stage[data-stage="1"] { display: none; }
  }

  /* ============================================================
     Responsive
     ============================================================ */
  @media (max-width: 1024px) {
    .ps-section { padding: 5rem 0 4rem; }
    .ps-list { gap: 5rem; }
    .ps-item {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .ps-item--reverse .ps-frame-col,
    .ps-item--reverse .ps-text-col {
      order: initial;
    }
    .ps-text-col {
      max-width: 560px;
      margin: 0 auto;
      text-align: center;
      align-items: center;
    }
    .ps-tag { align-self: center; }
