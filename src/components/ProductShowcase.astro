    font-family: 'Sora', sans-serif;
    font-size: 13px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    box-shadow: 0 8px 24px rgba(13,147,115,0.35);
  }
  .ps-pay-tabs {
    margin-top: auto;
