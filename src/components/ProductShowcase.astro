  }

  @media (max-width: 640px) {
    .ps-section { padding: 4rem 0 3rem; }
    .ps-list { gap: 4rem; }
    .ps-header { margin-bottom: 3rem; }
    .ps-phone { width: 230px; }
    .ps-browser-body { height: 320px; }
  }
</style>

<script>
  function initProductShowcase() {
    const items = document.querySelectorAll<HTMLElement>('.ps-section .ps-item');
    if (!items.length) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fmtPlain = new Intl.NumberFormat('en-AU');

    function runCount(el: HTMLElement) {
      const target = parseFloat(el.dataset.countTarget || '0');
      const start = parseFloat(el.dataset.countStart || '0');
      const decimals = parseInt(el.dataset.countDecimals || '0');
      const duration = 2200;
      const t0 = performance.now();
      function step(t: number) {
        const p = Math.min((t - t0) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const v = start + (target - start) * eased;
        if (decimals > 0) {
          el.textContent = v.toFixed(decimals);
        } else {
          el.textContent = fmtPlain.format(Math.round(v));
        }
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    const timers = new WeakMap<HTMLElement, number>();

    function startItem(item: HTMLElement) {
      const counters = Array.from(item.querySelectorAll<HTMLElement>('.ps-count'));
      counters.forEach(runCount);

      if (reduce) return;

      const loopMs = parseInt(item.dataset.loop || '6000');
      const id = window.setInterval(() => {
        counters.forEach(runCount);
      }, loopMs);
      timers.set(item, id);
    }

    function stopItem(item: HTMLElement) {
      const id = timers.get(item);
      if (id) {
        window.clearInterval(id);
        timers.delete(item);
      }
    }

    if (reduce) {
      items.forEach(item => {
        item.classList.add('in-view');
        const counters = Array.from(item.querySelectorAll<HTMLElement>('.ps-count'));
        counters.forEach(c => {
          const target = parseFloat(c.dataset.countTarget || '0');
          const decimals = parseInt(c.dataset.countDecimals || '0');
          c.textContent = decimals > 0 ? target.toFixed(decimals) : fmtPlain.format(Math.round(target));
        });
      });
      return;
    }

    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const item = entry.target as HTMLElement;
        if (entry.isIntersecting) {
          if (!item.classList.contains('in-view')) {
            item.classList.add('in-view');
            startItem(item);
          }
        } else {
          if (item.classList.contains('in-view')) {
            item.classList.remove('in-view');
            stopItem(item);
          }
        }
      });
    }, { threshold: 0.2, rootMargin: '0px 0px -10% 0px' });

    items.forEach(item => io.observe(item));
  }

  initProductShowcase();
  document.addEventListener('astro:after-swap', initProductShowcase);
</script>
