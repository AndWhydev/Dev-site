---
---

<section class="ps-section" id="showcase">
  <div class="ps-inner">
    <div class="ps-header reveal">
      <span class="section-label">Showcase</span>
      <h2 class="section-heading">A taste of what we build</h2>
      <p class="section-subheading">
        Five interface mockups, built entirely in code — animated and rendered live in your
        browser. No screenshots, no client names, no fictional projects.
      </p>
    </div>

    <div class="ps-list">

      <!-- ============================================================
           1. Mobile finance / payments — phone frame
           ============================================================ -->
      <article class="ps-item" data-loop="5400">
        <div class="ps-frame-col">
          <div class="ps-phone-wrap">
            <div class="ps-phone-glow" aria-hidden="true"></div>
            <div class="ps-phone">
              <div class="ps-phone-island" aria-hidden="true"></div>
              <div class="ps-phone-screen">
                <div class="ps-pay" role="img" aria-label="Mobile payments interface mockup">
                  <div class="ps-pay-status">9:41</div>

                  <div class="ps-pay-toolbar">
                    <span class="ps-pay-icon-btn" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    </span>
                    <span class="ps-pay-title">Send money</span>
                    <span class="ps-pay-icon-btn" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    </span>
                  </div>

                  <div class="ps-pay-people">
                    <div class="ps-pay-person is-active">
                      <span class="ps-pay-avatar a1">EM</span>
                      <span class="ps-pay-name">Emma</span>
                    </div>
                    <div class="ps-pay-person">
                      <span class="ps-pay-avatar a2">JR</span>
                      <span class="ps-pay-name">James</span>
                    </div>
                    <div class="ps-pay-person">
                      <span class="ps-pay-avatar a3">SK</span>
                      <span class="ps-pay-name">Sophie</span>
                    </div>
                    <div class="ps-pay-person">
                      <span class="ps-pay-avatar a-add" aria-hidden="true">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                      </span>
                      <span class="ps-pay-name">New</span>
                    </div>
                  </div>

                  <div class="ps-pay-card">
                    <div class="ps-pay-card-label">Amount</div>
                    <div class="ps-pay-card-value">
                      <span class="ps-pay-cur">$</span><span class="ps-count" data-count-target="1280" data-count-start="0">0</span><span class="ps-pay-dec">.00</span>
                    </div>
                    <div class="ps-pay-card-meta">No fee · AUD · arrives instantly</div>
                  </div>

                  <div class="ps-pay-method">
                    <div class="ps-pay-method-dot" aria-hidden="true"></div>
                    <div class="ps-pay-method-text">
                      <div class="ps-pay-method-name">Everyday Visa</div>
                      <div class="ps-pay-method-num">•••• 4271</div>
                    </div>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4a6359" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  </div>

                  <div class="ps-pay-send" role="button" aria-label="Send">
                    <span>Send</span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </div>

                  <div class="ps-pay-tabs">
                    <div class="ps-pay-tab"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M16 10h.01"/></svg><span>Wallet</span></div>
                    <div class="ps-pay-tab is-active"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg><span>Send</span></div>
                    <div class="ps-pay-tab"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg><span>Cards</span></div>
                    <div class="ps-pay-tab"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg><span>More</span></div>
                  </div>
                </div>
              </div>
            </div>
            <div class="ps-caption">
              <span class="ps-cap-badge"><span class="ps-cap-dot"></span>Payments app — sample interface</span>
            </div>
          </div>
        </div>

        <div class="ps-text-col">
          <span class="ps-tag">Fintech · mobile</span>
          <h3 class="ps-h3">Money flows, made calm</h3>
          <p class="ps-p">
            Send transfers, switch funding sources and surface activity without friction. We build
            native finance apps where the heavy lifting — settlement, fraud checks, KYC — happens
            quietly behind a clean interface.
          </p>
          <ul class="ps-bullets">
            <li>Native iOS and Android, single codebase</li>
            <li>Real-time payment rails</li>
            <li>Biometric authentication and 2FA</li>
          </ul>
        </div>
      </article>

      <!-- ============================================================
           2. Web analytics dashboard — desktop browser frame
           ============================================================ -->
      <article class="ps-item ps-item--reverse" data-loop="5800">
        <div class="ps-frame-col ps-frame-col--wide">
          <div class="ps-browser-wrap">
            <div class="ps-browser">
              <div class="ps-browser-chrome">
                <div class="ps-browser-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div>
                <div class="ps-browser-tabs">
                  <span class="ps-browser-tab is-active">Overview</span>
                  <span class="ps-browser-tab">Sources</span>
                  <span class="ps-browser-tab">Funnels</span>
                </div>
                <div class="ps-browser-url">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4a6359" stroke-width="2" stroke-linecap="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 1 1 8 0v3"/></svg>
                  <span>analytics.demo/overview</span>
                </div>
              </div>
              <div class="ps-browser-body ps-ana" role="img" aria-label="Web analytics dashboard mockup">
                <aside class="ps-ana-side">
                  <div class="ps-ana-logo"><svg width="14" height="14" viewBox="0 0 36 36" fill="none"><rect width="36" height="36" rx="9" fill="#0d9373"/><path d="M8 27L18 9L28 27" stroke="white" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M11.5 21.5H24.5" stroke="white" stroke-width="2.8" stroke-linecap="round"/></svg></div>
                  <span class="ps-ana-nav is-active"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg></span>
                  <span class="ps-ana-nav"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></span>
                  <span class="ps-ana-nav"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 3 5-7"/></svg></span>
                  <span class="ps-ana-nav"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06A2 2 0 1 1 4.29 16.96l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68 1.65 1.65 0 0 0 10 3.17V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span>
                </aside>

                <div class="ps-ana-main">
                  <div class="ps-ana-head">
                    <div>
                      <div class="ps-ana-title">Overview</div>
                      <div class="ps-ana-sub">Last 30 days</div>
                    </div>
                    <div class="ps-ana-actions">
                      <span class="ps-ana-chip">Last 30 days</span>
                      <span class="ps-ana-chip is-primary">Export</span>
                    </div>
                  </div>

                  <div class="ps-ana-kpis">
                    <div class="ps-ana-kpi">
                      <div class="ps-ana-kpi-label">Revenue</div>
                      <div class="ps-ana-kpi-val">$<span class="ps-count" data-count-target="284" data-count-start="0">0</span>K</div>
                      <div class="ps-ana-kpi-delta up">+12.4%</div>
                    </div>
                    <div class="ps-ana-kpi">
                      <div class="ps-ana-kpi-label">Sessions</div>
                      <div class="ps-ana-kpi-val"><span class="ps-count" data-count-target="42180" data-count-start="0">0</span></div>
                      <div class="ps-ana-kpi-delta up">+8.1%</div>
                    </div>
                    <div class="ps-ana-kpi">
                      <div class="ps-ana-kpi-label">Conv. rate</div>
                      <div class="ps-ana-kpi-val"><span class="ps-count" data-count-target="3.84" data-count-start="0" data-count-decimals="2">0</span>%</div>
                      <div class="ps-ana-kpi-delta up">+0.4%</div>
                    </div>
                    <div class="ps-ana-kpi">
                      <div class="ps-ana-kpi-label">Avg. order</div>
                      <div class="ps-ana-kpi-val">$<span class="ps-count" data-count-target="187" data-count-start="0">0</span></div>
                      <div class="ps-ana-kpi-delta down">−1.2%</div>
                    </div>
                  </div>

                  <div class="ps-ana-row">
                    <div class="ps-ana-card ps-ana-chart-card">
                      <div class="ps-ana-card-head">
                        <span class="ps-ana-card-title">Traffic by day</span>
                        <span class="ps-ana-card-meta">7 day average</span>
                      </div>
                      <div class="ps-ana-bars">
                        <span class="ps-ana-bar" style="--h: 42%"></span>
                        <span class="ps-ana-bar" style="--h: 58%"></span>
                        <span class="ps-ana-bar" style="--h: 36%"></span>
                        <span class="ps-ana-bar" style="--h: 72%"></span>
                        <span class="ps-ana-bar" style="--h: 64%"></span>
                        <span class="ps-ana-bar" style="--h: 88%"></span>
                        <span class="ps-ana-bar" style="--h: 78%"></span>
                      </div>
                      <div class="ps-ana-bars-axis">
                        <span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span><span>S</span>
                      </div>
                    </div>

                    <div class="ps-ana-card ps-ana-table-card">
                      <div class="ps-ana-card-head">
                        <span class="ps-ana-card-title">Top sources</span>
                      </div>
                      <div class="ps-ana-table">
                        <div class="ps-ana-trow"><span>Organic</span><span class="ps-ana-tv">14.2K</span><span class="ps-ana-td up">+6%</span></div>
                        <div class="ps-ana-trow"><span>Direct</span><span class="ps-ana-tv">9.4K</span><span class="ps-ana-td up">+3%</span></div>
                        <div class="ps-ana-trow"><span>Referral</span><span class="ps-ana-tv">6.1K</span><span class="ps-ana-td down">−2%</span></div>
                        <div class="ps-ana-trow"><span>Social</span><span class="ps-ana-tv">4.8K</span><span class="ps-ana-td up">+11%</span></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="ps-caption">
              <span class="ps-cap-badge"><span class="ps-cap-dot"></span>Analytics dashboard — sample build</span>
            </div>
          </div>
        </div>

        <div class="ps-text-col">
          <span class="ps-tag">Data · web</span>
          <h3 class="ps-h3">See the numbers that matter</h3>
          <p class="ps-p">
            KPI tiles, time-series charts and drill-down tables wired straight into your warehouse.
            We build analytics surfaces that load fast on real data and stay legible as the
            questions get harder.
          </p>
          <ul class="ps-bullets">
            <li>Warehouse-native pipelines</li>
            <li>Sub-second filtering and segmentation</li>
            <li>Scheduled, export-ready reports</li>
          </ul>
        </div>
      </article>

      <!-- ============================================================
           3. Booking / scheduling — desktop browser frame
           ============================================================ -->
      <article class="ps-item" data-loop="6200">
        <div class="ps-frame-col ps-frame-col--wide">
          <div class="ps-browser-wrap">
            <div class="ps-browser">
              <div class="ps-browser-chrome">
                <div class="ps-browser-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div>
                <div class="ps-browser-tabs">
                  <span class="ps-browser-tab is-active">Calendar</span>
                  <span class="ps-browser-tab">Services</span>
                  <span class="ps-browser-tab">Customers</span>
                </div>
                <div class="ps-browser-url">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4a6359" stroke-width="2" stroke-linecap="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 1 1 8 0v3"/></svg>
                  <span>bookings.demo/calendar</span>
                </div>
              </div>
              <div class="ps-browser-body ps-bk" role="img" aria-label="Booking and scheduling system mockup">
                <div class="ps-bk-head">
                  <div>
                    <div class="ps-bk-title">Bookings</div>
                    <div class="ps-bk-sub">Week of Mon 1 Jun</div>
                  </div>
                  <div class="ps-bk-head-right">
                    <span class="ps-bk-chev"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></span>
                    <span class="ps-bk-this">This week</span>
                    <span class="ps-bk-chev"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg></span>
                    <span class="ps-bk-new">+ New booking</span>
                  </div>
                </div>

                <div class="ps-bk-grid">
                  <div class="ps-bk-times">
                    <span>9</span><span>10</span><span>11</span><span>12</span><span>1</span><span>2</span>
                  </div>
                  <div class="ps-bk-col">
                    <div class="ps-bk-col-h">Mon 1</div>
                    <div class="ps-bk-slots">
                      <div class="ps-bk-appt c-green" style="--row: 1; --span: 2;">
                        <span class="t">9:00</span>
                        <span class="n">Consultation</span>
                      </div>
                      <div class="ps-bk-appt c-amber" style="--row: 4; --span: 1;">
                        <span class="t">12:30</span>
                        <span class="n">Review</span>
                      </div>
                    </div>
                  </div>
                  <div class="ps-bk-col">
                    <div class="ps-bk-col-h">Tue 2</div>
                    <div class="ps-bk-slots">
                      <div class="ps-bk-appt c-blue" style="--row: 2; --span: 1;">
                        <span class="t">10:00</span>
                        <span class="n">Onboarding</span>
                      </div>
                      <div class="ps-bk-appt c-green" style="--row: 5; --span: 2;">
                        <span class="t">1:00</span>
                        <span class="n">Workshop</span>
                      </div>
                    </div>
                  </div>
                  <div class="ps-bk-col">
                    <div class="ps-bk-col-h">Wed 3</div>
                    <div class="ps-bk-slots">
                      <div class="ps-bk-appt c-amber" style="--row: 1; --span: 1;">
                        <span class="t">9:00</span>
                        <span class="n">Standup</span>
                      </div>
                      <div class="ps-bk-appt ps-bk-new-appt c-green" style="--row: 3; --span: 2;">
                        <span class="t">11:00</span>
                        <span class="n">Strategy session</span>
                      </div>
                    </div>
                  </div>
                  <div class="ps-bk-col">
                    <div class="ps-bk-col-h">Thu 4</div>
                    <div class="ps-bk-slots">
                      <div class="ps-bk-appt c-blue" style="--row: 2; --span: 2;">
                        <span class="t">10:00</span>
                        <span class="n">Deep work</span>
                      </div>
                      <div class="ps-bk-appt c-green" style="--row: 5; --span: 1;">
                        <span class="t">1:00</span>
                        <span class="n">Check-in</span>
                      </div>
                    </div>
                  </div>
                  <div class="ps-bk-col">
                    <div class="ps-bk-col-h">Fri 5</div>
                    <div class="ps-bk-slots">
                      <div class="ps-bk-appt c-amber" style="--row: 1; --span: 1;">
                        <span class="t">9:00</span>
                        <span class="n">Planning</span>
                      </div>
                      <div class="ps-bk-appt c-blue" style="--row: 4; --span: 2;">
                        <span class="t">12:30</span>
                        <span class="n">Demo</span>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="ps-bk-toast" aria-hidden="true">
                  <span class="ps-bk-toast-check">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                  <span class="ps-bk-toast-text">
                    <strong>Booking confirmed</strong>
                    <span>Wed 11:00 · Strategy session</span>
                  </span>
                </div>
              </div>
            </div>
            <div class="ps-caption">
              <span class="ps-cap-badge"><span class="ps-cap-dot"></span>Booking platform — sample interface</span>
            </div>
          </div>
        </div>

        <div class="ps-text-col">
          <span class="ps-tag">Scheduling · web</span>
          <h3 class="ps-h3">Calendars that book themselves</h3>
          <p class="ps-p">
            Availability, holds, deposits and confirmations across staff, rooms and resources. We
            build scheduling that handles the awkward edges — overlaps, cancellations, time zones
            — so the rest of the flow just works.
          </p>
          <ul class="ps-bullets">
            <li>Multi-resource availability engine</li>
            <li>Calendar, email and SMS confirmations</li>
            <li>Stripe-ready deposits and refunds</li>
          </ul>
        </div>
      </article>

      <!-- ============================================================
           4. Logistics / fleet tracking — tablet frame
           ============================================================ -->
      <article class="ps-item ps-item--reverse" data-loop="6000">
        <div class="ps-frame-col ps-frame-col--wide">
          <div class="ps-tablet-wrap">
            <div class="ps-tablet">
              <div class="ps-tablet-cam" aria-hidden="true"></div>
              <div class="ps-tablet-screen">
                <div class="ps-fl" role="img" aria-label="Fleet tracking dashboard mockup">
                  <aside class="ps-fl-side">
                    <div class="ps-fl-side-h">
                      <span>Vehicles</span>
                      <span class="ps-fl-side-count">12</span>
                    </div>
                    <div class="ps-fl-veh is-active">
                      <div class="ps-fl-veh-row">
                        <span class="ps-fl-veh-id">TRK-04</span>
                        <span class="ps-fl-veh-status en-route"><span class="ps-fl-dot"></span>En route</span>
                      </div>
                      <div class="ps-fl-veh-meta">
                        <span>Driver M. Chen</span>
                        <span>ETA <span class="ps-count" data-count-target="12" data-count-start="18">18</span> min</span>
                      </div>
                    </div>
                    <div class="ps-fl-veh">
                      <div class="ps-fl-veh-row">
                        <span class="ps-fl-veh-id">TRK-07</span>
                        <span class="ps-fl-veh-status arrived"><span class="ps-fl-dot"></span>Arrived</span>
                      </div>
                      <div class="ps-fl-veh-meta">
                        <span>Driver L. Patel</span>
                        <span>Dock 3</span>
                      </div>
                    </div>
                    <div class="ps-fl-veh">
                      <div class="ps-fl-veh-row">
                        <span class="ps-fl-veh-id">TRK-12</span>
                        <span class="ps-fl-veh-status idle"><span class="ps-fl-dot"></span>Idle</span>
                      </div>
                      <div class="ps-fl-veh-meta">
                        <span>Driver A. Singh</span>
                        <span>Depot</span>
                      </div>
                    </div>
                  </aside>

                  <div class="ps-fl-map">
                    <svg class="ps-fl-svg" viewBox="0 0 400 280" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
                      <defs>
                        <pattern id="psFleetGrid" width="32" height="32" patternUnits="userSpaceOnUse">
                          <path d="M 32 0 L 0 0 0 32" fill="none" stroke="rgba(255,255,255,0.035)" stroke-width="1"/>
                        </pattern>
                        <linearGradient id="psRoute" x1="0" y1="0" x2="1" y2="0">
                          <stop offset="0%" stop-color="#0d9373" stop-opacity="0.3"/>
                          <stop offset="100%" stop-color="#0d9373" stop-opacity="1"/>
                        </linearGradient>
                      </defs>
