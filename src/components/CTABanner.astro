---
---

<section class="cta-banner" id="cta">
  <div class="cta-bg" aria-hidden="true">
    <div class="cta-glow-1"></div>
    <div class="cta-glow-2"></div>
    <div class="cta-grid-lines"></div>
  </div>

  <div class="cta-inner reveal">
    <div class="cta-badge">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
      <span>Let's Build Something Extraordinary</span>
    </div>

    <h2 class="cta-heading">
      Ready to Transform Your<br />
      Technology Operations?
    </h2>

    <p class="cta-sub">
      Join 150+ enterprise organisations that trust All Webbed Labs to deliver their most critical software projects.
      Let's talk about what we can build together.
    </p>

    <div class="cta-actions">
      <a href="/contact" class="cta-btn-primary">
        Book a Strategy Call
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="mailto:labs@allwebbedup.com.au" class="cta-btn-secondary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        labs@allwebbedup.com.au
      </a>
    </div>

    <div class="cta-proof">
      <div class="cta-proof-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Free 30-minute strategy call</span>
      </div>
      <div class="cta-proof-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>No commitment required</span>
      </div>
      <div class="cta-proof-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Response within 1 business day</span>
      </div>
      <div class="cta-proof-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>NDA available on request</span>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    padding: 6rem 0;
    background: linear-gradient(135deg, #061612 0%, #0a1d18 30%, #091511 60%, #061612 100%);
    position: relative;
    overflow: hidden;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-glow-1 {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(13,147,115,0.18) 0%, transparent 65%);
  }

  .cta-glow-2 {
    position: absolute;
    bottom: -30%;
    right: 10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(0,232,122,0.06) 0%, transparent 70%);
  }

  .cta-grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(13,147,115,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(13,147,115,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    padding: 0 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .cta-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(13,147,115,0.12);
    border: 1px solid rgba(13,147,115,0.3);
    color: #0d9373;
    padding: 0.5rem 1.125rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .cta-heading {
    font-family: 'Sora', sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: white;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .cta-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    color: #8aa09a;
    line-height: 1.65;
    margin: 0;
    max-width: 640px;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    background: #0d9373;
    color: white;
    padding: 1.0625rem 2.5rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1.0625rem;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 8px 40px rgba(13,147,115,0.45);
  }
  .cta-btn-primary:hover {
    background: #10b88a;
    transform: translateY(-2px);
    box-shadow: 0 12px 50px rgba(13,147,115,0.55);
  }

  .cta-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    background: transparent;
    color: #8aa09a;
    padding: 1.0625rem 1.75rem;
    border-radius: 50px;
    border: 1.5px solid #1e2d28;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .cta-btn-secondary:hover {
    border-color: #0d9373;
    color: #0d9373;
  }

  .cta-proof {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 0.5rem;
  }

  .cta-proof-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #4a6359;
  }

  .cta-proof-item svg {
    color: #0d9373;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .cta-banner {
      padding: 5rem 0;
    }
    .cta-actions {
      flex-direction: column;
    }
    .cta-btn-primary,
    .cta-btn-secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
