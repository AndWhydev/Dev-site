---
const pillars = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
    label: 'Enterprise-Grade Security',
    heading: 'Security Is Not An Afterthought',
    body: 'Every application we build is architected with security from line one. OWASP standards, penetration testing, end-to-end encryption and role-based access control are built-in, not bolted on.',
    visual: 'lock',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/><path d="M16 4.93A9 9 0 0121 12"/></svg>`,
    label: 'Transparent Delivery',
    heading: 'No Surprises. Ever.',
    body: 'A clear roadmap, weekly updates and milestones agreed in writing. If something is at risk, you hear it from us first, not when the deadline arrives.',
    visual: 'milestones',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`,
    label: 'Australian Entity',
    heading: 'Sydney-Registered, AEST Hours.',
    body: 'All Webbed Labs is the trading name of AW Labs Pty Ltd, an Australian-registered company based in Sydney. Sister to All Webbed Up. Delivery runs during AEST hours and work is not offshored or subcontracted overseas without your written consent.',
    visual: 'map',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    label: 'Post-Launch Support',
    heading: 'We Grow With You',
    body: 'Launch is the beginning, not the end. Every engagement includes a structured hypercare period, SLA-backed support and a dedicated account team for ongoing evolution.',
    visual: 'sla',
  },
];
---

<section class="why-section" id="why">
  <div class="why-inner">
    <div class="why-header reveal">
      <span class="section-label">Why All Webbed Labs</span>
      <h2 class="section-heading">The Enterprise Partner You Can Rely On</h2>
      <p class="section-subheading">
        We're not a traditional agency. We're a technology partner built to operate at the pace and complexity of enterprise.
      </p>
    </div>

    <div class="pillars-grid">
      {pillars.map((pillar, i) => (
        <div class={`pillar pillar--${pillar.visual} spotlight-card tilt-card reveal stagger-${i + 1}`}>
          {/* Per-pillar background visual, each one unique to the section. */}
          <div class="pillar-visual" aria-hidden="true">
            {pillar.visual === 'lock' && (
              <svg viewBox="0 0 120 120" class="pv-svg">
                {[0,1,2,3,4,5].map((j) => (
                  <circle cx="60" cy="60" r={18 + j * 8} fill="none" stroke="currentColor" stroke-opacity={0.18 - j * 0.025} stroke-width="1" />
                ))}
                <rect x="46" y="54" width="28" height="22" rx="4" fill="none" stroke="currentColor" stroke-opacity="0.55" stroke-width="1.4" />
                <path d="M52 54v-6a8 8 0 0116 0v6" fill="none" stroke="currentColor" stroke-opacity="0.55" stroke-width="1.4" stroke-linecap="round" />
              </svg>
            )}
            {pillar.visual === 'milestones' && (
              <svg viewBox="0 0 120 120" class="pv-svg">
                <line x1="14" y1="60" x2="106" y2="60" stroke="currentColor" stroke-opacity="0.25" stroke-width="1.2" stroke-dasharray="3 4" />
                {[20, 45, 70, 95].map((x, j) => (
                  <g>
                    <circle cx={x} cy="60" r="5" fill="currentColor" fill-opacity={0.18 + j * 0.07} />
                    <circle cx={x} cy="60" r="9" fill="none" stroke="currentColor" stroke-opacity={0.25 - j * 0.04} />
                  </g>
                ))}
              </svg>
            )}
            {pillar.visual === 'map' && (
              <svg viewBox="0 0 120 120" class="pv-svg">
                {/* Stylised Australia silhouette */}
                <path
                  d="M22 70 Q15 55 26 48 Q38 42 50 46 Q58 39 70 41 Q82 40 92 50 Q104 56 100 70 Q98 82 86 88 Q72 96 58 92 Q44 92 32 86 Q24 80 22 70 Z"
                  fill="none"
                  stroke="currentColor"
                  stroke-opacity="0.5"
                  stroke-width="1.4"
                  stroke-linejoin="round"
                />
                <circle cx="74" cy="70" r="3" fill="currentColor" />
                <circle cx="74" cy="70" r="9" fill="none" stroke="currentColor" stroke-opacity="0.4" />
                <circle cx="74" cy="70" r="14" fill="none" stroke="currentColor" stroke-opacity="0.15" />
              </svg>
            )}
            {pillar.visual === 'sla' && (
              <svg viewBox="0 0 120 120" class="pv-svg">
                <polyline
                  points="14,84 32,72 50,76 68,54 86,46 106,30"
                  fill="none"
                  stroke="currentColor"
                  stroke-opacity="0.55"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                {[
                  [14,84],[32,72],[50,76],[68,54],[86,46],[106,30],
                ].map(([x,y]) => (
                  <circle cx={x} cy={y} r="2.6" fill="currentColor" fill-opacity="0.85" />
                ))}
                <line x1="14" y1="100" x2="106" y2="100" stroke="currentColor" stroke-opacity="0.18" stroke-width="1" />
              </svg>
            )}
          </div>
          <div class="pillar-top">
            <div class="pillar-icon" set:html={pillar.icon} />
          </div>
          <div class="pillar-label">{pillar.label}</div>
          <h3 class="pillar-heading">{pillar.heading}</h3>
          <p class="pillar-body">{pillar.body}</p>
        </div>
      ))}
    </div>

    <!-- Bottom proof row -->
    <div class="proof-row reveal stagger-5">
      <div class="proof-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Senior engineers only, no juniors on client projects</span>
      </div>
      <div class="proof-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Fixed-price and time-and-materials engagement models</span>
      </div>
      <div class="proof-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Full IP ownership transferred to you on completion</span>
      </div>
      <div class="proof-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Comprehensive documentation and knowledge transfer</span>
      </div>
    </div>
  </div>
</section>

<style>
  .why-section {
    padding: 6rem 0;
    background: #0a0a0a;
    position: relative;
    overflow: hidden;
  }

  .why-section::after {
    content: '';
    position: absolute;
    right: -200px;
    top: 20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(13,147,115,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .why-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  .why-header {
    max-width: 680px;
    margin-bottom: 4rem;
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }

  .pillar {
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 20px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .pillar::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(13,147,115,0.5), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .pillar:hover {
    border-color: rgba(13,147,115,0.3);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.3), 0 0 30px rgba(13,147,115,0.08);
  }

  .pillar:hover::before {
    opacity: 1;
  }

  .pillar-visual {
    position: absolute;
    top: 50%;
    right: -8px;
    transform: translateY(-50%);
    width: 110px;
    height: 110px;
    color: #0d9373;
    opacity: 0.32;
    pointer-events: none;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .pillar-visual .pv-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .pillar:hover .pillar-visual {
    opacity: 0.55;
    transform: translateY(-50%) scale(1.04);
  }
  .pillar--lock .pillar-visual { animation: pv-lock-pulse 6s ease-in-out infinite; }
  .pillar--sla .pillar-visual { animation: pv-sla-drift 6s ease-in-out infinite; }
  @keyframes pv-lock-pulse {
    0%, 100% { opacity: 0.28; }
    50% { opacity: 0.42; }
  }
  @keyframes pv-sla-drift {
    0%, 100% { transform: translateY(-50%) translateX(0); }
    50% { transform: translateY(-50%) translateX(-3px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pillar--lock .pillar-visual,
    .pillar--sla .pillar-visual { animation: none; }
  }

  .pillar-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }

  .pillar-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: rgba(13,147,115,0.08);
    border: 1px solid rgba(13,147,115,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0d9373;
  }

  .pillar-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #4a6359;
    position: relative;
    z-index: 1;
  }

  .pillar-heading {
    font-family: 'Sora', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
    line-height: 1.2;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .pillar-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: #4a6359;
    line-height: 1.65;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .proof-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid #1e2d28;
    border-radius: 16px;
    padding: 1.75rem 2rem;
  }

  .proof-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
  }

  .proof-item svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .proof-item span {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #8aa09a;
    line-height: 1.5;
  }

  @media (max-width: 1100px) {
    .pillars-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .proof-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .why-section { padding: 4rem 0; }
    .why-inner { padding: 0 1.25rem; }
    .why-header { margin-bottom: 2.5rem; }
    .pillars-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .pillar { padding: 1.75rem 1.5rem; }
    .pillar-visual { width: 90px; height: 90px; right: -4px; }
    .proof-row {
      grid-template-columns: 1fr;
      padding: 1.25rem 1.5rem;
      gap: 1rem;
    }
  }
</style>
