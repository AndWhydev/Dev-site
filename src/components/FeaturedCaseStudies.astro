---
const featured = [
  {
    industry: 'AI & Automation',
    title: 'Customer Service AI Chatbot',
    summary: 'A Queensland telco resolved 71% of customer enquiries automatically — cutting average wait time from 18 minutes to under 2 minutes.',
    metric: '71%',
    metricLabel: 'enquiries resolved without humans',
    tags: ['OpenAI GPT-4', 'LangChain', 'RAG'],
    href: '/case-studies/customer-service-ai-chatbot',
    accent: '#0d9373',
  },
  {
    industry: 'Financial Services',
    title: 'Loan Application & Assessment Platform',
    summary: 'A Melbourne non-bank lender cut application assessment time from 5 days to 4 hours — without adding headcount.',
    metric: '4 hrs',
    metricLabel: 'average assessment time (was 5 days)',
    tags: ['React', 'FastAPI', 'Credit Assessment'],
    href: '/case-studies/loan-application-assessment-platform',
    accent: '#0d9373',
  },
  {
    industry: 'Logistics & Transport',
    title: 'Fleet Tracking & Job Dispatch System',
    summary: 'A Sydney courier company with 45 vehicles gained real-time GPS, automated ETAs and route optimisation — reducing average delivery time by 18%.',
    metric: '18%',
    metricLabel: 'reduction in average delivery time',
    tags: ['React', 'Flutter', 'Google Maps API'],
    href: '/case-studies/fleet-tracking-job-dispatch',
    accent: '#0d9373',
  },
];
---

<section class="fcs-section" id="case-studies-preview">
  <div class="fcs-inner">
    <div class="fcs-header reveal">
      <div class="fcs-header-left">
        <span class="section-label">Case Studies</span>
        <h2 class="section-heading">Problems Solved. Results Delivered.</h2>
        <p class="section-subheading">
          Real projects. Honest outcomes. Read the full story behind some of our recent work.
        </p>
      </div>
      <a href="/case-studies" class="btn-outline fcs-all-link">
        View All 34 Case Studies
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="fcs-grid">
      {featured.map((cs, i) => (
        <a href={cs.href} class={`fcs-card card-hover reveal stagger-${i + 1}`}>
          <!-- IMAGE_PLACEHOLDER — add real screenshot for {cs.title} -->
          <div class="fcs-card-img">
            <div class="fcs-industry-badge">{cs.industry}</div>
            <div class="fcs-metric-badge">
              <span class="fcs-metric-val">{cs.metric}</span>
              <span class="fcs-metric-lbl">{cs.metricLabel}</span>
            </div>
          </div>
          <div class="fcs-card-body">
            <h3 class="fcs-card-title">{cs.title}</h3>
            <p class="fcs-card-summary">{cs.summary}</p>
            <div class="fcs-card-tags">
              {cs.tags.map(t => <span class="fcs-tag">{t}</span>)}
            </div>
            <span class="fcs-card-cta">
              Read case study
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="fcs-bottom reveal stagger-4">
      <div class="fcs-stat">
        <span class="fcs-stat-num">34</span>
        <span class="fcs-stat-lbl">Case studies across 10 industries</span>
      </div>
      <div class="fcs-stat-divider" aria-hidden="true"></div>
      <div class="fcs-stat">
        <span class="fcs-stat-num">100%</span>
        <span class="fcs-stat-lbl">Australian business context</span>
      </div>
      <div class="fcs-stat-divider" aria-hidden="true"></div>
      <div class="fcs-stat">
        <span class="fcs-stat-num">Honest</span>
        <span class="fcs-stat-lbl">Metrics — not inflated figures</span>
      </div>
      <a href="/case-studies" class="btn-primary fcs-bottom-cta">
        Browse All Case Studies
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .fcs-section {
    padding: 8rem 0;
    background: #0f1614;
    position: relative;
    overflow: hidden;
  }
  .fcs-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #0a0f0e 0%, transparent 8%, transparent 92%, #0a0f0e 100%);
    pointer-events: none;
  }
  .fcs-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }
  .fcs-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  .fcs-header-left .section-subheading { margin-bottom: 0; }
  .fcs-all-link { flex-shrink: 0; }

  .fcs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .fcs-card {
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
  }

  .fcs-card-img {
    aspect-ratio: 16/9;
    background: linear-gradient(135deg, #141c1a 0%, #0f1614 100%);
    border-bottom: 1px solid #1e2d28;
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1rem;
  }
  .fcs-card-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 60%, rgba(13,147,115,0.15) 0%, transparent 65%);
  }

  .fcs-industry-badge {
    position: relative;
    z-index: 1;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #0d9373;
    background: rgba(13,147,115,0.12);
    border: 1px solid rgba(13,147,115,0.25);
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
  }

  .fcs-metric-badge {
    position: relative;
    z-index: 1;
    background: rgba(10, 15, 14, 0.85);
    border: 1px solid rgba(13,147,115,0.25);
    border-radius: 10px;
    padding: 0.625rem 0.875rem;
    text-align: right;
    backdrop-filter: blur(8px);
  }
  .fcs-metric-val {
    display: block;
    font-family: 'Sora', sans-serif;
    font-size: 1.375rem;
    font-weight: 800;
    color: #0d9373;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .fcs-metric-lbl {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.625rem;
    color: #4a6359;
    line-height: 1.3;
    max-width: 120px;
    margin-top: 0.2rem;
  }

  .fcs-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .fcs-card-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: white;
    margin: 0;
    line-height: 1.2;
    transition: color 0.2s ease;
  }
  .fcs-card:hover .fcs-card-title { color: #0d9373; }

  .fcs-card-summary {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #4a6359;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .fcs-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .fcs-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    color: #4a6359;
    background: rgba(255,255,255,0.04);
    border: 1px solid #1e2d28;
    padding: 0.175rem 0.45rem;
    border-radius: 4px;
  }

  .fcs-card-cta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #0d9373;
    transition: gap 0.2s ease;
  }
  .fcs-card:hover .fcs-card-cta { gap: 0.625rem; }

  /* Bottom row */
  .fcs-bottom {
    display: flex;
    align-items: center;
    gap: 2rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid #1e2d28;
    border-radius: 16px;
    padding: 1.75rem 2rem;
    flex-wrap: wrap;
  }
  .fcs-stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .fcs-stat-num {
    font-family: 'Sora', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.03em;
  }
  .fcs-stat-lbl {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
  }
  .fcs-stat-divider {
    width: 1px;
    height: 36px;
    background: #1e2d28;
    flex-shrink: 0;
  }
  .fcs-bottom-cta { margin-left: auto; }

  @media (max-width: 1024px) {
    .fcs-grid { grid-template-columns: 1fr; }
    .fcs-header { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 640px) {
    .fcs-section { padding: 5rem 0; }
    .fcs-bottom { flex-direction: column; align-items: flex-start; }
    .fcs-stat-divider { display: none; }
    .fcs-bottom-cta { margin-left: 0; }
  }
</style>
