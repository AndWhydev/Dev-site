---
/**
 * Craft-as-proof showcase. Three full-bore enterprise UI demos hosted on
 * this same site (/demos/*), embedded live via iframe so a visitor can
 * see them rendered, not just described. Posters cover the iframe until
 * it boots so first paint is instant; iframes are lazy-loaded.
 *
 * Honesty constraint: these are concept demos, not shipped client apps.
 * The "Concept demo" badge says so. The shipped-in-production proof
 * lives in LiveAppDemo (golf app) immediately below this section.
 */

const demos = [
  {
    href: '/demos/finance',
    host: 'demos.awlabs.com.au/finance',
    eyebrow: 'Concept demo',
    name: 'FinanceOS',
    title: 'Treasury & banking dashboard',
    blurb:
      'Multi-account positions, real-time exposure, audit trail. The kind of console a CFO actually opens at 8am.',
    chips: ['Sora type', 'Live state', 'Audit-ready'],
  },
  {
    href: '/demos/logistics',
    host: 'demos.awlabs.com.au/logistics',
    eyebrow: 'Concept demo',
    name: 'FleetCommand',
    title: 'Live fleet operations',
    blurb:
      'Vehicle map, exception lane, dispatcher queue. Designed for the screen that never gets closed during a shift.',
    chips: ['Map-first', 'Status SLAs', 'Dense data'],
  },
  {
    href: '/demos/saas',
    host: 'demos.awlabs.com.au/saas',
    eyebrow: 'Concept demo',
    name: 'NexusCRM',
    title: 'Pipeline & customer ops',
    blurb:
      'Pipeline, accounts, segments, automations. The CRM you would build if you knew what your team actually clicked on.',
    chips: ['Workflows', 'Segments', 'Roles & perms'],
  },
];
---

<section class="demos-showcase" aria-label="Live interface demos built by All Webbed Labs">
  <div class="demos-inner">

    <header class="demos-header reveal">
      <span class="section-label">Interface craft, live</span>
      <h2 class="section-heading">Three full interfaces. Embedded, not screenshotted.</h2>
      <p class="section-subheading">
        Every pixel below is real HTML and CSS rendered live in your browser. Click any panel to open the full demo in a new tab and have a play.
      </p>
    </header>

    <div class="demos-grid">
      {demos.map((d, i) => (
        <a
          class={`demo-card reveal stagger-${i + 1}`}
          href={d.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Open ${d.name} — ${d.title} — in a new tab`}
        >
          <div class="demo-chrome">
            <div class="demo-dots">
              <span class="dot red"></span>
              <span class="dot yellow"></span>
              <span class="dot green"></span>
            </div>
            <div class="demo-bar">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#4a6359" stroke-width="2" stroke-linecap="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 1 1 8 0v3"/></svg>
              <span>{d.host}</span>
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="demo-open" aria-hidden="true">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l10-10M9 7h8v8"/></svg>
            </span>
          </div>

          <div class="demo-stage">
            <div class="demo-poster" aria-hidden="true">
              <div class="poster-eyebrow">{d.eyebrow}</div>
              <div class="poster-title">{d.name}</div>
              <div class="poster-meta">{d.title}</div>
            </div>
            <iframe
              class="demo-iframe"
              src={d.href}
              title={`${d.name} — ${d.title}`}
              loading="lazy"
              referrerpolicy="no-referrer"
              sandbox="allow-scripts allow-same-origin"
              tabindex="-1"
              aria-hidden="true"
            ></iframe>
          </div>

          <div class="demo-meta">
            <div class="demo-meta-top">
              <h3 class="demo-name">{d.name}</h3>
              <span class="demo-pill">Live preview</span>
            </div>
            <p class="demo-blurb">{d.blurb}</p>
            <div class="demo-chips">
              {d.chips.map((c) => <span class="demo-chip">{c}</span>)}
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="demos-foot reveal">
      <p>
        Concept demos, built end-to-end by All Webbed Labs to show how we approach dense, production-grade interfaces. For an app that is <em>actually shipped and serving real users</em>, see the live golf app embed below.
      </p>
    </div>

  </div>
</section>

<style>
  .demos-showcase {
    background: #08100d;
    padding: 6.5rem 0;
    position: relative;
    overflow: hidden;
    border-top: 1px solid #1e2d28;
    border-bottom: 1px solid #1e2d28;
  }
  .demos-showcase::before {
    content: '';
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 1100px;
    height: 700px;
    background: radial-gradient(ellipse, rgba(13,147,115,0.07) 0%, transparent 65%);
    pointer-events: none;
  }
  .demos-inner {
    max-width: 1340px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
  }

  .demos-header {
    text-align: center;
    max-width: 820px;
    margin: 0 auto 4rem;
  }

  .demos-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  /* ── Card ──────────────────────────────────── */
  .demo-card {
    display: flex;
    flex-direction: column;
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.4s cubic-bezier(0.19, 1, 0.22, 1),
      border-color 0.3s ease,
      box-shadow 0.4s ease;
    box-shadow:
      0 18px 50px rgba(0,0,0,0.45),
      0 0 0 1px transparent;
    position: relative;
    isolation: isolate;
  }
  .demo-card:hover {
    transform: translateY(-4px);
    border-color: rgba(13,147,115,0.45);
    box-shadow:
      0 28px 70px rgba(0,0,0,0.6),
      0 0 30px rgba(13,147,115,0.18);
  }
  .demo-card:focus-visible {
    outline: 2px solid #0d9373;
    outline-offset: 3px;
  }

  /* ── Browser chrome ───────────────────────── */
  .demo-chrome {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.55rem 0.75rem;
    background: #0a0a0a;
    border-bottom: 1px solid #1e2d28;
  }
  .demo-dots { display: flex; gap: 5px; flex-shrink: 0; }
  .demo-dots .dot { width: 10px; height: 10px; border-radius: 50%; }
  .demo-dots .red { background: #ff5f57; }
  .demo-dots .yellow { background: #febc2e; }
  .demo-dots .green { background: #28c840; }
  .demo-bar {
    flex: 1;
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 6px;
    padding: 0.25rem 0.625rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    overflow: hidden;
    min-width: 0;
  }
  .demo-bar span {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    color: #8aa09a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
  }
  .demo-open {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: rgba(13,147,115,0.12);
    border: 1px solid rgba(13,147,115,0.3);
    color: #0d9373;
    flex-shrink: 0;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .demo-card:hover .demo-open {
    background: rgba(13,147,115,0.22);
    color: #10b88a;
  }

  /* ── Stage with poster + iframe ───────────── */
  .demo-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 11;
    background: #0a0f0e;
    overflow: hidden;
  }
  .demo-poster {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(80% 60% at 50% 30%, rgba(13,147,115,0.18) 0%, transparent 70%),
      linear-gradient(180deg, #0a0f0e 0%, #050807 100%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 1rem;
    gap: 0.4rem;
    pointer-events: none;
  }
  .poster-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0d9373;
  }
  .poster-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    letter-spacing: -0.02em;
  }
  .poster-meta {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #6b8079;
  }
  .demo-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    background: transparent;
    z-index: 1;
    pointer-events: none; /* card itself is the click target */
  }

  /* ── Footer meta ──────────────────────────── */
  .demo-meta {
    padding: 1.25rem 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    border-top: 1px solid #1e2d28;
  }
  .demo-meta-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .demo-name {
    font-family: 'Sora', sans-serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: white;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .demo-pill {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #0d9373;
    background: rgba(13,147,115,0.1);
    border: 1px solid rgba(13,147,115,0.25);
    padding: 0.2rem 0.55rem;
    border-radius: 50px;
    white-space: nowrap;
  }
  .demo-blurb {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #8aa09a;
    margin: 0;
  }
  .demo-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }
  .demo-chip {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    color: #cde0da;
    background: rgba(255,255,255,0.04);
    border: 1px solid #1e2d28;
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
  }

  /* ── Footer note ──────────────────────────── */
  .demos-foot {
    margin: 3rem auto 0;
    max-width: 760px;
    text-align: center;
  }
  .demos-foot p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    line-height: 1.7;
    color: #6b8079;
    margin: 0;
  }
  .demos-foot em {
    color: #cde0da;
    font-style: normal;
    font-weight: 600;
  }

  /* ── Responsive ───────────────────────────── */
  @media (max-width: 1100px) {
    .demos-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .demo-card:last-child { grid-column: 1 / -1; max-width: 640px; justify-self: center; width: 100%; }
  }
  @media (max-width: 720px) {
    .demos-showcase { padding: 4.5rem 0; }
    .demos-inner { padding: 0 1.25rem; }
    .demos-header { margin-bottom: 2.5rem; }
    .demos-grid { grid-template-columns: 1fr; gap: 1.25rem; }
    .demo-card:last-child { max-width: 100%; }
    .demo-stage { aspect-ratio: 16 / 12; }
  }
</style>
