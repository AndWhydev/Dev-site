---
const liveUrl = 'https://golf-app-demo.vercel.app';
---

<section class="rae-section" id="real-app">
  <div class="rae-inner">
    <div class="rae-header reveal">
      <span class="section-label">A real app we built</span>
      <h2 class="section-heading">Try it for yourself</h2>
      <p class="section-subheading">
        An animated preview of one of our shipped mobile interfaces —
        designed, built and styled end-to-end by our team.
      </p>
    </div>

    <div class="rae-row">
      <div class="rae-frame-col reveal-left">
        <div class="rae-phone-wrap">
          <div class="rae-phone-glow" aria-hidden="true"></div>
          <div class="rae-phone">
            <div class="rae-btn-silent" aria-hidden="true"></div>
            <div class="rae-btn-vol-up" aria-hidden="true"></div>
            <div class="rae-btn-vol-down" aria-hidden="true"></div>
            <div class="rae-btn-power" aria-hidden="true"></div>

            <div class="rae-phone-body">
              <div class="rae-phone-screen">
                <div class="rae-island" aria-hidden="true"></div>

                <div class="rae-mock-app" role="img" aria-label="Animated mobile application interface mockup">
                  <div class="rae-mock-status">
                    <span class="rae-mock-time">9:41</span>
                    <div class="rae-mock-status-icons">
                      <svg width="14" height="10" viewBox="0 0 14 10" fill="white" aria-hidden="true"><rect x="0" y="6" width="2.5" height="4" rx="0.5"/><rect x="3.5" y="4" width="2.5" height="6" rx="0.5"/><rect x="7" y="2" width="2.5" height="8" rx="0.5"/><rect x="10.5" y="0" width="2.5" height="10" rx="0.5"/></svg>
                      <svg width="13" height="10" viewBox="0 0 13 10" fill="white" aria-hidden="true"><path d="M6.5 0C4 0 1.7 1 0 2.5l1.2 1.2C2.6 2.5 4.5 1.8 6.5 1.8s3.9.7 5.3 1.9L13 2.5C11.3 1 9 0 6.5 0zm0 3.6C5 3.6 3.7 4.2 2.7 5l1.2 1.2c.7-.5 1.6-.9 2.6-.9s1.9.3 2.6.9L10.3 5C9.3 4.2 8 3.6 6.5 3.6zm0 3.4c-.8 0-1.5.3-2 .8L6.5 10l2-2.2c-.5-.5-1.2-.8-2-.8z"/></svg>
                      <svg width="22" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true"><rect x="0.5" y="0.5" width="18" height="9" rx="2" stroke="white" stroke-opacity="0.5"/><rect x="2" y="2" width="14" height="6" rx="1" fill="white"/><rect x="20" y="3.5" width="1.5" height="3" rx="0.5" fill="white" fill-opacity="0.5"/></svg>
                    </div>
                  </div>

                  <div class="rae-mock-header">
                    <div>
                      <div class="rae-mock-greeting">Good morning</div>
                      <div class="rae-mock-name">Welcome back</div>
                    </div>
                    <div class="rae-mock-avatar" aria-hidden="true">A</div>
                  </div>

                  <div class="rae-mock-balance">
                    <div class="rae-mock-balance-top">
                      <span class="rae-mock-balance-label">Total balance</span>
                      <span class="rae-mock-balance-trend">
                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 15 12 9 18 15"/></svg>
                        2.4%
                      </span>
                    </div>
                    <div class="rae-mock-balance-value">
                      <span class="rae-mock-currency">$</span><span class="rae-mock-count" data-start="12200" data-target="12847">12,847</span><span class="rae-mock-decimals">.50</span>
                    </div>
                    <svg class="rae-mock-chart" viewBox="0 0 220 64" preserveAspectRatio="none" aria-hidden="true">
                      <defs>
                        <linearGradient id="raeMockChartGrad" x1="0" y1="0" x2="0" y2="1">
                          <stop offset="0%" stop-color="#0d9373" stop-opacity="0.45"/>
                          <stop offset="100%" stop-color="#0d9373" stop-opacity="0"/>
                        </linearGradient>
                      </defs>
                      <path class="rae-mock-chart-fill" d="M0,48 C25,44 40,38 65,32 C90,26 105,30 130,22 C155,15 170,10 195,8 C205,7 215,6 220,5 L220,64 L0,64Z" fill="url(#raeMockChartGrad)"/>
                      <path class="rae-mock-chart-line" d="M0,48 C25,44 40,38 65,32 C90,26 105,30 130,22 C155,15 170,10 195,8 C205,7 215,6 220,5" fill="none" stroke="#0d9373" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                    <div class="rae-mock-range">
                      <span class="rae-mock-range-pill active">7D</span>
                      <span class="rae-mock-range-pill">1M</span>
                      <span class="rae-mock-range-pill">3M</span>
                      <span class="rae-mock-range-pill">1Y</span>
                    </div>
                  </div>

                  <div class="rae-mock-section-title">
                    <span>Recent activity</span>
                    <span class="rae-mock-link">View all</span>
                  </div>

                  <div class="rae-mock-activity">
                    <div class="rae-mock-act-row">
                      <div class="rae-mock-act-icon green" aria-hidden="true">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                      </div>
                      <div class="rae-mock-act-info">
                        <div class="rae-mock-act-name">Deposit</div>
                        <div class="rae-mock-act-meta">Today · 09:32</div>
                      </div>
                      <div class="rae-mock-act-amt up">+$420.00</div>
                    </div>
                    <div class="rae-mock-act-row">
                      <div class="rae-mock-act-icon blue" aria-hidden="true">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l10-10M7 7h10v10"/></svg>
                      </div>
                      <div class="rae-mock-act-info">
                        <div class="rae-mock-act-name">Transfer</div>
                        <div class="rae-mock-act-meta">Yesterday</div>
                      </div>
                      <div class="rae-mock-act-amt">−$84.50</div>
                    </div>
                    <div class="rae-mock-act-row">
                      <div class="rae-mock-act-icon amber" aria-hidden="true">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 12h6"/></svg>
                      </div>
                      <div class="rae-mock-act-info">
                        <div class="rae-mock-act-name">Payment</div>
                        <div class="rae-mock-act-meta">2 days ago</div>
                      </div>
                      <div class="rae-mock-act-amt">−$32.00</div>
                    </div>
                  </div>

                  <div class="rae-mock-tabbar" role="tablist" aria-label="App navigation">
                    <button class="rae-mock-tab" data-i="0" type="button" aria-label="Home">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10l9-7 9 7v10a2 2 0 01-2 2h-4v-7h-6v7H5a2 2 0 01-2-2z"/></svg>
                      <span>Home</span>
                    </button>
                    <button class="rae-mock-tab" data-i="1" type="button" aria-label="Overview">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>
                      <span>Overview</span>
                    </button>
                    <button class="rae-mock-tab" data-i="2" type="button" aria-label="Activity">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                      <span>Activity</span>
                    </button>
                    <button class="rae-mock-tab" data-i="3" type="button" aria-label="Reports">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                      <span>Reports</span>
                    </button>
                    <div class="rae-mock-home-indicator" aria-hidden="true"></div>
                  </div>
                </div>

                <div class="rae-screen-overlay" aria-hidden="true"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="rae-text-col reveal-right">
        <span class="rae-tag">Animated demo</span>
        <h3 class="rae-h3">A real app, animated right inside the page.</h3>
        <p class="rae-p">
          The phone on the left is an in-code animation of an app our team
          designed and built — crisp motion, native-feeling interactions,
          no external embed. Open the real app in a new tab whenever you're
          ready.
        </p>
        <ul class="rae-bullets">
          <li>Designed and built end-to-end by our team</li>
          <li>Smooth, native-feeling animation throughout</li>
          <li>Open in a new tab to try the real thing</li>
        </ul>
        <a class="rae-cta" href={liveUrl} target="_blank" rel="noopener noreferrer">
          <span>Open in new tab</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17l10-10M9 7h8v8"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .rae-section {
    background: #0a0f0e;
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
    border-top: 1px solid #1e2d28;
    border-bottom: 1px solid #1e2d28;
  }
  .rae-section::before {
    content: '';
    position: absolute;
    top: 10%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(13,147,115,0.06) 0%, transparent 65%);
    pointer-events: none;
  }
  .rae-section::after {
    content: '';
    position: absolute;
    bottom: -10%;
    left: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(13,147,115,0.045) 0%, transparent 65%);
    pointer-events: none;
  }
  .rae-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
  }
  .rae-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 4rem;
  }

  .rae-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 5rem;
    align-items: center;
  }
  .rae-frame-col { display: flex; justify-content: center; }
  .rae-text-col {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    max-width: 460px;
  }
  .rae-tag {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #0d9373;
    background: rgba(13,147,115,0.1);
    border: 1px solid rgba(13,147,115,0.22);
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
  }
  .rae-h3 {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.6rem, 2.4vw, 2.1rem);
    font-weight: 700;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0;
  }
  .rae-p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    color: #8aa09a;
    margin: 0;
  }
  .rae-bullets {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .rae-bullets li {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #cde0da;
    padding-left: 1.4rem;
    position: relative;
  }
  .rae-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #0d9373;
    box-shadow: 0 0 0 3px rgba(13,147,115,0.18);
  }
  .rae-cta {
    margin-top: 1rem;
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Sora', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, #0d9373 0%, #0a7559 100%);
    border-radius: 999px;
    padding: 0.85rem 1.4rem;
    text-decoration: none;
    box-shadow: 0 10px 28px rgba(13,147,115,0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .rae-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 34px rgba(13,147,115,0.4);
  }

  /* ============ Phone frame (matches LiveAppDemo dimensions) ============ */
  .rae-phone-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .rae-phone-glow {
    position: absolute;
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 340px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(13,147,115,0.18) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .rae-phone {
    position: relative;
    width: 280px;
    z-index: 1;
    flex-shrink: 0;
  }
  .rae-phone-body {
    background: linear-gradient(160deg, #3a3a3c 0%, #1c1c1e 30%, #242426 60%, #3a3a3c 100%);
    border-radius: 48px;
    padding: 13px;
    position: relative;
    box-shadow:
      0 0 0 1px #4a4a4c,
      0 0 0 2.5px #0a0f0e,
      0 30px 100px rgba(0,0,0,0.9),
      0 0 60px rgba(13,147,115,0.12),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }
  .rae-btn-silent,
  .rae-btn-vol-up,
  .rae-btn-vol-down,
  .rae-btn-power {
    position: absolute;
    background: linear-gradient(to right, #2a2a2c, #3c3c3e);
    border-radius: 3px 0 0 3px;
    width: 3.5px;
  }
  .rae-btn-silent { left: -3.5px; top: 88px; height: 28px; }
  .rae-btn-vol-up { left: -3.5px; top: 135px; height: 52px; }
  .rae-btn-vol-down { left: -3.5px; top: 200px; height: 52px; }
  .rae-btn-power {
    right: -3.5px;
    left: auto;
    top: 155px;
    height: 68px;
    background: linear-gradient(to left, #2a2a2c, #3c3c3e);
    border-radius: 0 3px 3px 0;
  }
  .rae-phone-screen {
    background: #000;
    border-radius: 37px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 9 / 19.5;
  }
  .rae-island {
    position: absolute;
    top: 11px;
    left: 50%;
    transform: translateX(-50%);
    width: 110px;
    height: 34px;
    background: #000;
    border-radius: 50px;
    z-index: 12;
    pointer-events: none;
  }
  .rae-screen-overlay {
    position: absolute;
    inset: 0;
    border-radius: 37px;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05);
    pointer-events: none;
    z-index: 11;
  }

  /* ============ Mock app (in-code animated UI) ============ */
  .rae-mock-app {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 80% at 50% -10%, rgba(13,147,115,0.18) 0%, transparent 60%),
      linear-gradient(180deg, #0a0f0e 0%, #050807 100%);
    display: flex;
    flex-direction: column;
    font-family: 'DM Sans', sans-serif;
    color: white;
    z-index: 2;
    overflow: hidden;
    border-radius: 37px;
  }

  .rae-mock-status {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px 0;
    height: 48px;
    flex-shrink: 0;
  }
  .rae-mock-time {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: white;
    letter-spacing: -0.01em;
  }
  .rae-mock-status-icons {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .rae-mock-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px 12px;
    flex-shrink: 0;
  }
  .rae-mock-greeting {
    font-size: 10px;
    color: #6b8079;
    font-weight: 500;
  }
  .rae-mock-name {
    font-family: 'Sora', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: white;
    line-height: 1.2;
    margin-top: 2px;
  }
  .rae-mock-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, #0d9373 0%, #0a6e57 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Sora', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: white;
    box-shadow: 0 0 0 2px rgba(13,147,115,0.15);
  }

  .rae-mock-balance {
    margin: 0 14px;
    background: linear-gradient(155deg, rgba(13,147,115,0.18) 0%, rgba(13,147,115,0.04) 60%, rgba(255,255,255,0.02) 100%);
    border: 1px solid rgba(13,147,115,0.22);
    border-radius: 18px;
    padding: 14px 14px 10px;
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }
  .rae-mock-balance::before {
    content: '';
    position: absolute;
    top: -40%;
    right: -30%;
    width: 160px;
    height: 160px;
    background: radial-gradient(circle, rgba(13,147,115,0.25) 0%, transparent 60%);
    pointer-events: none;
  }
  .rae-mock-balance-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }
  .rae-mock-balance-label {
    font-size: 10px;
    font-weight: 500;
    color: #8aa09a;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .rae-mock-balance-trend {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    font-size: 10px;
    font-weight: 600;
    color: #0d9373;
    background: rgba(13,147,115,0.15);
    border-radius: 50px;
    padding: 2px 7px;
  }
  .rae-mock-balance-value {
    font-family: 'Sora', sans-serif;
    font-size: 26px;
    font-weight: 700;
    color: white;
    line-height: 1;
    margin-top: 6px;
    letter-spacing: -0.02em;
    position: relative;
    display: flex;
    align-items: baseline;
  }
  .rae-mock-currency {
    font-size: 16px;
    font-weight: 600;
    color: rgba(255,255,255,0.65);
    margin-right: 1px;
  }
  .rae-mock-decimals {
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.45);
    margin-left: 1px;
  }
  .rae-mock-chart {
    width: 100%;
    height: 50px;
    margin-top: 8px;
    display: block;
    position: relative;
  }
  .rae-mock-chart-line {
    stroke-dasharray: 280;
    stroke-dashoffset: 280;
    animation: raeMockChartDraw 6s ease-in-out infinite;
  }
  .rae-mock-chart-fill {
    opacity: 0;
    animation: raeMockChartFill 6s ease-in-out infinite;
  }
  @keyframes raeMockChartDraw {
    0% { stroke-dashoffset: 280; }
    35% { stroke-dashoffset: 0; }
    85% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 280; }
  }
  @keyframes raeMockChartFill {
    0%, 10% { opacity: 0; }
    45%, 85% { opacity: 1; }
    100% { opacity: 0; }
  }
  .rae-mock-range {
    display: flex;
    gap: 4px;
    margin-top: 6px;
    position: relative;
  }
  .rae-mock-range-pill {
    font-size: 9px;
    font-weight: 600;
    color: #6b8079;
    padding: 3px 8px;
    border-radius: 50px;
    letter-spacing: 0.02em;
  }
  .rae-mock-range-pill.active {
    color: white;
    background: rgba(255,255,255,0.08);
  }

  .rae-mock-section-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px 8px;
    flex-shrink: 0;
  }
  .rae-mock-section-title > span:first-child {
    font-family: 'Sora', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: white;
  }
  .rae-mock-link {
    font-size: 10px;
    font-weight: 500;
    color: #0d9373;
  }

  .rae-mock-activity {
    padding: 0 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
    min-height: 0;
  }
  .rae-mock-act-row {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 12px;
    padding: 9px 10px;
  }
  .rae-mock-act-icon {
    width: 28px;
    height: 28px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .rae-mock-act-icon.green { background: rgba(13,147,115,0.18); color: #0d9373; }
  .rae-mock-act-icon.blue { background: rgba(99,102,241,0.18); color: #a5b4fc; }
  .rae-mock-act-icon.amber { background: rgba(251,191,36,0.15); color: #fbbf24; }
  .rae-mock-act-info {
    flex: 1;
    min-width: 0;
  }
  .rae-mock-act-name {
    font-family: 'DM Sans', sans-serif;
