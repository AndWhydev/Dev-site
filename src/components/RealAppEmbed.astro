    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    white-space: nowrap;
  }
  .rae-mock-act-amt.up { color: #0d9373; }

  .rae-mock-tabbar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    align-items: center;
    padding: 8px 6px 6px;
    background: rgba(8,12,11,0.85);
    border-top: 1px solid rgba(255,255,255,0.04);
    backdrop-filter: blur(8px);
    flex-shrink: 0;
    position: relative;
  }
  .rae-mock-tab {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 6px 0 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    color: rgba(255,255,255,0.32);
    font-family: 'DM Sans', sans-serif;
