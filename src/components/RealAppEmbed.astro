---
const liveUrl = 'https://golf-app-demo.vercel.app';
---

<section class="rae-section" id="real-app">
  <div class="rae-inner">
    <div class="rae-header reveal">
      <span class="section-label">A real app we built</span>
      <h2 class="section-heading">Try it for yourself</h2>
      <p class="section-subheading">
        A live, interactive web app — embedded right here in the page. Tap, scroll, navigate.
        It's the same code we ship to production.
      </p>
    </div>

    <div class="rae-row">
      <div class="rae-frame-col reveal-left">
        <div class="rae-phone-wrap">
          <div class="rae-phone-glow" aria-hidden="true"></div>
          <div class="rae-phone">
            <div class="rae-btn-silent" aria-hidden="true"></div>
            <div class="rae-btn-vol-up" aria-hidden="true"></div>
            <div class="rae-btn-vol-down" aria-hidden="true"></div>
            <div class="rae-btn-power" aria-hidden="true"></div>

            <div class="rae-phone-body">
              <div class="rae-phone-screen">
                <div class="rae-island" aria-hidden="true"></div>

                <div class="rae-poster" id="rae-poster" aria-hidden="true">
                  <div class="rae-poster-top">
                    <div class="rae-poster-logo">
                      <svg width="22" height="22" viewBox="0 0 36 36" fill="none" aria-hidden="true">
                        <rect width="36" height="36" rx="9" fill="white" fill-opacity="0.95"/>
                        <path d="M8 27L18 9L28 27" stroke="#0d9373" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M11.5 21.5H24.5" stroke="#0d9373" stroke-width="2.8" stroke-linecap="round"/>
                      </svg>
                    </div>
                  </div>
                  <div class="rae-poster-body">
                    <div class="rae-poster-heading">
                      <div class="rae-poster-line lg"></div>
                      <div class="rae-poster-line sm"></div>
                    </div>
                    <div class="rae-poster-card"></div>
                    <div class="rae-poster-card"></div>
                    <div class="rae-poster-card short"></div>
                  </div>
                  <div class="rae-poster-loader">
                    <span class="rae-poster-spinner" aria-hidden="true"></span>
                    Loading live app…
                  </div>
                </div>

                <iframe
                  id="rae-iframe"
                  class="rae-iframe"
                  data-src={liveUrl}
                  title="Live web app demo — running right in the page"
                  loading="lazy"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allow="clipboard-write; fullscreen"
                ></iframe>

                <div class="rae-screen-overlay" aria-hidden="true"></div>
              </div>
            </div>
          </div>

          <div class="rae-caption">
            <span class="rae-cap-badge">
              <span class="rae-cap-dot"></span>
              Live app, fully interactive
            </span>
            <a class="rae-cap-link" href={liveUrl} target="_blank" rel="noopener noreferrer">
              Open in new tab
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17l10-10M9 7h8v8"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="rae-text-col reveal-right">
        <span class="rae-tag">Live demo</span>
        <h3 class="rae-h3">No screenshots. No promises. Just the app.</h3>
        <p class="rae-p">
          We don't believe in static mockups when we can show you the real thing. The frame on the
          left is a working build of an app we shipped — the same React code, the same data flow,
          the same interactions.
        </p>
        <ul class="rae-bullets">
          <li>Built end-to-end by our team</li>
          <li>Runs on production infrastructure</li>
          <li>Embedded here under a few hundred kilobytes</li>
        </ul>
        <a class="rae-cta" href={liveUrl} target="_blank" rel="noopener noreferrer">
          <span>Open the live app</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <p class="rae-fineprint">
          Tip on mobile: in-frame scrolling can feel fiddly. The button above opens the app
          full-screen.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .rae-section {
    background: #0a0f0e;
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
    border-top: 1px solid #1e2d28;
    border-bottom: 1px solid #1e2d28;
  }
  .rae-section::before {
    content: '';
    position: absolute;
    top: 10%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(13,147,115,0.06) 0%, transparent 65%);
    pointer-events: none;
  }
  .rae-section::after {
    content: '';
    position: absolute;
    bottom: -10%;
    left: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(13,147,115,0.045) 0%, transparent 65%);
    pointer-events: none;
  }
  .rae-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
  }
  .rae-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 4rem;
  }

  .rae-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 5rem;
    align-items: center;
  }
  .rae-frame-col { display: flex; justify-content: center; }
  .rae-text-col {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    max-width: 460px;
  }
  .rae-tag {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #0d9373;
    background: rgba(13,147,115,0.1);
    border: 1px solid rgba(13,147,115,0.22);
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
  }
  .rae-h3 {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.6rem, 2.4vw, 2.1rem);
    font-weight: 700;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0;
  }
  .rae-p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    color: #8aa09a;
    margin: 0;
  }
  .rae-bullets {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .rae-bullets li {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #cde0da;
    padding-left: 1.4rem;
    position: relative;
  }
  .rae-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #0d9373;
    box-shadow: 0 0 0 3px rgba(13,147,115,0.18);
  }
  .rae-cta {
    margin-top: 1rem;
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Sora', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, #0d9373 0%, #0a7559 100%);
    border-radius: 999px;
    padding: 0.85rem 1.4rem;
    text-decoration: none;
    box-shadow: 0 10px 28px rgba(13,147,115,0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .rae-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 34px rgba(13,147,115,0.4);
  }
  .rae-fineprint {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #6b8079;
    margin: 0.25rem 0 0;
  }

  /* ============ Phone frame (matches LiveAppDemo dimensions) ============ */
  .rae-phone-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .rae-phone-glow {
    position: absolute;
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 340px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(13,147,115,0.18) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .rae-phone {
    position: relative;
    width: 280px;
    z-index: 1;
    flex-shrink: 0;
  }
  .rae-phone-body {
    background: linear-gradient(160deg, #3a3a3c 0%, #1c1c1e 30%, #242426 60%, #3a3a3c 100%);
    border-radius: 48px;
    padding: 13px;
    position: relative;
    box-shadow:
      0 0 0 1px #4a4a4c,
      0 0 0 2.5px #0a0f0e,
      0 30px 100px rgba(0,0,0,0.9),
      0 0 60px rgba(13,147,115,0.12),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }
  .rae-btn-silent,
  .rae-btn-vol-up,
  .rae-btn-vol-down,
  .rae-btn-power {
    position: absolute;
    background: linear-gradient(to right, #2a2a2c, #3c3c3e);
    border-radius: 3px 0 0 3px;
    width: 3.5px;
  }
  .rae-btn-silent { left: -3.5px; top: 88px; height: 28px; }
  .rae-btn-vol-up { left: -3.5px; top: 135px; height: 52px; }
  .rae-btn-vol-down { left: -3.5px; top: 200px; height: 52px; }
  .rae-btn-power {
    right: -3.5px;
    left: auto;
    top: 155px;
    height: 68px;
    background: linear-gradient(to left, #2a2a2c, #3c3c3e);
    border-radius: 0 3px 3px 0;
  }
  .rae-phone-screen {
    background: #000;
    border-radius: 37px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 9 / 19.5;
  }
  .rae-island {
    position: absolute;
    top: 11px;
    left: 50%;
    transform: translateX(-50%);
    width: 110px;
    height: 34px;
    background: #000;
    border-radius: 50px;
    z-index: 12;
    pointer-events: none;
  }

  .rae-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    background: transparent;
    z-index: 2;
    /* Allow touch scrolling inside the iframe on iOS */
    -webkit-overflow-scrolling: touch;
  }

  .rae-screen-overlay {
    position: absolute;
    inset: 0;
    border-radius: 37px;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05);
    pointer-events: none;
    z-index: 11;
  }

  /* ============ Poster placeholder shown until iframe is ready ============ */
  .rae-poster {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(180deg, #0f1614 0%, #0a0f0e 100%);
    display: flex;
    flex-direction: column;
    transition: opacity 0.4s ease;
  }
  .rae-poster.rae-poster-hidden {
    opacity: 0;
    pointer-events: none;
  }
  .rae-poster-top {
    height: 96px;
    background: linear-gradient(135deg, #0d9373 0%, #0a7559 60%, #0d9373 100%);
    display: flex;
    align-items: flex-end;
    padding: 0 20px 16px;
    flex-shrink: 0;
  }
  .rae-poster-logo {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }
  .rae-poster-body {
    flex: 1;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .rae-poster-heading {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 4px;
  }
  .rae-poster-line {
    background: linear-gradient(90deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.06) 100%);
    background-size: 200% 100%;
    border-radius: 6px;
    height: 14px;
    animation: raeShimmer 1.6s ease-in-out infinite;
  }
  .rae-poster-line.lg { width: 75%; height: 18px; }
  .rae-poster-line.sm { width: 50%; height: 11px; }
  .rae-poster-card {
    background: linear-gradient(90deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 100%);
    background-size: 200% 100%;
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 12px;
    height: 76px;
    animation: raeShimmer 1.6s ease-in-out infinite;
    animation-delay: 0.15s;
  }
  .rae-poster-card.short { height: 56px; animation-delay: 0.3s; }
  @keyframes raeShimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .rae-poster-loader {
    margin-top: auto;
    padding: 14px 16px 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: #8aa09a;
  }
  .rae-poster-spinner {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1.5px solid rgba(13,147,115,0.25);
    border-top-color: #0d9373;
    animation: raeSpin 0.9s linear infinite;
  }
  @keyframes raeSpin {
    to { transform: rotate(360deg); }
  }

  /* ============ Caption row under phone ============ */
  .rae-caption {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .rae-cap-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #0d9373;
    background: rgba(13,147,115,0.1);
    border: 1px solid rgba(13,147,115,0.25);
    padding: 0.35rem 0.8rem;
    border-radius: 50px;
  }
  .rae-cap-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #0d9373;
    box-shadow: 0 0 8px rgba(13,147,115,0.7);
    animation: raePulse 2.2s ease-in-out infinite;
  }
  @keyframes raePulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.25); opacity: 0.7; }
  }
  .rae-cap-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #8aa09a;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .rae-cap-link:hover { color: white; }

  /* ============ Reduced motion ============ */
  @media (prefers-reduced-motion: reduce) {
    .rae-poster-line,
    .rae-poster-card,
    .rae-poster-spinner,
    .rae-cap-dot {
      animation: none !important;
    }
  }

  /* ============ Responsive ============ */
  @media (max-width: 1024px) {
    .rae-row {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .rae-text-col {
      max-width: 560px;
      margin: 0 auto;
      text-align: center;
      align-items: center;
      order: 2;
    }
    .rae-frame-col { order: 1; }
    .rae-tag { align-self: center; }
    .rae-bullets li { text-align: left; }
    .rae-cta { align-self: center; }
  }
  @media (max-width: 640px) {
    .rae-section { padding: 4rem 0; }
    .rae-header { margin-bottom: 2.5rem; }
    .rae-phone { width: 250px; }
    .rae-phone-body { padding: 11px; border-radius: 40px; }
    .rae-phone-screen { border-radius: 30px; }
    .rae-island { top: 9px; width: 92px; height: 28px; }
    .rae-caption { gap: 0.5rem; }
  }
</style>

<script>
  function initRealAppEmbed() {
    const iframe = document.querySelector<HTMLIFrameElement>('#rae-iframe');
    const poster = document.querySelector<HTMLElement>('#rae-poster');
    if (!iframe) return;
    if (iframe.dataset.loaded === '1') return;

    const src = iframe.dataset.src;
    if (!src) return;

    function load() {
      if (iframe!.dataset.loaded === '1') return;
      iframe!.dataset.loaded = '1';
      iframe!.addEventListener('load', () => {
        // Hide the poster shortly after load so the app paints first
        window.setTimeout(() => {
          poster?.classList.add('rae-poster-hidden');
        }, 200);
      }, { once: true });
      iframe!.src = src;
    }

    // Native lazy-load support: rely on browser
    if ('loading' in HTMLIFrameElement.prototype) {
      // We still control src via IntersectionObserver for the lighter initial load
    }

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            load();
            io.disconnect();
          }
        });
      }, { rootMargin: '400px 0px' });
      io.observe(iframe);
    } else {
      // Fallback: load immediately
      load();
    }

    // Safety fallback: load once the page becomes idle if observer never fires
    const idle = (window as any).requestIdleCallback as ((cb: () => void, opts?: { timeout: number }) => number) | undefined;
    if (idle) {
      idle(() => load(), { timeout: 6000 });
    } else {
      window.setTimeout(load, 4000);
    }
  }

  initRealAppEmbed();
  document.addEventListener('astro:after-swap', initRealAppEmbed);
</script>
