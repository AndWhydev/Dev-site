---

<section class="services-section" id="services">
  <div class="services-inner">
    <div class="services-header reveal">
      <span class="section-label">Our Capabilities</span>
      <h2 class="section-heading">Everything Your Enterprise Needs</h2>
      <p class="section-subheading">
        Twenty specialisations. One trusted partner. We cover the full technology spectrum so you can focus on running your business.
      </p>
    </div>

    <div class="services-grid">
      {services.map((service, i) => (
        <div class={`service-card card-hover spotlight-card tilt-card reveal stagger-${Math.min((i % 4) + 1, 6)} ${service.featured ? 'service-card--featured gradient-border' : ''}`}>
          <div class="service-icon" set:html={service.icon} />
          <h3 class="service-title">{service.title}</h3>
          <p class="service-desc">{service.description}</p>
          <div class="service-tags">
            {service.tags.map((tag) => (
              <span class="service-tag">{tag}</span>
            ))}
          </div>
          <a href="/services" class="service-cta">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>

    <div class="services-footer reveal">
      <p>Not sure which service you need? <a href="/contact">Let's have a conversation.</a></p>
      <a href="/services" class="btn-outline">
        View All Services
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 8rem 0;
    background: #0a0f0e;
  }

  .services-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .services-header {
    margin-bottom: 4rem;
    max-width: 700px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: 4rem;
  }

  .service-card {
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(13,147,115,0.03) 0%, transparent 60%);
    border-radius: 16px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .service-card:hover::before {
    opacity: 1;
  }

  .service-card--featured {
    border-color: rgba(13,147,115,0.25);
    background: linear-gradient(135deg, rgba(13,147,115,0.05) 0%, #0f1614 60%);
  }
  .service-card--featured::after {
    content: 'Popular';
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(13,147,115,0.15);
    border: 1px solid rgba(13,147,115,0.3);
    color: #0d9373;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.2rem 0.625rem;
    border-radius: 50px;
    letter-spacing: 0.04em;
  }

  .service-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(13,147,115,0.08);
    border: 1px solid rgba(13,147,115,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0d9373;
    flex-shrink: 0;
  }

  .service-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: white;
    line-height: 1.2;
    margin: 0;
  }

  .service-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #4a6359;
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .service-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    color: #4a6359;
    background: rgba(255,255,255,0.04);
    border: 1px solid #1e2d28;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .service-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #0d9373;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: gap 0.2s ease, color 0.2s ease;
  }
  .service-cta:hover {
    gap: 0.625rem;
    color: #10b88a;
  }

  .services-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 3rem;
    border-top: 1px solid #1e2d28;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .services-footer p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: #8aa09a;
    margin: 0;
  }

  .services-footer p a {
    color: #0d9373;
    text-decoration: none;
  }
  .services-footer p a:hover {
    text-decoration: underline;
  }

  @media (max-width: 1200px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .services-section {
      padding: 5rem 0;
    }
    .services-grid {
      grid-template-columns: 1fr;
    }
    .services-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
