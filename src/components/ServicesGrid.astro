<style>
  .bento-section {
    padding: 8rem 0;
    background: #111111;
    position: relative;
    overflow: hidden;
  }

  .bento-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .bento-header {
    margin-bottom: 3.5rem;
    max-width: 700px;
  }

  /* ── Grid ───────────────────────────── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(180px, auto);
    gap: 1rem;
  }

  /* ── Cards ──────────────────────────── */
  .bento-card {
    background: #0f1614;
    border: 1px solid rgba(30, 45, 40, 0.5);
    border-radius: 20px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  }

  .bento-card:hover {
    border-color: rgba(13,147,115,0.35);
    background: #111a17;
  }

  /* Size variants */
  .bento-hero { grid-column: span 2; grid-row: span 2; padding: 2.5rem; }
  .bento-tall { grid-row: span 2; }
  .bento-wide { grid-column: span 2; }
  .bento-full { grid-column: span 4; }
  .bento-featured { background: linear-gradient(135deg, rgba(13,147,115,0.08) 0%, #0f1614 60%); }
  .bento-sm { min-height: 160px; }

  /* ── Card content ───────────────────── */
  .bento-card-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
  }

  .bento-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(13,147,115,0.08);
    border: 1px solid rgba(13,147,115,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0d9373;
    flex-shrink: 0;
  }

  .bento-icon.sm {
    width: 36px;
    height: 36px;
    border-radius: 10px;
  }

  .bento-card h3 {
    font-family: 'Sora', sans-serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: white;
    margin: 0;
    line-height: 1.2;
  }

  .bento-hero h3 { font-size: 1.375rem; }

  .bento-card p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #4a6359;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .bento-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
  }

  .bento-tags span {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    color: #4a6359;
    background: rgba(255,255,255,0.04);
    border: 1px solid #1e2d28;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  /* Full-card click surface. The visible "Explore →" text is preserved for
     screen readers but hidden visually — the whole card acts as the link.
     Cards get cursor: pointer + a subtle lift on hover to signal clickability. */
  .bento-link {
    position: absolute;
    inset: 0;
    z-index: 3;
    text-indent: -9999px;
    overflow: hidden;
    white-space: nowrap;
    color: transparent;
  }
  .bento-link svg { display: none; }
  .bento-card:has(.bento-link) { cursor: pointer; }
  .bento-card:has(.bento-link):hover { transform: translateY(-2px); }
  .bento-link:focus-visible { outline: 2px solid #0d9373; outline-offset: -2px; border-radius: 20px; }

  /* ── Hero card code bg ──────────────── */
  .bento-card-bg-code {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 50%;
    display: flex;
    align-items: center;
    padding: 1.5rem;
    opacity: 0.5;
    font-family: 'Courier New', monospace;
    font-size: 0.7rem;
    line-height: 1.6;
    color: #4a6359;
    overflow: hidden;
  }

  .bento-card-bg-code pre {
    margin: 0;
    white-space: pre;
  }

  .c-green { color: #0d9373; }
  .c-str { color: #10b88a; }
  .c-comment { color: #2a3d35; font-style: italic; }

  /* ── Flutter phone visual ────────────── */
  .flutter-visual {
    display: flex;
    justify-content: center;
    padding: 1rem 0 0.5rem;
    margin-top: auto;
    position: relative;
    z-index: 2;
  }

  .phone-mini {
    width: 80px;
    background: #1a1a1c;
    border-radius: 14px;
    padding: 6px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    border: 1px solid #2a2a2c;
  }

  .phone-mini-screen {
    background: #111111;
    border-radius: 9px;
    overflow: hidden;
    aspect-ratio: 9/16;
  }

  .app-bar {
    height: 14px;
    background: rgba(13,147,115,0.4);
    border-radius: 0;
  }

  .app-content {
    padding: 6px 5px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .app-card {
    height: 24px;
    background: #1e2d28;
    border-radius: 4px;
    animation: card-shimmer 2s ease-in-out infinite;
  }

  .app-card.sm { height: 14px; }

  @keyframes card-shimmer {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  /* ── AI pulse ────────────────────────── */
  .ai-pulse {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .ai-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(13,147,115,0.3);
    animation: ai-ripple 3s ease-out infinite;
  }

  .r1 { width: 60px; height: 60px; animation-delay: 0s; }
  .r2 { width: 60px; height: 60px; animation-delay: 0.8s; }
  .r3 { width: 60px; height: 60px; animation-delay: 1.6s; }

  @keyframes ai-ripple {
    0% { transform: scale(1); opacity: 0.6; }
