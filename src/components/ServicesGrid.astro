          </div>
          <h3>Enterprise Software Solutions</h3>
          <p>Large-scale platforms, ERP integrations and mission-critical systems built for complexity and compliance. From scoping to hypercare support.</p>
          <div class="bento-tags"><span>ERP</span><span>CRM</span><span>Compliance</span><span>Multi-region</span></div>
          <a href="/services/enterprise-software" class="bento-link">Explore <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <!-- CARD: API Development -->
      <div class="bento-card spotlight-card tilt-card reveal stagger-3">
        <div class="bento-card-content">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
          </div>
          <h3>API Development</h3>
          <p>RESTful and GraphQL APIs built for reliability, security and developer experience.</p>
          <a href="/services/api-development" class="bento-link">Explore <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <!-- SMALL CARDS ROW -->
      <div class="bento-card bento-sm spotlight-card tilt-card reveal stagger-1">
        <div class="bento-card-content">
          <div class="bento-icon sm">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3>Custom SaaS</h3>
          <p>Multi-tenant, subscription-ready products.</p>
          <a href="/services/saas-development" class="bento-link">Explore <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <div class="bento-card bento-sm spotlight-card tilt-card reveal stagger-2">
        <div class="bento-card-content">
          <div class="bento-icon sm">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><path d="M8.56 2.75L4 6l.5 3"/></svg>
          </div>
          <h3>UI & UX Design</h3>
          <p>Interfaces that convert and retain.</p>
          <a href="/services/ui-ux-design" class="bento-link">Explore <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <div class="bento-card bento-sm spotlight-card tilt-card reveal stagger-3">
        <div class="bento-card-content">
          <div class="bento-icon sm">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Cybersecurity</h3>
          <p>Pen testing and compliance frameworks.</p>
          <a href="/services/cybersecurity" class="bento-link">Explore <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <div class="bento-card bento-sm spotlight-card tilt-card reveal stagger-4">
        <div class="bento-card-content">
          <div class="bento-icon sm">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg>
          </div>
          <h3>Legacy Modernisation</h3>
          <p>Phased migration with zero downtime.</p>
          <a href="/services/legacy-modernisation" class="bento-link">Explore <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <!-- WIDE CARD: Data Analytics -->
      <div class="bento-card bento-wide spotlight-card reveal stagger-1">
        <div class="chart-bg" aria-hidden="true">
          <svg viewBox="0 0 300 80" preserveAspectRatio="none" class="chart-svg">
            <defs>
              <linearGradient id="chartFill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#0d9373" stop-opacity="0.3"/>
                <stop offset="100%" stop-color="#0d9373" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <path d="M0,70 C40,65 60,45 90,35 C120,25 140,15 170,12 C200,9 220,18 250,14 C275,11 290,8 300,5" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M0,70 C40,65 60,45 90,35 C120,25 140,15 170,12 C200,9 220,18 250,14 C275,11 290,8 300,5 L300,80 L0,80Z" fill="url(#chartFill)"/>
          </svg>
        </div>
        <div class="bento-card-content">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
