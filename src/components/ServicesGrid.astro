---
---

<section class="bento-section" id="services">
  <div class="bento-inner">
    <div class="bento-header reveal">
      <span class="section-label">Our Capabilities</span>
      <h2 class="section-heading">Everything Your Enterprise Needs</h2>
      <p class="section-subheading">Twenty specialisations. One trusted partner. We cover the full technology spectrum.</p>
    </div>

    <div class="bento-grid">

      <!-- HERO CARD: Custom App Development -->
      <div class="bento-card bento-hero spotlight-card reveal stagger-1">
        <div class="bento-card-bg-code" aria-hidden="true">
          <pre><code>const app = await build(<span class="c-green">&#123;</span>
  client: <span class="c-str">"Enterprise Co."</span>,
  stack: [<span class="c-str">"React"</span>, <span class="c-str">"Node"</span>, <span class="c-str">"AWS"</span>],
  security: <span class="c-green">&#123; grade: "A+"</span> <span class="c-green">&#125;</span>,
  timeline: <span class="c-str">"12 weeks"</span>,
<span class="c-green">&#125;</span>);

await app.deploy(<span class="c-str">"production"</span>);
<span class="c-comment">// ✓ 99.97% uptime · zero incidents</span></code></pre>
        </div>
        <div class="bento-card-content">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3>Custom App Development</h3>
          <p>End-to-end web and mobile applications built to enterprise specifications. We own every layer of the stack from architecture to deployment.</p>
          <div class="bento-tags">
            <span>Web</span><span>Mobile</span><span>Full-Stack</span>
          </div>
          <a href="/services/custom-app-development" class="bento-link">
            Explore
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- TALL CARD: Flutter -->
      <div class="bento-card bento-tall spotlight-card tilt-card reveal stagger-2">
        <div class="bento-card-visual flutter-visual" aria-hidden="true">
          <div class="phone-mini">
            <div class="phone-mini-screen">
              <div class="app-bar"></div>
              <div class="app-content">
                <div class="app-card"></div>
                <div class="app-card sm"></div>
                <div class="app-card sm"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="bento-card-content">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18" stroke-width="2.5"/></svg>
          </div>
          <h3>Flutter Development</h3>
          <p>One codebase. iOS and Android. Zero performance compromise.</p>
          <a href="/services/flutter-development" class="bento-link">Explore <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <!-- CARD: AI Tools -->
      <div class="bento-card bento-featured spotlight-card tilt-card reveal stagger-3">
        <div class="ai-pulse" aria-hidden="true">
          <div class="ai-ring r1"></div>
          <div class="ai-ring r2"></div>
          <div class="ai-ring r3"></div>
          <div class="ai-core">AI</div>
        </div>
        <div class="bento-card-content">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3>AI Tools & Chatbots</h3>
          <p>Proprietary AI trained on your data, embedded into your workflows.</p>
          <a href="/ai-consulting" class="bento-link">Explore <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <!-- CARD: Cloud & DevOps -->
      <div class="bento-card spotlight-card tilt-card reveal stagger-4">
        <div class="bento-card-content">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>Cloud & DevOps</h3>
          <p>AWS, GCP and Azure infrastructure. Fully automated, resilient and cost-optimised.</p>
          <div class="bento-tags"><span>AWS</span><span>K8s</span><span>Terraform</span></div>
          <a href="/services/cloud-infrastructure" class="bento-link">Explore <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <!-- CARD: React & Next.js -->
      <div class="bento-card spotlight-card tilt-card reveal stagger-1">
        <div class="bento-card-content">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          </div>
          <h3>React & Next.js</h3>
          <p>Server-side rendering, edge deployment and TypeScript-first development.</p>
          <div class="bento-tags"><span>React</span><span>Next.js</span></div>
          <a href="/services/react-nextjs" class="bento-link">Explore <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>

      <!-- WIDE CARD: Enterprise Software -->
      <div class="bento-card bento-wide spotlight-card reveal stagger-2">
        <div class="enterprise-bg" aria-hidden="true">
          <div class="e-node n1"></div>
          <div class="e-node n2"></div>
          <div class="e-node n3"></div>
          <div class="e-line l1"></div>
          <div class="e-line l2"></div>
        </div>
        <div class="bento-card-content">
          <div class="bento-icon">
