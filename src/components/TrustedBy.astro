---
/* Abstract geometric brand marks — no fake company names. Marquee preserves the
   visual rhythm while remaining honest until real client logos are approved. */
const marks = [
  { id: 'm1', shape: 'circle-ring' },
  { id: 'm2', shape: 'hex' },
  { id: 'm3', shape: 'square-rot' },
  { id: 'm4', shape: 'triangle' },
  { id: 'm5', shape: 'plus' },
  { id: 'm6', shape: 'circle-dot' },
  { id: 'm7', shape: 'split-arc' },
  { id: 'm8', shape: 'grid-4' },
];
---

<section class="trusted-section">
  <div class="trusted-inner">
    <p class="trusted-label reveal">Trusted by Australian businesses · client names confidential</p>

    <div class="logos-track-wrap">
      <div class="logos-track" aria-label="Client brand marks (anonymised)">
        {[...marks, ...marks].map((m, i) => (
          <div class="logo-item" aria-hidden="true">
            <div class="logo-placeholder">
              <svg width="44" height="32" viewBox="0 0 44 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                {m.shape === 'circle-ring' && (
                  <>
                    <circle cx="22" cy="16" r="10" />
                    <circle cx="22" cy="16" r="4" />
                  </>
                )}
                {m.shape === 'hex' && (
                  <polygon points="22,4 34,11 34,21 22,28 10,21 10,11" />
                )}
                {m.shape === 'square-rot' && (
                  <>
                    <rect x="14" y="8" width="16" height="16" transform="rotate(45 22 16)" />
                    <rect x="18" y="12" width="8" height="8" />
                  </>
                )}
                {m.shape === 'triangle' && (
                  <>
                    <polygon points="22,5 36,27 8,27" />
                    <polygon points="22,11 31,25 13,25" />
                  </>
                )}
                {m.shape === 'plus' && (
                  <>
                    <line x1="22" y1="4" x2="22" y2="28" />
                    <line x1="10" y1="16" x2="34" y2="16" />
                    <circle cx="22" cy="16" r="6" />
                  </>
                )}
                {m.shape === 'circle-dot' && (
                  <>
                    <circle cx="22" cy="16" r="11" />
                    <circle cx="22" cy="16" r="2.5" fill="currentColor" stroke="none" />
                  </>
                )}
                {m.shape === 'split-arc' && (
                  <>
                    <path d="M10 16 A 12 12 0 0 1 34 16" />
                    <path d="M14 22 A 8 8 0 0 0 30 22" />
                    <circle cx="22" cy="16" r="2" fill="currentColor" stroke="none" />
                  </>
                )}
                {m.shape === 'grid-4' && (
                  <>
                    <rect x="11" y="6" width="9" height="9" />
                    <rect x="24" y="6" width="9" height="9" />
                    <rect x="11" y="17" width="9" height="9" />
                    <rect x="24" y="17" width="9" height="9" />
                  </>
                )}
              </svg>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .trusted-section {
    padding: 4rem 0;
    border-top: 1px solid #1e2d28;
    border-bottom: 1px solid #1e2d28;
    background: rgba(255,255,255,0.01);
    overflow: hidden;
  }

  .trusted-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .trusted-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #4a6359;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .logos-track-wrap {
    position: relative;
    overflow: hidden;
  }

  .logos-track-wrap::before,
  .logos-track-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
  }
  .logos-track-wrap::before {
    left: 0;
    background: linear-gradient(to right, #0a0f0e, transparent);
  }
  .logos-track-wrap::after {
    right: 0;
    background: linear-gradient(to left, #0a0f0e, transparent);
  }

  .logos-track {
    display: flex;
    gap: 4rem;
    width: max-content;
    animation: scroll-logos 38s linear infinite;
  }

  .logos-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll-logos {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .logo-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 52px;
    color: rgba(205, 224, 218, 0.45);
    transition: color 0.25s ease, transform 0.25s ease;
    cursor: default;
  }
  .logo-item:hover {
    color: rgba(13, 147, 115, 0.85);
    transform: translateY(-2px);
  }

  .logo-placeholder {
    border: 1px solid #1e2d28;
    border-radius: 8px;
    padding: 0.5rem 1.5rem;
    background: rgba(255,255,255,0.02);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .logos-track {
      animation: none;
      flex-wrap: wrap;
      width: auto;
      justify-content: center;
    }
  }
</style>
