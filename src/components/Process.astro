---
const steps = [
  {
    number: '01',
    title: 'Discovery & Strategy',
    description: 'We invest heavily in understanding your business before writing a line of code. Stakeholder workshops, technical audits, competitive analysis and requirements documentation — the foundation for everything that follows.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    duration: '1-2 weeks',
  },
  {
    number: '02',
    title: 'Architecture & Design',
    description: 'System architecture documents, database schemas, API contracts and high-fidelity UI prototypes. Every decision is documented and agreed before development begins — eliminating scope creep and costly rework.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    duration: '2-3 weeks',
  },
  {
    number: '03',
    title: 'Development & Build',
    description: 'Agile two-week sprints with daily standups, continuous integration and transparent progress tracking via your dedicated project portal. You see real progress every single day.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    duration: '4-16 weeks',
  },
  {
    number: '04',
    title: 'Quality Assurance',
    description: 'Automated and manual testing, performance benchmarking, security scanning and user acceptance testing. We don\'t ship code that isn\'t production-ready — no exceptions.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>`,
    duration: '1-2 weeks',
  },
  {
    number: '05',
    title: 'Launch & Deploy',
    description: 'Zero-downtime deployments, infrastructure provisioning, monitoring setup and go-live support. We manage the technical complexity so your team can focus on the business launch.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>`,
    duration: '3-5 days',
  },
  {
    number: '06',
    title: 'Support & Scale',
    description: 'SLA-backed support, proactive monitoring, regular performance reviews and a dedicated team ready to evolve your product as your business grows. We\'re with you for the long term.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    duration: 'Ongoing',
  },
];
---

<section class="process-section" id="process">
  <div class="process-inner">
    <div class="process-header reveal">
      <span class="section-label">How We Work</span>
      <h2 class="section-heading">From Idea to Production</h2>
      <p class="section-subheading">
        A delivery framework built for complex organisations — predictable, transparent and designed so nothing about how we work is a surprise.
      </p>
    </div>

    <div class="process-grid">
      {steps.map((step, i) => (
        <div class={`process-step reveal stagger-${Math.min(i + 1, 6)}`}>
          <div class="step-connector" aria-hidden="true"></div>
          <div class="step-number-wrap">
            <div class="step-number">{step.number}</div>
            <div class="step-icon" set:html={step.icon} />
          </div>
          <div class="step-content">
            <div class="step-duration">{step.duration}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- In-code CI/CD pipeline mockup — animates only when in view -->
    <div class="process-pipeline reveal stagger-5" data-pipeline aria-hidden="true">
      <div class="pp-head">
        <div class="pp-head-left">
          <span class="pp-head-label">Sample · CI/CD pipeline</span>
          <span class="pp-head-title">Build, test, deploy — without breaking production</span>
        </div>
        <div class="pp-head-status">
          <span class="pp-head-dot"></span>
          <span class="pp-head-status-text">Pipeline running</span>
        </div>
      </div>

      <div class="pp-track">
        <div class="pp-rail"></div>
        <div class="pp-progress"></div>

        <div class="pp-step" data-step="0">
          <div class="pp-step-node">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <div class="pp-step-text">
            <div class="pp-step-name">Build</div>
            <div class="pp-step-meta">22s</div>
          </div>
        </div>
        <div class="pp-step" data-step="1">
          <div class="pp-step-node">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </div>
          <div class="pp-step-text">
            <div class="pp-step-name">Test</div>
            <div class="pp-step-meta">412 passing</div>
          </div>
        </div>
        <div class="pp-step" data-step="2">
          <div class="pp-step-node">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="pp-step-text">
            <div class="pp-step-name">Security scan</div>
            <div class="pp-step-meta">0 issues</div>
          </div>
        </div>
        <div class="pp-step" data-step="3">
          <div class="pp-step-node">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          </div>
          <div class="pp-step-text">
            <div class="pp-step-name">Deploy</div>
            <div class="pp-step-meta">3 regions</div>
          </div>
        </div>
        <div class="pp-step" data-step="4">
          <div class="pp-step-node">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div class="pp-step-text">
            <div class="pp-step-name">Live</div>
            <div class="pp-step-meta">zero downtime</div>
          </div>
        </div>
      </div>
    </div>

    <div class="process-cta reveal stagger-6">
      <div class="process-cta-text">
        <h3>Want a closer look at how we work?</h3>
        <p>The full process — methodology, tooling, who's on your team — is laid out on our About page.</p>
      </div>
      <a href="/about" class="btn-primary">
        View our process in detail
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .process-section {
    padding: 6rem 0;
    background: #111111;
    position: relative;
    overflow: hidden;
  }

  .process-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #0a0f0e 0%, transparent 8%, transparent 92%, #0a0f0e 100%);
    pointer-events: none;
    z-index: 0;
  }

  .process-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  .process-header {
    margin-bottom: 4rem;
    max-width: 600px;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-bottom: 4rem;
    position: relative;
  }

  .process-step {
    padding: 2.5rem;
    border: 1px solid #1e2d28;
    position: relative;
    transition: background 0.3s ease;
  }

  .process-step:hover {
    background: rgba(13,147,115,0.03);
  }

  /* Create grid borders without double borders */
  .process-step:nth-child(n+4) {
    border-top: none;
  }
  .process-step:not(:nth-child(3n)) {
    border-right: none;
  }

  .step-connector {
    display: none;
  }

  .step-number-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .step-number {
    font-family: 'Sora', sans-serif;
    font-size: 3rem;
    font-weight: 800;
    color: rgba(13,147,115,0.15);
    line-height: 1;
    letter-spacing: -0.05em;
    transition: color 0.3s ease;
  }

  .process-step:hover .step-number {
    color: rgba(13,147,115,0.3);
  }

  .step-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(13,147,115,0.08);
    border: 1px solid rgba(13,147,115,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0d9373;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .process-step:hover .step-icon {
    background: rgba(13,147,115,0.15);
    border-color: rgba(13,147,115,0.3);
  }

  .step-duration {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0d9373;
    margin-bottom: 0.625rem;
  }

  .step-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.1875rem;
    font-weight: 700;
    color: white;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .step-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: #4a6359;
    line-height: 1.65;
    margin: 0;
  }

  .process-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(13,147,115,0.06);
    border: 1px solid rgba(13,147,115,0.2);
    border-radius: 20px;
    padding: 2.5rem 3rem;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .process-cta-text h3 {
    font-family: 'Sora', sans-serif;
    font-size: 1.375rem;
    font-weight: 700;
    color: white;
    margin: 0 0 0.5rem;
  }

  .process-cta-text p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: #8aa09a;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .process-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .process-step:nth-child(n+4) {
      border-top: 1px solid #1e2d28;
    }
    .process-step:nth-child(n+3) {
      border-top: none;
    }
    .process-step:not(:nth-child(2n)) {
      border-right: none;
    }
    .process-step:nth-child(2n) {
      border-right: 1px solid #1e2d28;
    }
  }

  @media (max-width: 640px) {
    .process-section {
      padding: 4rem 0;
    }
    .process-inner {
      padding: 0 1.25rem;
    }
    .process-grid {
      grid-template-columns: 1fr;
    }
    .process-step {
      border-right: 1px solid #1e2d28 !important;
      border-top: 1px solid #1e2d28 !important;
      padding: 2rem 1.5rem;
    }
    .process-step:first-child {
      border-top: 1px solid #1e2d28;
    }
    .process-cta {
      padding: 1.75rem 1.5rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }
    .process-cta-text h3 {
      font-size: 1.125rem;
    }
    .process-cta .btn-primary {
      width: 100%;
      justify-content: center;
      min-height: 44px;
    }
  }

  /* ============================================================
     CI/CD pipeline mockup
     ============================================================ */
  .process-pipeline {
    background:
      radial-gradient(120% 60% at 50% 0%, rgba(13,147,115,0.08) 0%, transparent 70%),
      linear-gradient(180deg, #0f1614 0%, #0a0f0e 100%);
    border: 1px solid #1e2d28;
    border-radius: 20px;
    padding: 1.75rem 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 18px 50px rgba(0,0,0,0.35);
    font-family: 'DM Sans', sans-serif;
  }
  .pp-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .pp-head-left { min-width: 0; }
  .pp-head-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0d9373;
    margin-bottom: 0.375rem;
  }
  .pp-head-title {
    display: block;
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: white;
    line-height: 1.3;
  }
  .pp-head-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.6875rem;
    font-weight: 600;
    color: #0d9373;
    background: rgba(13,147,115,0.1);
    border: 1px solid rgba(13,147,115,0.3);
    padding: 0.3rem 0.65rem;
    border-radius: 50px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .pp-head-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #0d9373;
    box-shadow: 0 0 6px rgba(13,147,115,0.7);
  }
  .process-pipeline.in-view .pp-head-dot {
    animation: ppPulse 1.6s ease-in-out infinite;
  }
  @keyframes ppPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.7); }
  }

  .pp-track {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
    position: relative;
    padding-top: 0.5rem;
  }
  .pp-rail {
    position: absolute;
    top: calc(0.5rem + 14px);
    left: 8%;
    right: 8%;
    height: 2px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
  }
  .pp-progress {
    position: absolute;
    top: calc(0.5rem + 14px);
    left: 8%;
    /* Rest at full target width (84%) and animate with transform: scaleX so the
       running bar never re-layouts the pipeline. The scaleX values below are
       the original width-percent stops divided by 84% (e.g. 17/84 ≈ 0.2024). */
    width: 84%;
    height: 2px;
    background: linear-gradient(90deg, #0d9373, #10b88a);
    border-radius: 2px;
    box-shadow: 0 0 8px rgba(13,147,115,0.4);
    transform: scaleX(0);
    transform-origin: left center;
  }
  .process-pipeline.in-view .pp-progress {
    animation: ppProgress 6s cubic-bezier(0.4,0,0.2,1) infinite;
    will-change: transform;
  }
  @keyframes ppProgress {
    0% { transform: scaleX(0); }
    20% { transform: scaleX(0.2024); }
    40% { transform: scaleX(0.4524); }
    60% { transform: scaleX(0.7024); }
    80% { transform: scaleX(0.9524); }
    92%, 100% { transform: scaleX(1); }
  }

  .pp-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    position: relative;
    min-width: 0;
  }
  .pp-step-node {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: #0a0f0e;
    border: 1.5px solid rgba(255,255,255,0.1);
    color: #4a6359;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    transition: background 0.4s, border-color 0.4s, color 0.4s, box-shadow 0.4s;
  }
  .process-pipeline.in-view .pp-step[data-step="0"] .pp-step-node {
    animation: ppNode 6s cubic-bezier(0.4,0,0.2,1) 0s infinite;
  }
  .process-pipeline.in-view .pp-step[data-step="1"] .pp-step-node {
    animation: ppNode 6s cubic-bezier(0.4,0,0.2,1) 1.2s infinite;
  }
  .process-pipeline.in-view .pp-step[data-step="2"] .pp-step-node {
    animation: ppNode 6s cubic-bezier(0.4,0,0.2,1) 2.4s infinite;
  }
  .process-pipeline.in-view .pp-step[data-step="3"] .pp-step-node {
    animation: ppNode 6s cubic-bezier(0.4,0,0.2,1) 3.6s infinite;
  }
  .process-pipeline.in-view .pp-step[data-step="4"] .pp-step-node {
    animation: ppNode 6s cubic-bezier(0.4,0,0.2,1) 4.8s infinite;
  }
  @keyframes ppNode {
    0%, 12% {
      background: #0a0f0e;
      border-color: rgba(255,255,255,0.1);
      color: #4a6359;
      box-shadow: none;
    }
    18%, 92% {
      background: rgba(13,147,115,0.18);
      border-color: rgba(13,147,115,0.6);
      color: #0d9373;
      box-shadow: 0 0 0 4px rgba(13,147,115,0.12), 0 0 14px rgba(13,147,115,0.3);
    }
    100% {
      background: #0a0f0e;
      border-color: rgba(255,255,255,0.1);
      color: #4a6359;
      box-shadow: none;
    }
  }

  .pp-step-text {
    min-width: 0;
  }
  .pp-step-name {
    font-family: 'Sora', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: white;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .pp-step-meta {
    font-size: 0.625rem;
    color: #6b8079;
    margin-top: 2px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .process-pipeline .pp-head-dot,
    .process-pipeline .pp-progress,
    .process-pipeline .pp-step-node {
      animation: none !important;
    }
    .process-pipeline .pp-progress {
      width: 84%;
      transform: scaleX(1);
    }
    .process-pipeline .pp-step-node {
      background: rgba(13,147,115,0.18);
      border-color: rgba(13,147,115,0.6);
      color: #0d9373;
    }
  }

  @media (max-width: 768px) {
    .process-pipeline {
      padding: 1.5rem 1.25rem;
    }
    .pp-step-name { font-size: 0.6875rem; }
    .pp-step-meta { font-size: 0.5625rem; }
    .pp-track {
      gap: 0.375rem;
    }
  }

  /* ≤480px: stack the 5 pipeline steps vertically with a vertical progress
     rail down the left so each step is fully legible (name + meta) without
     forcing horizontal compression. */
  @media (max-width: 480px) {
    .process-pipeline {
      padding: 1.5rem 1.25rem;
    }
    .pp-head-title { font-size: 0.875rem; }
    .pp-track {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding-left: 1.25rem;
      padding-top: 0.25rem;
    }
    .pp-rail,
    .pp-progress {
      top: 0.25rem;
      bottom: 0.25rem;
      height: auto;
      left: 14px;
      right: auto;
      width: 2px;
    }
    .pp-progress {
      transform: scaleY(0);
      transform-origin: top center;
    }
    .process-pipeline.in-view .pp-progress {
      animation: ppProgressV 6s cubic-bezier(0.4,0,0.2,1) infinite;
    }
    @keyframes ppProgressV {
      0% { transform: scaleY(0); }
      20% { transform: scaleY(0.2024); }
      40% { transform: scaleY(0.4524); }
      60% { transform: scaleY(0.7024); }
      80% { transform: scaleY(0.9524); }
      92%, 100% { transform: scaleY(1); }
    }
    .pp-step {
      flex-direction: row;
      align-items: center;
      gap: 0.875rem;
      text-align: left;
      min-height: 44px;
    }
    .pp-step-node {
      width: 30px;
      height: 30px;
      margin-left: -1.25rem; /* sit on the rail */
    }
    .pp-step-text { flex: 1; min-width: 0; }
    .pp-step-name { font-size: 0.875rem; white-space: normal; }
    .pp-step-meta { font-size: 0.75rem; display: block; }
  }
</style>

<script>
  function initPipeline() {
    const nodes = document.querySelectorAll<HTMLElement>('[data-pipeline]');
    if (!nodes.length) return;
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const el = entry.target as HTMLElement;
        if (entry.isIntersecting) {
          el.classList.add('in-view');
        } else {
          el.classList.remove('in-view');
        }
      });
    }, { threshold: 0.2 });
    nodes.forEach((n) => obs.observe(n));
    document.addEventListener('astro:before-swap', () => obs.disconnect(), { once: true });
  }
  initPipeline();
  document.addEventListener('astro:after-swap', initPipeline);
</script>
