---
// TODO: Replace placeholder testimonials with real client quotes
// For each testimonial you'll need: name, title, company, quote, avatar image (optional), star rating, project type
const testimonials = [
  {
    quote: "TODO: Add real testimonial from enterprise client. This should be a specific quote about the project outcome, ROI achieved or business impact. Something like: 'All Webbed Labs delivered a platform that processes 50,000 transactions daily with zero downtime since launch. Their team understood our compliance requirements from day one.'",
    name: 'Client Name',
    title: 'Chief Technology Officer',
    company: 'Enterprise Company Name',
    rating: 5,
    project: 'Enterprise Platform Build',
    placeholder: true,
  },
  {
    quote: "TODO: Add real testimonial. Focus on the team quality, communication and process. Something specific about how the engagement worked and why they would recommend All Webbed Labs to other enterprise organisations.",
    name: 'Client Name',
    title: 'Head of Digital Transformation',
    company: 'Enterprise Company Name',
    rating: 5,
    project: 'Legacy Modernisation',
    placeholder: true,
  },
  {
    quote: "TODO: Add real testimonial about AI or automation work if possible. The more specific and results-oriented the better — include metrics, timelines or dollar values if the client permits.",
    name: 'Client Name',
    title: 'Chief Digital Officer',
    company: 'Enterprise Company Name',
    rating: 5,
    project: 'AI Automation Suite',
    placeholder: true,
  },
];
---

<section class="testimonials-section" id="testimonials">
  <div class="testimonials-inner">
    <div class="testimonials-header reveal">
      <span class="section-label">Client Testimonials</span>
      <h2 class="section-heading">Don't Take Our Word For It</h2>
      <p class="section-subheading">
        Results speak louder than promises. Here's what enterprise clients say about working with All Webbed Labs.
      </p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <div class={`testimonial-card reveal stagger-${i + 1} ${t.placeholder ? 'is-placeholder' : ''}`}>
          {t.placeholder && (
            <div class="placeholder-notice">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
              <span>Placeholder — add real testimonial</span>
            </div>
          )}

          <div class="testimonial-stars">
            {Array.from({ length: t.rating }).map(() => (
              <span class="tstar">★</span>
            ))}
          </div>

          <blockquote class="testimonial-quote">
            "{t.quote}"
          </blockquote>

          <div class="testimonial-author">
            <div class="author-avatar">
              {/* TODO: Replace with real client avatar image: <img src={`/testimonials/${t.avatarSlug}.jpg`} alt={t.name} /> */}
              <div class="avatar-placeholder">{t.name.charAt(0)}</div>
            </div>
            <div class="author-info">
              <div class="author-name">{t.name}</div>
              <div class="author-role">{t.title}</div>
              <div class="author-company">{t.company}</div>
            </div>
            <div class="testimonial-project">{t.project}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Google reviews link placeholder -->
    <!-- TODO: Add link to Google Business profile once created -->
    <div class="reviews-footer reveal">
      <div class="reviews-summary">
        <div class="reviews-stars-big">
          {"★★★★★".split('').map((_, i) => (
            <span class="tstar-big" key={i}>★</span>
          ))}
        </div>
        <div>
          <div class="reviews-score">5.0 / 5.0</div>
          <div class="reviews-source">Google Reviews · TODO: Add review count once collected</div>
        </div>
      </div>
      <a href="#" class="btn-outline" target="_blank" rel="noopener noreferrer">
        <!-- TODO: Replace href with actual Google Reviews URL -->
        Read All Reviews
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: 8rem 0;
    background: #0a0f0e;
  }

  .testimonials-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .testimonials-header {
    margin-bottom: 4rem;
    max-width: 620px;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .testimonial-card {
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 20px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .testimonial-card:hover {
    border-color: rgba(13,147,115,0.25);
    transform: translateY(-3px);
  }

  .is-placeholder {
    opacity: 0.65;
    border-style: dashed;
  }

  .placeholder-notice {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    color: #4a6359;
    background: rgba(255,255,255,0.03);
    border: 1px solid #1e2d28;
    padding: 0.25rem 0.625rem;
    border-radius: 50px;
    align-self: flex-start;
  }

  .testimonial-stars {
    display: flex;
    gap: 2px;
  }

  .tstar {
    color: #FBBC05;
    font-size: 1rem;
  }

  .testimonial-quote {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #8aa09a;
    line-height: 1.7;
    margin: 0;
    flex: 1;
    font-style: italic;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 1rem;
    border-top: 1px solid #1e2d28;
    flex-wrap: wrap;
  }

  .author-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid #1e2d28;
  }

  .avatar-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0d9373, #0a7a5e);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Sora', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: white;
  }

  .author-info {
    flex: 1;
    min-width: 0;
  }

  .author-name {
    font-family: 'Sora', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
  }

  .author-role {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #4a6359;
    margin-top: 1px;
  }

  .author-company {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #0d9373;
    margin-top: 1px;
  }

  .testimonial-project {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    color: #4a6359;
    background: rgba(255,255,255,0.03);
    border: 1px solid #1e2d28;
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    white-space: nowrap;
    align-self: flex-start;
  }

  .reviews-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255,255,255,0.02);
    border: 1px solid #1e2d28;
    border-radius: 16px;
    padding: 1.75rem 2rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .reviews-summary {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .reviews-stars-big {
    display: flex;
    gap: 2px;
  }

  .tstar-big {
    color: #FBBC05;
    font-size: 1.375rem;
  }

  .reviews-score {
    font-family: 'Sora', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
  }

  .reviews-source {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
    margin-top: 2px;
  }

  @media (max-width: 900px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .testimonials-section {
      padding: 5rem 0;
    }
    .reviews-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
