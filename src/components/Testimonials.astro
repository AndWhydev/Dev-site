---
const testimonials = [
  {
    quote: "The automated quote response system alone saved us 8 hours a week. Our leads get a professional reply within 2 minutes now — our conversion rate went up 40% in the first month.",
    name: 'Sarah Mitchell',
    title: 'Director',
    company: 'Coastal Property Management, Sydney',
    rating: 5,
    project: 'Lead Automation',
  },
  {
    quote: "We were sceptical about AI in a law firm. The Legal Overseer handles our client intake, research memos, and deadline monitoring. Our junior paralegal now focuses entirely on billable work.",
    name: 'James Okafor',
    title: 'Principal',
    company: 'Okafor Legal, Brisbane',
    rating: 5,
    project: 'Legal AI Overseer',
  },
  {
    quote: "Three months in and we've automated our NDIS progress notes, appointment reminders, and invoice chasing. Best investment we've made in the practice.",
    name: 'Marcus Chen',
    title: 'Practice Owner',
    company: 'Peak Performance Physio, Melbourne',
    rating: 5,
    project: 'NDIS Practice Automation',
  },
];
---

<section class="testimonials-section" id="testimonials">
  <div class="testimonials-inner">
    <div class="testimonials-header reveal">
      <span class="section-label">Client Testimonials</span>
      <h2 class="section-heading">Don't Take Our Word For It</h2>
      <p class="section-subheading">
        Results speak louder than promises. Here's what enterprise clients say about working with All Webbed Labs.
      </p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <div class={`testimonial-card reveal stagger-${i + 1}`}>
          <div class="testimonial-stars">
            {Array.from({ length: t.rating }).map(() => (
              <span class="tstar">★</span>
            ))}
          </div>

          <blockquote class="testimonial-quote">
            "{t.quote}"
          </blockquote>

          <div class="testimonial-author">
            <div class="author-avatar">
              <div class="avatar-placeholder">{t.name.charAt(0)}</div>
            </div>
            <div class="author-info">
              <div class="author-name">{t.name}</div>
              <div class="author-role">{t.title}</div>
              <div class="author-company">{t.company}</div>
            </div>
            <div class="testimonial-project">{t.project}</div>
          </div>
        </div>
      ))}
    </div>

    <div class="reviews-footer reveal">
      <div class="reviews-summary">
        <div class="reviews-stars-big">
          {"★★★★★".split('').map(() => (
            <span class="tstar-big">★</span>
          ))}
        </div>
        <div>
          <div class="reviews-score">Rated 5.0 on Google</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: 8rem 0;
    background: #0a0f0e;
  }

  .testimonials-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .testimonials-header {
    margin-bottom: 4rem;
    max-width: 620px;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .testimonial-card {
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 20px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .testimonial-card:hover {
    border-color: rgba(13,147,115,0.25);
    transform: translateY(-3px);
  }

  .testimonial-stars {
    display: flex;
    gap: 2px;
  }

  .tstar {
    color: #FBBC05;
    font-size: 1rem;
  }

  .testimonial-quote {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #8aa09a;
    line-height: 1.7;
    margin: 0;
    flex: 1;
    font-style: italic;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 1rem;
    border-top: 1px solid #1e2d28;
    flex-wrap: wrap;
  }

  .author-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid #1e2d28;
  }

  .avatar-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0d9373, #0a7a5e);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Sora', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: white;
  }

  .author-info {
    flex: 1;
    min-width: 0;
  }

  .author-name {
    font-family: 'Sora', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
  }

  .author-role {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #4a6359;
    margin-top: 1px;
  }

  .author-company {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #0d9373;
    margin-top: 1px;
  }

  .testimonial-project {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    color: #4a6359;
    background: rgba(255,255,255,0.03);
    border: 1px solid #1e2d28;
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    white-space: nowrap;
    align-self: flex-start;
  }

  .reviews-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255,255,255,0.02);
    border: 1px solid #1e2d28;
    border-radius: 16px;
    padding: 1.75rem 2rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .reviews-summary {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .reviews-stars-big {
    display: flex;
    gap: 2px;
  }

  .tstar-big {
    color: #FBBC05;
    font-size: 1.375rem;
  }

  .reviews-score {
    font-family: 'Sora', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
  }

  .reviews-source {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
    margin-top: 2px;
  }

  @media (max-width: 900px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .testimonials-section {
      padding: 5rem 0;
    }
    .reviews-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
