---
---

<section class="web3-section" id="web3">
  <div class="web3-inner">
    <div class="web3-grid">
      <div class="web3-content reveal-left">
        <span class="section-label">Web3 & Blockchain</span>
        <h2 class="section-heading">
          Building The<br />
          <span class="gradient-text-green">Decentralised Future</span>
        </h2>
        <p class="section-subheading" style="margin-bottom: 2rem;">
          From smart contracts to DeFi platforms, All Webbed Labs has the expertise to build on Ethereum, Solana, Polygon and beyond.
          We bridge the gap between traditional enterprise and Web3 technology.
        </p>
        <div class="web3-chains reveal stagger-2">
          <span class="chain-tag">Ethereum</span>
          <span class="chain-tag">Solana</span>
          <span class="chain-tag">Polygon</span>
          <span class="chain-tag">Base</span>
          <span class="chain-tag">Avalanche</span>
          <span class="chain-tag">BNB Chain</span>
        </div>

        <!-- In-code transaction confirmation mockup, pure CSS animation, scroll-triggered -->
        <div class="w3-tx reveal stagger-3" data-w3-tx aria-hidden="true">
          <div class="w3-tx-head">
            <div class="w3-tx-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="w3-tx-icon-ring"></span>
            </div>
            <div class="w3-tx-meta">
              <div class="w3-tx-title">Transaction confirmed</div>
              <div class="w3-tx-sub">Sample · Ethereum mainnet</div>
            </div>
            <span class="w3-tx-tag">Demo</span>
          </div>
          <div class="w3-tx-body">
            <div class="w3-tx-row">
              <span class="w3-tx-label">Hash</span>
              <span class="w3-tx-value mono">0x4f2a…c81b</span>
            </div>
            <div class="w3-tx-row">
              <span class="w3-tx-label">Block</span>
              <span class="w3-tx-value">19,842,007</span>
            </div>
            <div class="w3-tx-row">
              <span class="w3-tx-label">Confirmations</span>
              <span class="w3-tx-value w3-tx-conf">
                <span class="w3-tx-conf-num">12</span>
                <span class="w3-tx-conf-bar"><span class="w3-tx-conf-fill"></span></span>
              </span>
            </div>
          </div>
        </div>

        <a href="/web3-crypto" class="btn-primary" style="margin-top: 2rem; display: inline-flex; align-items: center; gap: 0.5rem;">
          Explore Web3 Services
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="web3-cards reveal-right stagger-2">
        <div class="w3-card">
          <div class="w3-card-icon">⛓️</div>
          <h3>Smart Contracts</h3>
          <p>Audited, gas-optimised Solidity and Rust contracts for EVM and Solana ecosystems.</p>
        </div>
        <div class="w3-card">
          <div class="w3-card-icon">🏦</div>
          <h3>DeFi Platforms</h3>
          <p>Lending protocols, AMMs, yield farming and liquidity management platforms.</p>
        </div>
        <div class="w3-card">
          <div class="w3-card-icon">🖼️</div>
          <h3>NFT Marketplaces</h3>
          <p>Custom NFT platforms with minting, trading, royalties and wallet integration.</p>
        </div>
        <div class="w3-card">
          <div class="w3-card-icon">🏛️</div>
          <h3>DAO Governance</h3>
          <p>On-chain voting, treasury management and governance tooling for decentralised organisations.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .web3-section {
    padding: 6rem 0;
    background: linear-gradient(180deg, #111111 0%, rgba(13,147,115,0.04) 50%, #111111 100%);
    position: relative;
    overflow: hidden;
  }

  .web3-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 50% 60% at 80% 50%, rgba(99,91,255,0.05) 0%, transparent 60%),
                radial-gradient(ellipse 40% 40% at 10% 30%, rgba(13,147,115,0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .web3-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  .web3-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .web3-chains {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .chain-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #8aa09a;
    background: rgba(99,91,255,0.08);
    border: 1px solid rgba(99,91,255,0.2);
    padding: 0.375rem 0.875rem;
    border-radius: 50px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .chain-tag:hover {
    background: rgba(99,91,255,0.15);
    border-color: rgba(99,91,255,0.35);
    color: white;
  }

  .web3-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .w3-card {
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .w3-card:hover {
    border-color: rgba(99,91,255,0.25);
    transform: translateY(-3px);
  }

  .w3-card-icon {
    font-size: 1.5rem;
  }

  .w3-card h3 {
    font-family: 'Sora', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: white;
    margin: 0;
  }

  .w3-card p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 900px) {
    .web3-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 640px) {
    .web3-section { padding: 4rem 0; }
    .web3-inner { padding: 0 1.25rem; }
    .web3-cards { grid-template-columns: 1fr 1fr; gap: 0.625rem; }
    .w3-card { padding: 1.125rem; }
  }
  @media (max-width: 380px) {
    .web3-cards { grid-template-columns: 1fr; }
  }

  /* ============================================================
     Transaction confirmation mockup
     ============================================================ */
  .w3-tx {
    width: 100%;
    max-width: 420px;
    margin-top: 1.5rem;
    background:
      radial-gradient(110% 80% at 0% 0%, rgba(99,91,255,0.1) 0%, transparent 60%),
      linear-gradient(180deg, #0f1614 0%, #0a0f0e 100%);
    border: 1px solid #1e2d28;
    border-radius: 14px;
    overflow: hidden;
    font-family: 'DM Sans', sans-serif;
    box-shadow:
      0 16px 50px rgba(0,0,0,0.45),
      0 0 28px rgba(99,91,255,0.05);
  }

  .w3-tx-head {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem 0.875rem;
    border-bottom: 1px solid #1e2d28;
    background: rgba(8,12,11,0.6);
  }
  .w3-tx-icon {
    position: relative;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(13,147,115,0.18);
    color: #0d9373;
    border: 1px solid rgba(13,147,115,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .w3-tx-icon-ring {
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    border: 1.5px solid rgba(13,147,115,0.4);
    opacity: 0;
  }
  .w3-tx.in-view .w3-tx-icon-ring {
    animation: w3TxRing 2.4s ease-out infinite;
  }
  @keyframes w3TxRing {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(1.7); opacity: 0; }
  }
  .w3-tx-meta { flex: 1; min-width: 0; }
  .w3-tx-title {
    font-family: 'Sora', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: white;
    line-height: 1.2;
  }
  .w3-tx-sub {
    font-size: 0.6875rem;
    color: #6b8079;
    margin-top: 2px;
  }
  .w3-tx-tag {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #635bff;
    background: rgba(99,91,255,0.1);
    border: 1px solid rgba(99,91,255,0.3);
    padding: 0.2rem 0.5rem;
    border-radius: 50px;
    flex-shrink: 0;
  }

  .w3-tx-body {
    padding: 0.75rem 0.875rem 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .w3-tx-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.625rem;
    font-size: 0.75rem;
  }
  .w3-tx-label {
    color: #6b8079;
  }
  .w3-tx-value {
    color: white;
    font-weight: 600;
    text-align: right;
  }
  .w3-tx-value.mono {
    font-family: 'Courier New', monospace;
    font-size: 0.6875rem;
    color: #cde0da;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 0.15rem 0.45rem;
    border-radius: 6px;
  }
  .w3-tx-conf {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .w3-tx-conf-num {
    font-family: 'Sora', sans-serif;
    color: #0d9373;
    font-weight: 700;
    min-width: 16px;
    text-align: right;
  }
  .w3-tx-conf-bar {
    width: 88px;
    height: 4px;
    background: rgba(255,255,255,0.06);
    border-radius: 50px;
    overflow: hidden;
    position: relative;
  }
  .w3-tx-conf-fill {
    display: block;
    /* Rest at full width; animate with transform: scaleX so the running fill
       stays on the compositor and never re-layouts the surrounding card. */
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, #0d9373, #10b88a);
    border-radius: 50px;
    transform: scaleX(0);
    transform-origin: left center;
  }
  .w3-tx.in-view .w3-tx-conf-fill {
    animation: w3TxFill 5s cubic-bezier(0.4,0,0.2,1) infinite;
    will-change: transform;
  }
  @keyframes w3TxFill {
    0% { transform: scaleX(0); }
    50%, 90% { transform: scaleX(1); }
    100% { transform: scaleX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .w3-tx .w3-tx-icon-ring,
    .w3-tx .w3-tx-conf-fill {
      animation: none !important;
    }
    .w3-tx .w3-tx-conf-fill {
      width: 100%;
      transform: none;
    }
  }

  @media (max-width: 480px) {
    .w3-tx { max-width: 100%; }
    .w3-tx-conf-bar { width: 64px; }
  }
</style>

<script>
  function initW3Tx() {
    const nodes = document.querySelectorAll<HTMLElement>('[data-w3-tx]');
    if (!nodes.length) return;
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const el = entry.target as HTMLElement;
        if (entry.isIntersecting) {
          el.classList.add('in-view');
        } else {
          el.classList.remove('in-view');
        }
      });
    }, { threshold: 0.25 });
    nodes.forEach((n) => obs.observe(n));
    document.addEventListener('astro:before-swap', () => obs.disconnect(), { once: true });
  }
  initW3Tx();
  document.addEventListener('astro:after-swap', initW3Tx);
</script>
