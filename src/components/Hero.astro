---
const rotatingPhrases = [
  'From AI tools to enterprise platforms.',
  'From mobile apps to Web3 solutions.',
  'From startup MVPs to legacy modernisation.',
  'From automation to digital transformation.',
  'From custom SaaS to cloud infrastructure.',
];
---

<section class="hero hero-grain" id="hero">

  <!-- Aurora background blobs -->
  <div class="aurora" aria-hidden="true">
    <div class="a-blob a1"></div>
    <div class="a-blob a2"></div>
    <div class="a-blob a3"></div>
    <div class="a-blob a4"></div>
  </div>

  <!-- Dot grid -->
  <div class="hero-dots" aria-hidden="true"></div>

  <!-- Central glow orb -->
  <div class="hero-orb" aria-hidden="true"></div>

  <div class="hero-inner">

    <div class="hero-badge reveal stagger-1">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
      <span>Australia's Premier Enterprise Software Partner</span>
    </div>

    <h1 class="hero-headline" id="hero-headline">
      We Build The Software<br />
      <span class="hero-headline-accent shimmer-text">That Runs Your Business.</span>
    </h1>

    <div class="hero-rotating reveal stagger-3" aria-live="polite">
      {rotatingPhrases.map((phrase, i) => (
        <span class={`rotating-phrase ${i === 0 ? 'active' : ''}`} aria-hidden={i !== 0 ? 'true' : 'false'}>
          {phrase}
        </span>
      ))}
    </div>

    <p class="hero-desc reveal stagger-3">
      All Webbed Labs delivers enterprise-grade software, AI tools and digital platforms for large Australian and global organisations.
      From custom applications to full digital transformation — we build what your business needs to scale.
    </p>

    <div class="hero-ctas reveal stagger-4">
      <a href="/contact" class="btn-primary hero-cta-primary">
        Book a Strategy Call
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/portfolio" class="btn-outline hero-cta-secondary">
        View Our Work
      </a>
    </div>

    <!-- Glassmorphism stats -->
    <div class="hero-stats reveal stagger-5">
      <div class="hero-stat">
        <span class="hero-stat-num">150+</span>
        <span class="hero-stat-lbl">Projects Delivered</span>
      </div>
      <div class="hero-stat-divider" aria-hidden="true"></div>
      <div class="hero-stat">
        <span class="hero-stat-num">8+</span>
        <span class="hero-stat-lbl">Years Experience</span>
      </div>
      <div class="hero-stat-divider" aria-hidden="true"></div>
      <div class="hero-stat">
        <span class="hero-stat-num">98%</span>
        <span class="hero-stat-lbl">Client Retention</span>
      </div>
      <div class="hero-stat-divider" aria-hidden="true"></div>
      <div class="hero-stat">
        <span class="hero-stat-num">⭐ 5.0</span>
        <span class="hero-stat-lbl">Average Rating</span>
      </div>
    </div>

    <!-- Google Reviews badge -->
    <div class="hero-reviews reveal stagger-6">
      <div class="reviews-badge">
        <div class="google-logo">
          <svg width="16" height="16" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          <span>Google</span>
        </div>
        <div class="reviews-stars">★★★★★</div>
        <div class="reviews-text"><strong>5.0</strong> · Google Reviews</div>
      </div>
      <div class="trust-indicators">
        <div class="trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>100% Australian Team</span>
        </div>
        <div class="trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Enterprise Security Standards</span>
        </div>
        <div class="trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Full IP Ownership Transfer</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll-cue" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #050a09;
    padding-top: 90px;
  }

  /* ── Aurora blobs ────────────────── */
  .aurora {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .a-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0;
    animation: blob-appear 2s ease forwards, blob-drift linear infinite;
  }

  .a1 {
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(13,147,115,0.25), rgba(13,147,115,0.05));
    top: -20%;
    left: 30%;
    animation-duration: 2s, 22s;
    animation-delay: 0s, 0s;
  }
  .a2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0,200,140,0.15), transparent);
    bottom: -10%;
    right: 5%;
    animation-duration: 2s, 28s;
    animation-delay: 0.3s, -8s;
  }
  .a3 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(5,80,60,0.2), transparent);
    top: 40%;
    left: -5%;
    animation-duration: 2s, 35s;
    animation-delay: 0.6s, -15s;
  }
  .a4 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(0,232,122,0.1), transparent);
    top: 20%;
    right: 20%;
    animation-duration: 2s, 20s;
    animation-delay: 0.9s, -5s;
  }

  @keyframes blob-appear {
    to { opacity: 1; }
  }

  @keyframes blob-drift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(40px, -30px) scale(1.04); }
    50% { transform: translate(-20px, 40px) scale(0.96); }
    75% { transform: translate(-40px, -15px) scale(1.02); }
  }

  /* ── Dot grid ────────────────────── */
  .hero-dots {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(rgba(13,147,115,0.18) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
    opacity: 0.4;
  }

  /* ── Central glow orb ────────────── */
  .hero-orb {
    position: absolute;
    top: 40%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(13,147,115,0.12) 0%, transparent 70%);
    z-index: 0;
    pointer-events: none;
    animation: orb-pulse 6s ease-in-out infinite;
  }

  @keyframes orb-pulse {
    0%, 100% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.1); }
  }

  /* ── Content ─────────────────────── */
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 2rem 5rem;
    width: 100%;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(13,147,115,0.08);
    border: 1px solid rgba(13,147,115,0.25);
    color: #0d9373;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
    backdrop-filter: blur(10px);
    animation: float-badge 3s ease-in-out infinite;
  }

  @keyframes float-badge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  /* ── Word-by-word reveal headline ── */
  .hero-headline {
    font-family: 'Sora', sans-serif;
    font-size: clamp(3rem, 7.5vw, 6.5rem);
    font-weight: 800;
    color: white;
    line-height: 1.04;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
    max-width: 980px;
  }

  .hero-headline .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }

  .hero-headline.words-visible .word {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-headline-accent {
    display: block;
  }

  /* ── Rotating subheadline ─────────── */
  .hero-rotating {
    position: relative;
    height: 2em;
    overflow: hidden;
    margin-bottom: 1.25rem;
    max-width: 700px;
  }

  .rotating-phrase {
    position: absolute;
    top: 0;
    left: 0;
    font-family: 'Sora', sans-serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 500;
    color: rgba(138,160,154,0.8);
    letter-spacing: -0.01em;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    line-height: 2;
    white-space: nowrap;
  }

  .rotating-phrase.active { opacity: 1; transform: translateY(0); }
  .rotating-phrase.exit { opacity: 0; transform: translateY(-20px); }

  .hero-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    color: rgba(138,160,154,0.75);
    max-width: 600px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .hero-cta-primary {
    padding: 1rem 2.25rem;
    font-size: 1rem;
    box-shadow: 0 0 40px rgba(13,147,115,0.35), 0 8px 30px rgba(13,147,115,0.2);
  }

  .hero-cta-secondary { padding: 1rem 2.25rem; font-size: 1rem; }

  /* ── Glassmorphism stats ─────────── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    padding: 0;
    margin-bottom: 2rem;
    width: fit-content;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 4px 30px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 2rem;
    gap: 0.2rem;
  }

  .hero-stat-num {
    font-family: 'Sora', sans-serif;
    font-size: 1.375rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .hero-stat-lbl {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    color: #4a6359;
    white-space: nowrap;
  }

  .hero-stat-divider {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,0.07);
    flex-shrink: 0;
  }

  /* ── Reviews ─────────────────────── */
  .hero-reviews {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
  }

  .reviews-badge {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 0.75rem 1rem;
    backdrop-filter: blur(10px);
  }

  .google-logo {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: #8aa09a;
  }

  .reviews-stars { color: #FBBC05; font-size: 0.8125rem; letter-spacing: 1px; }

  .reviews-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #8aa09a;
  }
  .reviews-text strong { color: white; font-weight: 600; }

  .trust-indicators { display: flex; flex-wrap: wrap; gap: 0.875rem; }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
  }

  /* ── Scroll cue ──────────────────── */
  .hero-scroll-cue {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 1;
  }

  .hero-scroll-cue span {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #2a3d35;
  }

  .scroll-line {
    width: 1px;
    height: 52px;
    background: linear-gradient(to bottom, rgba(13,147,115,0.8), transparent);
    animation: scroll-pulse 2.2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  @media (max-width: 768px) {
    .hero-inner { padding: 4rem 1.5rem 5rem; }
    .hero-ctas { flex-direction: column; }
    .hero-cta-primary, .hero-cta-secondary { width: fit-content; }
    .hero-reviews { flex-direction: column; align-items: flex-start; }
    .hero-scroll-cue { display: none; }
    .hero-stats { flex-wrap: wrap; width: auto; }
    .hero-stat-divider { display: none; }
  }
</style>

<script>
  // Word-by-word headline animation
  function initHeadline() {
    const headline = document.getElementById('hero-headline');
    if (!headline) return;

    // Split both text nodes into word spans, preserving the inner accent span
    const accentSpan = headline.querySelector('.hero-headline-accent');
    if (!accentSpan) return;

    // Wrap first line words
    const firstLineText = headline.childNodes[0];
    if (firstLineText && firstLineText.nodeType === Node.TEXT_NODE) {
      const words = firstLineText.textContent?.trim().split(' ') ?? [];
      const fragment = document.createDocumentFragment();
      words.forEach((w, i) => {
        const span = document.createElement('span');
        span.className = 'word';
        span.style.transitionDelay = `${i * 0.07}s`;
        span.textContent = w + ' ';
        fragment.appendChild(span);
      });
      headline.insertBefore(fragment, firstLineText);
      firstLineText.remove();
    }

    // Wrap accent span words
    const accentText = accentSpan.textContent ?? '';
    const accentWords = accentText.trim().split(' ');
    accentSpan.innerHTML = accentWords.map((w, i) =>
      `<span class="word" style="transition-delay:${(3 + i) * 0.08}s">${w} </span>`
    ).join('');

    // Trigger on scroll-into-view
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          headline.classList.add('words-visible');
          obs.unobserve(headline);
        }
      });
    }, { threshold: 0.1 });
    obs.observe(headline);
  }

  // Rotating subheadline
  function initRotating() {
    const phrases = document.querySelectorAll<HTMLElement>('.rotating-phrase');
    let current = 0;
    function rotate() {
      const prev = current;
      current = (current + 1) % phrases.length;
      phrases[prev].classList.add('exit');
      phrases[prev].setAttribute('aria-hidden', 'true');
      setTimeout(() => phrases[prev].classList.remove('active', 'exit'), 600);
      phrases[current].classList.add('active');
      phrases[current].setAttribute('aria-hidden', 'false');
    }
    setInterval(rotate, 3000);
  }

  initHeadline();
  initRotating();
  document.addEventListener('astro:after-swap', () => { initHeadline(); initRotating(); });
</script>
