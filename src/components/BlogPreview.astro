<section class="blog-preview-section" id="blog-preview">
  <div class="blog-preview-inner">
    <div class="blog-preview-header reveal">
      <div>
        <span class="section-label">Insights</span>
        <h2 class="section-heading">From Our Engineering Team</h2>
      </div>
      <a href="/blog" class="btn-outline blog-view-all">
        View All Articles
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="blog-cards">
      {posts.map((post, i) => (
        <a href={post.href} class={`blog-card card-hover reveal stagger-${i + 1}`}>
          <!-- IMAGE_PLACEHOLDER — add real blog post hero image here (1200x630px) -->
          <div class="blog-img-placeholder">
            <div class="blog-img-cat">{post.category}</div>
          </div>
          <div class="blog-card-body">
            <div class="blog-card-meta">
              <span class="blog-tag">{post.category}</span>
              <span class="blog-date">{post.date}</span>
              <span class="blog-read">{post.readTime}</span>
            </div>
            <h3 class="blog-title">{post.title}</h3>
            <p class="blog-excerpt">{post.excerpt}</p>
            <div class="blog-read-more">
              Read article
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .blog-preview-section {
