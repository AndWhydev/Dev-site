---
const year = new Date().getFullYear();

const services = [
  { title: 'Custom App Development', href: '/services/custom-app-development' },
  { title: 'Flutter Development', href: '/services/flutter-development' },
  { title: 'AI Tools & Chatbots', href: '/ai-consulting' },
  { title: 'React & Next.js', href: '/services/web-mobile-apps' },
  { title: 'Cloud & DevOps', href: '/services/cloud-infrastructure' },
  { title: 'Enterprise Software', href: '/services/enterprise-software' },
  { title: 'Web3 & Blockchain', href: '/web3-crypto' },
  { title: 'Staff Augmentation', href: '/staff-augmentation' },
];

const industries = [
  { title: 'Financial Services', href: '/industries/finance-fintech' },
  { title: 'Healthcare', href: '/industries/healthcare' },
  { title: 'Logistics', href: '/industries/logistics-transport' },
  { title: 'Retail & E-Commerce', href: '/industries/retail-ecommerce' },
  { title: 'Government', href: '/industries/government-enterprise' },
  { title: 'Education', href: '/industries/education' },
  { title: 'Construction', href: '/industries/construction-trades' },
  { title: 'Real Estate', href: '/industries/real-estate' },
];

const company = [
  { title: 'About Us', href: '/about' },
  { title: 'How We Deliver', href: '/methodology' },
  { title: 'Trust & Compliance', href: '/trust' },
  { title: 'R&D Tax Incentive', href: '/r-and-d' },
  { title: 'Technology Radar', href: '/technology-radar' },
  { title: 'Pricing', href: '/pricing' },
  { title: 'Careers', href: '/careers' },
];
---

<footer>
  <div class="footer-top">
    <div class="footer-grid">
      <!-- Col 1: Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <svg width="38" height="38" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="36" height="36" rx="9" fill="#0d9373"/>
            <path d="M8 27L18 9L28 27" stroke="white" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M11.5 21.5H24.5" stroke="white" stroke-width="2.8" stroke-linecap="round"/>
          </svg>
          <div>
            <div class="footer-logo-main">All Webbed Labs</div>
            <div class="footer-logo-sub">Sister to All Webbed Up</div>
          </div>
        </a>
        <p class="footer-tagline">
          All Webbed Labs is a Sydney based enterprise AI and software development company. Sister company to All Webbed Up, the branding and marketing agency we deliver client work alongside.
        </p>
        <div class="footer-socials">
          <a href="https://linkedin.com/company/allwebbedup" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://facebook.com/allwebbedup" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://instagram.com/allwebbedup" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Services -->
      <div class="footer-col">
        <h4 class="footer-col-title">Services</h4>
        <ul>
          {services.map((s) => (
            <li><a href={s.href} class="footer-link">{s.title}</a></li>
          ))}
          <li><a href="/services" class="footer-link footer-link-all">All Services →</a></li>
        </ul>
      </div>

      <!-- Col 3: Industries -->
      <div class="footer-col">
        <h4 class="footer-col-title">Industries</h4>
        <ul>
          {industries.map((ind) => (
            <li><a href={ind.href} class="footer-link">{ind.title}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Company -->
      <div class="footer-col">
        <h4 class="footer-col-title">Company</h4>
        <ul>
          {company.map((c) => (
            <li><a href={c.href} class="footer-link">{c.title}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 5: Contact -->
      <div class="footer-col">
        <h4 class="footer-col-title">Contact</h4>
        <div class="footer-contact">
          <a href="mailto:labs@allwebbedup.com.au" class="footer-contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            labs@allwebbedup.com.au
          </a>
          <a href="tel:1800714148" class="footer-contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.15a16 16 0 006.29 6.29l1.42-1.42a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 15.16v.76z"/></svg>
            1800 714 148
          </a>
          <div class="footer-contact-item footer-address">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            204 Birdwood Rd, Georges Hall NSW 2198
          </div>
          <a href="https://allwebbedup.com.au" target="_blank" rel="noopener noreferrer" class="footer-contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            allwebbedup.com.au
          </a>
          <a href="/contact" class="btn-primary footer-cta-btn">
            Book a Call
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p>&copy; {year} AW Labs Pty Ltd, trading as All Webbed Labs. ABN: 32 698 684 105. Sister company to All Webbed Up Pty Ltd.</p>
      <div class="footer-legal">
        <a href="/privacy" class="footer-legal-link">Privacy Policy</a>
        <a href="/terms" class="footer-legal-link">Terms of Service</a>
        <a href="/sitemap-index.xml" class="footer-legal-link">Sitemap</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #060c0b;
    border-top: 1px solid #1e2d28;
  }

  .footer-top {
    max-width: 1360px;
    margin: 0 auto;
    padding: 5rem 2rem 3rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr 1.3fr;
    gap: 2.5rem;
  }

  /* Brand col */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    text-decoration: none;
    margin-bottom: 1.25rem;
  }

  .footer-logo-main {
    font-family: 'Sora', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    color: white;
    line-height: 1.2;
  }

  .footer-logo-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    color: #4a6359;
    line-height: 1.2;
    margin-top: 1px;
  }

  .footer-tagline {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #4a6359;
    line-height: 1.65;
    margin-bottom: 1.5rem;
    max-width: 280px;
  }

  .footer-socials {
    display: flex;
    gap: 0.625rem;
    margin-bottom: 1.5rem;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 9px;
    border: 1px solid #1e2d28;
    color: #4a6359;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .social-btn:hover {
    color: #0d9373;
    border-color: rgba(13,147,115,0.35);
    background: rgba(13,147,115,0.05);
  }

  /* Content cols */
  .footer-col-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    color: white;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #4a6359;
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1.4;
  }

  .footer-link:hover {
    color: #8aa09a;
  }

  .footer-link-all {
    color: #0d9373;
    font-weight: 600;
  }

  /* Contact col */
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1.4;
  }

  .footer-contact-item:not(.footer-address):hover {
    color: #8aa09a;
  }

  .footer-contact-item svg {
    flex-shrink: 0;
    margin-top: 1px;
  }

  .footer-cta-btn {
    margin-top: 0.5rem;
    align-self: flex-start;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid #1e2d28;
    padding: 1.375rem 2rem;
  }

  .footer-bottom-inner {
    max-width: 1360px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-bottom-inner p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #2a3d35;
    margin: 0;
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer-legal-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #2a3d35;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-legal-link:hover {
    color: #4a6359;
  }

  @media (max-width: 1200px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .footer-tagline {
      max-width: 100%;
    }
  }

  @media (max-width: 760px) {
    .footer-top {
      padding: 3.5rem 1.5rem;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    /* Bump labels + microcopy from 11px to 13px on phones for readability —
       Apple HIG / Material both recommend ≥14px for body, ≥12px for labels. */
    .footer-logo-sub,
    .footer-col-title {
      font-size: 0.8125rem;
    }
    .footer-tagline {
      font-size: 0.9375rem;
    }
  }
</style>
