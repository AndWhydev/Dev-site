<script>
  function initMockApp() {
    const app = document.querySelector<HTMLElement>('.mock-app');
    if (!app || app.dataset.mockInit === '1') return;
    app.dataset.mockInit = '1';

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const tabs = Array.from(app.querySelectorAll<HTMLButtonElement>('.mock-tab'));
    if (tabs.length) {
      tabs[0].classList.add('mock-tab-active');
    }

    const counter = app.querySelector<HTMLElement>('.mock-count');
    const start = counter ? parseFloat(counter.dataset.start || '0') : 0;
    const target = counter ? parseFloat(counter.dataset.target || '0') : 0;
    const formatter = new Intl.NumberFormat('en-AU');

    function runCount() {
      if (!counter) return;
      const duration = 2200;
      const t0 = performance.now();
      function step(t: number) {
        const p = Math.min((t - t0) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const v = Math.round(start + (target - start) * eased);
        counter!.textContent = formatter.format(v);
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    if (reduce) {
      if (counter) counter.textContent = formatter.format(target);
      return;
    }

    runCount();
    let i = 0;
    const cycleMs = 3000;
    const tabTimer = window.setInterval(() => {
      if (!tabs.length) return;
      tabs[i].classList.remove('mock-tab-active');
      i = (i + 1) % tabs.length;
      tabs[i].classList.add('mock-tab-active');
    }, cycleMs);

    const countTimer = window.setInterval(runCount, 6000);

    document.addEventListener('astro:before-swap', () => {
      window.clearInterval(tabTimer);
      window.clearInterval(countTimer);
    }, { once: true });
  }

  initMockApp();
  document.addEventListener('astro:after-swap', initMockApp);
</script>
