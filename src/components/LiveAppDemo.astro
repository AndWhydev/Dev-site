---
---

<section class="demo-section" id="demo">
  <div class="demo-inner">
    <div class="demo-header reveal">
      <span class="section-label">Live App Demo</span>
      <h2 class="section-heading">See What We Build</h2>
      <p class="section-subheading">
        Real applications. Real results. Every product we deliver is built to enterprise standards —
        performant, secure and scalable from day one.
      </p>
    </div>

    <div class="demo-showcase">
      <!-- iPhone mockup with video -->
      <div class="phone-wrap reveal-left stagger-1">
        <div class="phone-glow" aria-hidden="true"></div>
        <div class="iphone">
          <!-- Side buttons -->
          <div class="btn-silent" aria-hidden="true"></div>
          <div class="btn-vol-up" aria-hidden="true"></div>
          <div class="btn-vol-down" aria-hidden="true"></div>
          <div class="btn-power" aria-hidden="true"></div>

          <div class="iphone-body">
            <div class="iphone-screen">
              <div class="dynamic-island" aria-hidden="true"></div>
              <div class="mock-app" role="img" aria-label="Animated mobile application interface mockup">
                <div class="mock-status">
                  <span class="mock-time">9:41</span>
                  <div class="mock-status-icons">
                    <svg width="14" height="10" viewBox="0 0 14 10" fill="white" aria-hidden="true"><rect x="0" y="6" width="2.5" height="4" rx="0.5"/><rect x="3.5" y="4" width="2.5" height="6" rx="0.5"/><rect x="7" y="2" width="2.5" height="8" rx="0.5"/><rect x="10.5" y="0" width="2.5" height="10" rx="0.5"/></svg>
                    <svg width="13" height="10" viewBox="0 0 13 10" fill="white" aria-hidden="true"><path d="M6.5 0C4 0 1.7 1 0 2.5l1.2 1.2C2.6 2.5 4.5 1.8 6.5 1.8s3.9.7 5.3 1.9L13 2.5C11.3 1 9 0 6.5 0zm0 3.6C5 3.6 3.7 4.2 2.7 5l1.2 1.2c.7-.5 1.6-.9 2.6-.9s1.9.3 2.6.9L10.3 5C9.3 4.2 8 3.6 6.5 3.6zm0 3.4c-.8 0-1.5.3-2 .8L6.5 10l2-2.2c-.5-.5-1.2-.8-2-.8z"/></svg>
                    <svg width="22" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true"><rect x="0.5" y="0.5" width="18" height="9" rx="2" stroke="white" stroke-opacity="0.5"/><rect x="2" y="2" width="14" height="6" rx="1" fill="white"/><rect x="20" y="3.5" width="1.5" height="3" rx="0.5" fill="white" fill-opacity="0.5"/></svg>
                  </div>
                </div>

                <div class="mock-header">
                  <div>
                    <div class="mock-greeting">Good morning</div>
                    <div class="mock-name">Welcome back</div>
                  </div>
                  <div class="mock-avatar" aria-hidden="true">A</div>
                </div>

                <div class="mock-balance">
                  <div class="mock-balance-top">
                    <span class="mock-balance-label">Total balance</span>
                    <span class="mock-balance-trend">
                      <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 15 12 9 18 15"/></svg>
                      2.4%
                    </span>
                  </div>
                  <div class="mock-balance-value">
                    <span class="mock-currency">$</span><span class="mock-count" data-start="12200" data-target="12847">12,847</span><span class="mock-decimals">.50</span>
                  </div>
                  <svg class="mock-chart" viewBox="0 0 220 64" preserveAspectRatio="none" aria-hidden="true">
                    <defs>
                      <linearGradient id="mockChartGrad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#0d9373" stop-opacity="0.45"/>
                        <stop offset="100%" stop-color="#0d9373" stop-opacity="0"/>
                      </linearGradient>
                    </defs>
                    <path class="mock-chart-fill" d="M0,48 C25,44 40,38 65,32 C90,26 105,30 130,22 C155,15 170,10 195,8 C205,7 215,6 220,5 L220,64 L0,64Z" fill="url(#mockChartGrad)"/>
                    <path class="mock-chart-line" d="M0,48 C25,44 40,38 65,32 C90,26 105,30 130,22 C155,15 170,10 195,8 C205,7 215,6 220,5" fill="none" stroke="#0d9373" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                  <div class="mock-range">
                    <span class="mock-range-pill active">7D</span>
                    <span class="mock-range-pill">1M</span>
                    <span class="mock-range-pill">3M</span>
                    <span class="mock-range-pill">1Y</span>
                  </div>
                </div>

                <div class="mock-section-title">
                  <span>Recent activity</span>
                  <span class="mock-link">View all</span>
                </div>

                <div class="mock-activity">
                  <div class="mock-act-row">
                    <div class="mock-act-icon green" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </div>
                    <div class="mock-act-info">
                      <div class="mock-act-name">Deposit</div>
                      <div class="mock-act-meta">Today · 09:32</div>
                    </div>
                    <div class="mock-act-amt up">+$420.00</div>
                  </div>
                  <div class="mock-act-row">
                    <div class="mock-act-icon blue" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l10-10M7 7h10v10"/></svg>
                    </div>
                    <div class="mock-act-info">
                      <div class="mock-act-name">Transfer</div>
                      <div class="mock-act-meta">Yesterday</div>
                    </div>
                    <div class="mock-act-amt">−$84.50</div>
                  </div>
                  <div class="mock-act-row">
                    <div class="mock-act-icon amber" aria-hidden="true">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 12h6"/></svg>
                    </div>
                    <div class="mock-act-info">
                      <div class="mock-act-name">Payment</div>
                      <div class="mock-act-meta">2 days ago</div>
                    </div>
                    <div class="mock-act-amt">−$32.00</div>
                  </div>
                </div>

                <div class="mock-tabbar" role="tablist" aria-label="App navigation">
                  <button class="mock-tab" data-i="0" type="button" aria-label="Home">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10l9-7 9 7v10a2 2 0 01-2 2h-4v-7h-6v7H5a2 2 0 01-2-2z"/></svg>
                    <span>Home</span>
                  </button>
                  <button class="mock-tab" data-i="1" type="button" aria-label="Overview">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>
                    <span>Overview</span>
                  </button>
                  <button class="mock-tab" data-i="2" type="button" aria-label="Activity">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    <span>Activity</span>
                  </button>
                  <button class="mock-tab" data-i="3" type="button" aria-label="Reports">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                    <span>Reports</span>
                  </button>
                  <div class="mock-home-indicator" aria-hidden="true"></div>
                </div>
              </div>
              <div class="screen-overlay" aria-hidden="true"></div>
            </div>
          </div>
        </div>

        <div class="phone-caption">
          <div class="phone-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#0d9373"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/></svg>
            <span>Product demo</span>
          </div>
          <p>Mobile app — built with our platform</p>
        </div>
      </div>

      <!-- Desktop browser mockup -->
      <div class="browser-wrap reveal-right stagger-2">
        <div class="browser">
          <div class="browser-chrome">
            <div class="browser-dots">
              <span class="dot red"></span>
              <span class="dot yellow"></span>
              <span class="dot green"></span>
            </div>
            <div class="browser-tabs">
              <div class="browser-tab active">Dashboard</div>
              <div class="browser-tab">Analytics</div>
              <div class="browser-tab">Reports</div>
            </div>
            <div class="browser-bar">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4a6359" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <span>app.enterprise-dashboard.io/overview</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
          </div>
          <div class="browser-content">
            <div class="dashboard">
              <!-- Sidebar -->
              <div class="dash-sidebar">
                <div class="dash-logo-mark">
                  <svg width="20" height="20" viewBox="0 0 36 36" fill="none"><rect width="36" height="36" rx="9" fill="#0d9373"/><path d="M8 27L18 9L28 27" stroke="white" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M11.5 21.5H24.5" stroke="white" stroke-width="2.8" stroke-linecap="round"/></svg>
                </div>
                <nav class="dash-nav">
                  <a class="dash-nav-item active" aria-label="Dashboard">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                  </a>
                  <a class="dash-nav-item" aria-label="Analytics">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                  </a>
                  <a class="dash-nav-item" aria-label="Projects">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
                  </a>
                  <a class="dash-nav-item" aria-label="Team">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                  </a>
                  <a class="dash-nav-item" aria-label="Settings">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                  </a>
                </nav>
              </div>

              <!-- Main content -->
              <div class="dash-main">
                <div class="dash-topbar">
                  <div>
                    <div class="dash-title">Overview</div>
                    <div class="dash-date">May 2026</div>
                  </div>
                  <div class="dash-topbar-right">
                    <div class="dash-search">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4a6359" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                      <span>Search...</span>
                    </div>
                    <div class="dash-avatar">AW</div>
                  </div>
                </div>

                <!-- Stat cards -->
                <div class="stat-cards">
                  <div class="stat-card">
                    <div class="stat-icon rev"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg></div>
                    <div class="stat-val">$2.4M</div>
                    <div class="stat-lbl">Revenue</div>
                    <div class="stat-delta up">+18.2%</div>
                  </div>
                  <div class="stat-card">
                    <div class="stat-icon usr"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div>
                    <div class="stat-val">14,832</div>
                    <div class="stat-lbl">Active Users</div>
                    <div class="stat-delta up">+4.7%</div>
                  </div>
                  <div class="stat-card">
                    <div class="stat-icon prj"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
                    <div class="stat-val">98.7%</div>
                    <div class="stat-lbl">Uptime</div>
                    <div class="stat-delta up">+0.3%</div>
                  </div>
                  <div class="stat-card">
                    <div class="stat-icon rat"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
                    <div class="stat-val">4.9 / 5</div>
                    <div class="stat-lbl">Rating</div>
                    <div class="stat-delta up">+0.1</div>
                  </div>
                </div>

                <!-- Mini chart -->
                <div class="dash-chart-row">
                  <div class="dash-chart">
                    <div class="chart-header">
                      <span class="chart-title">Revenue Trend</span>
                      <span class="chart-period">Last 7 months</span>
                    </div>
                    <svg class="line-chart" viewBox="0 0 320 80" preserveAspectRatio="none">
                      <defs>
                        <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                          <stop offset="0%" stop-color="#0d9373" stop-opacity="0.3"/>
                          <stop offset="100%" stop-color="#0d9373" stop-opacity="0"/>
                        </linearGradient>
                      </defs>
                      <path d="M0,65 C30,60 50,45 80,40 C110,35 130,25 160,20 C190,15 210,22 240,18 C270,14 290,10 320,8" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round"/>
                      <path d="M0,65 C30,60 50,45 80,40 C110,35 130,25 160,20 C190,15 210,22 240,18 C270,14 290,10 320,8 L320,80 L0,80Z" fill="url(#chartGrad)"/>
                    </svg>
                  </div>

                  <!-- Recent projects list -->
                  <div class="dash-projects">
                    <div class="chart-header">
                      <span class="chart-title">Recent Deployments</span>
                    </div>
                    <div class="project-list">
                      <div class="project-row">
                        <div class="proj-dot green"></div>
                        <div class="proj-info">
                          <div class="proj-name">Auth Service v2.1</div>
                          <div class="proj-time">2m ago</div>
                        </div>
                        <div class="proj-status success">Live</div>
                      </div>
                      <div class="project-row">
                        <div class="proj-dot green"></div>
                        <div class="proj-info">
                          <div class="proj-name">API Gateway</div>
                          <div class="proj-time">1h ago</div>
                        </div>
                        <div class="proj-status success">Live</div>
                      </div>
                      <div class="project-row">
                        <div class="proj-dot yellow"></div>
                        <div class="proj-info">
                          <div class="proj-name">ML Pipeline</div>
                          <div class="proj-time">3h ago</div>
                        </div>
                        <div class="proj-status pending">Building</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="browser-caption">
          <div class="phone-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            <span>Enterprise Dashboard</span>
          </div>
          <p>React / Next.js — custom SaaS platform</p>
        </div>
      </div>
    </div>

    <!-- Supporting points -->
    <div class="demo-points reveal stagger-3">
      <div class="demo-point">
        <div class="demo-point-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 13 9 20 9"/><path d="M20 14.66V20a2 2 0 01-2 2H4a2 2 0 01-2-2V4a2 2 0 012-2h5.34"/><polygon points="18 2 22 6 12 16 8 16 8 12 18 2"/></svg>
        </div>
        <div>
          <strong>Production-Ready Code</strong>
          <p>Every line of code is written to enterprise standards with full test coverage, documentation and CI/CD pipelines.</p>
        </div>
      </div>
      <div class="demo-point">
        <div class="demo-point-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <strong>Security First</strong>
          <p>Built with OWASP standards, end-to-end encryption, role-based access control and penetration testing as standard.</p>
        </div>
      </div>
      <div class="demo-point">
        <div class="demo-point-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div>
          <strong>Built to Scale</strong>
          <p>Architected for millions of users. Cloud-native, containerised and auto-scaling from the ground up.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .demo-section {
    padding: 6rem 0;
    background: #0a0a0a;
    position: relative;
    overflow: hidden;
  }

  .demo-section::before {
    content: '';
    position: absolute;
    top: 10%;
    left: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(13,147,115,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .demo-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .demo-header {
    margin-bottom: 4rem;
  }

  .demo-showcase {
    display: grid;
    grid-template-columns: 1fr 1.7fr;
    gap: 5rem;
    align-items: center;
    margin-bottom: 5rem;
  }

  /* ---- iPhone ---- */
  .phone-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    position: relative;
  }

  .phone-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 340px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(13,147,115,0.2) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .iphone {
    position: relative;
    width: 280px;
    z-index: 1;
    flex-shrink: 0;
  }

  .iphone-body {
    background: linear-gradient(160deg, #3a3a3c 0%, #1c1c1e 30%, #242426 60%, #3a3a3c 100%);
    border-radius: 48px;
    padding: 13px;
    box-shadow:
      0 0 0 1px #4a4a4c,
      0 0 0 2.5px #0a0f0e,
      0 30px 100px rgba(0,0,0,0.9),
      0 0 60px rgba(13,147,115,0.12),
      inset 0 1px 0 rgba(255,255,255,0.08);
    position: relative;
  }

  .btn-silent {
    position: absolute;
    left: -3.5px;
    top: 88px;
    width: 3.5px;
    height: 28px;
    background: linear-gradient(to right, #2a2a2c, #3c3c3e);
    border-radius: 3px 0 0 3px;
  }
  .btn-vol-up {
    position: absolute;
    left: -3.5px;
    top: 135px;
    width: 3.5px;
    height: 52px;
    background: linear-gradient(to right, #2a2a2c, #3c3c3e);
    border-radius: 3px 0 0 3px;
  }
  .btn-vol-down {
    position: absolute;
    left: -3.5px;
    top: 200px;
    width: 3.5px;
    height: 52px;
