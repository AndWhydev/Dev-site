---
---

<section class="roi-section" id="roi-calculator">
  <div class="roi-inner">
    <div class="roi-header reveal">
      <span class="section-label">Savings Estimate</span>
      <h2 class="section-heading">What Could Automation Save You?</h2>
      <p class="section-subheading">
        A simple order-of-magnitude estimate of hours and payroll cost you could redirect by automating repetitive manual work. Build cost depends on integrations and data complexity, we'll quote it after a discovery call.
      </p>
    </div>

    <div class="roi-grid">
      <!-- Inputs -->
      <div class="roi-inputs reveal-left stagger-1">
        <div class="roi-input-group">
          <label for="roi-employees">
            <span>Employees affected</span>
            <span class="roi-input-val" id="employees-val">10</span>
          </label>
          <input type="range" id="roi-employees" min="1" max="500" value="10" step="1" />
          <div class="roi-range-labels"><span>1</span><span>500</span></div>
        </div>

        <div class="roi-input-group">
          <label for="roi-hours">
            <span>Hours/week each spends on the task</span>
            <span class="roi-input-val" id="hours-val">10</span>
          </label>
          <input type="range" id="roi-hours" min="1" max="40" value="10" step="1" />
          <div class="roi-range-labels"><span>1</span><span>40</span></div>
        </div>

        <div class="roi-input-group">
          <label for="roi-rate">
            <span>Average loaded hourly cost (AUD)</span>
            <span class="roi-input-val" id="rate-val">$65</span>
          </label>
          <input type="range" id="roi-rate" min="30" max="200" value="65" step="5" />
          <div class="roi-range-labels"><span>$30</span><span>$200</span></div>
        </div>

        <div class="roi-input-group">
          <label for="roi-automation">
            <span>How much of the task is automatable</span>
            <span class="roi-input-val" id="automation-val">50%</span>
          </label>
          <input type="range" id="roi-automation" min="10" max="90" value="50" step="5" />
          <div class="roi-range-labels"><span>10%</span><span>90%</span></div>
        </div>

        <div class="roi-note">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          Indicative only. Real savings depend on workflow complexity, exception handling and adoption. We do not quote build cost or payback from a calculator, only from a scoping call.
        </div>
      </div>

      <!-- Outputs -->
      <div class="roi-outputs reveal-right stagger-2">
        <div class="roi-output-card primary">
          <div class="roi-output-label">Hours redirected per year</div>
          <div class="roi-output-val" id="hours-saved">13,000</div>
          <div class="roi-output-sub">time your team gets back from this one task</div>
        </div>

        <div class="roi-output-card">
          <div class="roi-output-label">Annual payroll cost recovered</div>
          <div class="roi-output-val green" id="money-saved">$845K</div>
          <div class="roi-output-sub">at the loaded hourly cost you entered</div>
        </div>

        <div class="roi-output-card">
          <div class="roi-output-label">Per-employee hours back</div>
          <div class="roi-output-val" id="hours-per-employee">1,300</div>
          <div class="roi-output-sub">hours/year, per affected employee</div>
        </div>

        <div class="roi-cta">
          <a href="/contact" class="btn-primary">
            Get a real quote
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <p>We'll scope the build, the integrations and the realistic adoption curve, then quote a fixed price.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .roi-section {
    padding: 6rem 0;
    background: #0a0a0a;
    position: relative;
    overflow: hidden;
  }

  .roi-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #0a0f0e 0%, transparent 10%, transparent 90%, #0a0f0e 100%);
    pointer-events: none;
  }

  .roi-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  .roi-header {
    margin-bottom: 4rem;
    max-width: 640px;
  }

  .roi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Inputs */
  .roi-input-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .roi-input-group label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #8aa09a;
  }
  .roi-input-group label > span:first-child {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .roi-input-val {
    font-family: 'Sora', sans-serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: #0d9373;
  }

  /* Sliders, wrapped in a tall hit area so the whole 44px row is tappable
     on touch screens, even though the visible rail is thin. */
  input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 44px;
    background: transparent;
    outline: none;
    cursor: pointer;
    /* Custom rail painted behind the thumb so we keep the slim look without
       sacrificing the 44px tap target. */
    background-image: linear-gradient(#1e2d28, #1e2d28);
    background-repeat: no-repeat;
    background-size: 100% 4px;
    background-position: 0 50%;
    border-radius: 2px;
  }

  input[type="range"]::-webkit-slider-runnable-track {
    height: 44px;
    background: transparent;
  }
  input[type="range"]::-moz-range-track {
    height: 4px;
    background: #1e2d28;
    border-radius: 2px;
  }

  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 24px;
    height: 24px;
    margin-top: -10px; /* centre on the 4px rail at 50% */
    border-radius: 50%;
    background: #0d9373;
    cursor: pointer;
    border: 2px solid #0a0a0a;
    box-shadow: 0 0 0 4px rgba(13,147,115,0.18), 0 2px 8px rgba(0,0,0,0.4);
    transition: box-shadow 0.2s ease, transform 0.15s ease;
  }
  input[type="range"]::-moz-range-thumb {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #0d9373;
    cursor: pointer;
    border: 2px solid #0a0a0a;
    box-shadow: 0 0 0 4px rgba(13,147,115,0.18), 0 2px 8px rgba(0,0,0,0.4);
  }

  input[type="range"]::-webkit-slider-thumb:hover { box-shadow: 0 0 0 6px rgba(13,147,115,0.25); }
  input[type="range"]:active::-webkit-slider-thumb { transform: scale(1.08); }

  @media (max-width: 480px) {
    input[type="range"]::-webkit-slider-thumb {
      width: 28px; height: 28px; margin-top: -12px;
    }
    input[type="range"]::-moz-range-thumb {
      width: 28px; height: 28px;
    }
  }

  .roi-range-labels {
    display: flex;
    justify-content: space-between;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    color: #4a6359;
  }

  .roi-note {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
    background: rgba(13,147,115,0.04);
    border: 1px solid rgba(13,147,115,0.1);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    line-height: 1.5;
    margin-top: 0.5rem;
  }

  /* Outputs */
  .roi-outputs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .roi-output-card {
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 14px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    transition: border-color 0.2s ease;
  }

  .roi-output-card:hover {
    border-color: rgba(13,147,115,0.25);
  }

  .roi-output-card.primary {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, rgba(13,147,115,0.08) 0%, #0a0f0e 60%);
    border-color: rgba(13,147,115,0.2);
  }

  .roi-output-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #4a6359;
  }

  .roi-output-val {
    font-family: 'Sora', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    transition: all 0.3s ease;
  }

  .roi-output-card.primary .roi-output-val {
    font-size: 2rem;
  }

  .roi-output-val.green {
    color: #0d9373;
  }

  .roi-output-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #4a6359;
  }

  .roi-cta {
    grid-column: 1 / -1;
    background: rgba(13,147,115,0.05);
    border: 1px solid rgba(13,147,115,0.2);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .roi-cta p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #8aa09a;
    margin: 0;
    flex: 1;
    min-width: 200px;
  }

  @media (max-width: 900px) {
    .roi-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* Keep the four output cards in a 2x2 grid all the way down to 360px so
     the section never collapses to a long stack, the user explicitly asked
     for 2x2 on mobile. The primary card stays full-width above. */
  @media (max-width: 480px) {
    .roi-section { padding: 4rem 0; }
    .roi-inner { padding: 0 1.25rem; }
    .roi-header { margin-bottom: 2.5rem; }
    .roi-input-group { margin-bottom: 1.5rem; }
    .roi-input-group label { font-size: 0.875rem; }
    .roi-input-val { font-size: 1rem; }
    .roi-outputs { gap: 0.625rem; }
    .roi-output-card { padding: 1rem; }
    .roi-output-val { font-size: 1.25rem; }
    .roi-output-card.primary .roi-output-val { font-size: 1.75rem; }
    .roi-output-label { font-size: 0.625rem; letter-spacing: 0.06em; }
    .roi-cta { padding: 1.25rem; min-height: 44px; }
  }
</style>

<script>
  const employees = document.getElementById('roi-employees') as HTMLInputElement;
  const hours = document.getElementById('roi-hours') as HTMLInputElement;
  const rate = document.getElementById('roi-rate') as HTMLInputElement;
  const automation = document.getElementById('roi-automation') as HTMLInputElement;

  const employeesVal = document.getElementById('employees-val')!;
  const hoursVal = document.getElementById('hours-val')!;
  const rateVal = document.getElementById('rate-val')!;
  const automationVal = document.getElementById('automation-val')!;

  const hoursSavedEl = document.getElementById('hours-saved')!;
  const moneySavedEl = document.getElementById('money-saved')!;
  const hoursPerEmployeeEl = document.getElementById('hours-per-employee')!;

  function fmt(n: number): string {
    if (n >= 1_000_000) return `$${(n / 1_000_000).toFixed(1)}M`;
    if (n >= 1000) return `$${Math.round(n / 1000)}K`;
    return `$${Math.round(n)}`;
  }

  function calc() {
    const e = parseInt(employees.value);
    const h = parseInt(hours.value);
    const r = parseInt(rate.value);
    const a = parseInt(automation.value);

    employeesVal.textContent = String(e);
    hoursVal.textContent = String(h);
    rateVal.textContent = `$${r}`;
    automationVal.textContent = `${a}%`;

    const factor = a / 100;
    const hoursSaved = Math.round(e * h * 52 * factor);
    const moneySaved = Math.round(hoursSaved * r);
    const hoursPerEmployee = Math.round(h * 52 * factor);

    hoursSavedEl.textContent = hoursSaved.toLocaleString();
    moneySavedEl.textContent = fmt(moneySaved) + '/yr';
    hoursPerEmployeeEl.textContent = hoursPerEmployee.toLocaleString();
  }

  [employees, hours, rate, automation].forEach((inp) => inp.addEventListener('input', calc));
  calc();
</script>
