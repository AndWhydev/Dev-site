---
import Layout, { BRAND_DEFINITION } from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';

export interface Benefit {
  icon: string;
  title: string;
  description: string;
}

export interface UseCase {
  title: string;
  description: string;
  industry?: string;
}

export interface ProcessStep {
  step: string;
  title: string;
  description: string;
  duration?: string;
}

export interface FAQ {
  question: string;
  answer: string;
}

export interface RelatedService {
  title: string;
  href: string;
}

export interface PricingTier {
  name: string;
  range: string;
  detail: string;
}

export interface Comparison {
  rightFor: string[];
  notRightFor: string[];
}

export interface Definition {
  term: string;
  definition: string;
}

interface Props {
  metaTitle: string;
  metaDescription: string;
  category: string;
  heroHeadline: string;
  heroTagline: string;
  description: string[];
  benefits: Benefit[];
  useCases: UseCase[];
  technologies: string[];
  process: ProcessStep[];
  industries: string[];
  faqs: FAQ[];
  relatedServices: RelatedService[];
  heroIcon?: string;
  /** Short service name used in question-based headings and Service schema, e.g. "API Development". Falls back to category. */
  serviceName?: string;
  /** Slug for schema @id/url, e.g. "api-development". Falls back to the current pathname. */
  slug?: string;
  /** One-sentence, third-person liftable summary of this service. */
  summaryStatement?: string;
  /** Pricing tiers (placeholder ranges, AUD). */
  pricing?: PricingTier[];
  /** When this IS / is NOT the right solution — also carries the negative qualifiers. */
  comparison?: Comparison;
  /** Definition blocks for technical terms used on this page. */
  definitions?: Definition[];
}

const {
  metaTitle,
  metaDescription,
  category,
  heroHeadline,
  heroTagline,
  description,
  benefits,
  useCases,
  technologies,
  process,
  industries,
  faqs,
  relatedServices,
  heroIcon,
  serviceName,
  slug,
  summaryStatement,
  pricing,
  comparison,
  definitions,
} = Astro.props;

const siteUrl = 'https://aibusinesssolutions.au';
const name = serviceName ?? category;
const pageSlug = slug ?? Astro.url.pathname.replace(/\/+$/, '').split('/').pop() ?? '';
const canonicalUrl = `${siteUrl}/services/${pageSlug}`;

// ── Semantic schema for AI search (GEO): Service + FAQPage + BreadcrumbList ──
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonicalUrl}#service`,
  name: name,
  serviceType: name,
  category: category,
  description: metaDescription,
  url: canonicalUrl,
  provider: { '@id': `${siteUrl}/#organization` },
  areaServed: { '@type': 'Country', name: 'Australia' },
  audience: { '@type': 'BusinessAudience', name: 'Australian enterprises and scale-ups' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${canonicalUrl}#faq`,
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${siteUrl}/services` },
    { '@type': 'ListItem', position: 3, name: name, item: canonicalUrl },
  ],
};

const extraSchema = [serviceSchema, faqSchema, breadcrumbSchema];
const entitySentence = BRAND_DEFINITION;
---

<Layout title={metaTitle} description={metaDescription} canonical={canonicalUrl} extraSchema={extraSchema}>
  <Header />
  <main>
    <!-- Hero -->
    <section class="svc-hero">
      <div class="svc-hero-bg" aria-hidden="true"></div>
      <div class="svc-hero-inner">
        <div class="svc-hero-content reveal">
          <div class="svc-breadcrumb">
            <a href="/">Home</a>
            <span>/</span>
            <a href="/services">Services</a>
            <span>/</span>
            <span>{category}</span>
          </div>
          <span class="section-label">{category}</span>
          <h1 class="svc-hero-title">{heroHeadline}</h1>
          <p class="svc-hero-tagline">{heroTagline}</p>
          <div class="svc-hero-ctas">
            <a href="/contact" class="btn-primary">
              Get a Quote
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/contact" class="btn-outline">Book a Discovery Call</a>
          </div>
        </div>
        {heroIcon && (
          <div class="svc-hero-icon reveal-right stagger-2" set:html={heroIcon} />
        )}
      </div>
    </section>

    <!-- What it is -->
    <section class="svc-what">
      <div class="svc-inner">
        <div class="svc-what-grid">
          <div class="reveal-left">
            <span class="section-label">Overview</span>
            <h2 class="section-heading">What does {name} involve?</h2>
            {summaryStatement && <p class="svc-liftable">{summaryStatement}</p>}
            {description.map((para) => <p class="svc-para">{para}</p>)}
            <p class="svc-entity-note">{entitySentence}</p>
          </div>
          <div class="svc-what-highlights reveal-right stagger-2">
            <div class="highlight-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Senior engineers only — no juniors on client work</span>
            </div>
            <div class="highlight-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Full IP ownership transferred on completion</span>
            </div>
            <div class="highlight-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Comprehensive documentation included</span>
            </div>
            <div class="highlight-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Post-launch support and SLA available</span>
            </div>
            <div class="highlight-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Australian-based team, AEST timezone</span>
            </div>
            <div class="highlight-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Enterprise security standards built-in</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="svc-benefits">
      <div class="svc-inner">
        <div class="reveal">
          <span class="section-label">Key Benefits</span>
          <h2 class="section-heading">Why choose All Webbed Labs for {name}?</h2>
        </div>
        <div class="benefits-grid">
          {benefits.map((b, i) => (
            <div class={`benefit-card card-hover reveal stagger-${Math.min(i + 1, 6)}`}>
              <div class="benefit-icon" set:html={b.icon} />
              <h3>{b.title}</h3>
              <p>{b.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Video placeholder -->
    <section class="svc-video-section">
      <div class="svc-inner">
        <div class="video-placeholder-wrap reveal">
          <!-- VIDEO_PLACEHOLDER — add Rotato demo video here showing this service in action -->
          <div class="video-placeholder">
            <div class="vp-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
            </div>
            <p class="vp-label">Demo Video</p>
            <p class="vp-note">VIDEO_PLACEHOLDER — add Rotato demo video here</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Use Cases -->
    <section class="svc-usecases">
      <div class="svc-inner">
        <div class="reveal">
          <span class="section-label">Real-World Applications</span>
          <h2 class="section-heading">How do Australian businesses use {name}?</h2>
        </div>
        <div class="usecases-grid">
          {useCases.map((uc, i) => (
            <div class={`usecase-card reveal stagger-${Math.min(i + 1, 4)}`}>
              {uc.industry && <div class="uc-industry">{uc.industry}</div>}
              <h3>{uc.title}</h3>
              <p>{uc.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Technology Stack -->
    <section class="svc-tech">
      <div class="svc-inner">
        <div class="reveal">
          <span class="section-label">Technology Stack</span>
          <h2 class="section-heading">What technologies does All Webbed Labs use for {name}?</h2>
        </div>
        <div class="tech-tags reveal stagger-1">
          {technologies.map((tech) => (
            <span class="tech-tag-badge">{tech}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="svc-process">
      <div class="svc-inner">
        <div class="reveal">
          <span class="section-label">Our Process</span>
          <h2 class="section-heading">What does the {name} process look like?</h2>
        </div>
        <div class="svc-process-list">
          {process.map((step, i) => (
            <div class={`svc-step reveal stagger-${Math.min(i + 1, 6)}`}>
              <div class="svc-step-num">{step.step}</div>
              <div class="svc-step-content">
                {step.duration && <div class="svc-step-duration">{step.duration}</div>}
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
              {i < process.length - 1 && (
                <div class="svc-step-connector" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1e2d28" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Industries -->
    <section class="svc-industries">
      <div class="svc-inner">
        <div class="reveal">
          <span class="section-label">Industries Served</span>
          <h2 class="section-heading">Who is {name} for?</h2>
        </div>
        <div class="svc-industry-tags reveal stagger-1">
          {industries.map((ind) => (
            <span class="svc-ind-tag">{ind}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Comparison: right fit vs not the right fit (negative qualifiers) -->
    {comparison && (
      <section class="svc-fit">
        <div class="svc-inner">
          <div class="reveal">
            <span class="section-label">Honest Fit Assessment</span>
            <h2 class="section-heading">Is {name} the right solution for you?</h2>
          </div>
          <div class="fit-grid">
            <div class="fit-col fit-yes reveal stagger-1">
              <div class="fit-col-head">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <h3>When {name} is the right fit</h3>
              </div>
              <ul>
                {comparison.rightFor.map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <div class="fit-col fit-no reveal stagger-2">
              <div class="fit-col-head">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#b4604f" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                <h3>When it is not the right fit</h3>
              </div>
              <ul>
                {comparison.notRightFor.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Pricing -->
    {pricing && pricing.length > 0 && (
      <section class="svc-pricing">
        <div class="svc-inner">
          <div class="reveal">
            <span class="section-label">Indicative Pricing</span>
            <h2 class="section-heading">How much does {name} cost?</h2>
            <p class="svc-pricing-note">Indicative ranges in AUD to help you budget. Every engagement is scoped individually — book a discovery call for a fixed quote tailored to your requirements.</p>
          </div>
          <div class="pricing-grid">
            {pricing.map((tier, i) => (
              <div class={`pricing-card reveal stagger-${Math.min(i + 1, 4)}`}>
                <div class="pricing-tier">{tier.name}</div>
                <div class="pricing-range">{tier.range}</div>
                <p class="pricing-detail">{tier.detail}</p>
              </div>
            ))}
          </div>
          <div class="pricing-cta reveal">
            <a href="/contact" class="btn-primary">
              Book a Discovery Call
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- Definitions -->
    {definitions && definitions.length > 0 && (
      <section class="svc-definitions">
        <div class="svc-inner">
          <div class="reveal">
            <span class="section-label">Key Terms, Defined</span>
            <h2 class="section-heading">{name}: a quick glossary</h2>
          </div>
          <dl class="definitions-list">
            {definitions.map((d, i) => (
              <div class={`definition-item reveal stagger-${Math.min(i + 1, 6)}`}>
                <dt>{d.term}</dt>
                <dd>{d.definition}</dd>
              </div>
            ))}
          </dl>
        </div>
      </section>
    )}

    <!-- Case Study Placeholder -->
    <section class="svc-casestudy">
      <div class="svc-inner">
        <div class="casestudy-placeholder reveal">
          <!-- CASE_STUDY_PLACEHOLDER — add real case study here when available -->
          <div class="csp-badge">Case Study</div>
          <h3>See This Service in Action</h3>
          <p>We're preparing a detailed case study showing how we delivered this service for a leading Australian enterprise. Check back soon, or <a href="/contact">contact us</a> to discuss similar work.</p>
          <div class="csp-stats">
            <div class="csp-stat">
              <span class="csp-stat-num">TODO</span>
              <span class="csp-stat-label">Add real metric</span>
            </div>
            <div class="csp-stat">
              <span class="csp-stat-num">TODO</span>
              <span class="csp-stat-label">Add real metric</span>
            </div>
            <div class="csp-stat">
              <span class="csp-stat-num">TODO</span>
              <span class="csp-stat-label">Add real metric</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="svc-faq">
      <div class="svc-inner">
        <div class="reveal">
          <span class="section-label">Common Questions</span>
          <h2 class="section-heading">Common questions about {name}</h2>
        </div>
        <div class="faq-list">
          {faqs.map((faq, i) => (
            <div class={`faq-item reveal stagger-${Math.min(i + 1, 6)}`}>
              <button class="faq-q" data-faq={i} aria-expanded="false">
                <span>{faq.question}</span>
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-a" id={`faq-${i}`} hidden>
                <p>{faq.answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Related Services -->
    <section class="svc-related">
      <div class="svc-inner">
        <div class="reveal">
          <span class="section-label">Explore Further</span>
          <h2 class="section-heading">What should you explore next?</h2>
        </div>
        <div class="related-grid">
          {relatedServices.map((rs, i) => (
            <a href={rs.href} class={`related-card card-hover reveal stagger-${Math.min(i + 1, 4)}`}>
              <span>{rs.title}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>

<style>
  .svc-hero {
    padding: 9rem 0 6rem;
    background: #0a0f0e;
    position: relative;
    overflow: hidden;
  }

  .svc-hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 60% 30%, rgba(13,147,115,0.09) 0%, transparent 65%);
    pointer-events: none;
  }

  .svc-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
  }

  .svc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
    margin-bottom: 1.5rem;
  }

  .svc-breadcrumb a {
    color: #4a6359;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .svc-breadcrumb a:hover {
    color: #0d9373;
  }

  .svc-hero-title {
    font-family: 'Sora', sans-serif;
    font-size: clamp(2.25rem, 5.5vw, 4rem);
    font-weight: 800;
    color: white;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    max-width: 700px;
  }

  .svc-hero-tagline {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    color: #8aa09a;
    max-width: 560px;
    line-height: 1.65;
    margin-bottom: 2.5rem;
  }

  .svc-hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .svc-hero-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 240px;
    height: 240px;
    border-radius: 28px;
    background: rgba(13,147,115,0.05);
    border: 1px solid rgba(13,147,115,0.15);
    color: rgba(13,147,115,0.3);
  }

  .svc-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* What it is */
  .svc-what {
    padding: 7rem 0;
    background: #0f1614;
  }

  .svc-what-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .svc-para {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: #4a6359;
    line-height: 1.75;
    margin: 0 0 1.25rem;
  }

  .svc-what-highlights {
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 20px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 4.5rem;
  }

  .highlight-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #8aa09a;
  }

  /* Benefits */
  .svc-benefits {
    padding: 7rem 0;
    background: #0a0f0e;
  }

  .svc-benefits .section-heading { margin-bottom: 3rem; }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .benefit-card {
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .benefit-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(13,147,115,0.08);
    border: 1px solid rgba(13,147,115,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0d9373;
  }

  .benefit-card h3 {
    font-family: 'Sora', sans-serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: white;
    margin: 0;
  }

  .benefit-card p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #4a6359;
    line-height: 1.65;
    margin: 0;
  }

  /* Video placeholder */
  .svc-video-section {
    padding: 4rem 0;
    background: #0f1614;
  }

  .video-placeholder-wrap {
    display: flex;
    justify-content: center;
  }

  .video-placeholder {
    width: 100%;
    max-width: 800px;
    aspect-ratio: 16/9;
    background: #0a0f0e;
    border: 2px dashed #1e2d28;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    cursor: default;
    transition: border-color 0.2s ease;
  }

  .video-placeholder:hover {
    border-color: rgba(13,147,115,0.3);
  }

  .vp-icon {
    opacity: 0.5;
  }

  .vp-label {
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #4a6359;
    margin: 0;
  }

  .vp-note {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #2a3d35;
    margin: 0;
    font-style: italic;
  }

  /* Use Cases */
  .svc-usecases {
    padding: 7rem 0;
    background: #0a0f0e;
  }

  .svc-usecases .section-heading { margin-bottom: 3rem; }

  .usecases-grid {
    display: grid;
