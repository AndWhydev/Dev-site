---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import PremiumEffects from '../components/PremiumEffects.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  /** Additional JSON-LD objects to emit alongside the Organization schema (Service, FAQPage, BreadcrumbList, etc.) */
  extraSchema?: Record<string, unknown>[];
}

const {
  title,
  description,
  ogImage = '/og-image.jpg',
  canonical,
  noindex = false,
  extraSchema = [],
} = Astro.props;

const siteUrl = 'https://awlabs.com.au';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;

// Canonical brand definition — entity-locking sentence used site-wide for AI search (GEO).
// Keep this string identical wherever it appears across the site.
export const BRAND_DEFINITION =
  'All Webbed Labs is the enterprise AI and software development arm of All Webbed Up, a Sydney based agency building autonomous systems for Australian businesses.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: 'All Webbed Labs',
  alternateName: 'AWL',
  url: siteUrl,
  logo: `${siteUrl}/logo.svg`,
  description: BRAND_DEFINITION,
  email: 'labs@allwebbedup.com.au',
  telephone: '1800714148',
  founder: {
    '@type': 'Person',
    name: 'Andy',
    jobTitle: 'Founder',
    worksFor: { '@type': 'Organization', name: 'All Webbed Labs' },
  },
  areaServed: { '@type': 'Country', name: 'Australia' },
  knowsAbout: [
    'Custom software development',
    'Enterprise application development',
    'Artificial intelligence integration',
    'Large language model integration',
    'Retrieval-augmented generation',
    'Cloud infrastructure and DevOps',
    'Cybersecurity',
    'Blockchain and smart contract development',
    'Data analytics',
    'Workflow automation',
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: '204 Birdwood Rd',
    addressLocality: 'Georges Hall',
    addressRegion: 'NSW',
    postalCode: '2198',
    addressCountry: 'AU',
  },
  parentOrganization: {
    '@type': 'Organization',
    name: 'All Webbed Up',
    url: 'https://allwebbedup.com.au',
  },
  sameAs: [
    'https://linkedin.com/company/allwebbedup',
    'https://facebook.com/allwebbedup',
    'https://instagram.com/allwebbedup',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).href} />
    <meta property="og:site_name" content="All Webbed Labs" />
    <meta property="og:locale" content="en_AU" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, siteUrl).href} />

    <!-- Fonts — non-render-blocking. Preconnect warms TLS to the font CDNs,
         the print-media trick lets the browser fetch the stylesheet without
         delaying first paint, and `display=swap` shows fallback text until
         the webfont arrives. Weights are subset to the ones actually used
         site-wide (Sora 300-800, DM Sans 300-700). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" />
    </noscript>

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0f0e" />
    <meta name="msapplication-TileColor" content="#0a0f0e" />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    {extraSchema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- View Transitions -->
    <ClientRouter />

    {/* Suppress benign InvalidStateError that the View Transitions API throws
        when a navigation is superseded by another (fast click, back button,
        link clicked mid-transition). The page still renders correctly — this
        just keeps the console quiet for an error that has no functional
        impact and that Astro itself does not handle internally. */}
    <script is:inline>
      window.addEventListener('unhandledrejection', (e) => {
        const r = e.reason;
        if (r && r.name === 'InvalidStateError' &&
            typeof r.message === 'string' &&
            r.message.includes('Transition was aborted')) {
          e.preventDefault();
        }
      });
    </script>
  </head>

  <body>
    <style is:global>
      /* View transition animations */
      ::view-transition-old(root) {
        animation: 220ms cubic-bezier(0.4, 0, 1, 1) both vt-fade-out;
      }
      ::view-transition-new(root) {
        animation: 280ms cubic-bezier(0, 0, 0.2, 1) both vt-fade-in;
      }
      @keyframes vt-fade-out {
        from { opacity: 1; transform: translateY(0); }
        to   { opacity: 0; transform: translateY(-8px); }
      }
      @keyframes vt-fade-in {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    </style>

    <PremiumEffects />

    <!-- Loading screen -->
    <div id="page-loader">
      <div class="loader-inner">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="48" height="48" rx="12" fill="#0d9373"/>
          <path d="M12 36L24 12L36 36" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M15.5 28.5H32.5" stroke="white" stroke-width="3.5" stroke-linecap="round"/>
        </svg>
        <span>All Webbed Labs</span>
        <div class="loader-bar"><div class="loader-fill"></div></div>
      </div>
    </div>

    <slot />

    <style>
      #page-loader {
        position: fixed;
        inset: 0;
        background: #0a0f0e;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        transition: opacity 0.5s ease, visibility 0.5s ease;
      }
      #page-loader.hidden {
        opacity: 0;
        visibility: hidden;
      }
      .loader-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }
      .loader-inner svg {
        animation: loader-pulse 1s ease-in-out infinite;
      }
      .loader-inner span {
        font-family: 'Sora', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        color: #8aa09a;
        text-transform: uppercase;
      }
      .loader-bar {
        width: 200px;
        height: 2px;
        background: #1e2d28;
        border-radius: 2px;
        overflow: hidden;
      }
      .loader-fill {
        width: 100%;
        height: 100%;
        background: #0d9373;
        border-radius: 2px;
        transform: scaleX(0);
        transform-origin: left center;
        animation: loader-fill 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
      }
      @keyframes loader-pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
      }
      @keyframes loader-fill {
        from { transform: scaleX(0); }
        to   { transform: scaleX(1); }
      }
    </style>

    <script>
      // Page loader close logic.
      //
      // The loader is rendered into the layout, so it appears on every page —
      // including pages swapped in by Astro's ClientRouter. Two distinct paths
      // need to close it:
      //
      //   1. Initial hard load: wait for window.load, then add .hidden (with a
      //      600ms delay so the loader animation doesn't snap shut mid-frame).
      //   2. ClientRouter swap: window.load never refires after a transition,
      //      so the layout's freshly-painted loader would stay visible forever.
      //      The astro:after-swap listener kills it on every navigation.
      //
      // Returning sessions skip the splash entirely (display:none, no animation).
      const isFirstVisit = !sessionStorage.getItem('awl_visited');
      sessionStorage.setItem('awl_visited', '1');

      if (!isFirstVisit) {
        const loader = document.getElementById('page-loader');
        if (loader) loader.style.display = 'none';
      } else {
        const closeLoader = () => {
          setTimeout(() => {
            const loader = document.getElementById('page-loader');
            if (loader) loader.classList.add('hidden');
          }, 600);
        };
        if (document.readyState === 'complete') closeLoader();
        else window.addEventListener('load', closeLoader, { once: true });
      }

      // ClientRouter navigations swap a fresh layout (including a fresh
      // loader DOM node) into the page. window.load won't fire again, so
      // hide the new node immediately on every swap.
      document.addEventListener('astro:after-swap', () => {
        const loader = document.getElementById('page-loader');
        if (loader) loader.style.display = 'none';
      });

      // Scroll reveal — runs on initial load and after every view transition
      function initReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08 }
        );
        document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach((el) => {
          observer.observe(el);
        });
      }

      initReveal();
      document.addEventListener('astro:after-swap', initReveal);
    </script>
  </body>
</html>
