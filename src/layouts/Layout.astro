---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = '/og-image.jpg',
  canonical,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://labs.allwebbedup.com.au';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'All Webbed Labs',
  url: siteUrl,
  logo: `${siteUrl}/logo.svg`,
  description: 'Enterprise software development and technology solutions for large corporations and enterprises across Australia and globally.',
  email: 'labs@allwebbedup.com.au',
  telephone: '1800714148',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '204 Birdwood Rd',
    addressLocality: 'Georges Hall',
    addressRegion: 'NSW',
    postalCode: '2198',
    addressCountry: 'AU',
  },
  parentOrganization: {
    '@type': 'Organization',
    name: 'All Webbed Up',
    url: 'https://allwebbedup.com.au',
  },
  sameAs: [
    'https://linkedin.com/company/allwebbedup',
    'https://facebook.com/allwebbedup',
    'https://instagram.com/allwebbedup',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).href} />
    <meta property="og:site_name" content="All Webbed Labs" />
    <meta property="og:locale" content="en_AU" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, siteUrl).href} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap" />

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0f0e" />
    <meta name="msapplication-TileColor" content="#0a0f0e" />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <!-- View Transitions -->
    <ClientRouter />
  </head>

  <body>
    <style is:global>
      /* View transition animations */
      ::view-transition-old(root) {
        animation: 220ms cubic-bezier(0.4, 0, 1, 1) both vt-fade-out;
      }
      ::view-transition-new(root) {
        animation: 280ms cubic-bezier(0, 0, 0.2, 1) both vt-fade-in;
      }
      @keyframes vt-fade-out {
        from { opacity: 1; transform: translateY(0); }
        to   { opacity: 0; transform: translateY(-8px); }
      }
      @keyframes vt-fade-in {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    </style>

    <!-- Loading screen -->
    <div id="page-loader">
      <div class="loader-inner">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="48" height="48" rx="12" fill="#0d9373"/>
          <path d="M12 36L24 12L36 36" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M15.5 28.5H32.5" stroke="white" stroke-width="3.5" stroke-linecap="round"/>
        </svg>
        <span>All Webbed Labs</span>
        <div class="loader-bar"><div class="loader-fill"></div></div>
      </div>
    </div>

    <slot />

    <style>
      #page-loader {
        position: fixed;
        inset: 0;
        background: #0a0f0e;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        transition: opacity 0.5s ease, visibility 0.5s ease;
      }
      #page-loader.hidden {
        opacity: 0;
        visibility: hidden;
      }
      .loader-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }
      .loader-inner svg {
        animation: loader-pulse 1s ease-in-out infinite;
      }
      .loader-inner span {
        font-family: 'Sora', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        color: #8aa09a;
        text-transform: uppercase;
      }
      .loader-bar {
        width: 200px;
        height: 2px;
        background: #1e2d28;
        border-radius: 2px;
        overflow: hidden;
      }
      .loader-fill {
        height: 100%;
        background: #0d9373;
        border-radius: 2px;
        animation: loader-fill 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
      }
      @keyframes loader-pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
      }
      @keyframes loader-fill {
        from { width: 0%; }
        to { width: 100%; }
      }
    </style>

    <script>
      // Page loader — only on first visit, not on view transitions
      const isFirstVisit = !sessionStorage.getItem('awl_visited');
      if (!isFirstVisit) {
        const loader = document.getElementById('page-loader');
        if (loader) loader.style.display = 'none';
      }
      sessionStorage.setItem('awl_visited', '1');

      window.addEventListener('load', () => {
        setTimeout(() => {
          const loader = document.getElementById('page-loader');
          if (loader) loader.classList.add('hidden');
        }, 600);
      });

      // Scroll reveal — runs on initial load and after every view transition
      function initReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08 }
        );
        document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach((el) => {
          observer.observe(el);
        });
      }

      initReveal();
      document.addEventListener('astro:after-swap', initReveal);
    </script>
  </body>
</html>
