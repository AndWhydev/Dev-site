---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';

export interface PainPoint {
  icon: string;
  title: string;
  description: string;
}

export interface UseCase {
  title: string;
  description: string;
  techStack: string;
  videoNote: string;
}

export interface IndustryService {
  title: string;
  href: string;
}

export interface IndustryStat {
  value: string;
  label: string;
}

export interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  metaTitle: string;
  metaDescription: string;
  industryName: string;
  heroHeadline: string;
  heroTagline: string;
  heroAccentColor?: string;
  painPoints: PainPoint[];
  solutions: string[];
  useCases: UseCase[];
  relevantServices: IndustryService[];
  stats: IndustryStat[];
  faqs: FAQ[];
  ctaHeadline: string;
  ctaDescription: string;
}

const {
  metaTitle,
  metaDescription,
  industryName,
  heroHeadline,
  heroTagline,
  painPoints,
  solutions,
  useCases,
  relevantServices,
  stats,
  faqs,
  ctaHeadline,
  ctaDescription,
} = Astro.props;
---

<Layout title={metaTitle} description={metaDescription}>
  <Header />
  <main>
    <!-- Hero -->
    <section class="ind-hero">
      <div class="ind-hero-bg" aria-hidden="true"></div>
      <div class="ind-hero-inner">
        <div class="reveal">
          <div class="ind-breadcrumb">
            <a href="/">Home</a>
            <span>/</span>
            <a href="/industries">Industries</a>
            <span>/</span>
            <span>{industryName}</span>
          </div>
          <div class="ind-pill">{industryName}</div>
          <h1 class="ind-hero-title">{heroHeadline}</h1>
          <p class="ind-hero-tagline">{heroTagline}</p>
          <div class="ind-hero-ctas">
            <a href="/contact" class="btn-primary">
              Talk to an Expert
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/services" class="btn-outline">View Our Services</a>
          </div>
        </div>
      </div>
      <!-- Industry stats bar -->
      <div class="ind-stats-bar">
        <div class="ind-stats-inner">
          {stats.map((s) => (
            <div class="ind-stat">
              <span class="ind-stat-val">{s.value}</span>
              <span class="ind-stat-lbl">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pain points -->
    <section class="ind-pain">
      <div class="ind-inner">
        <div class="reveal">
          <span class="section-label">Challenges We Solve</span>
          <h2 class="section-heading">The Pain Points We Understand</h2>
          <p class="section-subheading">
            We've worked inside {industryName.toLowerCase()} deeply enough to know exactly what keeps technology leaders up at night.
          </p>
        </div>
        <div class="pain-grid">
          {painPoints.map((p, i) => (
            <div class={`pain-card card-hover reveal stagger-${Math.min(i + 1, 4)}`}>
              <div class="pain-icon" set:html={p.icon} />
              <h3>{p.title}</h3>
              <p>{p.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Solutions -->
    <section class="ind-solutions">
      <div class="ind-inner">
        <div class="ind-solutions-grid">
          <div class="reveal-left">
            <span class="section-label">Our Solutions</span>
            <h2 class="section-heading">What We Build For {industryName}</h2>
            <p class="section-subheading" style="max-width: 480px;">
              Purpose-built software and technology solutions designed around the specific needs, compliance requirements and workflows of {industryName.toLowerCase()} organisations.
            </p>
            <a href="/contact" class="btn-primary" style="margin-top: 1.5rem; display: inline-flex; align-items: center; gap: 0.5rem;">
              Discuss Your Project
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="solutions-list reveal-right stagger-2">
            {solutions.map((sol, i) => (
              <div class="solution-item">
                <div class="sol-num">{String(i + 1).padStart(2, '0')}</div>
                <span>{sol}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Use Cases -->
    <section class="ind-usecases">
      <div class="ind-inner">
        <div class="reveal">
          <span class="section-label">Real World Applications</span>
          <h2 class="section-heading">Solutions We've Built For This Industry</h2>
        </div>
        <div class="usecases-grid">
          {useCases.map((uc, i) => (
            <div class={`uc-card reveal stagger-${Math.min(i + 1, 3)}`}>
              <!-- VIDEO_PLACEHOLDER, add Rotato industry demo video here showing {uc.videoNote} -->
              <div class="uc-video-placeholder">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0d9373" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
                <span>Demo coming</span>
              </div>
              <div class="uc-content">
                <h3>{uc.title}</h3>
                <p>{uc.description}</p>
                <div class="uc-tech">{uc.techStack}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Relevant Services -->
    <section class="ind-services">
      <div class="ind-inner">
        <div class="reveal">
          <span class="section-label">What You'll Need</span>
          <h2 class="section-heading">Services Most Relevant to {industryName}</h2>
        </div>
        <div class="ind-services-grid">
          {relevantServices.map((s, i) => (
            <a href={s.href} class={`ind-service-card card-hover reveal stagger-${Math.min(i + 1, 6)}`}>
              <span>{s.title}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Case Study Placeholder -->
    <section class="ind-casestudy">
      <div class="ind-inner">
        <div class="casestudy-placeholder reveal">
          <!-- CASE_STUDY_PLACEHOLDER, add real {industryName} case study here when available -->
          <span class="csp-label">Case Study</span>
          <h3>Success Story Coming Soon</h3>
          <p>We're preparing a detailed {industryName.toLowerCase()} case study with full metrics, architecture breakdown and business outcomes. <a href="/contact">Contact us</a> for references or to discuss similar work we've done.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="ind-faq">
      <div class="ind-inner">
        <div class="reveal">
          <span class="section-label">Common Questions</span>
          <h2 class="section-heading">FAQ, {industryName}</h2>
        </div>
        <div class="faq-list">
          {faqs.map((faq, i) => (
            <div class={`faq-item reveal stagger-${Math.min(i + 1, 5)}`}>
              <button class="faq-q" data-faq={`ind-${i}`} aria-expanded="false">
                <span>{faq.question}</span>
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-a" id={`faq-ind-${i}`} hidden>
                <p>{faq.answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA tailored to industry -->
    <section class="ind-cta">
      <div class="ind-cta-inner">
        <div class="ind-cta-glow" aria-hidden="true"></div>
        <div class="ind-cta-content reveal">
          <span class="section-label">{industryName} Partner</span>
          <h2>{ctaHeadline}</h2>
          <p>{ctaDescription}</p>
          <div class="ind-cta-actions">
            <a href="/contact" class="btn-primary">
              Book a Discovery Call
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/about" class="btn-outline">Meet Our Team</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* Hero */
  .ind-hero {
    padding: 9rem 0 0;
    background: #0a0f0e;
    position: relative;
    overflow: hidden;
  }

  .ind-hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(13,147,115,0.09) 0%, transparent 65%);
    pointer-events: none;
  }

  .ind-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem 5rem;
    position: relative;
    z-index: 1;
  }

  .ind-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
    margin-bottom: 1.5rem;
  }

  .ind-breadcrumb a {
    color: #4a6359;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .ind-breadcrumb a:hover {
    color: #0d9373;
  }

  .ind-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(13,147,115,0.1);
    border: 1px solid rgba(13,147,115,0.3);
    color: #0d9373;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .ind-hero-title {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.75rem, 5.5vw, 4rem);
    font-weight: 800;
    color: white;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    max-width: 780px;
  }

  .ind-hero-tagline {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.125rem;
    color: #8aa09a;
    max-width: 580px;
    line-height: 1.65;
    margin-bottom: 2.5rem;
  }

  .ind-hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .ind-stats-bar {
    background: rgba(255,255,255,0.02);
    border-top: 1px solid #1e2d28;
  }

  .ind-stats-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .ind-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.75rem 1rem;
    border-right: 1px solid #1e2d28;
  }

  .ind-stat:last-child {
    border-right: none;
  }

  .ind-stat-val {
    font-family: 'Sora', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    color: #0d9373;
    letter-spacing: -0.03em;
  }

  .ind-stat-lbl {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: #4a6359;
    text-align: center;
    margin-top: 0.25rem;
  }

  /* Inner container */
  .ind-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Pain Points */
  .ind-pain {
    padding: 7rem 0;
    background: #0f1614;
  }

  .ind-pain .section-heading { margin-bottom: 1rem; }
  .ind-pain .section-subheading { margin-bottom: 3rem; }

  .pain-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .pain-card {
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .pain-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(239,68,68,0.06);
    border: 1px solid rgba(239,68,68,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ef4444;
  }

  .pain-card h3 {
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: white;
    margin: 0;
  }

  .pain-card p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #4a6359;
    line-height: 1.65;
    margin: 0;
  }

  /* Solutions */
  .ind-solutions {
    padding: 7rem 0;
    background: #0a0f0e;
  }

  .ind-solutions-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: start;
  }

  .solutions-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid #1e2d28;
    border-radius: 16px;
    overflow: hidden;
    margin-top: 4rem;
  }

  .solution-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #1e2d28;
    transition: background 0.2s ease;
  }

  .solution-item:last-child {
    border-bottom: none;
  }

  .solution-item:hover {
    background: rgba(13,147,115,0.03);
  }

  .sol-num {
    font-family: 'Sora', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(13,147,115,0.5);
    flex-shrink: 0;
    width: 28px;
  }

  .solution-item span {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #8aa09a;
  }

  /* Use Cases */
  .ind-usecases {
    padding: 7rem 0;
    background: #0f1614;
  }

  .ind-usecases .section-heading { margin-bottom: 3rem; }

  .usecases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .uc-card {
    background: #0a0f0e;
    border: 1px solid #1e2d28;
    border-radius: 20px;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .uc-card:hover {
    border-color: rgba(13,147,115,0.3);
    transform: translateY(-3px);
  }

  .uc-video-placeholder {
    aspect-ratio: 16/9;
    background: #060c0b;
    border-bottom: 1px solid #1e2d28;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .uc-video-placeholder span {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    color: #1e2d28;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .uc-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .uc-content h3 {
    font-family: 'Sora', sans-serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: white;
    margin: 0;
  }

  .uc-content p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #4a6359;
    line-height: 1.6;
    margin: 0;
  }

  .uc-tech {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: #0d9373;
    background: rgba(13,147,115,0.08);
    border: 1px solid rgba(13,147,115,0.15);
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    align-self: flex-start;
  }

  /* Services */
  .ind-services {
    padding: 6rem 0;
    background: #0a0f0e;
  }

  .ind-services .section-heading { margin-bottom: 2.5rem; }

  .ind-services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .ind-service-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    background: #0f1614;
    border: 1px solid #1e2d28;
    border-radius: 12px;
    padding: 1.125rem 1.25rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #8aa09a;
    text-decoration: none;
  }

  .ind-service-card:hover {
    color: white;
  }

  /* Case Study */
  .ind-casestudy {
    padding: 5rem 0;
    background: #0f1614;
  }

  .casestudy-placeholder {
    background: rgba(255,255,255,0.02);
    border: 1px dashed #1e2d28;
    border-radius: 20px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 700px;
  }

  .csp-label {
    display: inline-flex;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    color: #4a6359;
    background: rgba(255,255,255,0.04);
    border: 1px solid #1e2d28;
    padding: 0.2rem 0.625rem;
    border-radius: 50px;
    align-self: flex-start;
  }

  .casestudy-placeholder h3 {
    font-family: 'Sora', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
    margin: 0;
  }

  .casestudy-placeholder p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #4a6359;
    line-height: 1.65;
    margin: 0;
  }

  .casestudy-placeholder p a {
    color: #0d9373;
    text-decoration: none;
  }

  /* FAQ */
  .ind-faq {
    padding: 7rem 0;
    background: #0a0f0e;
  }

  .ind-faq .section-heading { margin-bottom: 2.5rem; }

  .faq-list {
    display: flex;
    flex-direction: column;
    max-width: 900px;
  }

  .faq-item {
    border-bottom: 1px solid #1e2d28;
  }

  .faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.375rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: white;
    transition: color 0.2s ease;
  }

  .faq-q:hover { color: #0d9373; }
  .faq-q[aria-expanded="true"] { color: #0d9373; }

  .faq-chevron {
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: #4a6359;
  }

  .faq-q[aria-expanded="true"] .faq-chevron {
    transform: rotate(180deg);
    color: #0d9373;
  }

  .faq-a {
    padding-bottom: 1.375rem;
  }

  .faq-a p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #4a6359;
    line-height: 1.7;
    margin: 0;
  }

  /* CTA */
  .ind-cta {
    padding: 7rem 0;
    background: linear-gradient(135deg, #061612 0%, #0a1d18 40%, #091511 100%);
    position: relative;
    overflow: hidden;
  }

  .ind-cta-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(13,147,115,0.15) 0%, transparent 65%);
    pointer-events: none;
  }

  .ind-cta-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 2rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .ind-cta-content h2 {
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: white;
    margin: 0.75rem 0 1rem;
    letter-spacing: -0.02em;
  }

  .ind-cta-content p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    color: #8aa09a;
    line-height: 1.65;
    margin: 0 0 2rem;
  }

  .ind-cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .ind-stats-inner {
      grid-template-columns: repeat(2, 1fr);
    }
    .ind-stat:nth-child(2) { border-right: none; }
    .ind-stat:nth-child(1),
    .ind-stat:nth-child(2) {
      border-bottom: 1px solid #1e2d28;
    }
    .pain-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .ind-solutions-grid {
      grid-template-columns: 1fr;
    }
    .solutions-list { margin-top: 0; }
    .usecases-grid {
      grid-template-columns: 1fr;
    }
    .ind-services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .ind-hero { padding-top: 7rem; }
    .pain-grid { grid-template-columns: 1fr; }
    .ind-services-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      const idx = btn.dataset.faq;
      const panel = document.getElementById(`faq-${idx}`);
      btn.setAttribute('aria-expanded', String(!isOpen));
      if (panel) panel.hidden = isOpen;
    });
  });
</script>
